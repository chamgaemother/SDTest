{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(\"1.2.3+exp.sha.5114f85\") returns Semver instance with build-only identifiers",
      "path": "B0→B2→B3",
      "precondition": "none",
      "expectedResult": "non-null Semver; getBuild() yields [\"exp\",\"sha\",\"5114f85\"]; getPreRelease() is empty",
      "tags": [
        "positive",
        "build-only",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse build-only version",
        "  GIVEN",
        "    String version = \"1.2.3+exp.sha.5114f85\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNotNull(result);",
        "    assertEquals(Collections.emptyList(), result.getPreRelease());",
        "    assertEquals(Arrays.asList(\"exp\",\"sha\",\"5114f85\"), result.getBuild());"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(\"1.2.3.\") catches parse error for trailing dot and returns null",
      "path": "B0→B2→B4",
      "precondition": "none",
      "expectedResult": "null returned due to invalid trailing dot format",
      "tags": [
        "negative",
        "exception-path",
        "format-error"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse invalid trailing-dot version",
        "  GIVEN",
        "    String version = \"1.2.3.\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNull(result);"
      ]
    }
  ]
}