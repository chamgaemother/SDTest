{
  "scenarios": [
    {
      "id": "TC05",
      "description": "parse accepts a version string with pre-release and build metadata",
      "path": "B0→B2→B3→B4→B5",
      "precondition": "none",
      "expectedResult": "returns a Semver with preRelease = [\"beta\",\"4\"] and build = [\"meta\",\"5\"] and version \"1.2.3-beta.4+meta.5\"",
      "tags": [
        "positive",
        "pre-release",
        "build",
        "metadata"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 parse pre-release and build metadata",
        "  GIVEN",
        "    String version = \"1.2.3-beta.4+meta.5\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.2.3-beta.4+meta.5\");",
        "    assert result.getPreRelease().equals(Arrays.asList(\"beta\",\"4\"));",
        "    assert result.getBuild().equals(Arrays.asList(\"meta\",\"5\"));",
        "END"
      ]
    }
  ]
}