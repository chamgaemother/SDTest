      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse missing-patch",
        "  GIVEN",
        "    String version = \"1.2\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;"
      ]
    }
