{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(\"1.2.3-alpha.beta.gamma+build.meta.data\") returns Semver with multiple prerelease and build tokens",
      "path": "B0→B2→B3→B5",
      "precondition": "none",
      "expectedResult": "Semver instance with preRelease = [\"alpha\",\"beta\",\"gamma\"] and build = [\"build\",\"meta\",\"data\"]",
      "tags": [
        "positive",
        "multi-token",
        "pre-release",
        "build"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse-multi-tokens",
        "  GIVEN",
        "    String version = \"1.2.3-alpha.beta.gamma+build.meta.data\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getPreRelease().equals(Arrays.asList(\"alpha\",\"beta\",\"gamma\"));",
        "    assert result.getBuild().equals(Arrays.asList(\"build\",\"meta\",\"data\"));",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(\"1.2.3+\") returns Semver with empty prerelease and single empty build token",
      "path": "B0→B2→B3→B5",
      "precondition": "none",
      "expectedResult": "Semver instance with preRelease empty and build = [\"\"]",
      "tags": [
        "positive",
        "edge",
        "build-empty-token"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse-empty-build-token",
        "  GIVEN",
        "    String version = \"1.2.3+\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getPreRelease().isEmpty();",
        "    assert result.getBuild().equals(Collections.singletonList(\"\"));",
        "END"
      ]
    }
  ]
}