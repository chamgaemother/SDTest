{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(null) returns null when input version is null (branch version==null)",
      "path": "B1→B2",
      "precondition": "none",
      "expectedResult": "result is null",
      "tags": [
        "branch-true",
        "null-input",
        "exception-path=false"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse null-input",
        "  GIVEN",
        "    String version = null;",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(\" 1.2.3 \") returns a Semver when input is valid after trim (branch version!=null, no exception)",
      "path": "B1→B3→B4",
      "precondition": "none",
      "expectedResult": "result is non-null Semver with getVersion()==\"1.2.3\"",
      "tags": [
        "branch-false",
        "valid-input",
        "exception-path=false"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02 parse valid-version-with-whitespace",
        "  GIVEN",
        "    String version = \" 1.2.3 \";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.2.3\");",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(\"not-a-version\") returns null when StrictParser.parse throws (branch version!=null, exception path)",
      "path": "B1→B3→B5",
      "precondition": "none",
      "expectedResult": "result is null",
      "tags": [
        "branch-false",
        "invalid-input",
        "exception-path=true"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03 parse invalid-version",
        "  GIVEN",
        "    String version = \"not-a-version\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    }
  ]
}