{
  "scenarios": [
    {
      "id": "TC06",
      "description": "parse(\"1.2.3-alpha.beta.gamma\") returns Semver covering multi-segment pre-release without exception",
      "path": "B0→B1(false)→B3→B4",
      "precondition": "none",
      "expectedResult": "non-null Semver with version \"1.2.3-alpha.beta.gamma\" and preRelease [\"alpha\",\"beta\",\"gamma\"]",
      "tags": [
        "positive",
        "pre-release",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 parse multi-segment pre-release",
        "  GIVEN",
        "    String version = \"1.2.3-alpha.beta.gamma\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNotNull(result);",
        "    assertEquals(\"1.2.3-alpha.beta.gamma\", result.getVersion());",
        "    assertEquals(Arrays.asList(\"alpha\",\"beta\",\"gamma\"), result.getPreRelease());"
      ]
    },
    {
      "id": "TC07",
      "description": "parse(\"   \") returns null covering exception path when input is only whitespace",
      "path": "B0→B1(false)→B3→B5",
      "precondition": "none",
      "expectedResult": "null returned due to StrictParser exception on empty string after trim",
      "tags": [
        "negative",
        "boundary",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parse whitespace-only string",
        "  GIVEN",
        "    String version = \"   \";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNull(result);"
      ]
    }
  ]
}