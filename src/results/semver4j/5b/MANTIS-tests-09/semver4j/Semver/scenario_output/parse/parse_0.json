{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(null) returns null covering the branch where input is null",
      "path": "B0→B1(true)→B2",
      "precondition": "none",
      "expectedResult": "return value is null",
      "tags": [
        "branch-true",
        "exception-path",
        "null-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse null-input",
        "  GIVEN",
        "    String version = null;",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(\"1.2.3\") returns a Semver instance for a valid semver string",
      "path": "B0→B1(false)→B3→B4",
      "precondition": "none",
      "expectedResult": "return value is Semver object with version=\"1.2.3\", major=1, minor=2, patch=3",
      "tags": [
        "branch-false",
        "valid-input"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse valid-version",
        "  GIVEN",
        "    String version = \"1.2.3\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.2.3\");",
        "    assert result.getMajor() == 1 && result.getMinor() == 2 && result.getPatch() == 3;",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(\"foo\") returns null covering the exception path for invalid version",
      "path": "B0→B1(false)→B3→B5(Exception)→B2",
      "precondition": "none",
      "expectedResult": "return value is null",
      "tags": [
        "branch-false",
        "exception-path",
        "invalid-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse invalid-version",
        "  GIVEN",
        "    String version = \"foo\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    }
  ]
}