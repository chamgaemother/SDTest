{
  "scenarios": [
    {
      "id": "TC15",
      "description": "parse rejects pre-release numeric identifier with leading zeros causing StrictParser exception",
      "path": "B0→B1→B6",
      "precondition": "none",
      "expectedResult": "return null due to invalid pre-release numeric leading zeros",
      "tags": [
        "negative",
        "exception",
        "pre-release-format"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 parse invalid pre-release numeric-leading-zeros",
        "  GIVEN",
        "    String version = \"1.2.3-alpha.01\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;"
      ]
    },
