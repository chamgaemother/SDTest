      "path": "B0→B1(true)→B4",
      "precondition": "none",
      "expectedResult": "return value is null",
      "tags": [
        "branch-true",
        "null-input",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse null-input",
        "  GIVEN",
        "    String version = null;",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;"
      ]
    },
