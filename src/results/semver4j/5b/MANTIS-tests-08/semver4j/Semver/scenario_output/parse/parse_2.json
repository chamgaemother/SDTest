      "pseudocode": [
        "TEST TC12 parse dangling hyphen",
        "  GIVEN",
        "    String version = \"1.2.3-\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNull(result);"
      ]
    }
  ]
