{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(null) returns null for null input (version==null branch)",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "return value is null",
      "tags": [
        "branch-true",
        "exception",
        "null-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse-null-input",
        "  GIVEN",
        "    String version = null;",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(\"\") returns null for empty string after trimming (constructor throws)",
      "path": "B0→B2→B3",
      "precondition": "none",
      "expectedResult": "return value is null",
      "tags": [
        "branch-false",
        "exception",
        "empty-string"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse-empty-string",
        "  GIVEN",
        "    String version = \"\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(\"1.0.0\") returns Semver(\"1.0.0\") for valid version",
      "path": "B0→B2→B4",
      "precondition": "none",
      "expectedResult": "return value is non-null Semver with getVersion()==\"1.0.0\", getMajor()==1, getMinor()==0, getPatch()==0",
      "tags": [
        "branch-false",
        "positive",
        "simple-version"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse-basic-version",
        "  GIVEN",
        "    String version = \"1.0.0\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.0.0\");",
        "END"
      ]
    },
    {
      "id": "TC04",
      "description": "parse(\" 2.3.4-alpha.1+exp.sha \") trims input and returns correct Semver",
      "path": "B0→B2→B4",
      "precondition": "none",
      "expectedResult": "return value is non-null Semver with getVersion()==\"2.3.4-alpha.1+exp.sha\", getPreRelease()==[\"alpha\",\"1\"], getBuild()==[\"exp\",\"sha\"]",
      "tags": [
        "branch-false",
        "positive",
        "whitespace",
        "pre-release",
        "build"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 parse-trimmed-pre-release-build",
        "  GIVEN",
        "    String version = \" 2.3.4-alpha.1+exp.sha \";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"2.3.4-alpha.1+exp.sha\");",
        "END"
      ]
    }
  ]
}