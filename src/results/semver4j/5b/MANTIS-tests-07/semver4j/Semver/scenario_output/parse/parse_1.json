{
  "scenarios": [
    {
      "id": "TC05",
      "description": "parse(\"\") returns null when input is empty after trim (r0 == null branch)",
      "path": "B0→B2→B5→B7",
      "precondition": "none",
      "expectedResult": "return null for empty version string",
      "tags": [
        "negative",
        "boundary",
        "empty"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 parse empty-string returns null",
        "  GIVEN",
        "    String version = \"\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result == null;",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "parse(\"1.2.3-alpha\") returns Semver with only pre-release tokens and no build",
      "path": "B0→B2→B3→B4→B6",
      "precondition": "none",
      "expectedResult": "parsed Semver with getVersion() == \"1.2.3-alpha\", preRelease=[\"alpha\"], build empty",
      "tags": [
        "positive",
        "prerelease"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse prerelease-only version",
        "  GIVEN",
        "    String version = \"1.2.3-alpha\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.2.3-alpha\");",
        "    assert result.getPreRelease().equals(Collections.singletonList(\"alpha\"));",
        "    assert result.getBuild().isEmpty();",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "parse(\"1.2.3+build123\") returns Semver with only build tokens and no pre-release",
      "path": "B0→B2→B3→B4→B6",
      "precondition": "none",
      "expectedResult": "parsed Semver with getVersion() == \"1.2.3+build123\", build=[\"build123\"], preRelease empty",
      "tags": [
        "positive",
        "build"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parse build-only version",
        "  GIVEN",
        "    String version = \"1.2.3+build123\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assert result != null;",
        "    assert result.getVersion().equals(\"1.2.3+build123\");",
        "    assert result.getBuild().equals(Collections.singletonList(\"build123\"));",
        "    assert result.getPreRelease().isEmpty();",
        "END"
      ]
    }
  ]
}