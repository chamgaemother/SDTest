{
  "scenarios": [
    {
      "id": "TC08",
      "description": "parse(\"01.002.0003\") normalizes leading zeros and returns Semver(1.2.3)",
      "path": "B0→B2→B3→B4→B6",
      "precondition": "none",
      "expectedResult": "non-null Semver with version \"1.2.3\", major=1, minor=2, patch=3",
      "tags": [
        "positive",
        "normalization",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 parse normalizes leading zeros",
        "  GIVEN",
        "    String version = \"01.002.0003\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNotNull(result);",
        "    assertEquals(\"1.2.3\", result.getVersion());",
        "    assertEquals(1, result.getMajor());",
        "    assertEquals(2, result.getMinor());",
        "    assertEquals(3, result.getPatch());",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "parse(\"v1.2.3\") returns null when non-numeric prefix causes parse exception",
      "path": "B0→B2→B5→B7",
      "precondition": "none",
      "expectedResult": "return null",
      "tags": [
        "negative",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 parse non-numeric prefix",
        "  GIVEN",
        "    String version = \"v1.2.3\";",
        "  WHEN",
        "    Semver result = Semver.parse(version);",
        "  THEN",
        "    assertNull(result);",
        "END"
      ]
    }
  ]
}