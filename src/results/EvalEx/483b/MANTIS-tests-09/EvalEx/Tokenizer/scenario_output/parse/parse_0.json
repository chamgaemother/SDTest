{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Empty input returns empty token list (r14 == null at first check)",
      "path": "B0→B1→B7→B9→B11",
      "precondition": "ExpressionConfiguration with default settings",
      "expectedResult": "return value is an empty list",
      "tags": [
        "branch-false",
        "loop-0",
        "return-normal"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse empty-input",
        "  GIVEN",
        "    String expr = \"\";",
        "  WHEN",
        "    List<Token> tokens = new Tokenizer(expr, config).parse();",
        "  THEN",
        "    assert tokens.isEmpty();",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "Single number literal yields one NUMBER_LITERAL token (implicit multiplication not possible)",
      "path": "B0→B1→B6→B1→B7→B9→B11",
      "precondition": "ExpressionConfiguration with default settings",
      "expectedResult": "return list contains one token of type NUMBER_LITERAL and value \"123\"",
      "tags": [
        "branch-false",
        "loop-1",
        "return-normal"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse single-number",
        "  GIVEN",
        "    String expr = \"123\";",
        "  WHEN",
        "    List<Token> tokens = new Tokenizer(expr, config).parse();",
        "  THEN",
        "    assert tokens.size() == 1;",
        "    assert tokens.get(0).getType() == TokenType.NUMBER_LITERAL;",
        "    assert tokens.get(0).getTokenString().equals(\"123\");",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "Implicit multiplication inserted between number and variable when allowed (NUMBER_LITERAL→VARIABLE_OR_CONSTANT)",
      "path": "B0→B1→B6→B1→B2→B3→B4→B6→B1→B7→B9→B11",
      "precondition": "ExpressionConfiguration.isImplicitMultiplicationAllowed() returns true",
      "expectedResult": "return list contains NUMBER_LITERAL \"2\", INFIX_OPERATOR \"*\", VARIABLE_OR_CONSTANT \"x\" in order",
      "tags": [
        "branch-true",
        "branch-false",
        "loop-N",
        "implicit-multiplication",
        "return-normal"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse number-then-variable with implicit multiplication",
        "  GIVEN",
        "    config.setImplicitMultiplicationAllowed(true);",
        "    String expr = \"2x\";",
        "  WHEN",
        "    List<Token> tokens = new Tokenizer(expr, config).parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(1).getTokenString().equals(\"*\");",
        "END"
      ]
    },
    {
