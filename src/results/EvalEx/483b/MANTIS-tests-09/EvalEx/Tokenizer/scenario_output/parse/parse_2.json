        "positive",
        "number",
        "scientific"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC22 valid-scientific-notation",
        "  GIVEN",
        "    ExpressionConfiguration config = new StubConfig();",
        "    Tokenizer tokenizer = new Tokenizer(\"3.14e+2\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 1;",
        "    assert tokens.get(0).getType() == TokenType.NUMBER_LITERAL;",
        "    assert tokens.get(0).getTokenString().equals(\"3.14e+2\");",
        "END"
