    @Test
    @DisplayName("TC19: Undefined function call throws \"Undefined function 'foo'\"")
    void test_TC19() {
        // GIVEN config with no function named foo
        FunctionDictionaryIfc fdict = mock(FunctionDictionaryIfc.class);
        when(fdict.hasFunction("foo")).thenReturn(false);

        ExpressionConfiguration cfg = mock(ExpressionConfiguration.class);
        when(cfg.getOperatorDictionary()).thenReturn(mock(OperatorDictionaryIfc.class));
        when(cfg.getFunctionDictionary()).thenReturn(fdict);
        when(cfg.isArraysAllowed()).thenReturn(false);
        when(cfg.isStructuresAllowed()).thenReturn(false);
        when(cfg.isImplicitMultiplicationAllowed()).thenReturn(false);
        when(cfg.isSingleQuoteStringLiteralsAllowed()).thenReturn(false);

        String expr = "foo()";
        Tokenizer tz = new Tokenizer(expr, cfg);

        // WHEN / THEN
        ParseException ex = assertThrows(ParseException.class, tz::parse);
        assertTrue(ex.getMessage().contains("Undefined function 'foo'"));
    }

    @Test
    @DisplayName("TC20: Implicit multiplication inserted between two grouped expressions when allowed (BRACE_CLOSE→BRACE_OPEN)")
    void test_TC20() throws Exception {
        // GIVEN config allowing implicit multiplication
        ExpressionConfiguration cfg = mock(ExpressionConfiguration.class);
        when(cfg.getOperatorDictionary()).thenReturn(mock(OperatorDictionaryIfc.class));
        when(cfg.getFunctionDictionary()).thenReturn(mock(FunctionDictionaryIfc.class));
        when(cfg.isImplicitMultiplicationAllowed()).thenReturn(true);
        when(cfg.isArraysAllowed()).thenReturn(false);
        when(cfg.isStructuresAllowed()).thenReturn(false);
        when(cfg.isSingleQuoteStringLiteralsAllowed()).thenReturn(false);

        String expr = "(1)(2)";
        Tokenizer tz = new Tokenizer(expr, cfg);

        // WHEN
        List<Token> tokens = tz.parse();

        // THEN
        assertEquals(7, tokens.size());
        assertEquals(Token.TokenType.BRACE_OPEN, tokens.get(0).getType());
        assertEquals(Token.TokenType.NUMBER_LITERAL, tokens.get(1).getType());
        assertEquals(Token.TokenType.BRACE_CLOSE, tokens.get(2).getType());
        assertEquals(Token.TokenType.INFIX_OPERATOR, tokens.get(3).getType());
        assertEquals("*", tokens.get(3).getTokenValue());
        assertEquals(Token.TokenType.BRACE_OPEN, tokens.get(4).getType());
        assertEquals(Token.TokenType.NUMBER_LITERAL, tokens.get(5).getType());
        assertEquals(Token.TokenType.BRACE_CLOSE, tokens.get(6).getType());
    }

    @Test
    @DisplayName("TC21: Unmatched open array throws 'Closing array not found'")
    void test_TC21() {
        // GIVEN config allowing arrays but no closing ']'
        ExpressionConfiguration cfg = mock(ExpressionConfiguration.class);
        when(cfg.getOperatorDictionary()).thenReturn(mock(OperatorDictionaryIfc.class));
        when(cfg.getFunctionDictionary()).thenReturn(mock(FunctionDictionaryIfc.class));
        when(cfg.isArraysAllowed()).thenReturn(true);
        when(cfg.isStructuresAllowed()).thenReturn(false);
        when(cfg.isImplicitMultiplicationAllowed()).thenReturn(false);
        when(cfg.isSingleQuoteStringLiteralsAllowed()).thenReturn(false);

        String expr = "[";
        Tokenizer tz = new Tokenizer(expr, cfg);

        // WHEN / THEN
        ParseException ex = assertThrows(ParseException.class, tz::parse);
        assertTrue(ex.getMessage().contains("Closing array not found"));
    }
