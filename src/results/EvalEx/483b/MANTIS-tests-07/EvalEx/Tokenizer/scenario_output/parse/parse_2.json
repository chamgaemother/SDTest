{
  "scenarios": [
    {
      "id": "TC24",
      "description": "Prefix operator '-' before number yields PREFIX_OPERATOR then NUMBER_LITERAL",
      "path": "B0â†’B1â†’B2(false)â†’B6â†’B1â†’B2(false)â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "none",
      "expectedResult": "Two tokens: '-' as PREFIX_OPERATOR and '1' as NUMBER_LITERAL",
      "tags": [
        "positive",
        "prefix-operator"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC24 prefix minus before number",
        "  GIVEN",
        "    String expr = \"-1\";",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    Tokenizer tokenizer = new Tokenizer(expr, config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 2;",
        "    assert tokens.get(0).getType() == TokenType.PREFIX_OPERATOR;",
        "    assert tokens.get(0).getValue().equals(\"-\");",
        "    assert tokens.get(1).getType() == TokenType.NUMBER_LITERAL;",
        "    assert tokens.get(1).getValue().equals(\"1\");",
        "END"
      ]
    },
