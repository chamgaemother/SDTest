      "id": "TC28",
      "description": "Implicit multiplication between number and '(' when allowed inserts '*'",
      "path": "B0â†’B1â†’B2(true)â†’B4â†’B6â†’B1â†’B2(false)â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "none",
      "expectedResult": "Three tokens: '2', '*', '('",
      "tags": [
        "positive",
        "implicit-multiplication",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC28 number-before-brace implicit multiplication",
        "  GIVEN",
        "    String expr = \"2(3)\";",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    config.setImplicitMultiplicationAllowed(true);",
        "    Tokenizer tokenizer = new Tokenizer(expr, config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(0).getValue().equals(\"2\");",
        "    assert tokens.get(1).getValue().equals(\"*\");",
        "    assert tokens.get(1).getType() == TokenType.INFIX_OPERATOR;",
        "    assert tokens.get(2).getValue().equals(\"(\");",
        "END"
      ]
    }
