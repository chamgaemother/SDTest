      "description": "Unmatched opening array throws 'Closing array not found' when arraysAllowed=true",
      "path": "B0â†’B1â†’B2(false)â†’B6â†’B1â†’B7â†’B9â†’B10",
      "precondition": "none",
      "expectedResult": "ParseException with message 'Closing array not found'",
      "tags": [
        "negative",
        "exception",
        "array"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC26 unmatched opening array",
        "  GIVEN",
        "    String expr = \"[\";",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    config.setArraysAllowed(true);",
        "    Tokenizer tokenizer = new Tokenizer(expr, config);",
        "  WHEN",
        "    call tokenizer.parse();",
        "  THEN",
        "    throws ParseException with message containing \"Closing array not found\";",
        "END"
      ]
    },
