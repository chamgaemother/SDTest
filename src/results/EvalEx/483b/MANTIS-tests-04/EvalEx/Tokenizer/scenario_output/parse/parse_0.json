      "id": "TC01",
      "description": "Empty expression returns empty token list (no loop iterations, no braces or arrays)",
      "path": "B0â†’B1â†’B7â†’B9â†’B11",
      "precondition": "ExpressionConfiguration with default settings (implicitMultiplicationAllowed=true, arraysAllowed=true, structuresAllowed=true)",
      "expectedResult": "return value is empty List<Token>",
      "tags": [
        "loop-0",
        "normal-return",
        "branch-false",
        "branch-false",
        "branch-true",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 empty-expression",
        "  GIVEN",
        "    String expr = \"\"; ExpressionConfiguration cfg = defaultConfig();",
        "  WHEN",
        "    List<Token> result = new Tokenizer(expr, cfg).parse();",
        "  THEN",
        "    assert result.isEmpty();",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "Single decimal number produces one NUMBER_LITERAL token and then exits loop",
      "path": "B0â†’B1â†’B2â†’B3â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "ExpressionConfiguration default",
      "expectedResult": "return value size is 1 and token[0].getType() == NUMBER_LITERAL and value == \"123\"",
      "tags": [
        "loop-1",
        "normal-return",
        "branch-false",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 single-number-literal",
        "  GIVEN",
        "    String expr = \"123\"; ExpressionConfiguration cfg = defaultConfig();",
        "  WHEN",
        "    List<Token> result = new Tokenizer(expr, cfg).parse();",
        "  THEN",
        "    assert result.size() == 1; assert result.get(0).getType() == NUMBER_LITERAL; assert result.get(0).getValue().equals(\"123\");",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "Implicit multiplication inserts '*' between NUMBER_LITERAL and BRACE_OPEN when allowed",
      "path": "B0â†’B1â†’B2â†’B3â†’B4â†’B6â†’B1â†’B2â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "ExpressionConfiguration with isImplicitMultiplicationAllowed() == true",
      "expectedResult": "return value sequence types [NUMBER_LITERAL, INFIX_OPERATOR(\"*\"), BRACE_OPEN, NUMBER_LITERAL, BRACE_CLOSE]",
      "tags": [
        "loop-N",
        "implicit-multiplication-true",
        "branch-true",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 implicit-multiplication-allowed",
        "  GIVEN",
        "    String expr = \"2(3)\"; ExpressionConfiguration cfg = configAllowImplicit();",
        "  WHEN",
        "    List<Token> result = new Tokenizer(expr, cfg).parse();",
        "  THEN",
        "    assert result.get(1).getType() == INFIX_OPERATOR; assert result.get(1).getValue().equals(\"*\");",
        "END"
      ]
    },
