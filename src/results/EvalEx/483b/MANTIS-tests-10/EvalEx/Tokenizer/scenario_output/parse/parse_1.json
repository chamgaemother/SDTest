      "id": "TC17",
      "description": "Balanced array open and close returns ARRAY_OPEN and ARRAY_CLOSE tokens",
      "path": "B0â†’B1â†’B6â†’B1â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "ExpressionConfiguration arraysAllowed=true",
