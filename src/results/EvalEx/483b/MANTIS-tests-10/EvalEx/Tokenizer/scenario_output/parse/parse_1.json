      "id": "TC12",
      "description": "Valid structure separator between variable and variable when structures allowed",
      "path": "B0â†’B1â†’B6â†’B1â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "ExpressionConfiguration structuresAllowed=true",
      "expectedResult": "Tokens: VARIABLE_OR_CONSTANT 'a', STRUCTURE_SEPARATOR '.', VARIABLE_OR_CONSTANT 'b'",
      "tags": [
        "positive",
        "structure",
        "separator"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 structure-separator-valid",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    config.setStructuresAllowed(true);",
        "    Tokenizer tokenizer = new Tokenizer(\"a.b\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(1).getType() == STRUCTURE_SEPARATOR;"
      ]
    },
