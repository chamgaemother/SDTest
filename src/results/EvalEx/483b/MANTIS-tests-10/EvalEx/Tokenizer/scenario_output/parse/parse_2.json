    {
      "id": "TC17",
      "description": "Balanced array [1] returns ARRAY_OPEN, NUMBER_LITERAL, ARRAY_CLOSE when arraysAllowed",
      "path": "B0→B1(loop×3)→B6→B1→B7→B9→B11",
      "precondition": "configuration with arraysAllowed=true",
      "expectedResult": "returns three tokens: ARRAY_OPEN, NUMBER_LITERAL, ARRAY_CLOSE",
      "tags": [
        "positive",
        "array",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 balanced array",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    config.setArraysAllowed(true);",
        "    Tokenizer tokenizer = new Tokenizer(\"[1]\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(0).getType() == ARRAY_OPEN;",
        "    assert tokens.get(1).getType() == NUMBER_LITERAL;",
        "    assert tokens.get(2).getType() == ARRAY_CLOSE;",
        "END"
      ]
    },
