      "tags": [
        "positive",
        "hex",
        "literal"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 hex number literal",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    Tokenizer tokenizer = new Tokenizer(\"0x1A\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 1;",
        "    assert tokens.get(0).getType() == NUMBER_LITERAL;",
        "    assert tokens.get(0).getTokenValue().equals(\"0x1A\");",
        "END"
      ]
    },
