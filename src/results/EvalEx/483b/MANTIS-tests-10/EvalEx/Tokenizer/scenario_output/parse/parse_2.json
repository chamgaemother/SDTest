{
  "scenarios": [
    {
      "id": "TC12",
      "description": "Valid variable structure access a.b produces VARIABLE, STRUCTURE_SEPARATOR, VARIABLE when structures allowed",
      "path": "B0→B1(loop×3)→B7→B9→B11",
      "precondition": "configuration with structuresAllowed=true",
      "expectedResult": "returns three tokens: VARIABLE_OR_CONSTANT, STRUCTURE_SEPARATOR, VARIABLE_OR_CONSTANT",
      "tags": [
        "positive",
        "structure",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 valid structure access",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    config.setStructuresAllowed(true);",
        "    Tokenizer tokenizer = new Tokenizer(\"a.b\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(0).getType() == VARIABLE_OR_CONSTANT;",
        "    assert tokens.get(1).getType() == STRUCTURE_SEPARATOR;",
        "    assert tokens.get(2).getType() == VARIABLE_OR_CONSTANT;",
        "END"
      ]
    },
    {
