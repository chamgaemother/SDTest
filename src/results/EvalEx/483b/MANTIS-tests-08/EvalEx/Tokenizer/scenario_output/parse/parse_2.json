{
  "scenarios": [
    {
      "id": "TC14",
      "description": "Implicit multiplication between ')' and '(' disallowed throws Missing operator",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "configuration.isImplicitMultiplicationAllowed() == false",
      "expectedResult": "ParseException with message 'Missing operator'",
      "tags": [
        "negative",
        "implicit-multiplication",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 implicit-mult brace-close to brace-open disallowed",
        "  GIVEN",
        "    String expr = \")(\";",
        "    ExpressionConfiguration config = new StubConfig(false, true, true, true);",
        "    Tokenizer tokenizer = new Tokenizer(expr, config);",
        "  WHEN",
        "    call tokenizer.parse();",
        "  THEN",
        "    throws ParseException with message 'Missing operator';",
        "END"
      ]
    },
    {
      "id": "TC15",
      "description": "Implicit multiplication between number and variable inserts '*'",
      "path": "B0→B1→B2→B4→B6→…→B11",
      "precondition": "configuration.isImplicitMultiplicationAllowed() == true",
      "expectedResult": "Tokens sequence [2,*,x] with infix '*' inserted",
      "tags": [
        "positive",
        "implicit-multiplication",
        "variable"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 implicit-mult number to variable allowed",
        "  GIVEN",
        "    String expr = \"2x\";",
        "    ExpressionConfiguration config = new StubConfig(true, true, true, true);",
        "    Tokenizer tokenizer = new Tokenizer(expr, config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(0).getToken().equals(\"2\");",
        "    assert tokens.get(1).getToken().equals(\"*\");",
        "    assert tokens.get(2).getToken().equals(\"x\");",
        "END"
      ]
    },
