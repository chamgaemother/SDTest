{
  "scenarios": [
    {
      "id": "TC07",
      "description": "Normal infix expression with no implicit multiplication yields token list and normal return",
      "path": "B0→B1→B6(loop×3)→B1→B7→B9→B11",
      "precondition": "default ExpressionConfiguration",
      "expectedResult": "List of tokens [NUMBER_LITERAL(\"1\"), INFIX_OPERATOR(\"+\"), NUMBER_LITERAL(\"2\")], no exception",
      "tags": [
        "positive",
        "infix",
        "normal-return"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 normal infix parse",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    Tokenizer tokenizer = new Tokenizer(\"1+2\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 3;",
        "    assert tokens.get(0).getType() == NUMBER_LITERAL;",
        "    assert tokens.get(1).getType() == INFIX_OPERATOR;",
        "    assert tokens.get(2).getType() == NUMBER_LITERAL;",
        "END"
      ]
    },
    {
