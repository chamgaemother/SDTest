      "description": "parseDecimalNumberLiteral accepts valid scientific notation '3.14e2'",
      "path": "B0â†’B6â†’B6â†’B1â†’B7â†’B9â†’B11",
      "precondition": "none",
      "expectedResult": "One NUMBER_LITERAL token with value '3.14e2'",
      "tags": ["positive","number","scientific"],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 valid-scientific-notation",
        "  GIVEN",
        "    ExpressionConfiguration config = new ExpressionConfiguration();",
        "    Tokenizer tokenizer = new Tokenizer(\"3.14e2\", config);",
        "  WHEN",
        "    List<Token> tokens = tokenizer.parse();",
        "  THEN",
        "    assert tokens.size() == 1;",
        "    assert tokens.get(0).getType() == TokenType.NUMBER_LITERAL;",
        "    assert tokens.get(0).getValue().equals(\"3.14e2\");",
        "END"
