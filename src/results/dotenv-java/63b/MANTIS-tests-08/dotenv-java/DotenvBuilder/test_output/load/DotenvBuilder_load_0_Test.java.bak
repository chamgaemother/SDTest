import io.github.cdimascio.dotenv.Dotenv;
import io.github.cdimascio.dotenv.DotenvBuilder;
import io.github.cdimascio.dotenv.DotenvException;
import io.github.cdimascio.dotenv.DotenvEntry;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.io.IOException;
import java.nio.file.*;
import java.util.*;
import java.util.stream.Collectors;

import static org.junit.jupiter.api.Assertions.*;

public class DotenvBuilder_load_Test {

    @Test
    @DisplayName("TC01: load() with systemProperties=false and empty .env list returns DotenvImpl wrapping only system environment entries")
    public void test_TC01() throws IOException, DotenvException {
        // Prepare a temp directory with an empty .env file
        Path tempDir = Files.createTempDirectory("dotenv_tc01");
        Path envFile = Files.createFile(tempDir.resolve(".env"));
        // Record system properties before load to verify none are added
        Properties beforeProps = new Properties();
        beforeProps.putAll(System.getProperties());

        DotenvBuilder builder = new DotenvBuilder()
                .directory(tempDir.toString());
        // systemProperties flag remains false, so path B0→B2 taken
        Dotenv result = builder.load();

        // Build expected entries from System.getenv()
        Set<DotenvEntry> expected = System.getenv().entrySet().stream()
                .map(e -> new DotenvEntry(e.getKey(), e.getValue()))
                .collect(Collectors.toSet());
        assertEquals(expected, result.entries(),
                "entries() should match current System.getenv()");
        // No new system properties should be added
        Properties afterProps = System.getProperties();
        assertEquals(beforeProps, afterProps,
                "System properties must remain unchanged when systemProperties=false");
        // Cleanup
        Files.deleteIfExists(envFile);
        Files.deleteIfExists(tempDir);
    }

    @Test
    @DisplayName("TC02: load() with systemProperties=true and zero entries applies no properties but returns DotenvImpl")
    public void test_TC02() throws IOException, DotenvException {
        // Prepare a temp directory with an empty .env file
        Path tempDir = Files.createTempDirectory("dotenv_tc02");
        Path envFile = Files.createFile(tempDir.resolve(".env"));
        // Record system properties before load
        Properties beforeProps = new Properties();
        beforeProps.putAll(System.getProperties());

        DotenvBuilder builder = new DotenvBuilder()
                .directory(tempDir.toString())
                .systemProperties(); // sets systemProperties=true, path B0→B1→B2
        Dotenv result = builder.load();

        // entries() still only from System.getenv()
        Set<DotenvEntry> expected = System.getenv().entrySet().stream()
                .map(e -> new DotenvEntry(e.getKey(), e.getValue()))
                .collect(Collectors.toSet());
        assertEquals(expected, result.entries(),
                "entries() should match System.getenv() when .env is empty");
        // systemProperties=true but zero entries => no new system props
        Properties afterProps = System.getProperties();
        assertEquals(beforeProps, afterProps,
                "No new system properties should be set when .env has no entries");
        // Cleanup
        Files.deleteIfExists(envFile);
        Files.deleteIfExists(tempDir);
    }

    @Test
    @DisplayName("TC03: load() with systemProperties=false and one entry in .env returns DotenvImpl containing that entry plus system env")
    public void test_TC03() throws IOException, DotenvException {
        // Prepare a temp directory and write one key=value line
        Path tempDir = Files.createTempDirectory("dotenv_tc03");
        Path envFile = tempDir.resolve(".env");
        Files.write(envFile, Collections.singletonList("FOO=BAR"), StandardOpenOption.CREATE);
        // systemProperties is false by default => path B0→B2
        DotenvBuilder builder = new DotenvBuilder().directory(tempDir.toString());
        Dotenv result = builder.load();

        // The custom entry should be retrievable via get()
        assertEquals("BAR", result.get("FOO"),
                "get(\"FOO\") should return the value defined in .env");
        // entries() must contain the new entry
        assertTrue(result.entries().contains(new DotenvEntry("FOO", "BAR")),
                "entries() must include DotenvEntry(\"FOO\",\"BAR\")");
        // Cleanup
        Files.deleteIfExists(envFile);
        Files.deleteIfExists(tempDir);
    }

    @Test
    @DisplayName("TC04: load() with systemProperties=true and multiple entries in .env sets each as system property and returns DotenvImpl")
    public void test_TC04() throws IOException, DotenvException {
        // Prepare temp dir with two entries
        Path tempDir = Files.createTempDirectory("dotenv_tc04");
        Path envFile = tempDir.resolve(".env");
        List<String> lines = Arrays.asList("A=1", "B=2");
        Files.write(envFile, lines, StandardOpenOption.CREATE);
        // Record any existing properties to restore later
        String prevA = System.getProperty("A");
        String prevB = System.getProperty("B");

        // systemProperties=true => path B0→B1→B2
        DotenvBuilder builder = new DotenvBuilder()
                .directory(tempDir.toString())
                .systemProperties();
        Dotenv result = builder.load();

        // The entries should be in the result
        assertAll("Verify loaded values and system properties",
                () -> assertEquals("1", result.get("A"), "result.get(\"A\") should be '1'"),
                () -> assertEquals("2", result.get("B"), "result.get(\"B\") should be '2'"),
                () -> assertEquals("1", System.getProperty("A"), "System property A must be set to '1'"),
                () -> assertEquals("2", System.getProperty("B"), "System property B must be set to '2'")
        );

        // Restore previous system properties
        if (prevA != null) System.setProperty("A", prevA); else System.clearProperty("A");
        if (prevB != null) System.setProperty("B", prevB); else System.clearProperty("B");

        // Cleanup
        Files.deleteIfExists(envFile);
        Files.deleteIfExists(tempDir);
    }

    @Test
    @DisplayName("TC05: load() throws DotenvException when .env file is missing and throwIfMissing=true")
    public void test_TC05() {
        // Point to a non-existent directory; default throwIfMissing=true => exception at B0
        Path nonExistent = Paths.get("nonexistent_dir_for_tc05");
        assertFalse(Files.exists(nonExistent), "Directory must not exist for this test");
        // Record system properties before to verify none are changed
        Properties beforeProps = new Properties();
        beforeProps.putAll(System.getProperties());

        DotenvBuilder builder = new DotenvBuilder()
                .directory(nonExistent.toString());
        DotenvException ex = assertThrows(DotenvException.class,
                builder::load,
                "load() must throw DotenvException when .env is missing");
        // No system properties modified
        Properties afterProps = System.getProperties();
        assertEquals(beforeProps, afterProps,
                "System properties must remain unchanged when load() fails");
    }
}