      "description": "load() throws DotenvException when .env is malformed and throwIfMalformed=true (default)",
      "path": "B0→exception",
      "precondition": "none",
      "expectedResult": "DotenvException is thrown due to malformed entry",
      "tags": [
        "negative",
        "exception",
        "malformed"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 load throws on malformed without ignore",
        "  GIVEN",
        "    // Arrange malformed .env file",
        "    writeLinesToFile(\".env\", [\"BAD_LINE_WITHOUT_EQUALS\"]);",
        "    DotenvBuilder builder = Dotenv.configure();",
        "  WHEN",
        "    // Act & Assert",
        "    call builder.load();",
        "  THEN",
        "    throws DotenvException;",
        "END"
      ]
    }
  ]
