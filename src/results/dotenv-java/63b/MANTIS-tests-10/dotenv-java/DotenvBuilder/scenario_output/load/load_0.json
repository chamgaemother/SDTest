        "TEST TC08 ignore-malformed",
        "  GIVEN",
        "    Path dir = Files.createTempDirectory(\"dir6\");",
        "    Files.write(dir.resolve(\".env\"), Arrays.asList(\"GOOD=1\",\"BAD_LINE\"));",
