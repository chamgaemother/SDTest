      "id": "TC08",
      "description": "load() ignores malformed entries when ignoreIfMalformed() is set and returns only valid entries",
      "path": "B0→B1→B2",
      "precondition": "Create .env with ['GOOD=1','BAD_LINE']; builder.ignoreIfMalformed()",
      "expectedResult": "returned entries contains only DotenvEntry(\"GOOD\",\"1\")",
      "tags": [
        "branch-true",
