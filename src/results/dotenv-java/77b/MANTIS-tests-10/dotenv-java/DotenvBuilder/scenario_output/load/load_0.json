      "path": "B0→B2",
      "precondition": "Create file './.env' with 5 distinct 'K{i}=V{i}'; clear these System.properties beforehand",
      "expectedResult": "for i=1..5, System.getProperty(\"K\"+i)==\"V\"+i",
