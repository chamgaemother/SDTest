{
  "method": "load",
  "scenarios": [
    {
      "id": "TC01",
      "description": "default load() with missing .env throws DotenvException (throwIfMissing=true)",
      "path": "B0",
      "precondition": "Ensure directory './' contains no .env file; no mocks",
      "expectedResult": "throws io.github.cdimascio.dotenv.DotenvException; no system properties set",
      "tags": [
        "exception",
        "branch-true",
        "throwIfMissing",
        "load:directory='./',filename='.env'"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 load missing-file default",
        "  GIVEN",
        "    // Ensure no .env in './'",
        "    DotenvBuilder builder = Dotenv.configure();",
        "  WHEN",
        "    call builder.load();",
        "  THEN",
        "    throws DotenvException;"
      ]
    },
    {
      "id": "TC02",
      "description": "ignoreIfMissing().load() with missing .env returns empty Dotenv (throwIfMissing=false)",
      "path": "B0→B1→B2",
      "precondition": "Ensure directory './' contains no .env file; no mocks",
      "expectedResult": "return Dotenv instance; entries() and entries(null) return only current system environment entries; setInFile empty",
      "tags": [
        "branch-true",
        "loop-0",
        "ignoreIfMissing",
        "load:directory='./',filename='.env'"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02 load ignoreIfMissing missing-file",
        "  GIVEN",
        "    DotenvBuilder builder = Dotenv.configure().ignoreIfMissing();",
        "  WHEN",
        "    Dotenv dotenv = builder.load();",
        "  THEN",
        "    assert dotenv.entries().size() >= 0;",
        "    assert dotenv.entries(null).isEmpty();"
      ]
    },
    {
      "id": "TC03",
      "description": "default load() with one-entry .env returns Dotenv with one file entry and no systemProperties set",
      "path": "B0→B1→B2",
      "precondition": "Create file './.env' containing 'KEY=VALUE'; delete existing System.property KEY if any",
      "expectedResult": "return Dotenv instance; dotenv.get(\"KEY\") == \"VALUE\"; System.getProperty(\"KEY\") == null",
      "tags": [
        "branch-true",
        "loop-1",
        "file-entry",
        "load:directory='./',filename='.env'"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03 load one-entry-file",
        "  GIVEN",
        "    writeFile(\"./.env\",\"KEY=VALUE\");",
        "    DotenvBuilder builder = Dotenv.configure();",
        "  WHEN",
        "    Dotenv dotenv = builder.load();",
        "  THEN",
        "    assert dotenv.get(\"KEY\").equals(\"VALUE\");"
      ]
    },
