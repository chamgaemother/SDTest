{
  "method": "load",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Default load() with empty .env file does not set system properties and returns empty Dotenv entries",
      "path": "B0→B2",
      "precondition": "Temporary empty .env file created at working directory; real DotenvParser and DotenvReader used",
      "expectedResult": "returned Dotenv.entries() is empty set; no new System.getProperty() entries for any key",
      "tags": [
        "branch-false",
        "loop-0",
        "positive",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 load empty-file no-systemProperties",
        "  GIVEN",
        "    DotenvBuilder builder = Dotenv.configure().directory(tempDir).filename(\".env\");",
        "  WHEN",
        "    Dotenv result = builder.load();",
        "  THEN",
        "    assert result.entries().isEmpty();"
      ]
    },
