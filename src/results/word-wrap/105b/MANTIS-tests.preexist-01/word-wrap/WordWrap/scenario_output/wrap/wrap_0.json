      "path": "B0→B1→B5→B6→B7→B10",
      "precondition": "none",
      "expectedResult": "return value contains a hyphen at line break",
      "tags": [
        "overload:()",
        "loop-N",
        "branch-true",
        "breakWords-true",
        "insertHyphens-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 wrap() hyphenation",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"ABCDEFGHIJKL\").maxWidth(5);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.contains(\"ABC-\");"
      ]
    },
    {
      "id": "TC04_O1",
      "description": "wrap() does not break long word when breakWords false covering broken-word-no-hyphen branch",
      "path": "B0→B1→B5→B6→B8→B10",
      "precondition": "none",
      "expectedResult": "return value contains no hyphen at line break",
      "tags": [
        "overload:()",
        "loop-N",
