{
  "method": "wrap",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "wrap() returns input text unchanged when text length ≤ maxWidth covering no-wrap branch",
      "path": "B0→B1→B2→B10",
      "precondition": "none",
      "expectedResult": "return value is \"Hello World\"",
      "tags": [
        "overload:()",
        "loop-0",
        "branch-false"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 wrap() simple no-wrap",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"Hello World\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"Hello World\");"
      ]
    },
    {
