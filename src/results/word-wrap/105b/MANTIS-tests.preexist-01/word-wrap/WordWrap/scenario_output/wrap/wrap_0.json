        "breakWords-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04_O1 wrap() no breakWords",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"ABCDEFGHIJKL\").maxWidth(5).breakWords(false);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert !result.contains(\"-\");"
      ]
    },
