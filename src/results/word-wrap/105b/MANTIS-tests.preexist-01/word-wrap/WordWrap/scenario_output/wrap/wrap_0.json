        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02_O1 wrap() handles existing newlines",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"Line1\\nLine2\");",
        "  WHEN",
