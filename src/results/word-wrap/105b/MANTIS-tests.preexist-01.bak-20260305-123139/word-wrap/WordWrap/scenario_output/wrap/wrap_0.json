{
  "method": "wrap",
  "scenarios": [
    {
      "id": "TC01_overload_wrap_String",
      "description": "Builder.wrap() returns original short text when under maxWidth (branch false for tooLong)",
      "path": "B0→B1→B2→B3",
      "precondition": "Reader on text \"Hello world\"; default maxWidth=80",
      "expectedResult": "return value is \"Hello world\"",
      "tags": [
        "branch-false",
        "loop-0",
        "overload:wrap()"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 simple-short-text",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"Hello world\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"Hello world\");"
      ]
    },
    {
      "id": "TC02_overload_wrap_String",
      "description": "Builder.wrap() splits long text at whitespace when exceeding maxWidth (branch true for tooLong then writeLine)",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "Reader on text \"one two three\"; set maxWidth to 7 via builder.maxWidth(7)",
      "expectedResult": "return value is \"one two\\nthree\"",
      "tags": [
        "branch-true",
        "boundary",
        "overload:wrap()"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 wrap-at-space",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"one two three\").maxWidth(7);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"one two\\nthree\");"
      ]
    },
    {
