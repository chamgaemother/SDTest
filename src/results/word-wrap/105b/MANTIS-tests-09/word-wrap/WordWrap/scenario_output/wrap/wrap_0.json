      "id": "TC01_O1",
      "description": "wrap(Writer) with single short word writes the word without line breaks (loop-1, branch-false)",
      "path": "B0→B1(loop×1)→B35→B36",
      "precondition": "Builder created via WordWrap.from(\"hello\") with default settings; uses real StringWriter",
      "expectedResult": "writer.toString() equals \"hello\"",
      "tags": [
        "overload:Writer",
        "loop-1",
        "branch-false",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 wrap writes single word",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"hello\"); StringWriter writer = new StringWriter();",
        "  WHEN",
        "    b.wrap(writer);",
        "  THEN",
        "    assert writer.toString().equals(\"hello\");"
      ]
    },
