      "id": "TC17",
      "description": "rightTrim() removes trailing whitespace from end of CharSequence",
      "path": "B0→B1(loop)→B3",
      "precondition": "none",
      "expectedResult": "returns substring without trailing spaces",
      "tags": [
        "utility",
        "boundary",
        "visibleForTesting"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 rightTrim trims trailing spaces",
        "  GIVEN",
        "    CharSequence s = \"abc   \";",
        "  WHEN",
        "    CharSequence r = WordWrap.rightTrim(s);",
        "  THEN",
        "    assertEquals(\"abc\", r.toString());"
      ]
    },
