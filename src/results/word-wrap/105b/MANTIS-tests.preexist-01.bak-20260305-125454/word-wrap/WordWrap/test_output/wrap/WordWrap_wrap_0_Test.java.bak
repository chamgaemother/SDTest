package org.davidmoten.text.utils;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertArrayEquals;

import java.io.BufferedReader;
import java.io.File;
import java.io.FileNotFoundException;
import java.io.IOException;
import java.io.InputStream;
import java.io.InputStreamReader;
import java.io.Reader;
import java.io.StringReader;
import java.io.StringWriter;
import java.io.Writer;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import java.util.function.Function;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import com.github.davidmoten.guavamini.Preconditions;
import com.github.davidmoten.guavamini.annotations.VisibleForTesting;

public class WordWrap_wrap_Test {

    @Test
    @DisplayName("TC01_O1: wrap() with empty input yields empty string (no loop iterations)")
    public void test_TC01_O1() {
        // empty input triggers zero iterations and returns empty
        String text = "";
        String result = WordWrap.from(text).wrap();
        assertEquals("", result);
    }

    @Test
    @DisplayName("TC02_O1: wrap() with single short word below maxWidth appends word without newline")
    public void test_TC02_O1() {
        // single word length 5 < default maxWidth=80, so direct append path
        String text = "hello";
        String result = WordWrap.from(text).wrap();
        assertEquals("hello", result);
    }

    @Test
    @DisplayName("TC03_O1: wrap() with word longer than maxWidth breaks word with hyphen default behavior")
    public void test_TC03_O1() {
        // word length=8 > maxWidth=5, breakWords=true and insertHyphens=true
        String text = "abcdefgh";
        String result = WordWrap.from(text)
                .maxWidth(5)
                .insertHyphens(true)
                .wrap();
        // expects hyphen at pos 3, newline, then rest broken further
        String expected = "abc-\nde" + "fgh";
        assertEquals(expected, result);
    }

    @Test
    @DisplayName("TC04_O1: wrap() with breakWords=false does not break long word, emits entire word on new line")
    public void test_TC04_O1() {
        // word length=6 > maxWidth=3, breakWords=false so no hyphen, broken flag path
        String text = "abcdef";
        String result = WordWrap.from(text)
                .maxWidth(3)
                .breakWords(false)
                .wrap();
        assertEquals("abcdef", result);
    }

    @Test
    @DisplayName("TC05_O2: wrapToList() returns list of lines for multi-line input")
    public void test_TC05_O2() {
        // characters and spaces cause wrapping each letter at maxWidth=1
        String text = "a b c d";
        List<String> lines = WordWrap.from(text)
                .maxWidth(1)
                .wrapToList();
        assertEquals(Arrays.asList("a", "b", "c", "d"), lines);
    }

    @Test
    @DisplayName("TC06_O3: wrap(LineConsumer) with custom consumer collects built lines for single input")
    public void test_TC06_O3() {
        // no wrap because length 11 < default maxWidth=80
        String text = "hello world";
        List<String> lines = new ArrayList<>();
        WordWrap.from(text).wrap(new LineConsumer() {
            private StringBuilder b = new StringBuilder();
            @Override
            public void write(char[] chars, int offset, int length) throws IOException {
                b.append(chars, offset, length);
            }
            @Override
            public void writeNewLine() throws IOException {
                lines.add(b.toString());
                b.setLength(0);
            }
            @Override
            public void write(String s) throws IOException {
                b.append(s);
            }
        });
        // after wrap, since only one line, writeNewLine not called, so last buffer added manually
        // but wrap(LineConsumer) appends at end
        // so we expect single element
        assertEquals(Arrays.asList("hello world"), lines);
    }

    @Test
    @DisplayName("TC07_O4: wrap(File,Charset) throws IORuntimeException for non-existent input file")
    public void test_TC07_O4() {
        // non-existent file triggers FileNotFoundException wrapped by IORuntimeException
        File file = new File("no-such.txt");
        IORuntimeException ex = assertThrows(IORuntimeException.class, () -> {
            WordWrap.from(file, StandardCharsets.UTF_8).wrap(new StringWriter());
        });
        assertEquals(FileNotFoundException.class, ex.getCause().getClass());
    }

    @Test
    @DisplayName("TC08_O5: wrapUtf8(String) writes wrapped content to file using UTF-8 encoding")
    public void test_TC08_O5() throws IOException {
        // write to temp file and verify content
        String text = "hello world";
        File temp = File.createTempFile("wwtest", ".txt");
        temp.deleteOnExit();
        String filename = temp.getAbsolutePath();
        WordWrap.from(text).wrapUtf8(filename);
        byte[] data = Files.readAllBytes(Paths.get(filename));
        assertEquals(text, new String(data, StandardCharsets.UTF_8));
    }

    @Test
    @DisplayName("TC09_O1: wrap() with custom newLine delimiter \r\n produces windows newlines")
    public void test_TC09_O1() {
        // two words separated by space, forced newline at maxWidth=1
        String text = "a b";
        String result = WordWrap.from(text)
                .maxWidth(1)
                .newLine("\r\n")
                .wrap();
        assertEquals("a\r\nb", result);
    }
}