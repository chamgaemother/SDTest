  "scenarios": [
    {
      "id": "TC11",
      "description": "Carriage return characters are ignored and Windows line endings produce correct lines",
      "path": "B0‚ÜíB3(ch!='\\n'&&ch!='\\r')‚ÜíB?‚Üí‚Ä¶‚ÜíEOF branch handling line break on '\\n'",
      "precondition": "none",
      "expectedResult": "lines [\"A\",\"B\"] are produced for input \"A\\r\\nB\"",
      "tags": [
        "positive",
        "newline",
        "carriage-return"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 carriage-return handling",
        "  GIVEN",
        "    Reader in = new StringReader(\"A\\r\\nB\");",
        "    WordWrap.Builder builder = WordWrap.from(in, true);",
        "  WHEN",
        "    List<String> lines = builder.wrapToList();",
        "  THEN",
        "    assert lines.equals(Arrays.asList(\"A\", \"B\"));",
        "END"
      ]
    },
