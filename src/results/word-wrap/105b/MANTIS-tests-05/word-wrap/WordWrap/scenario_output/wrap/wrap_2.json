      "id": "TC22",
      "description": "wrap(LineConsumer) overload writes lines via direct LineConsumer API",
      "path": "B0â†’Builder.wrap(LineConsumer)â†’wordWrap(in,consumer,...)â†’writeâ†’writeNewLineâ†’end",
      "precondition": "none",
      "expectedResult": "LineConsumer receives proper write and writeNewLine calls",
      "tags": [
        "positive",
        "overload",
        "LineConsumer"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 wrap-with-LineConsumer",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"A B\");",
        "    List<String> captured = new ArrayList<>();",
        "    WordWrap.LineConsumer lc = new LineConsumer() {",
        "      StringBuilder sb = new StringBuilder();",
        "      @Override public void write(char[] c, int off, int len) throws IOException { sb.append(c, off, len); }",
        "      @Override public void writeNewLine() throws IOException { captured.add(sb.toString()); sb.setLength(0); }",
        "    };",
        "  WHEN",
        "    b.wrap(lc);",
        "  THEN",
        "    assert captured equals [\"A B\"];",
        "END"
      ]
