    {
      "id": "TC16",
      "description": "Exercises wrap(LineConsumer) overload directly (LineConsumer path)",
      "path": "B0â†’Builder.wrap(LineConsumer)â†’static wordWrap Readerâ†’consumer.writeNewLine on newlineâ†’final",
      "precondition": "none",
      "expectedResult": "LineConsumer receives correct lines for '1 2'",
      "tags": [
        "overload",
        "lineconsumer",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 direct-lineconsumer-overload",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"1 2\");",
        "    List<String> captured = new ArrayList<>();",
        "    LineConsumer lc = new LineConsumer(){",
        "      StringBuilder sb=new StringBuilder();",
        "      public void write(char[] c,int off,int len){sb.append(c,off,len);}",
        "      public void writeNewLine(){captured.add(sb.toString()); sb.setLength(0);}        ",
        "    };",
        "  WHEN",
        "    b.wrap(lc);",
        "  THEN",
        "    assert captured.equals(Arrays.asList(\"1 2\"));",
        "END"
      ]
    },
