    {
      "id": "TC11",
      "description": "Handles carriage return characters by ignoring '\\r' (branch ch=='\\r')",
      "path": "B0â†’B3(loop start)â†’B4(ch!='\\n')â†’B5(ch=='\\r')â†’loop endâ†’B0",
      "precondition": "none",
      "expectedResult": "concatenates 'a' and 'b' into 'ab' without errors",
      "tags": [
        "branch",
        "carriage-return",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 ignore-carriage-return",
        "  GIVEN",
        "    Reader r = new BufferedReader(new StringReader(\"a\\rb\"));",
        "    StringWriter out = new StringWriter();",
        "    Builder b = WordWrap.from(r);",
        "  WHEN",
        "    b.wrap(out);",
        "  THEN",
        "    assert out.toString().equals(\"ab\");",
        "END"
      ]
    },
