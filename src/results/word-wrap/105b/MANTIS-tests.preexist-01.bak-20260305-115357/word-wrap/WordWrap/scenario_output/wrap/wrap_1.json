      "tags": [
        "positive",
        "punctuation",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 punctuation-split",
        "  GIVEN",
        "    String text = \"abcdef!gh\";",
        "    Builder b = WordWrap.from(text)",
        "                  .maxWidth(3)",
        "                  .excludeExtraWordChars(\"!\");",
        "  WHEN",
        "    List<String> lines = b.wrapToList();",
        "  THEN",
        "    assert lines.get(0).equals(\"abc\");",
        "    assert lines.get(1).equals(\"def\");",
        "    assert lines.get(2).equals(\"!gh\");",
        "END"
      ]
