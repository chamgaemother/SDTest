    {
      "id": "TC13",
      "description": "use wrap(LineConsumer) to collect chars and newlines via custom consumer",
      "path": "B0â†’B1(loopĂ—2)â†’B10â†’B11â†’B15â†’B16",
      "precondition": "none",
      "expectedResult": "consumer receives 'hi' then newline then 'yo'",
      "tags": [
        "positive",
        "consumer",
        "api"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 wrap-via-LineConsumer",
        "  GIVEN",
        "    StringReader r = new StringReader(\"hi yo\");",
        "    Builder b = WordWrap.from(r, false).maxWidth(2);",
        "    StringBuilder acc = new StringBuilder();",
        "  WHEN",
        "    b.wrap(new LineConsumer() {",
        "      write(chars,off,len)->acc.append(chars,off,len);",
        "      writeNewLine()->acc.append(\"|\");",
        "    });",
        "  THEN",
        "    assert acc.toString().equals(\"hi| yo\");",
        "END"
      ]
    },
