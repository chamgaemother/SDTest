      "id": "TC08_O2",
      "description": "wrap(File,Charset) writes wrapped content to file and reads back (successful file write branch)",
      "path": "B0→B1→B4→B5",
      "precondition": "temporary file created, default charset UTF-8",
      "expectedResult": "file content equals original text",
      "tags": [
        "file-io",
        "successful-write",
        "overload:wrap(File,Charset)"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 wrap-file-success",
        "  GIVEN",
        "    File f = tempFile();",
        "    Builder b = WordWrap.from(\"abc\");",
        "  WHEN",
        "    b.wrap(f, StandardCharsets.UTF_8);",
        "  THEN",
        "    assert readFile(f, UTF-8).equals(\"abc\");",
        "END"
      ]
