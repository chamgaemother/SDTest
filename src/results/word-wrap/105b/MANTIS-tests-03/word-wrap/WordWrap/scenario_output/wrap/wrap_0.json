    {
      "id": "TC01_O1",
      "description": "wrap() returns empty string when input is empty (no loop iterations, end-of-stream branch)",
      "path": "B0→B1→B2",
      "precondition": "Builder created from(CharSequence) with empty text",
      "expectedResult": "return value is \"\"",
      "tags": [
        "loop-0",
        "boundary",
        "empty-input",
        "overload:void()→String",
        "overload:wrap()"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 empty-input returns-empty",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"\"\");",
        "END"
      ]
    },
