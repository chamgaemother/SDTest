{
  "method": "wrap",
  "scenarios": [
    {
      "id": "TC01",
      "description": "wrap(CharSequence) with short text under maxWidth avoids any wrapping (branch false for tooLong)",
      "path": "B0→B1→B2(loop×N=… minimal iterations)→B9",
      "precondition": "none",
      "expectedResult": "return value equals original text without inserted newLine",
      "tags": [
        "branch-false",
        "loop-N",
        "overload:CharSequence"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 simple-no-wrap",
        "  GIVEN",
        "    String text = \"Hello world\";",
        "  WHEN",
        "    String result = WordWrap.from(text).wrap();",
        "  THEN",
        "    assert result.equals(\"Hello world\");",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "wrap(CharSequence) with newline in input preserves line boundary and does not wrap (branch ch=='\\n')",
      "path": "B0→B1→B3→B4→B5→B6",
      "precondition": "none",
      "expectedResult": "return value equals input lines separated by newLine",
      "tags": [
        "branch-true",
        "loop-1",
        "overload:CharSequence"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 preserve-newline",
        "  GIVEN",
        "    String text = \"A line\\nB line\";",
        "  WHEN",
        "    String result = WordWrap.from(text).wrap();",
        "  THEN",
        "    assert result.equals(\"A line\\nB line\");",
        "END"
      ]
    },
    {
