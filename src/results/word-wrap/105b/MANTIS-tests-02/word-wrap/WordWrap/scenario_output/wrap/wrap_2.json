      "description": "maxWidth(0) throws IllegalArgumentException for non‐positive width",
      "path": "B0→B1→B2(checkArgument)→B3",
      "precondition": "Builder created from non‐empty text",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 maxWidth zero throws",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"any\");",
        "  WHEN",
        "    call b.maxWidth(0);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
