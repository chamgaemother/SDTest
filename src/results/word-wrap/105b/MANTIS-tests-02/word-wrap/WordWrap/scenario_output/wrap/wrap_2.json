        "positive",
        "configuration",
        "newline"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC19 custom CRLF newLine",
        "  GIVEN",
        "    String text = \"a b\";",
        "    Builder b = WordWrap.from(text).maxWidth(1).newLine(\"\\r\\n\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
