    {
      "id": "TC15",
      "description": "fromClasspathUtf8 of nonexistent resource leads to NullPointerException on wrap",
      "path": "B0→B1(new Builder)→B2(stream null)→B3(reader)→B4(read)→B5(-1?)→B6(NPE)",
      "precondition": "no classpath resource named 'missing.txt'",
      "expectedResult": "NullPointerException is thrown during wrap()",
      "tags": [
        "exception",
        "classpath",
        "negative"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 fromClasspathUtf8 missing resource",
        "  GIVEN",
        "    String resource = \"missing.txt\"; // not on classpath",
        "    Builder b = WordWrap.fromClasspathUtf8(resource);",
        "  WHEN",
        "    call b.wrap();",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
      "id": "TC16",
      "description": "wrap(File,Charset) writes wrapped output to file and closes streams",
      "path": "B0→B1(wrap(File,Charset))→B2(write)→B3(close in finally)",
      "precondition": "temporary file is writable",
      "expectedResult": "file content matches expected wrapped text",
      "tags": [
        "positive",
        "file",
        "IO"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 wrap to file with charset",
        "  GIVEN",
        "    File temp = createTempFile();",
        "    String input = \"one two\";",
        "  WHEN",
        "    WordWrap.from(input).maxWidth(3).wrap(temp, StandardCharsets.UTF_8);",
        "  THEN",
        "    String content = readFile(temp, UTF_8);",
        "    assert content.equals(\"one\\n two\");",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "excludeExtraWordChars(',') treats comma as punctuation and breaks on comma",
      "path": "B0→B1(extraWordChars remove)→B2(punctuation branch)→B3(writeLine)",
      "precondition": "default extraWordChars contains ','",
      "expectedResult": "string breaks at comma: \"hello,\\nworld\"",
      "tags": [
        "positive",
        "configuration",
        "punctuation"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 exclude comma splits at punctuation",
        "  GIVEN",
        "    String text = \"hello,world\";",
        "    Builder b = WordWrap.from(text).maxWidth(6).excludeExtraWordChars(\",\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"hello,\\nworld\");",
        "END"
      ]
    },
    {
