    {
      "id": "TC17",
      "description": "writeBrokenWord without hyphens when word length ≤2",
      "path": "B0→B3→B6(word build)→B7(tooLong→breakWords→writeBrokenWord else branch)→B8",
      "precondition": "none",
      "expectedResult": "Word of length 2 splits one char per line without hyphens",
      "tags": [
        "positive",
        "broken-word",
        "boundary"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 broken word fallback no hyphen",
        "  GIVEN",
        "    String text = \"ab\";",
        "    Builder b = WordWrap.from(text).maxWidth(1).breakWords(true).insertHyphens(true);",
        "  WHEN",
        "    String out = b.wrap();",
        "  THEN",
