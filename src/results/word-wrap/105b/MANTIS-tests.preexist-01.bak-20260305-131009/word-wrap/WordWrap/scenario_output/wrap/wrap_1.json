{
  "scenarios": [
    {
      "id": "TC11",
      "description": "maxWidth ≤ 0 triggers IllegalArgumentException in Builder.maxWidth",
      "path": "B0→B1→B2",
      "precondition": "WordWrap.Builder b = WordWrap.from(\"irrelevant\");",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "parameter-validation"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 maxWidth validation throws",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"text\");",
        "  WHEN",
        "    call b.maxWidth(0);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC12",
      "description": "Carriage return characters are ignored and only line feed triggers wrap",
      "path": "B0→B3(loop with ch='\\r')→B3(loop with ch='\\n')→B4→B5",
      "precondition": "none",
      "expectedResult": "CR is skipped, LF causes line break",
      "tags": [
        "positive",
        "loop",
        "carriage-return"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 ignore carriage return",
        "  GIVEN",
        "    String input = \"A\\r\\nB\";",
        "    Builder b = WordWrap.from(input).maxWidth(10);",
        "  WHEN",
        "    String output = b.wrap();",
        "  THEN",
        "    assertEquals(\"A\\nB\", output);"
      ]
    },
    {
      "id": "TC13",
      "description": "Punctuation not in extraWordChars triggers wrapping at punctuation boundary",
      "path": "B0→B3→B6(punctuation path)→B7→B8",
      "precondition": "Builder.extraWordChars set to empty",
      "expectedResult": "Text splits before punctuation mark",
      "tags": [
        "boundary",
        "punctuation",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 wrap at punctuation when excluded",
        "  GIVEN",
        "    String text = \"foo,bar\";",
        "    Builder b = WordWrap.from(text).extraWordChars(\"\").maxWidth(3);",
        "  WHEN",
        "    String out = b.wrap();",
        "  THEN",
        "    assertEquals(\"foo\\n,bar\", out);"
      ]
    },
    {
      "id": "TC14",
      "description": "wrapToList returns correct list of lines for multi-line input",
      "path": "B0→B3(loop)→B9→B10",
      "precondition": "none",
      "expectedResult": "List has individual wrapped lines",
      "tags": [
        "positive",
        "wrapToList",
        "iteration"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 wrapToList multi-line",
        "  GIVEN",
        "    String input = \"one two three\";",
        "    Builder b = WordWrap.from(input).maxWidth(4);",
        "  WHEN",
        "    List<String> lines = b.wrapToList();",
        "  THEN",
        "    assert lines.equals(Arrays.asList(\"one\",\"two\",\"three\"));"
      ]
    },
