      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC20 wrapUtf8 String filename",
        "  GIVEN",
        "    File temp = File.createTempFile(\"w\",\".txt\"); temp.deleteOnExit();",
        "    WordWrap.Builder b = WordWrap.from(new StringReader(\"hello world\")).maxWidth(5);",
        "  WHEN",
        "    b.wrapUtf8(temp.getAbsolutePath());",
        "    String out = new String(Files.readAllBytes(temp.toPath()), StandardCharsets.UTF_8);",
