      "description": "wrap(File,Charset) throws IORuntimeException when file not found (exception path)",
      "path": "B0→[FileInputStream ctor throws FileNotFoundException]→catch→throw IORuntimeException",
      "precondition": "File f = nonExistentFile; Builder.from(f,UTF_8)",
      "expectedResult": "throws IORuntimeException",
      "tags": [
        "exception",
        "FileNotFoundException",
        "overload:File,Charset"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 from-file-not-found",
        "  GIVEN",
        "    File f = new File(\"no-such.txt\");",
        "  WHEN",
        "    call WordWrap.from(f,StandardCharsets.UTF_8);",
        "  THEN",
        "    throws IORuntimeException;"
      ]
    },
