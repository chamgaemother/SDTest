        "  GIVEN",
        "    Builder b = WordWrap.from(\"ab\\ncd\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"ab\\ncd\");"
      ]
    },
    {
      "id": "TC07",
      "description": "wrapToList() collects lines into List<String> path via LineConsumer",
      "path": "B0→B1→wrap(LineConsumer)→wordWrap→lines.add→B_last",
      "precondition": "Builder b = WordWrap.from(\"one two three\").maxWidth(4);",
      "expectedResult": "returned List is [\"one\",\"two\",\"thr\",\"ee\"]",
      "tags": [
        "loop-N",
        "LineConsumer",
        "overload:none"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 wrapToList multiple-lines",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"one two three\").maxWidth(4);",
        "  WHEN",
        "    List<String> lines = b.wrapToList();",
        "  THEN",
        "    assert lines.equals(Arrays.asList(\"one\",\"two\",\"thr\",\"ee\"));"
      ]
    },
    {
      "id": "TC08",
      "description": "wrap(Writer) with writer throwing IOException is wrapped into IORuntimeException",
      "path": "B0→B1→wrap(writer)→wordWrap→IOException→catch→throw IORuntimeException",
      "precondition": "Builder b = WordWrap.from(\"x\"); Writer w stub throws IOException on write",
      "expectedResult": "throws IORuntimeException; no reader left open",
      "tags": [
        "exception",
        "IOException",
        "overload:Writer"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 writer-io-exception",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"x\");",
        "    Writer w = stubWriter.throwOnFirstWrite();",
        "  WHEN",
        "    call b.wrap(w);",
        "  THEN",
        "    throws IORuntimeException;"
      ]
    },
    {
