{
  "method": "wrap",
  "scenarios": [
    {
      "id": "TC01",
      "description": "wrap() on empty input produces empty string (loop zero iterations)",
      "path": "B0→B1→[while-start false]→B_last",
      "precondition": "Builder b = WordWrap.from(\"\"); default settings",
      "expectedResult": "returned String is \"\"",
      "tags": [
        "loop-0",
        "boundary",
        "positive",
        "overload:String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 empty-input",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"\");"
      ]
    },
    {
      "id": "TC02",
      "description": "wrap() with single short word shorter than maxWidth stays on one line (branch false tooLong)",
      "path": "B0→B1→[read char 'x']→B2→B3→[tooLong false]→...→B_last",
      "precondition": "Builder b = WordWrap.from(\"hello\"); default maxWidth=80",
      "expectedResult": "returned String is \"hello\"",
      "tags": [
        "branch-false",
        "positive",
        "overload:String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 single-short-word",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"hello\");",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"hello\");"
      ]
    },
    {
      "id": "TC03",
      "description": "wrap() with word exactly at maxWidth boundary does not break (boundary tooLong false)",
      "path": "B0→B1→[chars read]→B2→B3→[tooLong false]→...→B_last",
      "precondition": "Builder b = WordWrap.from(\"abcdefghij\"); b.maxWidth(10);",
      "expectedResult": "returned String is \"abcdefghij\"",
      "tags": [
        "boundary",
        "branch-false",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 exact-width",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"abcdefghij\").maxWidth(10);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"abcdefghij\");"
      ]
    },
    {
      "id": "TC04",
      "description": "wrap() with long word exceeding maxWidth breaks word with hyphens (branch-true breakWords true insertHyphens true)",
      "path": "B0→B1→[read sequence]→B2→B3→[tooLong true]→B4→writeBrokenWord→...→B_last",
      "precondition": "Builder b = WordWrap.from(\"abcdefghijklmnop\").maxWidth(5);",
      "expectedResult": "returned String is \"abc-\\nde-\\nfgh-\\nij-\\nkl-\\nmn-\\nop\"",
      "tags": [
        "branch-true",
        "loop-N",
        "breakWords-true",
        "insertHyphens-true",
        "overload:String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 hyphenated-break",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"abcdefghijklmnop\").maxWidth(5);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"abc-\\n\" +",
        "                         \"de-\\n\" +",
        "                         \"fgh-\\n\" +",
        "                         \"ij-\\n\" +",
        "                         \"kl-\\n\" +",
        "                         \"mn-\\n\" +",
        "                         \"op\");"
      ]
    },
    {
      "id": "TC05",
      "description": "wrap() with long word exceeding maxWidth without breaking words leaves word unbroken (branch-true breakWords false)",
      "path": "B0→B1→...→tooLong true→broken true→end-of-file",
      "precondition": "Builder b = WordWrap.from(\"abcdefghijk\").maxWidth(5).breakWords(false);",
      "expectedResult": "returned String is \"abcdefghijk\"",
      "tags": [
        "branch-true",
        "breakWords-false",
        "loop-1",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 no-breakWords",
        "  GIVEN",
        "    Builder b = WordWrap.from(\"abcdefghijk\").maxWidth(5).breakWords(false);",
        "  WHEN",
        "    String result = b.wrap();",
        "  THEN",
        "    assert result.equals(\"abcdefghijk\");"
      ]
    },
    {
