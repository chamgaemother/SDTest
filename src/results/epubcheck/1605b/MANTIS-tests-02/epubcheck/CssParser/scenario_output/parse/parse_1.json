      "tags": [
        "positive",
        "rule-set",
        "declaration",
        "iteration=1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse single rule-set with declaration",
        "  GIVEN",
        "    Reader reader = new StringReader(\"p{color:red;}\"),",
        "    CssErrorHandler err = new TestErrorHandler(),",
        "    CssContentHandler doc = new TestContentHandler();",
        "  WHEN",
        "    new CssParser().parse(reader, \"sys\", err, doc);",
        "  THEN",
        "    assert err.errors.isEmpty();",
        "    assert doc.selectorsCalled.get(0).get(0).equals(\"p\");",
        "    assert doc.declarationsRecorded(0).get(0).toCssString().contains(\"color:red\");",
        "    assert doc.endDocument() called once;",
        "END"
      ]
    },
