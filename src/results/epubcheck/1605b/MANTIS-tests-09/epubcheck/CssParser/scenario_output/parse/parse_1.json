        "    assert err.last.getErrorCode() == CssErrorCode.GRAMMAR_UNEXPECTED_TOKEN;",
        "    assert doc.events == [\"startDocument\",\"startAtRule(foo)\",\"endAtRule(foo)\",\"endDocument\"];",
