      "pseudocode": [
        "TEST TC10 three-token mixed sequence",
        "  GIVEN",
        "    CssParser parser = spy(new CssParser(Locale.ENGLISH));",
        "    CssErrorHandler err = mock(CssErrorHandler.class);",
        "    CssContentHandler doc = mock(CssContentHandler.class);",
        "    CssToken t1 = new CssToken(CssToken.Type.IDENT, \"id\", loc(1,1));",
        "    CssToken t2 = new CssToken(CssToken.Type.ATKEYWORD, \"@a\", loc(1,2));",
        "    CssToken t3 = new CssToken(CssToken.Type.IDENT, \"id2\", loc(1,3));",
        "    CssTokenIterator iter = iteratorOf(t1,t2,t3);",
        "    stubScan(parser, iter);",
        "    doNothing().when(parser).invokePrivate(\"handleRuleSet\", any(), any(), any(), any());",
        "    doNothing().when(parser).invokePrivate(\"handleAtRule\", any(), any(), any(), any());",
        "  WHEN",
        "    parser.parse(new StringReader(\"\"), \"sys\", err, doc);",
        "  THEN",
        "    verify(parser, times(2)).invokePrivate(\"handleRuleSet\", any(), any(), any(), any());",
        "    verify(parser, times(1)).invokePrivate(\"handleAtRule\", any(), any(), any(), any());",
        "    verify(doc).endDocument();",
        "END"
      ]
    },
