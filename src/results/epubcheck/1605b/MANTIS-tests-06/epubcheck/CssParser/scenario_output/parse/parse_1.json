      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 unexpected-closeparen-before-block",
        "  GIVEN",
        "    // Arrange selector then ')' token to hit MATCH_CLOSEPAREN",
        "    String css = \"h1){}\";",
        "    CssParser parser = new CssParser();",
        "    TestErrorHandler err = new TestErrorHandler();",
        "    TestContentHandler doc = new TestContentHandler();",
        "    StringReader reader = new StringReader(css);",
        "  WHEN",
        "    parser.parse(reader, \"id\", err, doc);",
        "  THEN",
        "    // Assert",
        "    assertTrue(err.errors.contains(CssErrorCode.GRAMMAR_UNEXPECTED_TOKEN));",
        "    assertEquals(1, doc.startDocumentCount);",
        "    assertEquals(1, doc.endDocumentCount);"
      ]
    },
