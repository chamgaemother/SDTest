      "path": "B0â†’B1â†’B2â†’B3(handleAtRule)â†’NoSuchElementExceptionâ†’catchâ†’doc.startAtRuleâ†’err.error(GRAMMAR_PREMATURE_EOF)â†’doc.endAtRuleâ†’throw PrematureEOFExceptionâ†’B6â†’B8",
      "precondition": "none",
