  "scenarios": [
    {
      "id": "TC01",
      "description": "call child(0) on element with no child nodes (childNodeSize()==0) throws IndexOutOfBoundsException",
      "path": "B0→B1_zero→B2_exception",
      "precondition": "Element parent = new Element(\"div\"); // no children",
      "expectedResult": "throws IndexOutOfBoundsException; no state mutated",
      "tags": [
        "branch-false",
        "loop-0",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 child no-children",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "  WHEN",
        "    call parent.child(0);",
        "  THEN",
        "    throws IndexOutOfBoundsException;"
      ]
    },
    {
      "id": "TC02",
      "description": "call child(0) on element with exactly one Element child returns that child (loop iterates once)",
      "path": "B0→B1_nonzero→B3_loop(1)→B4_return",
      "precondition": "Element parent = new Element(\"ul\"); parent.appendElement(\"li\");",
      "expectedResult": "return value is the only child element",
      "tags": [
        "branch-true",
        "loop-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 child single-element",
        "  GIVEN",
        "    Element parent = new Element(\"ul\");",
        "    Element child = parent.appendElement(\"li\");",
        "  WHEN",
        "    Element result = parent.child(0);",
        "  THEN",
        "    assert result == child;"
      ]
    },
    {
      "id": "TC03",
      "description": "call child(0) on element with mixed nodes (TextNode then Element) returns first Element child (loop filters non-Element)",
      "path": "B0→B1_nonzero→B3_loop(2)→B4_return",
      "precondition": "Element parent = new Element(\"p\"); parent.appendText(\"Hello\"); parent.appendElement(\"span\");",
      "expectedResult": "return value is the span element",
      "tags": [
        "branch-true",
        "loop-N"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 child mixed-nodes",
        "  GIVEN",
        "    Element parent = new Element(\"p\");",
        "    TextNode t = new TextNode(\"Hello\"); parent.appendChild(t);",
        "    Element span = parent.appendElement(\"span\");",
        "  WHEN",
        "    Element result = parent.child(0);",
        "  THEN",
        "    assert result == span;"
      ]
    },
    {
      "id": "TC04",
