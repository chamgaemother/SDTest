      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 child two-elements",
        "  GIVEN",
        "    Element parent = new Element(\"ol\");",
        "    Element first = parent.appendElement(\"li\");",
        "    Element second = parent.appendElement(\"li\");",
        "  WHEN",
        "    Element result = parent.child(1);",
        "  THEN",
        "    assert result == second;"
      ]
