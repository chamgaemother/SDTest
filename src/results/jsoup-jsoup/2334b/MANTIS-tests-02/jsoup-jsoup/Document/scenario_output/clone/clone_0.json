      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 quirksMode-preservation",
        "  GIVEN",
        "    Document doc = new Document(\"u\");",
        "    doc.quirksMode(Document.QuirksMode.limitedQuirks);",
