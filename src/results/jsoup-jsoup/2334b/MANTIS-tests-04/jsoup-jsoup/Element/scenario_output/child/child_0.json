      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 child single element",
        "  GIVEN",
        "    Element parent = new Element(\"ul\");",
        "    Element child = parent.appendElement(\"li\");",
        "  WHEN",
        "    Element result = parent.child(0);",
        "  THEN",
        "    assert result == child;"
      ]
