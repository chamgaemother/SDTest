{
  "scenarios": [
    {
      "id": "TC05",
      "description": "appendChild(Element) on empty parent creates NodeList and projects proper siblingIndex and parent",
      "path": "B0→B2→B3→B5",
      "precondition": "none",
      "expectedResult": "returned parent; child.parent()==parent; child.siblingIndex==0; parent.childNodeSize()==1",
      "tags": [
        "positive",
        "element-child",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 appendChild with Element node",
        "  GIVEN",
        "    Element parent = new Element(\"section\");",
        "    Element child = new Element(\"div\");",
        "  WHEN",
        "    Element result = parent.appendChild(child);",
        "  THEN",
        "    assertSame(parent, result);",
        "    assertSame(parent, child.parent());",
        "    assertEquals(1, parent.childNodeSize());",
        "    // via reflection verify siblingIndex is 0",
        "    int idx = getSiblingIndexViaReflection(child);",
        "    assertEquals(0, idx);",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "appendChild(moving Element) invalidates shadowChildrenRef cache and updates both source and target lists",
      "path": "B0→B2→B3→B5→B6",
      "precondition": "parent1 has two element children and shadow cache populated",
      "expectedResult": "child moved from parent1 to parent2; parent1.children().size()==1; parent2.children().size()==3",
      "tags": [
        "cache",
        "shadowChildrenRef",
        "move",
        "element-child"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 moving existing Element invalidates shadow cache",
        "  GIVEN",
        "    Element parent1 = new Element(\"ul\");",
        "    Element e1 = parent1.appendElement(\"li\");",
        "    Element e2 = parent1.appendElement(\"li\");",
        "    // populate shadowChildrenRef by calling children()",
        "    int before = parent1.children().size();",
        "    Element parent2 = new Element(\"ol\");",
        "  WHEN",
        "    parent2.appendChild(e1);",
        "  THEN",
        "    // e1 removed from parent1",
        "    assertEquals(before - 1, parent1.children().size());",
        "    // shadowChildrenRef was invalidated, so children() rebuilt list",
        "    assertFalse(parent1.children().contains(e1));",
        "    // target has no cache, children count updated",
        "    assertEquals(3, parent2.children().size());",
        "    assertSame(parent2, e1.parent());",
        "END"
      ]
    }
  ]
}