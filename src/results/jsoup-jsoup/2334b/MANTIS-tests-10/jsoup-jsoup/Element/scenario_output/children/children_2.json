{
  "scenarios": [
    {
      "id": "TC07",
      "description": "children() returns empty list after clearing existing element children, exercising EmptyChildren branch post-cache and nodelistChanged",
      "path": "B0→B1(false)→B2(true)→B0→B1(true)",
      "precondition": "Element with two child Elements",
      "expectedResult": "first children() builds cache with size 2; after empty(), children() returns empty list size 0",
      "tags": [
        "positive",
        "cache-invalidation",
        "empty",
        "post-cache"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 children empty post-cache",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    el.appendChild(new Element(\"a\"));",
        "    el.appendChild(new Element(\"b\"));",
        "    // build and cache shadowChildrenRef",
        "    Elements initial = el.children();",
        "  WHEN",
        "    el.empty();",
        "    Elements afterClear = el.children();",
        "  THEN",
        "    assert initial.size() == 2;",
        "    assert afterClear.size() == 0;",
        "END"
      ]
    }
  ]
}