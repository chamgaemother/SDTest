      "precondition": "Element parent = new Element(\"div\"); parent.appendChild(new Element(\"a\")); parent.appendChild(new TextNode(\"x\")); parent.appendChild(new Element(\"b\"));",
      "expectedResult": "return value is the second Element instance (\"b\")",
      "tags": [
        "positive",
        "branch-false(childNodeSize==0)",
        "loop-N"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 child mixed-children",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element first = new Element(\"a\"); parent.appendChild(first);",
        "    parent.appendChild(new TextNode(\"x\"));",
        "    Element second = new Element(\"b\"); parent.appendChild(second);",
        "  WHEN",
        "    Element result = parent.child(1);",
        "  THEN",
        "    assert result == second;"
      ]
