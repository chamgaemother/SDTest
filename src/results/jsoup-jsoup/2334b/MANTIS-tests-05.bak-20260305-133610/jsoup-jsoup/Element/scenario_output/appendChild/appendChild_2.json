{
  "scenarios": [
    {
      "id": "TC09",
      "description": "Re-appending the same child node to its own parent removes then re-adds, preserving one child and resetting sibling index",
      "path": "B0→B3→B4→B5",
      "precondition": "parent has one TextNode child",
      "expectedResult": "childNodeSize remains 1 and siblingIndex is 0",
      "tags": [
        "positive",
        "reparent",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 append same child twice",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"x\");",
        "    parent.appendChild(child);",
        "  WHEN",
        "    parent.appendChild(child);",
        "  THEN",
        "    assertEquals(1, parent.childNodeSize());",
        "    assertSame(child, parent.childNode(0));",
        "    assertEquals(0, child.siblingIndex());",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "Appending a DataNode child creates proper childNodes list and sets sibling index",
      "path": "B0→B3→B4→B5",
      "precondition": "parent is new Element",
      "expectedResult": "childNodeSize 1, DataNode present at index 0, siblingIndex 0",
      "tags": [
        "positive",
        "node-type",
        "boundary"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 append DataNode child",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    DataNode dataChild = new DataNode(\"data\");",
        "  WHEN",
        "    parent.appendChild(dataChild);",
        "  THEN",
        "    assertEquals(1, parent.childNodeSize());",
        "    assertSame(dataChild, parent.childNode(0));",
        "    assertEquals(0, dataChild.siblingIndex());",
        "END"
      ]
    }
  ]
}