package org.jsoup.nodes;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertSame;

/**
 * JUnit 5 tests for Element.appendChild based on provided scenarios.
 */
public class Element_appendChild_Test {

    @Test
    @DisplayName("TC05: appendChild returns the same element instance for chaining")
    public void test_TC05() {
        // GIVEN an empty parent element and a child TextNode to append
        Element parent = new Element("div");
        TextNode child = new TextNode("text");
        // WHEN appendChild is invoked, the returned value should be the parent itself for chaining
        Element returned = parent.appendChild(child);
        // The returned instance must be the same as the original parent to support method chaining
        assertSame(parent, returned, "appendChild should return the parent instance for chaining");
    }
}