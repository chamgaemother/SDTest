{
  "method": "appendChild",
  "scenarios": [
    {
      "id": "TC01",
      "description": "appendChild(null) throws IllegalArgumentException when child is null",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "throws IllegalArgumentException; no state mutated",
      "tags": [
        "exception",
        "branch-true: child==null"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 appendChild null-child",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Node child = null;",
        "  WHEN",
        "    call parent.appendChild(child);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC02",
      "description": "appendChild(firstChild) on empty element allocates childNodes and sets siblingIndex to 0",
      "path": "B0→B1→B3→B4→B5",
      "precondition": "parent.childNodes==EmptyNodes",
      "expectedResult": "parent.childNodeSize() == 1; child.parent() == parent; child.getSiblingIndex() == 0",
      "tags": [
        "branch-true: ensureChildNodes",
        "loop-0"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 appendChild first-child",
        "  GIVEN",
        "    Element parent = new Element(\"span\");",
        "    Node child = new TextNode(\"text\");",
        "  WHEN",
        "    parent.appendChild(child);",
        "  THEN",
        "    assert parent.childNodeSize() == 1;",
        "    assert child.parent() == parent;",
        "    assert child.getSiblingIndex() == 0;"
      ]
    },
    {
      "id": "TC03",
      "description": "appendChild(secondChild) on non-empty element reuses childNodes and sets siblingIndex to existing size",
      "path": "B0→B1→B4→B5→B1→B4→B5",
      "precondition": "parent.childNodes already contains one child",
      "expectedResult": "parent.childNodeSize() == 2; second.parent() == parent; second.getSiblingIndex() == 1",
      "tags": [
        "branch-false: ensureChildNodes",
        "loop-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 appendChild second-child",
        "  GIVEN",
        "    Element parent = new Element(\"p\");",
        "    Node first = new TextNode(\"one\");",
        "    parent.appendChild(first);",
        "    Node second = new TextNode(\"two\");",
        "  WHEN",
        "    parent.appendChild(second);",
        "  THEN",
        "    assert parent.childNodeSize() == 2;",
        "    assert second.parent() == parent;",
        "    assert second.getSiblingIndex() == 1;"
      ]
    },
    {
      "id": "TC04",
      "description": "appendChild(existingChild) moves child from old parent to new and updates siblingIndex",
      "path": "B0→B1→B3→B4→B5→B0→B1→B3→B4→B5",
      "precondition": "child is already attached to oldParent",
      "expectedResult": "oldParent.childNodeSize() == 0; newParent.childNodeSize() == 1; child.parent() == newParent; child.getSiblingIndex() == 0",
      "tags": [
        "branch-true: ensureChildNodes",
        "reparentChild",
        "loop-0"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 appendChild move-existing-child",
        "  GIVEN",
        "    Element oldParent = new Element(\"ul\");",
        "    Element newParent = new Element(\"ol\");",
        "    Node child = new Element(\"li\");",
        "    oldParent.appendChild(child);",
        "  WHEN",
        "    newParent.appendChild(child);",
        "  THEN",
        "    assert oldParent.childNodeSize() == 0;",
        "    assert newParent.childNodeSize() == 1;",
        "    assert child.parent() == newParent;",
        "    assert child.getSiblingIndex() == 0;"
      ]
    }
  ]
}