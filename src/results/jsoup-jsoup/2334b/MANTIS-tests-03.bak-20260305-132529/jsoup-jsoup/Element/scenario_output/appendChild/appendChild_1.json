{
  "scenarios": [
    {
      "id": "TC05",
      "description": "appendChild returns the same element instance for chaining",
      "path": "B0→B1→B3→B4→B6",
      "precondition": "none",
      "expectedResult": "returned Element is the same instance passed as parent",
      "tags": [
        "positive",
        "chaining",
        "return-value"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 appendChild returns self for chaining",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"text\");",
        "  WHEN",
        "    Element returned = parent.appendChild(child);",
        "  THEN",
        "    assert returned == parent;",
        "END"
      ]
    }
  ]
}