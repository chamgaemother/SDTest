      "id": "TC05",
      "description": "clone() preserves and shares a non-null Connection field so connection() returns the same instance",
      "path": "B0â†’B1â†’B2â†’returnâ†’connection() branch non-null",
      "precondition": "Document has a connection set via Jsoup.connect",
      "expectedResult": "clone.connection() == original.connection()",
      "tags": [
        "positive",
        "branch",
        "connection"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 clone preserves non-null connection",
        "  GIVEN",
        "    Document doc = new Document(\"http://ex\");",
        "    Connection conn = Jsoup.connect(\"http://ex\");",
        "    doc.connection(conn);",
        "  WHEN",
        "    Document clone = doc.clone();",
        "  THEN",
        "    assertSame(doc.connection(), clone.connection());"
      ]
    },
