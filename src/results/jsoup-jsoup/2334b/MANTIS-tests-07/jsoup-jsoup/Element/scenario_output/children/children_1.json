{
  "scenarios": [
    {
      "id": "TC11",
      "description": "children() rebuilds cache when existing shadowChildrenRef get() returns null",
      "path": "B0→B3→B6→B3→B5",
      "precondition": "Element with one child Element and shadowChildrenRef pointing to cleared WeakReference",
      "expectedResult": "returns fresh Elements list containing the child, and shadowChildrenRef updated",
      "tags": [
        "cache",
        "rebuild",
        "weakref"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 children rebuilds on cleared weakref",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element child = new Element(\"span\");",
        "    parent.appendChild(child);",
        "    // prime cache",
        "    parent.children();",
        "    // simulate GC clearing the cached list",
        "    Field refField = Element.class.getDeclaredField(\"shadowChildrenRef\");",
        "    refField.setAccessible(true);",
        "    @SuppressWarnings(\"unchecked\")",
        "    WeakReference<List<Element>> ref = (WeakReference<List<Element>>)refField.get(parent);",
        "    ref.clear();",
        "  WHEN",
        "    Elements result = parent.children();",
        "  THEN",
        "    assert result.size() == 1;",
        "    assertSame(child, result.get(0));",
        "    // new non-null cached list",
        "    assertNotNull(refField.get(parent));",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "children() invalidates cache after child removal via Node.remove()",
      "path": "B0→B3→B4→B6→B3",
      "precondition": "Element with two child Elements, cache populated, then one child removed",
      "expectedResult": "shadowChildrenRef cleared on removal and children() returns list of remaining child",
      "tags": [
        "cache",
        "invalidate",
        "remove"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 children invalidates after Node.remove",
        "  GIVEN",
        "    Element parent = new Element(\"ul\");",
        "    Element a = new Element(\"li\");",
        "    Element b = new Element(\"li\");",
        "    parent.appendChild(a);",
        "    parent.appendChild(b);",
        "    // prime cache",
        "    Elements first = parent.children();",
        "    assert first.size() == 2;",
        "  WHEN",
        "    // remove one child via Node.remove()",
        "    a.remove();",
        "    Elements result = parent.children();",
        "  THEN",
        "    assert result.size() == 1;",
        "    assertSame(b, result.get(0));",
        "    // ensure cache was cleared and rebuilt",
        "    Field f = Element.class.getDeclaredField(\"shadowChildrenRef\");",
        "    f.setAccessible(true);",
        "    assertNotNull(f.get(parent));",
        "END"
      ]
    }
  ]
}