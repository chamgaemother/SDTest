    {
      "id": "TC08",
      "description": "clone() on a Document parsed from HTML with a doctype retains and deepŌĆÉcopies the DocumentType node",
      "path": "B0ŌåÆsuper.clone()ŌåÆclone.outputSettingsŌåÆclone.parserŌåÆreturn",
      "precondition": "Document created via Jsoup.parse(\"<!DOCTYPE html><p>text</p>\")",
      "expectedResult": "clone.documentType() is equal in name to original but a distinct instance",
      "tags": [
        "positive",
        "doctype",
        "deep-copy",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 clone of document with doctype",
        "  GIVEN",
        "    Document original = Jsoup.parse(\"<!DOCTYPE html><p>text</p>\");",
        "    DocumentType origDt = original.documentType();",
        "  WHEN",
        "    Document clone = original.clone();",
        "    DocumentType cloneDt = clone.documentType();",
        "  THEN",
        "    assertNotNull(origDt);",
        "    assertNotNull(cloneDt);",
        "    assertNotSame(origDt, cloneDt);",
        "    assertEquals(origDt.name(), cloneDt.name());"
      ]
    },
    {
