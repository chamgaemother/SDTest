      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 clone preserves title element",
        "  GIVEN",
        "    Document original = Document.createShell(\"x\");",
        "    original.title(\"T\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "    original.title(\"U\");",
