        "    assert clone.title().equals(\"T\");"
      ]
    },
    {
      "id": "TC10",
      "description": "clone() supports chaining: modifying clone.outputSettings() does not affect original.outputSettings()",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "Document doc = new Document(\"u\");",
      "expectedResult": "after clone.outputSettings().prettyPrint(false), original.outputSettings().prettyPrint()==true",
      "tags": [
        "functionality",
        "chaining",
        "outputSettings",
        "branch-none"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 clone supports independent chaining on settings",
        "  GIVEN",
        "    Document original = new Document(\"u\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "    clone.outputSettings().prettyPrint(false);",
        "  THEN",
        "    assert original.outputSettings().prettyPrint();"
      ]
