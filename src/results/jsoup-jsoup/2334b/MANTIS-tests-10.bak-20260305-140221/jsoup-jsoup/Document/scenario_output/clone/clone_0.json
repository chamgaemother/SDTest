      "tags": [
        "functionality",
        "html-output",
        "branch-none"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 clone preserves rendered HTML",
        "  GIVEN",
        "    Document original = Document.createShell(\"u\");",
        "    original.body().text(\"hello\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "  THEN",
        "    assert clone.outerHtml().equals(original.outerHtml());"
      ]
    },
