      "pseudocode": [
        "TEST TC07 modifications on clone do not affect original",
        "  GIVEN",
        "    Document original = Document.createShell(\"b\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "    clone.appendElement(\"div\");",
