      "path": "B0→B1→B2→B3",
      "precondition": "original.quirksMode set to quirks",
      "expectedResult": "clone.quirksMode()==quirks even if original set to limitedQuirks",
      "tags": [
        "positive",
        "quirksMode"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 clone quirksMode deep-copy",
        "  GIVEN",
        "    Document original = new Document(\"u\");",
