    {
      "id": "TC11",
      "description": "clone() supports chaining: modifying clone.outputSettings().prettyPrint does not affect original",
      "path": "B0→B1→B2→B3",
      "precondition": "original.outputSettings().prettyPrint()==true",
      "expectedResult": "clone.outputSettings().prettyPrint()==false, original remains true",
      "tags": [
        "positive",
        "settings",
        "chain"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 clone outputSettings chaining",
        "  GIVEN",
        "    Document original = new Document(\"u\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "    clone.outputSettings().prettyPrint(false);",
        "  THEN",
        "    assertTrue(original.outputSettings().prettyPrint());",
        "    assertFalse(clone.outputSettings().prettyPrint());",
        "END"
      ]
    }
