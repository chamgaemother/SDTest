    {
      "id": "TC07",
      "description": "clone() clones attributes so adding attr to original after clone does not appear in clone",
      "path": "B0→B1→B2→B3",
      "precondition": "original has attribute 'a'",
      "expectedResult": "clone.hasAttr('a')==false, original.hasAttr('a')==true",
      "tags": [
        "positive",
        "attributes",
        "deep-copy"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 clone attributes deep-copy",
        "  GIVEN",
        "    Document original = Document.createShell(\"x\");",
        "    original.attr(\"a\",\"1\");",
        "  WHEN",
        "    Document clone = original.clone();",
        "    original.attr(\"b\",\"2\");",
        "  THEN",
        "    assertFalse(clone.hasAttr(\"a\"));",
        "    assertTrue(original.hasAttr(\"a\"));",
        "END"
      ]
    },
