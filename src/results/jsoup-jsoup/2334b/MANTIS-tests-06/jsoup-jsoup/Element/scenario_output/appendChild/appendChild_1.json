      "description": "appendChild moves a node from old parent to new parent (reparentChild path)",
      "path": "B0â†’reparentChild(parent!=null)â†’ensureChildNodesâ†’B3â†’B5",
      "precondition": "child appended already to originalParent",
      "expectedResult": "child is removed from originalParent and added to newParent with updated siblingIndex",
      "tags": [
        "positive",
        "reparent",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 appendChild reparentChild behavior",
        "  GIVEN",
        "    Element originalParent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"moved\");",
        "    originalParent.appendChild(child);",
        "    Element newParent = new Element(\"section\");",
        "  WHEN",
        "    newParent.appendChild(child);",
        "  THEN",
        "    // child removed from originalParent",
        "    assert originalParent.childNodeSize() == 0;",
        "    // child now in newParent as only child",
        "    assert newParent.childNodeSize() == 1;",
        "    assert newParent.childNode(0) == child;",
        "    // siblingIndex reset to 0",
        "    assert child.siblingIndex() == 0;",
        "END"
      ]
    }
  ]
