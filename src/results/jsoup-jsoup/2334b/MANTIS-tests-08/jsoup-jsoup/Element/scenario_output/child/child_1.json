{
  "scenarios": [
    {
      "id": "TC06",
      "description": "child(1) on element with two element children twice uses cached shadowChildrenRef on second call",
      "path": "B0→B1[F]→B2(loop×2)→B3→B4→B2[cached]→B3→B4",
      "precondition": "none",
      "expectedResult": "returns second child element both times; second call uses cached list",
      "tags": [
        "positive",
        "cache",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 child caching behavior",
        "  GIVEN",
        "    Element parent = new Element(\"ul\");",
        "    Element child1 = new Element(\"li\");",
        "    Element child2 = new Element(\"li\");",
        "    parent.appendChild(child1);",
        "    parent.appendChild(child2);",
        "  WHEN",
        "    Element firstCall = parent.child(1);",
        "    Element secondCall = parent.child(1);",
        "  THEN",
        "    assert firstCall == child2;",
        "    assert secondCall == child2;",
        "END"
      ]
    },
    {
