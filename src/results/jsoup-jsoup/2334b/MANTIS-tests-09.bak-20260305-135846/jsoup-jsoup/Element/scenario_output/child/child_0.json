      "expectedResult": "return value is the <b> child element at index 1",
      "tags": [
        "branch-true(non-empty)",
        "loop-N",
        "overload:int",
        "positive",
        "mixed-nodes"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 child mixed-nodes",
        "  GIVEN",
        "    Element el = new Element(\"div\"); el.appendText(\"text\"); el.appendElement(\"a\"); el.appendElement(\"b\");",
        "  WHEN",
        "    Element result = el.child(1);",
        "  THEN",
        "    assert result.tagName().equals(\"b\");"
      ]
    },
