{
  "method": "child",
  "scenarios": [
    {
      "id": "TC01",
      "description": "child(0) on element with no element children throws IndexOutOfBoundsException",
      "path": "B0→B1(empty)→B2",
      "precondition": "Element el = new Element(\"div\"); // no children",
      "expectedResult": "throws IndexOutOfBoundsException",
      "tags": [
        "exception",
        "branch-false(empty children)",
        "overload:int",
        "boundary",
        "loop-0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 child empty-list",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    call el.child(0);",
        "  THEN",
        "    throws IndexOutOfBoundsException;"
      ]
    },
    {
      "id": "TC02",
      "description": "child(0) returns the only child element when exactly one element child present (loop-1)",
      "path": "B0→B1(non-empty)→B3(loop×1)→B4",
      "precondition": "Element el = new Element(\"div\"); el.appendElement(\"span\");",
      "expectedResult": "return value is the <span> child element",
      "tags": [
        "branch-true(non-empty)",
        "loop-1",
        "overload:int",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 child single-element",
        "  GIVEN",
        "    Element el = new Element(\"div\"); el.appendElement(\"span\");",
        "  WHEN",
        "    Element result = el.child(0);",
        "  THEN",
        "    assert result.tagName().equals(\"span\");"
      ]
    },
    {
