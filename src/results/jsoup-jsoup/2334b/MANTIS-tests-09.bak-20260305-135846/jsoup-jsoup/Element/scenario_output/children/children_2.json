{
  "scenarios": [
    {
      "id": "TC07",
      "description": "children() with shadowChildrenRef non-null but referent GC’d rebuilds list (shadowChildrenRef.get()==null branch)",
      "path": "B0→B3→B4(get()==null)→B5",
      "precondition": "parent has two Element children and children() called once",
      "expectedResult": "children() returns fresh list of two elements after weak ref expired",
      "tags": [
        "cache",
        "weakref",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 children weak-ref-expired",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element c1 = parent.appendElement(\"p\");",
        "    Element c2 = parent.appendElement(\"span\");",
        "    Elements first = parent.children();  // primes shadowChildrenRef",
        "    // Simulate GC of cached list: clear referent",
        "    java.lang.reflect.Field refField = Element.class.getDeclaredField(\"shadowChildrenRef\");",
        "    refField.setAccessible(true);",
        "    refField.set(parent, new java.lang.ref.WeakReference<List<Element>>(null));",
        "  WHEN",
        "    Elements second = parent.children();",
        "  THEN",
        "    assertEquals(2, second.size());",
        "    assertSame(c1, second.get(0));",
        "    assertSame(c2, second.get(1));",
        "END"
      ]
    }
  ]
}