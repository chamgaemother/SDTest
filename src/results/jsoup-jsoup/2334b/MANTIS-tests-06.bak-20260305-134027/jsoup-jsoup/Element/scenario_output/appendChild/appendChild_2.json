{
  "scenarios": [
    {
      "id": "TC06",
      "description": "Reparenting a child into a non-empty new parent skips list creation and appends at correct index",
      "path": "B0â†’reparentChild(oldParent)â†’ensureChildNodes(skip)â†’addâ†’setSiblingIndexâ†’return",
      "precondition": "oldParent has one child, newParent has one existing child",
      "expectedResult": "child moved from oldParent to newParent at index 1; oldParent.childNodeSize() == 0; newParent.childNodeSize() == 2; child.parent() == newParent; siblingIndex == 1",
      "tags": [
        "positive",
        "reparent",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 appendChild reparent to non-empty parent",
        "  GIVEN",
        "    Element oldParent = new Element(\"ul\");",
        "    Element child = new Element(\"li\");",
        "    oldParent.appendChild(child);",
        "    Element newParent = new Element(\"ol\");",
        "    newParent.appendChild(new Element(\"li\"));  // initialize newParent childNodes",
        "  WHEN",
        "    Element result = newParent.appendChild(child);",
        "  THEN",
        "    assertSame(newParent, result);",
        "    assertEquals(0, oldParent.childNodeSize());",
        "    assertEquals(2, newParent.childNodeSize());",
        "    assertSame(newParent, child.parent());",
        "    // reflectively check siblingIndex == 1",
        "    Field sib = Node.class.getDeclaredField(\"siblingIndex\");",
        "    sib.setAccessible(true);",
        "    assertEquals(1, sib.getInt(child));",
        "END"
      ]
    }
  ]
}