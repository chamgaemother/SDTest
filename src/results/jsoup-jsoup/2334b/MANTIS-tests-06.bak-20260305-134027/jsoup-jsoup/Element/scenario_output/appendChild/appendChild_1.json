{
  "scenarios": [
    {
      "id": "TC05",
      "description": "Re-appending a child already in the same parent moves it to the end without changing size",
      "path": "B0→B2(true)→B3→B4→B5",
      "precondition": "parent has one child already appended",
      "expectedResult": "parent.childNodeSize() remains 1 and siblingIndex reset to 0",
      "tags": [
        "reparenting",
        "positive",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 appendChild same-child-reparent",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"x\");",
        "    parent.appendChild(child); // initial append",
        "  WHEN",
        "    parent.appendChild(child); // re-append same child",
        "  THEN",
        "    assert parent.childNodeSize() == 1;",
        "    assert child.parent() == parent;",
        "    assert child.siblingIndex() == 0;",
        "END"
      ]
    }
  ]
}