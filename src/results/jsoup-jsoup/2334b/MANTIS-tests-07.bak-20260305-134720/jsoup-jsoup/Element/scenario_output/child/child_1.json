{
  "scenarios": [
    {
      "id": "TC06",
      "description": "child(index) throws IndexOutOfBoundsException when index equals number of element children (upper-bound exception branch)",
      "path": "B0→B3(loop×2)→B5→B6",
      "precondition": "Element parent has exactly two Element children",
      "expectedResult": "IndexOutOfBoundsException is thrown",
      "tags": [
        "negative",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 child upper-bound-exception",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element first = new Element(\"span\");",
        "    Element second = new Element(\"b\");",
        "    parent.appendChild(first);",
        "    parent.appendChild(second);",
        "  WHEN",
        "    call parent.child(2);",
        "  THEN",
        "    throws IndexOutOfBoundsException;",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "child(index) returns correct element from mixed childNodes list after filtering non-Element nodes (filter loop with mixed types)",
      "path": "B0→B3(loop×5)→B4→B5",
      "precondition": "Element parent has TextNode, three Element children, and DataNode children in mixed order",
      "expectedResult": "Returns the second Element child in filtered list",
      "tags": [
        "positive",
        "filter",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 child mixed-node-filtering",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    parent.appendChild(new TextNode(\"t1\"));",
        "    Element e1 = new Element(\"p\");",
        "    parent.appendChild(e1);",
        "    Element e2 = new Element(\"span\");",
        "    parent.appendChild(e2);",
        "    parent.appendChild(new DataNode(\"d1\"));",
        "    Element e3 = new Element(\"b\");",
        "    parent.appendChild(e3);",
        "  WHEN",
        "    Element result = parent.child(1);",
        "  THEN",
        "    assert result == e2;",
        "END"
      ]
    }
  ]
}