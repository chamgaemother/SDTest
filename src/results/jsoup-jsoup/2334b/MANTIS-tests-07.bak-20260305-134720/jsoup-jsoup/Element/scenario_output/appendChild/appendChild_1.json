{
  "scenarios": [
    {
      "id": "TC04",
      "description": "appendChild(child with existing parent) reparents node (remove from old) then appends to new parent",
      "path": "B0→B1→B2(reparent)→B3_true→B5",
      "precondition": "oldParent with one child; newParent with no children",
      "expectedResult": "child removed from oldParent, appended to newParent, siblingIndex updated to 0",
      "tags": [
        "positive",
        "reparent",
        "iteration-0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 appendChild reparent existing-child",
        "  GIVEN",
        "    Element oldParent = new Element(\"div\");",
        "    Element newParent = new Element(\"section\");",
        "    Element child = new Element(\"span\");",
        "    // initially attach child to oldParent",
        "    oldParent.appendChild(child);",
        "    assert oldParent.childNodeSize() == 1;",
        "  WHEN",
        "    // Act: append same child to newParent",
        "    newParent.appendChild(child);",
        "  THEN",
        "    // Assert: child removed from oldParent",
        "    assert oldParent.childNodeSize() == 0;",
        "    // Assert: child now in newParent",
        "    assert newParent.childNodeSize() == 1;",
        "    // Assert: child's parent is newParent and siblingIndex is 0",
        "    assert child.parent() == newParent;",
        "    assert child.siblingIndex() == 0;",
        "END"
      ]
    }
  ]
}