    {
      "id": "TC03",
      "description": "appendChild on non-empty children list reuses existing childNodes",
      "path": "B1â†’B2â†’B3â†’B4(false)â†’B5â†’B6â†’B7",
      "precondition": "parent.appendChild(first) executed to create existing childNodes",
      "expectedResult": "parent.childNodeSize() == 2; parent.child(1) == second; second.parent() == parent",
      "tags": [
        "branch-ensureChildNodes-false",
        "loop-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 appendChild second-child",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode first = new TextNode(\"one\");",
