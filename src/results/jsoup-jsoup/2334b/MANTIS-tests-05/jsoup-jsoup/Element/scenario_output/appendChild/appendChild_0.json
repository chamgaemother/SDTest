        "    assert parent.child(1) == second;",
        "    assert second.parent() == parent;"
      ]
    },
    {
      "id": "TC04",
      "description": "appendChild reparents node from old parent to new parent",
      "path": "B1â†’B2â†’B3â†’B4(true)â†’B5â†’B6â†’B7",
      "precondition": "Node child initially appended to oldParent",
      "expectedResult": "oldParent.childrenSize() == 0; newParent.childrenSize() == 1; child.parent() == newParent",
      "tags": [
        "reparent",
        "branch-ensureChildNodes-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 appendChild reparent-existing-child",
        "  GIVEN",
        "    Element oldParent = new Element(\"div\");",
        "    Element newParent = new Element(\"span\");",
        "    TextNode child = new TextNode(\"txt\");",
        "    oldParent.appendChild(child);",
        "  WHEN",
        "    newParent.appendChild(child);",
        "  THEN",
        "    assert oldParent.childrenSize() == 0;",
        "    assert newParent.childrenSize() == 1;",
        "    assert child.parent() == newParent;"
      ]
    },
