{
  "scenarios": [
    {
      "id": "TC07",
      "description": "child(1) invoked twice uses cached shadowChildrenRef on second call",
      "path": "B0→B3→B5(loop×2)→B6→B8",
      "precondition": "parent with two element children and no prior childElementsList cache",
      "expectedResult": "both calls return the second appended child without rebuilding cache",
      "tags": [
        "positive",
        "cache",
        "iteration"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 child caching behavior",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element e1 = new Element(\"span\");",
        "    Element e2 = new Element(\"p\");",
        "    parent.appendChild(e1);",
        "    parent.appendChild(e2);",
        "  WHEN",
        "    Element firstCall = parent.child(1);",
        "    Element secondCall = parent.child(1);",
        "  THEN",
        "    assert firstCall == e2;",
        "    assert secondCall == e2;",
        "END"
      ]
    }
  ]
}