{
  "scenarios": [
    {
      "id": "TC06",
      "description": "appendChild assigns correct siblingIndex for each child after multiple appends",
      "path": "B0→B3→B4→B5",
      "precondition": "parent has one existing TextNode child",
      "expectedResult": "first child siblingIndex is 0; second child siblingIndex is 1",
      "tags": [
        "positive",
        "siblingIndex",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 appendChild siblingIndex sequencing",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode first = new TextNode(\"one\");",
        "    parent.appendChild(first);",
        "  WHEN",
        "    TextNode second = new TextNode(\"two\");",
        "    parent.appendChild(second);",
        "  THEN",
        "    assert first.siblingIndex() == 0;",
        "    assert second.siblingIndex() == 1;"
      ]
    }
  ]
}