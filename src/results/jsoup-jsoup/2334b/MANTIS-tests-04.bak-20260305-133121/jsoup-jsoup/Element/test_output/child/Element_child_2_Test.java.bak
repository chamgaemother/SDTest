import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertThrows;

import org.jsoup.nodes.Element;

public class Element_child_Test {

    @Test
    @DisplayName("child(0) on element with only non-Element children throws IndexOutOfBoundsException after filtering yields empty list")
    public void test_TC08() {
        // GIVEN an Element with only TextNode children: childNodeSize > 0 but no Element instances in childElementsList
        Element parent = new Element("div");
        parent.appendText("hello"); // adds a TextNode child
        parent.appendText("world"); // adds another TextNode child

        // WHEN & THEN: accessing child(0) should filter out all non-Element nodes, resulting in empty list -> IndexOutOfBoundsException
        assertThrows(IndexOutOfBoundsException.class, () -> {
            parent.child(0);
        });
    }
}