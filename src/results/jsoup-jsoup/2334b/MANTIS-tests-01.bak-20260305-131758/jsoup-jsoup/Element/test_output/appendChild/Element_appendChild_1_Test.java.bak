package org.jsoup.nodes;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.lang.reflect.Field;

import static org.junit.jupiter.api.Assertions.*;

public class Element_appendChild_Test {

    @Test
    @DisplayName("TC04: appendChild removes node from prior parent and re-parents correctly")
    public void test_TC04() throws Exception {
        // GIVEN a child node already attached to an old parent
        Element oldParent = new Element("div");
        TextNode child = new TextNode("x");
        oldParent.appendChild(child); // now child.parent() == oldParent, child.siblingIndex == 0

        // AND a new parent element
        Element newParent = new Element("section");

        // WHEN the child is appended to the new parent
        newParent.appendChild(child);
        // Path covers ensureChildNodes(true) -> reparentChild -> add -> return

        // THEN the old parent should have no children after reparenting
        assertEquals(0, oldParent.childNodeSize(), 
            "Old parent should have had its child removed");

        // AND the new parent should have exactly one child after append
        assertEquals(1, newParent.childNodeSize(), 
            "New parent should have exactly one child after appendChild");

        // AND the child's parent reference should point to the new parent
        assertSame(newParent, child.parent(), 
            "Child's parent() should return the new parent Element");

        // AND the child's siblingIndex should be updated to 0 in the new parent's child list
        Field siblingIndexField = Node.class.getDeclaredField("siblingIndex");
        siblingIndexField.setAccessible(true);
        int updatedIndex = siblingIndexField.getInt(child);
        assertEquals(0, updatedIndex, 
            "Child's siblingIndex should be 0 after reparenting to an empty new parent");
    }
}