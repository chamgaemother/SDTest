      "id": "TC04",
      "description": "appendChild removes node from prior parent and re-parents correctly",
      "path": "B0‚ÜíB1‚ÜíensureChildNodes(true)‚ÜíreparentChild‚ÜíB_add‚Üíreturn",
      "precondition": "child already has a parent Element",
      "expectedResult": "child is removed from its original parent‚Äôs children, added to new parent with correct siblingIndex and parent reference",
      "tags": [
        "positive",
        "reparent",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 reparent child",
        "  GIVEN",
        "    Element oldParent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"x\");",
        "    oldParent.appendChild(child); // establish original parent",
        "    Element newParent = new Element(\"section\");",
        "  WHEN",
        "    newParent.appendChild(child);",
        "  THEN",
        "    assert oldParent.childNodeSize() == 0;",
        "    assert newParent.childNodeSize() == 1;",
        "    assert child.parent() == newParent;",
        "    // verify sibling index updated",
        "    assert getSiblingIndex(child) == 0;",
        "END"
      ]
    }
  ]
