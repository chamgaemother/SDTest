{
  "scenarios": [
    {
      "id": "TC05",
      "description": "Appending the same child twice on a parent repositions it without duplication (reparentChild branch when child already in parent)",
      "path": "B0â†’reparentChildâ†’ensureChildNodes(false)â†’addâ†’return",
      "precondition": "parent has one child (same Node)",
      "expectedResult": "parent.childNodeSize() remains 1; child's siblingIndex resets to 0; parent returned",
      "tags": [
        "positive",
        "reparent",
        "duplicate-child"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 append same child twice",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    TextNode child = new TextNode(\"dup\");",
        "    parent.appendChild(child);",
        "  WHEN",
        "    Element result = parent.appendChild(child);",
        "  THEN",
        "    assert result == parent;",
        "    assert parent.childNodeSize() == 1;",
        "    assert child.parent() == parent;",
        "    // reflection: siblingIndex == 0",
        "    assert getSiblingIndex(child) == 0;",
        "END"
      ]
    },
