{"scenarios":{"charset":[{"id":"TC01","description":"charset(Charset) with updateMetaCharset=false should only update outputSettings.charset without adding or modifying meta charset element","path":"B1→B2","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(false); // meta update disabled","expectedResult":"doc.outputSettings().charset() == StandardCharsets.ISO_8859_1; head().selectFirst(\"meta[charset]\") == null","tags":["branch-false","no-update","html-syntax"],"priority":"P0","environment":"Java 8","pseudocode":["TEST TC01 updateMetaCharset disabled","  GIVEN","    Charset cs = StandardCharsets.ISO_8859_1;","    Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(false);","  WHEN","    doc.charset(cs);","  THEN","    assert doc.outputSettings().charset() == cs;","    assert doc.head().selectFirst(\"meta[charset]\") == null;","END"]},{"id":"TC02","description":"charset(Charset) with updateMetaCharset=true, html syntax, no existing meta[charset] and no obsolete meta[name=charset] should append new meta charset element","path":"B1→B3→B4","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true); // enable update","expectedResult":"doc.head().selectFirst(\"meta[charset]\").attr(\"charset\") == StandardCharsets.UTF_8.displayName()","tags":["branch-true","loop-0","html-syntax"],"priority":"P0","environment":"Java 8","pseudocode":["TEST TC02 append-meta-html","  GIVEN","    Charset cs = StandardCharsets.UTF_8;","    Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true);","  WHEN","    doc.charset(cs);","  THEN","    Element m = doc.head().selectFirst(\"meta[charset]\");","    assert m != null && m.attr(\"charset\")==cs.displayName();","END"]},{"id":"TC03","description":"charset(Charset) with updateMetaCharset=true, html syntax, existing meta[charset] plus obsolete meta[name=charset] should update charset attr and remove obsolete element","path":"B1→B3→B4","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true); doc.head().appendElement(\"meta\").attr(\"charset\",\"ASCII\"); doc.head().appendElement(\"meta\").attr(\"name\",\"charset\");","expectedResult":"doc.head().selectFirst(\"meta[charset]\").attr(\"charset\") == StandardCharsets.US_ASCII.displayName() && doc.head().select(\"meta[name=charset]\").isEmpty()","tags":["branch-true","existing-meta","html-syntax"],"priority":"P0","environment":"Java 8","pseudocode":["TEST TC03 update-existing-and-remove-obsolete","  GIVEN","    Charset cs = StandardCharsets.US_ASCII;","    Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true);","    doc.head().appendElement(\"meta\").attr(\"charset\",\"ASCII\");","    doc.head().appendElement(\"meta\").attr(\"name\",\"charset\");","  WHEN","    doc.charset(cs);","  THEN","    Element m = doc.head().selectFirst(\"meta[charset]\");","    assert m.attr(\"charset\")==cs.displayName();","    assert doc.head().select(\"meta[name=charset]\").isEmpty();","END"]},{"id":"TC04","description":"charset(Charset) with updateMetaCharset=true, xml syntax, no existing XmlDeclaration child should prepend new xml declaration with encoding and version","path":"B1→B3→B5","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true); doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml);","expectedResult":"doc.childNodes().get(0) instanceof XmlDeclaration && ((XmlDeclaration)doc.childNodes().get(0)).name().equals(\"xml\") && ((XmlDeclaration)doc.childNodes().get(0)).attr(\"encoding\") == StandardCharsets.UTF_8.displayName() && ((XmlDeclaration)doc.childNodes().get(0)).attr(\"version\")==\"1.0\"","tags":["branch-true","xml-syntax","no-existing-decl"],"priority":"P1","environment":"Java 8","pseudocode":["TEST TC04 prepend-xml-decl","  GIVEN","    Charset cs = StandardCharsets.UTF_8;","    Document doc = Document.createShell(\"http://example.com\");","    doc.updateMetaCharsetElement(true);","    doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml);","  WHEN","    doc.charset(cs);","  THEN","    Node n = doc.childNodes().get(0);","    assert n instanceof XmlDeclaration;","    XmlDeclaration xd = (XmlDeclaration)n;","    assert xd.name().equals(\"xml\");","    assert xd.attr(\"encoding\")==cs.displayName();","    assert xd.attr(\"version\")==\"1.0\";","END"]},{"id":"TC05","description":"charset(Charset) with updateMetaCharset=true, xml syntax, existing non-xml XmlDeclaration child should replace with xml declaration","path":"B1→B3→B5","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true); doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml); doc.prependChild(new XmlDeclaration(\"notxml\", false).attr(\"some\",\"value\"));","expectedResult":"doc.childNodes().get(0) instanceof XmlDeclaration && ((XmlDeclaration)doc.childNodes().get(0)).name().equals(\"xml\") && ((XmlDeclaration)doc.childNodes().get(0)).attr(\"encoding\")==StandardCharsets.UTF_8.displayName()","tags":["branch-true","xml-syntax","existing-non-xml-decl"],"priority":"P1","environment":"Java 8","pseudocode":["TEST TC05 replace-non-xml-decl","  GIVEN","    Charset cs = StandardCharsets.UTF_8;","    Document doc = Document.createShell(\"http://example.com\");","    doc.updateMetaCharsetElement(true);","    doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml);","    doc.prependChild(new XmlDeclaration(\"notxml\", false).attr(\"dummy\",\"1\"));","  WHEN","    doc.charset(cs);","  THEN","    Node n = doc.childNodes().get(0);","    assert n instanceof XmlDeclaration;","    XmlDeclaration xd = (XmlDeclaration)n;","    assert xd.name().equals(\"xml\");","    assert xd.attr(\"encoding\")==cs.displayName();","END"]},{"id":"TC06","description":"charset(Charset) with updateMetaCharset=true, xml syntax, existing xml XmlDeclaration with version attr should update encoding and retain version","path":"B1→B3→B5","precondition":"Document doc = Document.createShell(\"http://example.com\"); doc.updateMetaCharsetElement(true); doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml); XmlDeclaration existing = new XmlDeclaration(\"xml\", false); existing.attr(\"version\",\"2.0\"); doc.prependChild(existing);","expectedResult":"XmlDeclaration xd = (XmlDeclaration)doc.childNodes().get(0); assert xd.name().equals(\"xml\"); assert xd.attr(\"encoding\")==StandardCharsets.UTF_8.displayName(); assert xd.attr(\"version\")==\"1.0\"","tags":["branch-true","xml-syntax","existing-xml-decl"],"priority":"P1","environment":"Java 8","pseudocode":["TEST TC06 update-existing-xml-decl","  GIVEN","    Charset cs = StandardCharsets.UTF_8;","    Document doc = Document.createShell(\"http://example.com\");","    doc.updateMetaCharsetElement(true);","    doc.outputSettings().syntax(Document.OutputSettings.Syntax.xml);","    XmlDeclaration existing = new XmlDeclaration(\"xml\", false); existing.attr(\"version\",\"2.0\");","    doc.prependChild(existing);","  WHEN","    doc.charset(cs);","  THEN","    XmlDeclaration xd = (XmlDeclaration)doc.childNodes().get(0);","    assert xd.attr(\"encoding\")==cs.displayName();","    assert xd.attr(\"version\")==\"1.0\";","END"]}]}}"}