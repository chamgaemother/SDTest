      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 no-side-effect when update disabled",
        "  GIVEN",
        "    Document doc = Document.createShell(\"z\");",
        "    doc.updateMetaCharsetElement(false);",
        "  WHEN",
        "    doc.charset(Charset.forName(\"UTF-8\"));",
        "  THEN",
        "    assertEquals(Charset.forName(\"UTF-8\"), doc.outputSettings().charset());",
        "    assertNull(doc.selectFirst(\"meta[charset]\"));",
        "END"
      ]
    }
  ]
}