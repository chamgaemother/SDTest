      "path": "B0âupdateMetaCharsetElement(false)âensureMetaCharsetElement skipped",
      "precondition": "Document.createShell, doc.updateMetaCharsetElement(false)",
      "expectedResult": "charset set in outputSettings but no <meta charset> present",
      "tags": [
