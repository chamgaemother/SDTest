package org.jsoup.nodes;

import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.select.Elements;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.nio.charset.Charset;

import static org.junit.jupiter.api.Assertions.*;

public class Document_charset_Test {

    @Test
    @DisplayName("HTML syntax with only obsolete <meta name=charset> appends new <meta charset> and removes obsolete")
    public void test_TC08() {
        // GIVEN: a shell document with only an obsolete meta[name=charset] element
        Document doc = Document.createShell("http://example.com");
        // Ensures head exists and append obsolete charset meta
        Element obsoleteMeta = doc.head().appendElement("meta").attr("name", "charset");
        assertNotNull(obsoleteMeta, "Precondition: obsolete meta[name=charset] should be appended");
        // WHEN: setting charset should trigger HTML branch, no existing meta[charset], append new and remove obsolete
        Charset newCs = Charset.forName("ISO-8859-5");
        doc.charset(newCs);
        
        // THEN: new <meta charset> element is added with correct charset attribute
        Element newMeta = doc.head().selectFirst("meta[charset]");
        assertNotNull(newMeta, "Expected a new <meta charset> element to be present");
        assertEquals("ISO-8859-5", newMeta.attr("charset"),
                "The new <meta charset> element must have the updated charset value");
        
        // THEN: the obsolete <meta name=charset> elements are removed
        Elements obsoleteFound = doc.select("meta[name=charset]");
        assertTrue(obsoleteFound.isEmpty(), "Obsolete <meta name=charset> elements should be removed");
        
        // THEN: the document's outputSettings charset is updated accordingly
        assertEquals(newCs, doc.charset(),
                "Document.charset() should return the newly set charset");
    }
}