      "path": "B0→updateMetaCharsetElement(true)→outputSettings.charset(null)→NPE",
      "precondition": "Document created shell; no special settings",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "null"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 charset-null throws NPE",
        "  GIVEN",
        "    Document doc = Document.createShell(\"http://example.com\");",
        "  WHEN",
        "    call doc.charset(null);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    }
  ]
}