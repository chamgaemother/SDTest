package org.jsoup.parser;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.io.Reader;
import java.io.StringReader;
import java.lang.reflect.Field;
import java.util.concurrent.locks.ReentrantLock;

import static org.junit.jupiter.api.Assertions.*;

public class Parser_parseInput_Test {

    @Test
    @DisplayName("parseInput(Reader, String) with null Reader throws NullPointerException and releases lock")
    public void test_TC07() throws Exception {
        // GIVEN: a standard HTML parser and a null Reader input
        Parser parser = Parser.htmlParser();
        Reader input = null; // satisfy path B2 null input leads to NPE in parseInput
        String baseUri = "http://example";

        // WHEN / THEN: NullPointerException is thrown
        assertThrows(NullPointerException.class, () -> {
            parser.parseInput(input, baseUri);
        });

        // AND: lock must have been released (not held) after exception
        Field lockField = Parser.class.getDeclaredField("lock");
        lockField.setAccessible(true);
        ReentrantLock lock = (ReentrantLock) lockField.get(parser);
        assertFalse(lock.isLocked(), "Lock should be released after NPE");
    }

    @Test
    @DisplayName("parseInput(String, String) when TreeBuilder.parse throws Error propagates Error and releases lock")
    public void test_TC08() throws Exception {
        // GIVEN: a TreeBuilder stub that throws OutOfMemoryError during parse
        TreeBuilder stubBuilder = new HtmlTreeBuilder() {
            @Override
            public Document parse(Reader in, String baseUri, Parser p) {
                // simulate an unexpected Error in parse
                throw new OutOfMemoryError("oom");
            }
        };
        Parser parser = new Parser(stubBuilder);
        String html = "<x/>"; // input for parseInput(String, String)
        String baseUri = "uri";

        // WHEN / THEN: OutOfMemoryError with specific message is propagated
        OutOfMemoryError error = assertThrows(OutOfMemoryError.class, () -> {
            parser.parseInput(html, baseUri);
        });
        assertEquals("oom", error.getMessage());

        // AND: lock must have been released (not held) after Error
        Field lockField = Parser.class.getDeclaredField("lock");
        lockField.setAccessible(true);
        ReentrantLock lock = (ReentrantLock) lockField.get(parser);
        assertFalse(lock.isLocked(), "Lock should be released after Error");
    }
}