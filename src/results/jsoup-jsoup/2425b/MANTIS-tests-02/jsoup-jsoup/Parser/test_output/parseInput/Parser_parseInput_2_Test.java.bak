package org.jsoup.parser;

import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.nodes.Node;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.io.Reader;
import java.io.StringReader;
import java.util.List;

import static org.junit.jupiter.api.Assertions.assertThrows;

public class Parser_parseInput_Test {

    @Test
    @DisplayName("parseInput(Reader,String) propagates arbitrary RuntimeException from TreeBuilder.parse")
    public void test_TC05() {
        // Arrange: stub TreeBuilder throws RuntimeException to exercise B0→B1→B2→B3→B5 path
        TreeBuilder stubBuilder = new TreeBuilder() {
            @Override public ParseSettings defaultSettings() {
                return ParseSettings.preserveCase; // default settings unimportant for exception path
            }
            @Override public TreeBuilder newInstance() {
                return this; // reuse stub
            }
            @Override public String defaultNamespace() {
                return Parser.NamespaceHtml; // return a valid namespace
            }
            @Override public Document parse(Reader r, String u, Parser p) {
                throw new RuntimeException("boom"); // trigger exception propagation
            }
            @Override public List<Node> parseFragment(Reader r, Element c, String u, Parser p) {
                return null; // not used in this test
            }
            @Override public void process(org.jsoup.parser.Token t) {
                // no-op
            }
        };
        Parser parser = new Parser(stubBuilder);
        Reader reader = new StringReader("<p>fail</p>");
        String baseUri = "http://example.com";

        // Act & Assert: expect the RuntimeException with message "boom" to bubble up
        RuntimeException ex = assertThrows(RuntimeException.class, () -> parser.parseInput(reader, baseUri));
        // verify the stub exception message is preserved
        assert ex.getMessage().equals("boom");
    }

    @Test
    @DisplayName("parseInput(String,String) propagates NullPointerException when baseUri is null")
    public void test_TC06() {
        // Arrange: use htmlParser; null baseUri should cause NPE at or before calling treeBuilder.parse (B0→B1→B2→B4)
        String html = "<p>Test</p>";
        String baseUri = null;
        Parser parser = Parser.htmlParser();

        // Act & Assert: expect NullPointerException due to null baseUri
        assertThrows(NullPointerException.class, () -> parser.parseInput(html, baseUri));
    }
}