    {
      "id": "TC13",
      "description": "parseInput(String, String) unlocks lock after normal return",
      "path": "B0→B1→B2→B4→B6",
      "precondition": "stub TreeBuilder that sleeps before returning then returns a Document",
      "expectedResult": "lock is unlocked after parse and valid Document is returned",
      "tags": [
        "positive",
        "lock",
        "concurrency"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 parseInput releases lock on normal return",
        "  GIVEN",
        "    Document dummy = Document.createShell(\"http://x/\");",
        "    TreeBuilder slowStub = new org.jsoup.parser.Parser_parseInput_0_Test.StubTreeBuilder(dummy) {",
        "      @Override public Document parse(Reader in, String uri, Parser p) {",
        "        try { Thread.sleep(50); } catch (InterruptedException e) {}",
        "        return super.parse(in, uri, p);",
        "      }",
        "    };",
        "    Parser parser = new Parser(slowStub);",
        "    String html = \"<p>OK</p>\";",
        "    String baseUri = \"http://x/\";",
        "  WHEN",
        "    Document result = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert result == dummy;",
        "    assertFalse(extractLock(parser).isLocked());",
        "END"
      ]
    }
  ]
}