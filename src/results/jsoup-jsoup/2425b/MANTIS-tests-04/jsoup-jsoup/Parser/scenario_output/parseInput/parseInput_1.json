      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parseInput stub-builder returns null",
        "  GIVEN",
        "    Document toReturn = null;",
        "    TreeBuilder stub = new org.jsoup.parser.Parser_parseInput_0_Test.StubTreeBuilder(toReturn);",
        "    Parser parser = new Parser(stub);",
        "    String html = \"<tag/>\";",
        "    String baseUri = \"http://test/\";",
        "  WHEN",
        "    Document result = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert result == null;",
        "END"
