      "description": "parseInput(String, String) throws NullPointerException when baseUri is null",
      "path": "B0→B1→B2→B6",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "null-baseUri",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parseInput(String,String) null-baseUri",
        "  GIVEN",
        "    Parser parser = new Parser(new org.jsoup.parser.HtmlTreeBuilder());",
        "    String html = \"<p>test</p>\";",
        "    String baseUri = null;",
        "  WHEN",
        "    call parser.parseInput(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
