{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String, String) returns a Document with elements parsed for simple HTML",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "using real HtmlTreeBuilder; no mocks",
      "expectedResult": "returned Document contains one <p> element with text \"Hello\"",
      "tags": [
        "branch-normal",
        "overload:String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parseInput simple-HTML",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = new Parser(new HtmlTreeBuilder()).parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"p\").size() == 1;",
        "    assert doc.select(\"p\").first().text().equals(\"Hello\");"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parseInput(String, String) with empty HTML returns an empty body Document",
      "path": "B0→B1→B2→B3→B4",
