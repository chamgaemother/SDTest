    {
      "id": "TC09",
      "description": "parseInput(Reader,String) releases lock and propagates IllegalStateException from TreeBuilder.parse",
      "path": "B0â†’B1â†’B2â†’B4â†’B5",
      "precondition": "Parser constructed with stub TreeBuilder that throws IllegalStateException in parse(Reader,String,Parser)",
      "expectedResult": "IllegalStateException is thrown and lock is not held after call",
      "tags": [
        "exception",
        "lock-release",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 parseInput reader-overload stub exception",
        "  GIVEN",
        "    // Arrange a stub TreeBuilder that always throws",
        "    TreeBuilder stub = new TreeBuilder() {",
        "      @Override public Document parse(Reader in, String uri, Parser parser) {",
        "        throw new IllegalStateException(\"stub-fail\");",
        "      }",
        "      @Override public void process(Token token) {}",
        "      @Override public TreeBuilder newInstance() { return this; }",
        "      @Override public ParseSettings defaultSettings() { return ParseSettings.preserveCase(); }",
        "      @Override public TagSet defaultTagSet() { return TagSet.Html(); }",
        "    };",
        "    Parser parser = new Parser(stub);",
        "    Reader reader = new StringReader(\"<html></html>\");",
        "  WHEN",
        "    call parser.parseInput(reader, \"http://example.com\");",
        "  THEN",
        "    throws IllegalStateException with message \"stub-fail\";",
        "    assert parser.lock.isLocked() == false;",
        "END"
      ]
    },
