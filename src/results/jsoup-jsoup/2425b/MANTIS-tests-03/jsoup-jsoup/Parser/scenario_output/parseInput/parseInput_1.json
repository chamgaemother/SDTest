{
  "scenarios": [
    {
      "id": "TC05",
      "description": "parseInput(String, String) throws NullPointerException when html input is null",
      "path": "B0→B1(except)→B2",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 parseInput null-html",
        "  GIVEN",
        "    String html = null;",
        "    String baseUri = \"http://example.com\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call parser.parseInput(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "parseInput(Reader, String) returns a Document when using xmlParser and simple XML content",
      "path": "B0→B4→B6",
      "precondition": "none",
      "expectedResult": "return value is a Document with root element 'root'",
      "tags": [
        "positive",
        "overload",
        "variant"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 xmlParser parses XML content",
        "  GIVEN",
        "    Reader input = new StringReader(\"<root><child/></root>\");",
        "    String baseUri = \"file://local\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = parser.parseInput(input, baseUri);",
        "  THEN",
        "    assertNotNull(doc);",
        "    assertEquals(\"root\", doc.child(0).nodeName());",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "parseInput(Reader, String) propagates a RuntimeException from a custom TreeBuilder.parse",
      "path": "B0→B3→B7(except)→B2",
      "precondition": "Parser constructed with stub TreeBuilder whose parse throws IllegalStateException",
      "expectedResult": "IllegalStateException is thrown and not swallowed",
      "tags": [
        "negative",
        "exception",
        "custom-stub"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parseInput runtime-exception-propagation",
        "  GIVEN",
        "    TreeBuilder stubBuilder = new TreeBuilder() {",
        "      @Override public ParseSettings defaultSettings() { return new ParseSettings(); }",
        "      @Override public TreeBuilder newInstance() { return this; }",
        "      @Override public Document parse(Reader r, String baseUri, Parser parser) {",
        "        throw new IllegalStateException(\"fail-runtime\");",
        "      }",
        "      @Override public List<Node> parseFragment(Reader r, Element context, String baseUri, Parser parser) { return null; }",
        "    };",
        "    Parser parser = new Parser(stubBuilder);",
        "    Reader input = new StringReader(\"<p>test</p>\");",
        "    String baseUri = \"http://x\";",
        "  WHEN",
        "    call parser.parseInput(input, baseUri);",
        "  THEN",
        "    throws IllegalStateException with message \"fail-runtime\";",
        "END"
      ]
    }
  ]
}