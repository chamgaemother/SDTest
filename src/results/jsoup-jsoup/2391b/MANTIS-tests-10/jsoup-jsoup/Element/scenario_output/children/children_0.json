      "tags": [
        "branch-falseâ†’branch-true",
        "loop-0â†’loop-1",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 children dynamic-addition",
        "  GIVEN",
