    {
      "id": "TC09",
      "description": "children() preserves insertion order when removing and re-adding children (loop variants)",
      "path": "B0â†’B1â†’B3â†’B4â†’B5â†’B6â†’B0â†’B1â†’B3â†’B4â†’B5â†’B6",
      "precondition": "Element parent = new Element(\"div\"); Element c1 = new Element(\"p\"); Element c2 = new Element(\"span\"); parent.appendChild(c1); parent.appendChild(c2); parent.children(); parent.removeChild(c1); parent.appendChild(c1);",
      "expectedResult": "second children().get(0).tagName()==\"span\" and get(1).tagName()==\"p\"",
      "tags": [
        "branch-true",
        "loop-N",
        "order-preserved",
        "P2"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 children removal-and-readdition",
        "  GIVEN",
        "    Element parent = new Element(\"div\");",
        "    Element c1 = new Element(\"p\");",
        "    Element c2 = new Element(\"span\");",
        "    parent.appendChild(c1);",
        "    parent.appendChild(c2);",
        "    parent.children();",
        "    parent.removeChild(c1);",
        "    parent.appendChild(c1);",
        "  WHEN",
        "    Elements result = parent.children();",
        "  THEN",
        "    assert result.get(0).tagName().equals(\"span\");",
