      "path": "B0â†’B1â†’B3â†’B4â†’B5â†’B6â†’B3â†’B4â†’B6",
      "precondition": "Element parent = new Element(\"div\"); parent.attributes().userData().put(\"jsoup.childEls\", new WeakReference<>(Arrays.asList(new Element(\"p\")))); parent.attributes().userData().put(\"jsoup.childElsMod\", parent.childNodeSize());",
      "expectedResult": "returned Elements from second call equals wrapped cached list of size 1",
      "tags": [
        "branch-true",
        "loop-1",
        "cachedChildren",
