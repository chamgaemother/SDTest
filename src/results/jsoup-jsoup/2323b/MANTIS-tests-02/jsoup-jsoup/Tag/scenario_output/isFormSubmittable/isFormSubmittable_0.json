  "scenarios": [
    {
      "id": "TC01",
      "description": "Calling isFormSubmittable() on a known form-submittable tag (input) returns true",
      "path": "B0→B1",
      "precondition": "Tag input is registered in static initializer with formSubmit=true",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "known-tag",
        "form-submittable",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
