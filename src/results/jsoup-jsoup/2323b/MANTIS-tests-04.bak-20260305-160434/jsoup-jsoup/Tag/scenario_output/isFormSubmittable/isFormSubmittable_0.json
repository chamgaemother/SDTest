  "scenarios": [
    {
      "id": "TC01",
      "description": "Known form-submittable tag returns true (branch-true)",
      "path": "B0→B1",
      "precondition": "use real Tag via Tag.valueOf(\"input\") which is initialized with formSubmit=true",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known-submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;"
      ]
    },
