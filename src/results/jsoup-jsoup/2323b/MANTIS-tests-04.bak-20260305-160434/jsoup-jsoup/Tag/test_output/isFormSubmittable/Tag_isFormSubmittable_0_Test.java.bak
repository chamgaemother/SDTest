package org.jsoup.parser;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;

/**
 * Test class for Tag.isFormSubmittable method.
 */
public class Tag_isFormSubmittable_Test {

    @Test
    @DisplayName("Known form-submittable tag returns true (branch-true)")
    public void test_TC01() {
        // Given a standard HTML input tag, which should be form-submittable by specification
        Tag tag = Tag.valueOf("input");
        // When checking if the tag is submittable in a form
        boolean result = tag.isFormSubmittable();
        // Then expect true because 'input' is defined in formSubmitTags and initialized true
        assertEquals(true, result, "Expected 'input' tag to be form-submittable");
    }

    @Test
    @DisplayName("Unknown tag returns false (branch-false)")
    public void test_TC02() {
        // Given a custom unknown tag, not listed in formSubmitTags
        Tag tag = Tag.valueOf("customUnknown");
        // When checking if the tag is submittable in a form
        boolean result = tag.isFormSubmittable();
        // Then expect false because unknown tags default formSubmit = false
        assertEquals(false, result, "Expected unknown tag to not be form-submittable");
    }
}