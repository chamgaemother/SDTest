  "scenarios": [
    {
      "id": "TC06",
      "description": "valueOf(null, namespace, settings) throws IllegalArgumentException on null tagName",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown due to null tagName",
      "tags": [
        "exception",
        "negative",
        "valueOf"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 null-tagName",
        "  GIVEN",
        "    String tagName = null;",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, namespace, settings);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
