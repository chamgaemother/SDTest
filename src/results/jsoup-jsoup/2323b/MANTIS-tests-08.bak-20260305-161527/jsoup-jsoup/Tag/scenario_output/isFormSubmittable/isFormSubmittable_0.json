  "scenarios": [
    {
      "id": "TC01",
      "description": "Known form-submittable tag \"input\" returns true (formSubmit==true)",
      "path": "B0→B1",
      "precondition": "Call Tag.valueOf(\"input\") to get predefined tag with formSubmit=true",
      "expectedResult": "isFormSubmittable() returns true",
      "tags": [
        "branch-true",
        "known-tag",
        "submit-tag"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known submit",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
