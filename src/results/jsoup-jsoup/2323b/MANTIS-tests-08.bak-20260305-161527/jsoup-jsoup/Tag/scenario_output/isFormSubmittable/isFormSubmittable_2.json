  "scenarios": [
    {
      "id": "TC07",
      "description": "valueOf(null, namespace, settings) throws IllegalArgumentException on null tagName",
      "path": "B0→B1→EX",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown for null tagName",
      "tags": [
        "exception",
        "negative",
        "validate-notNull"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 valueOf null-tagName",
        "  GIVEN",
        "    String tagName = null;",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveLowerCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, namespace, settings);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
