{
  "scenarios": [
    {
      "id": "TC04",
      "description": "Known submittable tag 'input' in non-HTML namespace returns false after namespace mismatch branch",
      "path": "B0→B1→B3(fail first namespace check)→B5(fail second namespace check)→B8→B10",
      "precondition": "ParseSettings.preserveCase configured",
      "expectedResult": "return false (new generic tag, formSubmit==false)",
      "tags": [
        "negative",
        "namespace-mismatch",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 namespace-mismatch-form-submit",
        "  GIVEN",
        "    String tagName = \"input\";",
        "    String normalName = ParseSettings.normalName(tagName);",
        "    String otherNamespace = \"http://custom\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, normalName, otherNamespace, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    },
    {
