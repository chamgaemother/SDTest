{
  "scenarios": [
    {
      "id": "TC04",
      "description": "valueOf(null, …) throws NullPointerException at Validate.notNull(tagName)",
      "path": "B0→B1→EX",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "null-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 null-tagName throws",
        "  GIVEN",
        "    String tagName = null;",
        "    String ns = \"html\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, ns, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
