{
  "method": "isFormSubmittable",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "Default overload on known submittable tag returns true (formSubmit==true)",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is true",
      "tags": [
        "overload:String",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 isFormSubmittable default-overload known-tag",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
    {
      "id": "TC02_O2",
      "description": "Overload with ParseSettings on known non-submittable tag returns false (formSubmit==false)",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is false",
      "tags": [
        "overload:String,ParseSettings",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02_O2 isFormSubmittable settings-overload known-nonsubmit",
        "  GIVEN",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "    Tag tag = Tag.valueOf(\"div\", settings);",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    },
    {
      "id": "TC03_O3",
      "description": "Overload with namespace and settings on unknown tag returns false (default new generic tag formSubmit==false)",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is false",
      "tags": [
        "overload:String,String,ParseSettings",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O3 isFormSubmittable full-overload unknown-tag",
        "  GIVEN",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "    String ns = \"custom\";",
        "    Tag tag = Tag.valueOf(\"mytag\", ns, settings);",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    }
  ]
}