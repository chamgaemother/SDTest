    {
      "id": "TC09",
      "description": "Direct lookup path returns static known form-submittable tag without clone",
      "path": "B0→B3→B4",
      "precondition": "Tag \"textarea\" pre-registered with formSubmit=true",
      "expectedResult": "return static Tag instance and isFormSubmittable() == true",
      "tags": [
        "positive",
        "branch",
        "direct-return"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 direct-lookup static-submittable",
        "  GIVEN",
        "    String tagName = \"textarea\";",
        "    String ns = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, ns, settings);",
        "  THEN",
        "    assert tag.isFormSubmittable() == true;",
        "END"
      ]
    }
