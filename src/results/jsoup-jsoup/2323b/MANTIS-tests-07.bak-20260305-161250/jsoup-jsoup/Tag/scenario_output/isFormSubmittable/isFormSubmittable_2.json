{
  "scenarios": [
    {
      "id": "TC07",
      "description": "valueOf(tagName,namespace,settings) throws on null tagName",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "NullPointerException or IllegalArgumentException is thrown",
      "tags": [
        "exception",
        "negative",
        "validation"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 valueOf null-name validation",
        "  GIVEN",
        "    String tagName = null;",
        "    String ns = \"html\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, ns, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
