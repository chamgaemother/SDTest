    {
      "id": "TC09",
      "description": "valueOf(String,ParseSettings) with uppercase 'SELECT' and preserveCase triggers clone and retains submittable flag",
      "path": "B0→B1→B2→B4→B6→B7→B10",
      "precondition": "none",
      "expectedResult": "cloned Tag named 'SELECT', isFormSubmittable() returns true, != static instance",
      "tags": [
        "positive",
        "clone-branch",
        "iteration",
        "known-tag"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 valueOf-twoArg-clone-submittable",
        "  GIVEN",
        "    // uppercase SELECT differs from normalized 'select'",
        "    String raw = \"SELECT\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(raw, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert tag.getName().equals(\"SELECT\");",
        "    assert result == true;",
        "    assert tag != Tag.valueOf(\"select\");",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "valueOf(String,namespace,ParseSettings) with uppercase 'Br' clone-branch produces non-submittable empty tag",
      "path": "B0→B1→B2→B4→B6→B7→B8→B9",
      "precondition": "none",
      "expectedResult": "cloned Tag named 'Br', isEmpty()==true, isFormSubmittable()==false",
      "tags": [
        "positive",
        "clone-branch",
        "empty-tag",
        "negative"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 valueOf-threeArg-clone-empty",
        "  GIVEN",
        "    String raw = \"Br\";",
        "    String norm = ParseSettings.normalName(raw);",
        "    String ns = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(raw, norm, ns, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert tag.getName().equals(\"Br\");",
        "    assert tag.isEmpty() == true;",
        "    assert result == false;",
        "END"
      ]
    }
  ]
}