{
  "scenarios": [
    {
      "id": "TC07",
      "description": "valueOf(String) overload with non-submittable known tag 'textarea' returns false",
      "path": "B0→B3→B5→B8→B9",
      "precondition": "none",
      "expectedResult": "isFormSubmittable() returns false for <textarea>",
      "tags": [
        "positive",
        "overload",
        "known-tag",
        "negative"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 valueOf-oneArg-nonSubmittable",
        "  GIVEN",
        "    // default HTML namespace and preserveCase",
        "    String tagName = \"textarea\";",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    },
