{
  "scenarios": [
    {
      "id": "TC03",
      "description": "valueOf with PreserveCase settings and mismatched case triggers clone branch and retains formSubmit flag",
      "path": "B0→B2→B5→B6→B7(clone)→B8→B9",
      "precondition": "ParseSettings.preserveCase",
      "expectedResult": "returned Tag has tagName 'INPUT' and isFormSubmittable() == true",
      "tags": [
        "positive",
        "clone-branch",
        "formSubmit"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN",
        "  String raw = \"INPUT\";",
        "  String norm = ParseSettings.normalName(raw);",
        "  ParseSettings settings = ParseSettings.preserveCase;",
        "WHEN",
        "  Tag tag = Tag.valueOf(raw, norm, Parser.NamespaceHtml, settings);",
        "THEN",
        "  assert tag.getName().equals(\"INPUT\");",
        "  assert tag.isFormSubmittable();"
      ]
    },
    {
      "id": "TC04",
      "description": "valueOf with existing tag but different namespace returns new generic with formSubmit false",
      "path": "B0→B2→B3(mismatch)→B11(default-creation)→B12→B13",
      "precondition": "ParseSettings.preserveCase, namespace = Parser.NamespaceMathml",
      "expectedResult": "returned Tag.isFormSubmittable() == false",
      "tags": [
        "positive",
        "namespace-mismatch",
        "default-tag"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN",
        "  String name = \"input\";",
        "  String norm = \"input\";",
        "  String ns = Parser.NamespaceMathml;",
        "  ParseSettings settings = ParseSettings.preserveCase;",
        "WHEN",
        "  Tag tag = Tag.valueOf(name, norm, ns, settings);",
        "THEN",
        "  assert !tag.isFormSubmittable();"
      ]
    },
    {
