  "scenarios": [
    {
      "id": "TC01",
      "description": "Known form-submittable tag 'input' returns true (formSubmit==true)",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "known-tag",
        "boundary:formSubmit-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known submit control",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
