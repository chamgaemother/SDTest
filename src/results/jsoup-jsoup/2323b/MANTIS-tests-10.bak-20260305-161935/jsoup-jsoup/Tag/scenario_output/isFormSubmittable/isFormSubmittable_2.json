    {
      "id": "TC09",
      "description": "valueOf(\"INPUT\", default namespace, non-preserve settings) returns known tag without clone and formSubmit==true",
      "path": "B0→B1→B7→B8→B10",
      "precondition": "ParseSettings where preserveTagCase() returns false",
      "expectedResult": "returned Tag.tagName equals \"input\" and isFormSubmittable() is true",
      "tags": [
        "positive",
        "case-normalization",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 valueOf uppercase with ignore-case",
        "  GIVEN",
        "    String tagName = \"INPUT\";",
        "    ParseSettings settings = ParseSettings.lowerCase; // preserveTagCase=false",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, settings);",
        "  THEN",
        "    assert tag.getName().equals(\"input\");",
        "    assert tag.isFormSubmittable();",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "valueOf(String, ParseSettings) overload for known form-submit tag returns true",
      "path": "B0→B1→B7→B8→B10",
      "precondition": "none",
      "expectedResult": "isFormSubmittable() is true for tagName=\"option\" using overload",
      "tags": [
        "positive",
        "overload",
        "form-submit"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 overload-valueOf returns form-submit",
        "  GIVEN",
        "    String tagName = \"option\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    }
  ]
