      "precondition": "none",
      "expectedResult": "return value is false",
      "tags": [
        "negative",
        "namespace",
        "formSubmit"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 option non-html-namespace no-submit",
        "  GIVEN",
        "    String tagName = \"option\";",
        "    String namespace = Parser.NamespaceSvg; // not html",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, namespace, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false; // namespace mismatch yields new generic tag formSubmit==false",
        "END"
      ]
