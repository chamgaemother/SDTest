      "id": "TC04",
      "description": "Known form-submit tag \"option\" in default HTML namespace returns true",
      "path": "B1→B3",
      "precondition": "none",
      "expectedResult": "return value is true",
      "tags": [
        "positive",
        "known",
        "formSubmit"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 option default-namespace submit",
        "  GIVEN",
        "    // Arrange: use default html namespace and default settings",
        "    String tagName = \"option\";",
        "  WHEN",
        "    // Act",
        "    Tag tag = Tag.valueOf(tagName);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    // Assert: option is in SharedConstants.FormSubmitTags",
        "    assert result == true;",
        "END"
      ]
    },
