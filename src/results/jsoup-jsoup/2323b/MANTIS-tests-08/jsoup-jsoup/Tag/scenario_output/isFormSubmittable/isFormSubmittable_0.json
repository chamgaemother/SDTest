  "scenarios": [
    {
      "id": "TC01",
      "description": "isFormSubmittable() returns true for a known form-submittable tag 'input'",
      "path": "B0→B1→B2",
      "precondition": "Tags static initializer has run, 'input' is registered with formSubmit=true",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "known-tag",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known-submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
