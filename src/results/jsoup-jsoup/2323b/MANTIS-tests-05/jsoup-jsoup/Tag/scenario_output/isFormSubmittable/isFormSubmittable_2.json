{
  "scenarios": [
    {
      "id": "TC07",
      "description": "Uppercase known form-submit tag 'INPUT' with preserveTagCase=false returns static instance with formSubmit=true",
      "path": "B0→B1→B2→B10→B11→B12",
      "precondition": "ParseSettings preserveTagCase=false",
      "expectedResult": "returned tag == static registry instance; isFormSubmittable() == true",
      "tags": [
        "positive",
        "case-insensitive",
        "identity"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 uppercase-known-submit-without-preserve-case",
        "  GIVEN",
        "    String tagName = \"INPUT\";",
        "    ParseSettings settings = ParseSettings.preserveLowerCase;",
        "  WHEN",
        "    Tag resultTag = Tag.valueOf(tagName, Parser.NamespaceHtml, settings);",
        "  THEN",
        "    assertSame(Tag.valueOf(\"input\"), resultTag);",
        "    assertTrue(resultTag.isFormSubmittable());",
        "END"
      ]
    },
