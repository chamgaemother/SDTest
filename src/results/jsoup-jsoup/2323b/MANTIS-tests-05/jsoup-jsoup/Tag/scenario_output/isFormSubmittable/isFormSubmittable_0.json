    {
      "id": "TC04",
      "description": "Known submit tag 'button' in non-HTML namespace returns false (branch: namespace mismatch → new default Tag formSubmit==false)",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "isFormSubmittable() returns false",
      "tags": [
        "branch-false",
        "known-tag",
        "namespace-mismatch",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 isFormSubmittable namespace-mismatch",
        "  GIVEN",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "    String ns = \"http://www.example.com/custom\";",
        "    Tag tag = Tag.valueOf(\"button\", ns, settings);",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    }
