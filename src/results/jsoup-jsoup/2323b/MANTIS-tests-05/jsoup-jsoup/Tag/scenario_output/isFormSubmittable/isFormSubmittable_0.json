{
  "method": "isFormSubmittable",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Known form-submit tag 'input' returns true (branch: Tags.containsKey && formSubmit==true)",
      "path": "B0→B1",
      "precondition": "Ensure Tag.Tags is initialized with standard HTML tags via static init",
      "expectedResult": "isFormSubmittable() returns true",
      "tags": [
        "branch-true",
        "known-tag",
        "form-submittable",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 isFormSubmittable positive-known-submit",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "Known non-submit tag 'div' returns false (branch: Tags.containsKey && formSubmit==false)",
      "path": "B0→B1",
      "precondition": "Ensure Tag.Tags is initialized with standard HTML tags via static init",
      "expectedResult": "isFormSubmittable() returns false",
      "tags": [
        "branch-false",
        "known-tag",
        "non-submit",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02 isFormSubmittable known-non-submit",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"div\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    },
