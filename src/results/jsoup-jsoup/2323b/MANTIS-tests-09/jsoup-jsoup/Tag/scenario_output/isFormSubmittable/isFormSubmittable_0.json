    {
      "id": "TC01",
      "description": "Known form-submittable tag 'input' returns true (formSubmit==true)",
      "path": "B0→B1",
      "precondition": "Tags static init contains 'input' with formSubmit set to true",
      "expectedResult": "return value is true",
      "tags": [
        "positive",
        "known-tag",
        "formSubmit-true",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known form-submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
