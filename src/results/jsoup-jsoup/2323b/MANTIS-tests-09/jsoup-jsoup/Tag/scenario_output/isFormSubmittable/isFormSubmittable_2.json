      "description": "valueOf(null,normal,ns) throws NullPointerException at Validate.notNull(tagName)",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "validation",
        "negative"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 valueOf null-tagName throws NPE",
        "  GIVEN",
        "    String tagName = null;",
        "    String normalName = \"n\";",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, normalName, namespace, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
