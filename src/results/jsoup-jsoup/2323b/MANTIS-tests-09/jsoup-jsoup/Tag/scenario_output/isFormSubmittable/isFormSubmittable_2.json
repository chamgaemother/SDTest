    {
      "id": "TC11",
      "description": "Uppercase known tag with preserveCase but tagName equals normalName returns static instance without clone",
      "path": "B0→B1→B5→B6",
      "precondition": "static Tags contains 'div' with formSubmit=false",
      "expectedResult": "returns static Tag instance with name 'div'",
      "tags": [
        "positive",
        "branch",
        "preserve-case"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 valueOf uppercase-known without clone",
        "  GIVEN",
        "    String tagName = \"DIV\";",
        "    String normalName = \"div\";",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag result = Tag.valueOf(tagName, normalName, namespace, settings);",
        "  THEN",
        "    assertSame(Tag.valueOf(\"div\"), result);",
        "    assertEquals(\"div\", result.getName());",
        "END"
      ]
    },
