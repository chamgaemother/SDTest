  "scenarios": [
    {
      "id": "TC01",
      "description": "Built-in 'input' tag is form submittable (formSubmit == true)",
      "path": "B0→B1",
      "precondition": "Use real Tag.valueOf(tagName) to get predefined 'input' tag; no mocks",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "positive",
        "overload:instance"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 input-is-form-submittable",
        "  GIVEN",
        "    Tag t = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = t.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
