{
  "method": "isFormSubmittable",
  "scenarios": [
    {
      "id": "TC01",
      "description": "isFormSubmittable returns true for a predefined form-submittable tag (tagName 'input') covering branch-true",
      "path": "B0→B1",
      "precondition": "Tag.valueOf('input') returns a known Tag with formSubmit true as per static initialization; no mocks",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "known-tag",
        "predefined",
        "P0",
        "Java8"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable predefined-submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
