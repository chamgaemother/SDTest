    {
      "id": "TC05",
      "description": "valueOf(nonexistent, custom namespace, preserve case) returns new tag with formSubmit=false",
      "path": "B0→B1→B4→B5→B6",
      "precondition": "none",
      "expectedResult": "return Tag instance with isFormSubmittable() == false",
      "tags": [
        "positive",
        "unknown-tag",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 unknown-tag new-instance",
        "  GIVEN",
        "    String tagName = \"myCustom\";",
        "    String normalName = ParseSettings.normalName(tagName);",
        "    String namespace = \"http://example.com/ns\";",
        "    ParseSettings settings = new ParseSettings(false, false);",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, normalName, namespace, settings);",
        "  THEN",
        "    assert tag.isFormSubmittable() == false;",
        "END"
      ]
    }
