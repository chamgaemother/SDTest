{
  "scenarios": [
    {
      "id": "TC03",
      "description": "valueOf(null, namespace, settings) throws IllegalArgumentException for null tagName",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown due to Validate.notNull(tagName)",
      "tags": [
        "negative",
        "exception",
        "valueOf-overload"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 valueOf null-tagName throws",
        "  GIVEN",
        "    String tagName = null;",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, namespace, settings);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
