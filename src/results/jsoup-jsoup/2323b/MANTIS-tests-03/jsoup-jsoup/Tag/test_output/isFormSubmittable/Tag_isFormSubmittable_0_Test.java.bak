package org.jsoup.parser;

import static org.junit.jupiter.api.Assertions.assertEquals;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

/**
 * JUnit 5 tests for Tag.isFormSubmittable()
 */
public class Tag_isFormSubmittable_Test {

    @Test
    @DisplayName("TC01: isFormSubmittable returns true for a predefined form-submittable tag (tagName 'input') covering branch-true")
    public void test_TC01() {
        // GIVEN a predefined tag 'input' which per static init is marked as form-submittable
        Tag tag = Tag.valueOf("input");
        // WHEN checking if form submittable
        boolean result = tag.isFormSubmittable();
        // THEN should return true because 'input' is known to be submittable
        assertEquals(true, result, "Expected 'input' to be form submittable");
    }

    @Test
    @DisplayName("TC02: isFormSubmittable returns false for a non-submittable tag (tagName 'div') covering branch-false")
    public void test_TC02() {
        // GIVEN a predefined tag 'div' which per static init is NOT marked as form-submittable
        Tag tag = Tag.valueOf("div");
        // WHEN checking if form submittable
        boolean result = tag.isFormSubmittable();
        // THEN should return false because 'div' is not a form control
        assertEquals(false, result, "Expected 'div' to NOT be form submittable");
    }
}