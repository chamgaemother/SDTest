    {
      "id": "TC07",
      "description": "valueOf(String,ParseSettings) with uppercase known tag and preserveCase=true returns cloned Tag and retains submittable flag",
      "path": "B0→B5→B6→B7→B8→B9",
      "precondition": "Parser.NamespaceHtml has predefined 'input' tag in Tags",
      "expectedResult": "returned Tag.getName() == \"INPUT\" and isFormSubmittable() == true",
      "tags": [
        "positive",
        "clone",
        "preserve-case",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 uppercase input with preserveCase",
        "  GIVEN",
        "    String tagName = \"INPUT\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, settings);",
        "  THEN",
        "    assert tag.getName().equals(\"INPUT\");",
        "    assert tag.isFormSubmittable();",
        "END"
      ]
    }
