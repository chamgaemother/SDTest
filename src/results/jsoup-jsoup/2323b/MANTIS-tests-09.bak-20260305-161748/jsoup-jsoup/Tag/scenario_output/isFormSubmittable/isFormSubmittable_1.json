      "description": "valueOf(String,String,ParseSettings) throws NullPointerException when tagName is null",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "negative",
        "valueOf"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 valueOf null-tagName",
        "  GIVEN",
        "    String tagName = null;",
        "    String normalName = \"irrelevant\";",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, normalName, namespace, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
