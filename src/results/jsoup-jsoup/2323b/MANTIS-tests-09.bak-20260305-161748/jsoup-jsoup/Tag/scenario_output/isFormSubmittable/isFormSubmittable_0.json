{
  "method": "isFormSubmittable",
  "scenarios": [
    {
      "id": "TC01",
      "description": "isFormSubmittable returns true for a predefined submittable form control tag (input)",
      "path": "B0→B1→R",
      "precondition": "none",
      "expectedResult": "return value is true",
      "tags": [
        "positive",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known submittable",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
