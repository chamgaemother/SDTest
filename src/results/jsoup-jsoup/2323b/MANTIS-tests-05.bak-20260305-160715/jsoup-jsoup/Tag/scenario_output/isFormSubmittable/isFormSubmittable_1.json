{
  "scenarios": [
    {
      "id": "TC03",
      "description": "valueOf(null, namespace, settings) throws NullPointerException on null tagName",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "negative",
        "validate"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 valueOf null-tagName",
        "  GIVEN",
        "    String tagName = null;",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, namespace, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
