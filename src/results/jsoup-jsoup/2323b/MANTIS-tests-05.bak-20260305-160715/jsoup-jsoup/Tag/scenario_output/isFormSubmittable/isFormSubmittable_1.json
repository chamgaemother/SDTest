    {
      "id": "TC05",
      "description": "Unknown custom tag returns non-submittable Tag instance with formSubmit false",
      "path": "B0→B1→B2→B4→B7",
      "precondition": "none",
      "expectedResult": "new Tag created; isFormSubmittable() returns false",
      "tags": [
        "positive",
        "unknown",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 valueOf custom-unknown-tag",
        "  GIVEN",
        "    String tagName = \"customTag\";",
        "    String namespace = \"http://example.com/ns\";",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, namespace, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == false;",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "Known form-submittable tag with preserved case triggers clone path and returns true",
      "path": "B0→B1→B2→B5→B6→B7",
      "precondition": "Tag 'input' already in static map",
      "expectedResult": "cloned Tag with uppercase name; isFormSubmittable() returns true",
      "tags": [
        "positive",
        "preserve-case",
        "clone",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 valueOf preserveCase-clone-path",
        "  GIVEN",
        "    String tagName = \"INPUT\";",
        "    String namespace = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag tag = Tag.valueOf(tagName, namespace, settings);",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    }
