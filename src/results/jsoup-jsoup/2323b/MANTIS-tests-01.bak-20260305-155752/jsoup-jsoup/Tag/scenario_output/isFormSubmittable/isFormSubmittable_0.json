      "pseudocode": [
        "TEST TC01 unknown-tag formSubmittable",
        "  GIVEN",
        "    Tag t = Tag.valueOf(\"foo\",\"ns\",ParseSettings.preserveCase);",
        "  WHEN",
        "    boolean result = t.isFormSubmittable();",
        "  THEN",
        "    assert result == false;"
      ]
    },
