    {
      "id": "TC05",
      "description": "Uppercase known form-submit tag triggers clone path and preserves formSubmit=true",
      "path": "B0‚ÜíB1‚ÜíB2‚ÜíB4‚Üíclone‚Üíreturn",
      "precondition": "none",
      "expectedResult": "cloned Tag is not the static instance and isFormSubmittable() returns true",
      "tags": [
        "positive",
        "clone-path",
        "form-submit"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 uppercase-input-triggers-clone",
        "  GIVEN",
        "    String name = \"INPUT\";",
        "    String normal = ParseSettings.normalName(name);",
        "    String ns = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "    Tag base = Tag.valueOf(\"input\");",
        "  WHEN",
        "    Tag t = Tag.valueOf(name, normal, ns, settings);",
        "  THEN",
        "    assert t != base;",
        "    assert t.isFormSubmittable() == true;"
      ]
    }
  ]
