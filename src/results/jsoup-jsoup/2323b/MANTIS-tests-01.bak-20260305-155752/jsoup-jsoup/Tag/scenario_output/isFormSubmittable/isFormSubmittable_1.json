      "id": "TC03",
      "description": "Known form-submit tag ‚Äúoption‚Äù returns true via valueOf(String,ParseSettings) overload",
      "path": "B0‚ÜíB1‚ÜíB2‚ÜíB4‚ÜíB5‚Üíreturn",
      "precondition": "none",
      "expectedResult": "isFormSubmittable() returns true",
      "tags": [
        "positive",
        "overload",
        "form-submit"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 valueOf-option-with-settings",
        "  GIVEN",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    Tag t = Tag.valueOf(\"option\", settings);",
        "  THEN",
        "    assert t.isFormSubmittable() == true;"
