{
  "scenarios": [
    {
      "id": "TC06",
      "description": "valueOf throws NullPointerException when tagName is null",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "validation"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 null-tagName",
        "  GIVEN",
        "    String tagName = null;",
        "    String normal = \"anything\";",
        "    String ns = Parser.NamespaceHtml;",
        "    ParseSettings settings = ParseSettings.preserveCase;",
        "  WHEN",
        "    call Tag.valueOf(tagName, normal, ns, settings);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
