{
  "method": "isFormSubmittable",
  "scenarios": [
    {
      "id": "TC01",
      "description": "isFormSubmittable() returns true when tag is known form-submittable (formSubmit==true)",
      "path": "B0→B1",
      "precondition": "Use real Tag via Tag.valueOf(\"input\") which is initialized with formSubmit=true in static setup; no stubs/mocks",
      "expectedResult": "return value is true",
      "tags": [
        "branch-true",
        "positive",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 isFormSubmittable known-form-submit",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"input\");",
        "  WHEN",
        "    boolean result = tag.isFormSubmittable();",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
    {
      "id": "TC02",
