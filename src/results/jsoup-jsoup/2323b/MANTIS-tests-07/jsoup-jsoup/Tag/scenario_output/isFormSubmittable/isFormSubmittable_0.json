        "negative",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 isFormSubmittable unknown-tag",
        "  GIVEN",
        "    Tag tag = Tag.valueOf(\"customUnknown\");",
        "  WHEN",
