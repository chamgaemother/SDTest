package org.jsoup;

import org.jsoup.helper.HttpConnection;
import org.jsoup.nodes.Document;
import org.jsoup.parser.Parser;
import org.jsoup.Connection;
import org.jsoup.HttpStatusException;
import org.jsoup.UnsupportedMimeTypeException;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.mockito.MockedStatic;

import java.io.ByteArrayInputStream;
import java.io.File;
import java.io.IOException;
import java.io.InputStream;
import java.net.SocketTimeoutException;
import java.net.URL;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.charset.StandardCharsets;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

public class Jsoup_parse_Test {

    @Test
    @DisplayName("TC21: parse(File, charsetName, baseUri, parser) uses custom XML parser override branch")
    public void test_TC21() throws IOException {
        // Create temp XML file to satisfy parser non-null branch and file-loading branch
        File temp = File.createTempFile("tc21", ".xml");
        temp.deleteOnExit();
        String xmlContent = "<elem>XML</elem>";
        Files.write(temp.toPath(), xmlContent.getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "http://base/";
        Parser xmlParser = Parser.xmlParser();
        // When parsing with a non-null parser, should use parser.parseInput and preserve XML syntax and elements
        Document doc = Jsoup.parse(temp, charset, baseUri, xmlParser);
        assertEquals(xmlParser.getSettings().syntax(),
                     doc.outputSettings().syntax(),
                     "Expected document syntax to match XML parser syntax");
        assertTrue(doc.body().html().contains(xmlContent),
                   "Expected body to contain original XML elements");
    }

    @Test
    @DisplayName("TC22: parse(Path, charsetName, baseUri, parser) uses custom XML parser override branch")
    public void test_TC22() throws IOException {
        // Use a Path input to trigger Path overload with non-null parser
        Path tmpPath = Files.createTempFile("tc22", ".xml");
        tmpPath.toFile().deleteOnExit();
        String xmlContent = "<n>5</n>";
        Files.write(tmpPath, xmlContent.getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "http://pbase/";
        Parser xmlParser = Parser.xmlParser();
        Document doc = Jsoup.parse(tmpPath, charset, baseUri, xmlParser);
        assertEquals(xmlParser.getSettings().syntax(),
                     doc.outputSettings().syntax(),
                     "Expected document syntax to match XML parser syntax");
        assertTrue(doc.body().html().contains(xmlContent),
                   "Expected body to contain original XML elements");
    }

    @Test
    @DisplayName("TC23: parse(InputStream, charsetName, baseUri, parser) uses custom XML parser override branch")
    public void test_TC23() throws IOException {
        // Provide InputStream to trigger in-stream overload with non-null parser
        String xmlContent = "<x>7</x>";
        InputStream in = new ByteArrayInputStream(xmlContent.getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "http://i/uri";
        Parser xmlParser = Parser.xmlParser();
        Document doc = Jsoup.parse(in, charset, baseUri, xmlParser);
        assertEquals(xmlParser.getSettings().syntax(),
                     doc.outputSettings().syntax(),
                     "Expected document syntax to match XML parser syntax");
        assertTrue(doc.body().html().contains(xmlContent),
                   "Expected body to contain original XML elements");
    }

    @Test
    @DisplayName("TC24: parse(URL, timeout) throws SocketTimeoutException when connection times out")
    public void test_TC24() throws Exception {
        URL url = new URL("http://example.com");
        int timeout = 10;
        Connection mockCon = mock(Connection.class);
        when(mockCon.timeout(timeout)).thenReturn(mockCon);
        when(mockCon.get()).thenThrow(new SocketTimeoutException("timeout"));
        try (MockedStatic<HttpConnection> httpConnMock = mockStatic(HttpConnection.class)) {
            httpConnMock.when(() -> HttpConnection.connect(url)).thenReturn((HttpConnection) mockCon);
            // Expect SocketTimeoutException from get()
            assertThrows(SocketTimeoutException.class,
                         () -> Jsoup.parse(url, timeout),
                         "Expected SocketTimeoutException when connection times out");
        }
    }

    @Test
    @DisplayName("TC25: parse(URL, timeout) throws HttpStatusException when HTTP status not OK")
    public void test_TC25() throws Exception {
        URL url = new URL("http://example.com");
        int timeout = 20;
        HttpStatusException httpEx = new HttpStatusException("err", 500, "");
        Connection mockCon = mock(Connection.class);
        when(mockCon.timeout(timeout)).thenReturn(mockCon);
        when(mockCon.get()).thenThrow(httpEx);
        try (MockedStatic<HttpConnection> httpConnMock = mockStatic(HttpConnection.class)) {
            httpConnMock.when(() -> HttpConnection.connect(url)).thenReturn((HttpConnection) mockCon);
            assertThrows(HttpStatusException.class,
                         () -> Jsoup.parse(url, timeout),
                         "Expected HttpStatusException when HTTP status not OK");
        }
    }

    @Test
    @DisplayName("TC26: parse(URL, timeout) throws UnsupportedMimeTypeException on unsupported MIME")
    public void test_TC26() throws Exception {
        URL url = new URL("http://example.com");
        int timeout = 30;
        UnsupportedMimeTypeException mimeEx = new UnsupportedMimeTypeException("type", "url");
        Connection mockCon = mock(Connection.class);
        when(mockCon.timeout(timeout)).thenReturn(mockCon);
        when(mockCon.get()).thenThrow(mimeEx);
        try (MockedStatic<HttpConnection> httpConnMock = mockStatic(HttpConnection.class)) {
            httpConnMock.when(() -> HttpConnection.connect(url)).thenReturn((HttpConnection) mockCon);
            assertThrows(UnsupportedMimeTypeException.class,
                         () -> Jsoup.parse(url, timeout),
                         "Expected UnsupportedMimeTypeException on unsupported MIME type");
        }
    }
}