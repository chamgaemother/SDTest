{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File) overload reads file with default null charset and uses file path as baseUri",
      "path": "B0→B?→DataUtil.load(File,null,baseUri)→return",
      "precondition": "temp HTML file exists with UTF-8 content",
      "expectedResult": "Document.body().html() contains file content and baseUri equals file absolute path",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse_file_default_charset",
        "  GIVEN",
        "    File f = temp HTML file with '<p>Z</p>' in UTF-8;",
        "  WHEN",
        "    Document doc = Jsoup.parse(f);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>Z</p>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File, charsetName, baseUri, parser) uses custom XML parser override",
      "path": "B0→B?→DataUtil.load(...,parser)→return",
      "precondition": "temp XML file exists",
      "expectedResult": "Document.outputSettings().syntax() equals xml syntax and body contains fragment",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse_file_with_parser",
        "  GIVEN",
        "    File f = temp file containing '<elem>1</elem>';",
        "    Parser p = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, \"UTF-8\", \"http://base/\", p);",
        "  THEN",
        "    assert doc.outputSettings().syntax() == Parser.xmlParser().getSettings().syntax();",
        "    assert doc.body().html().contains(\"<elem>1</elem>\");"
      ]
    },
