{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri returns DOM with correct base URI (branch: html non-empty, baseUri non-empty)",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.getBaseUri() == \"http://example.com/\" and Document.body().html() contains \"<p>Hello</p>\"",
      "tags": [
        "overload:String,String",
        "branch-true",
        "P0",
        "Java 8"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse(html, baseUri) nonEmpty",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.getBaseUri().equals(baseUri);",
        "    assert doc.body().html().contains(\"<p>Hello</p>\");"
      ]
    },
    {
