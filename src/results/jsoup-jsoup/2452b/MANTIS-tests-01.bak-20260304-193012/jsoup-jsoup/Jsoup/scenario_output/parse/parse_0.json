        "overload:String,String,Parser",
        "branch-true",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse(html,baseUri,parser) custom-parser",
        "  GIVEN",
        "    String html = \"<xml/>\";",
        "    String baseUri = \"http://x/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.equals(parser.parseInput(html, baseUri));"
      ]
    },
