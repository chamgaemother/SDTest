      "id": "TC09_O9",
      "description": "parse(html,baseUri) resolves relative links using baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "doc.select(\"a\").first().absUrl(\"href\") equals \"http://x.com/rel\"",
      "tags": [
        "overload:String,String",
        "branch-true",
        "boundary"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 parse(html,baseUri) relative-link-resolution",
        "  GIVEN",
        "    String html = \"<a href='/rel'>link</a>\";",
        "    String baseUri = \"http://x.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://x.com/rel\");"
      ]
