{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html) invokes Parser.parse with empty baseUri for default overload",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document is equal to Parser.parse(\"<p>test</p>\", \"\")",
      "tags": [
        "overload:String",
        "default-baseUri",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse(html) default-baseUri",
        "  GIVEN",
        "    String html = \"<p>test</p>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.equals(Parser.parse(html, \"\"));"
      ]
    },
    {
      "id": "TC02_O2",
      "description": "parse(html,baseUri) passes non-empty baseUri through to Parser.parse",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document is equal to Parser.parse(\"<a href='x'>x</a>\", \"http://example.com/\")",
      "tags": [
        "overload:String,String",
        "branch-true",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse(html,baseUri) non-empty-baseUri",
        "  GIVEN",
        "    String html = \"<a href='x'>x</a>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.equals(Parser.parse(html, baseUri));"
      ]
    },
    {
      "id": "TC03_O3",
