{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(String html) delegates to Parser.parse(html, \"\") and returns Document with empty baseUri",
      "path": "B0→B3→B5",
      "precondition": "none",
      "expectedResult": "Document.baseUri() is empty string; body contains input fragment",
      "tags": [
        "positive",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 parse html only",
        "  GIVEN",
        "    String html = \"<span>abc</span>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.body().html().contains(\"<span>abc</span>\");",
        "END"
      ]
    },
    {
      "id": "TC11",
      "description": "parse(File file, String charsetName, String baseUri, Parser parser) uses provided parser for file input",
      "path": "B0→B?→B?",
      "precondition": "temp HTML file exists with XML content",
      "expectedResult": "Document parsed by parser; baseUri matches provided",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse file with parser",
        "  GIVEN",
        "    File temp = create temp file with content \"<item/>\";",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://file/\";",
        "    Parser xml = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, charset, baseUri, xml);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"item\").size() == 1;",
        "END"
      ]
    },
