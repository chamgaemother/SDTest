{
  "scenarios": [
    {
      "id": "TC19",
      "description": "clean(String, String, Safelist) sets baseUri to DummyUri when baseUri is empty and safelist.preserveRelativeLinks() is true",
      "path": "B0→B1(true)→B2→B3→B5",
      "precondition": "none",
      "expectedResult": "returned HTML retains relative links unchanged and no exception",
      "tags": [
        "positive",
        "branch",
        "clean",
        "safelist",
        "relative-links"
      ],
      "priority": "P1",
      "environment": "Java 11",
      "pseudocode": [
        "TEST TC19 clean empty-baseUri with preserveRelativeLinks",
        "  GIVEN",
        "    String html = \"<a href=\\\"/foo\\\">link</a>\";",
        "    Safelist safelist = Safelist.relaxed();",
        "    safelist.preserveRelativeLinks(true);",
        "  WHEN",
        "    String result = Jsoup.clean(html, \"\", safelist);",
        "  THEN",
        "    assert result.contains(\"<a href=\\\"/foo\\\">link</a>\");",
        "END"
      ]
    },
    {
      "id": "TC20",
      "description": "clean(String, String, Safelist) skips DummyUri branch when baseUri is non-empty",
      "path": "B0→B1(false)→B4→B5",
      "precondition": "none",
      "expectedResult": "returned HTML contains sanitized output and no DummyUri applied",
      "tags": [
        "positive",
        "branch",
        "clean",
        "safelist"
      ],
      "priority": "P2",
      "environment": "Java 11",
      "pseudocode": [
        "TEST TC20 clean non-empty-baseUri skips DummyUri",
        "  GIVEN",
        "    String html = \"<b>bold</b>\";",
        "    Safelist safelist = Safelist.simpleText();",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    String result = Jsoup.clean(html, baseUri, safelist);",
        "  THEN",
        "    assert result.equals(\"<b>bold</b>\");",
        "END"
      ]
    },
    {
      "id": "TC21",
      "description": "clean(String, String, Safelist, OutputSettings) applies supplied output settings",
      "path": "B0→B6→B7→B8",
      "precondition": "none",
      "expectedResult": "returned HTML is pretty-printed according to provided settings",
      "tags": [
        "positive",
        "clean",
        "outputSettings"
      ],
      "priority": "P2",
      "environment": "Java 11",
      "pseudocode": [
        "TEST TC21 clean with outputSettings",
        "  GIVEN",
        "    String html = \"<p>one<em>two</em>three</p>\";",
        "    Safelist safelist = Safelist.none();",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String result = Jsoup.clean(html, \"\", safelist, os);",
        "  THEN",
        "    assert result.contains(\"one<em>two</em>three\");",
        "END"
      ]
    },
    {
