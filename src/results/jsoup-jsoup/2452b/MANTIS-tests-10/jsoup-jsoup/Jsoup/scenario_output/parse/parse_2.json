        "parse",
        "network"
      ],
      "priority": "P0",
      "environment": "Java 11",
      "pseudocode": [
        "TEST TC24 parse URL with server delay triggers timeout",
        "  GIVEN",
        "    start HTTP server that sleeps 500ms before sending",
        "    URL url = new URL(\"http://localhost:port/\");",
        "    int timeoutMillis = 100;",
        "  WHEN",
        "    call Jsoup.parse(url, timeoutMillis);",
        "  THEN",
