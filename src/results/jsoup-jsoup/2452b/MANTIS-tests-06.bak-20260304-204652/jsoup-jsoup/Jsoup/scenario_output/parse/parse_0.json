{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_parse_S_S",
      "description": "parse(html, baseUri) with non-empty html and baseUri resolves relative links",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document contains html content and all relative URLs resolved against baseUri",
      "tags": [
        "branch-false",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_parse_S_S resolves relative URLs",
        "  GIVEN",
        "    String html = \"<a href=\\\"page.html\\\">link</a>\"; String baseUri=\"http://example.com/sub/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://example.com/sub/page.html\");"
      ]
    },
    {
      "id": "TC02_parse_S_emptyBase",
      "description": "parse(html,\"\") with non-empty html uses empty baseUri",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document contains html content; absUrl(…) returns empty string for relative links",
      "tags": [
        "branch-true",
        "overload:String,String",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02_parse_S_emptyBase empty baseUri",
        "  GIVEN",
        "    String html = \"<img src=\\\"img.png\\\">\"; String baseUri=\"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"img\").first().absUrl(\"src\").equals(\"\");"
      ]
    },
    {
      "id": "TC03_parse_S",
      "description": "parse(html) delegates to parse(html,\"\")",
      "path": "B0→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document same as parse(html,\"\")",
      "tags": [
        "overload:String",
        "delegation"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_parse_S empty-baseUri-delegation",
        "  GIVEN",
        "    String html = \"<p>test</p>\";",
        "  WHEN",
        "    Document doc1 = Jsoup.parse(html); Document doc2 = Jsoup.parse(html,\"\");",
        "  THEN",
        "    assert doc1.outerHtml().equals(doc2.outerHtml());"
      ]
    },
