{
  "scenarios": [
    {
      "id": "TC20",
      "description": "parse(Path, charsetName, baseUri) reads file via Path overload and resolves relative links against provided baseUri",
      "path": "B0→BXX→BYY→BZZ→Bret",
      "precondition": "Path to temporary HTML file exists with content '<a href=\"q.html\">x</a>'",
      "expectedResult": "Document with one <a> element whose absUrl('href') equals baseUri + 'q.html'",
      "tags": [
        "positive",
        "overload",
        "Path"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse Path with charset and baseUri",
        "  GIVEN",
        "    Path p = temp html file with '<a href=\"q.html\">x</a>';",
        "    String cs = 'UTF-8';",
        "    String base = 'http://site.com/dir/';",
        "  WHEN",
        "    Document doc = Jsoup.parse(p, cs, base);",
        "  THEN",
        "    assert doc.select('a').first().absUrl('href').equals('http://site.com/dir/q.html');"
      ]
    },
    {
      "id": "TC21",
      "description": "parse(Path, charsetName, baseUri) throws IOException when Path does not exist",
      "path": "B0→BXX→Berr",
      "precondition": "Path to non-existent file",
      "expectedResult": "IOException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload",
        "Path"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 parse non-existent Path throws",
        "  GIVEN",
        "    Path p = Paths.get('no_such_file.html');",
        "    String cs = 'UTF-8';",
        "    String base = 'u';",
        "  WHEN",
        "    call Jsoup.parse(p, cs, base);",
        "  THEN",
        "    throws IOException;"
      ]
    },
    {
      "id": "TC22",
      "description": "parse(URL, timeout) throws SocketTimeoutException if server delays beyond timeout",
      "path": "B0→B1→B2(timeout)→Berr",
      "precondition": "MockWebServer enqueues delayed response (> timeoutMillis)",
      "expectedResult": "java.net.SocketTimeoutException is thrown",
      "tags": [
        "negative",
        "exception",
        "timeout",
        "URL"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 parse URL timeout exception",
        "  GIVEN",
        "    MockWebServer server = new MockWebServer();",
        "    server.enqueue(new MockResponse().setBody('<p>').setBodyDelay(2, TimeUnit.SECONDS));",
        "    server.start();",
        "    URL url = server.url('/').url();",
        "    int timeout = 500; // ms",
        "  WHEN",
        "    call Jsoup.parse(url, timeout);",
        "  THEN",
        "    throws SocketTimeoutException;"
      ]
    },
