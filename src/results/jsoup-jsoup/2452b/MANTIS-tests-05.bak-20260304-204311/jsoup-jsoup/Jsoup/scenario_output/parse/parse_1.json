      "id": "TC13",
      "description": "parse(File file, String charsetName) loads file with explicit charset and uses file path as baseUri",
      "path": "B0â†’B2â†’B8â†’B9",
      "precondition": "temp HTML file exists with UTF-8 content",
      "expectedResult": "Document contains file content and baseUri equals file absolute path",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse file charset overload",
        "  GIVEN",
        "    Path p = Files.createTempFile(\"jsoup\", \".html\");",
        "    Files.write(p, \"<span>ABC</span>\".getBytes(StandardCharsets.UTF_8));",
        "    File file = p.toFile();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, \"UTF-8\");",
        "  THEN",
        "    assertEquals(\"ABC\", doc.select(\"span\").text());",
        "    assertEquals(file.getAbsolutePath(), doc.baseUri());",
        "    Files.deleteIfExists(p);",
        "END"
      ]
    },
