      "description": "parse(InputStream in, String charsetName, String baseUri) with valid stream returns Document",
      "path": "B0→B18→B19→B20",
      "precondition": "none; uses ByteArrayInputStream with UTF-8 bytes of '<span>XYZ</span>'",
      "expectedResult": "return Document whose span text equals 'XYZ' and baseUri equals 'http://u'",
      "tags": [
        "overload:InputStream,String,String",
        "loop-0",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse(InputStream,String,String) valid-stream",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<span>XYZ</span>\".getBytes(StandardCharsets.UTF_8));",
        "    String charsetName = \"UTF-8\";",
        "    String baseUri = \"http://u\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charsetName, baseUri);",
        "  THEN",
        "    assert doc.select(\"span\").text().equals(\"XYZ\");",
        "    assert doc.baseUri().equals(\"http://u\");",
        "END"
