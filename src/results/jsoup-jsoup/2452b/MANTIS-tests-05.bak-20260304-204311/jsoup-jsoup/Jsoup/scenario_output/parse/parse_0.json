{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(String html, String baseUri) with valid HTML and non-empty baseUri returns parsed Document",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "return Document with html containing <p>Test</p> and baseUri set to 'http://example.com'",
      "tags": [
        "overload:String,String",
        "branch-normal",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse(String,String) valid-input",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"p\").text().equals(\"Test\");",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "END"
      ]
    },
    {
