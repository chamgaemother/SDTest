        "overload:URL,int",
        "loop-0",
        "positive",
        "stubbed-connection"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 parse(URL,int) http-get-success",
        "  GIVEN",
        "    URL url = new URL(\"http://example.com\");",
        "    int timeoutMillis = 1000;",
        "    // Stub: HttpConnection.connect(url).timeout(timeoutMillis).get() returns Document with <div>OK</div>",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeoutMillis);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>OK</div>\");",
        "END"
      ]
