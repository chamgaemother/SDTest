    {
      "id": "TC06",
      "description": "parse(File file, String charsetName, String baseUri) with non-gzipped file returns parsed Document",
      "path": "B0→B10→B11→B12",
      "precondition": "none; uses real file on disk",
      "expectedResult": "return Document containing <h1>Heading</h1> and baseUri equals provided baseUri",
      "tags": [
        "overload:File,String,String",
        "positive",
        "real-file"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 parse(File,String,String) valid-file",
        "  GIVEN",
        "    File file = tempFile containing \"<h1>Heading</h1>\";",
        "    String charsetName = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charsetName, baseUri);",
        "  THEN",
        "    assert doc.select(\"h1\").text().equals(\"Heading\");",
        "    assert doc.baseUri().equals(\"http://base/\");",
        "END"
      ]
    },
