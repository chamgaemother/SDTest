{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) with non-empty html and non-empty baseUri returns Document with correct body text",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.body().text() == \"Hello World\"",
      "tags": [
        "branch-normal",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello World</p>\"; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().text().equals(\"Hello World\");",
        "END"
      ]
    },
