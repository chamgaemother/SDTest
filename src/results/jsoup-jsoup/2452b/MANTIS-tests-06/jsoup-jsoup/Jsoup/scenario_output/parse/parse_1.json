{
  "scenarios": [
    {
      "id": "TC09",
      "description": "parse(File, String) with null charsetName uses BOM/meta or defaults to UTF-8",
      "path": "B0→B1→B4→B5",
      "precondition": "existing temp HTML file with UTF-8 BOM-less content",
      "expectedResult": "body.html()==\"<h1>Title</h1>\"",
      "tags": [
        "positive",
        "overload",
        "file",
        "default-charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 parse file with null charset",
        "  GIVEN",
        "    File file = createTempFile(\"<h1>Title</h1>\");",
        "    String charset = null;",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset);",
        "  THEN",
        "    assert doc.body().html().equals(\"<h1>Title</h1>\");"
      ]
    },
    {
      "id": "TC10",
      "description": "parse(File, String, String, Parser) with custom Parser.xmlParser() applied",
      "path": "B0→B2→B6→B7",
      "precondition": "existing temp XML file with root element",
      "expectedResult": "doc.select(\"root\").text()==\"value\"",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser",
        "xml"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse file with custom xml parser",
        "  GIVEN",
        "    File file = createTempFile(\"<root>value</root>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"unused\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"root\").text().equals(\"value\");"
      ]
    },
    {
