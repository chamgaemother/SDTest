{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, charsetName) uses file path as baseUri when charsetName non-null",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "temporary HTML file exists with content '<p>foo</p>' and charset 'UTF-8'",
      "expectedResult": "Document.body().html() == '<p>foo</p>' and doc.baseUri() equals file.getAbsolutePath()",
      "tags": [
        "positive",
        "overload",
        "file",
        "charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse file two-arg overload",
        "  GIVEN",
        "    File f = createTempFile(\"<p>foo</p>\");",
        "    String charset = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, charset);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>foo</p>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "END"
      ]
    },
