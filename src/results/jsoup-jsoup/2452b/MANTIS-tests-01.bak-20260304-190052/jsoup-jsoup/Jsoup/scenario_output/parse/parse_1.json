      "id": "TC19",
      "description": "parseBodyFragment(String, String) resolves relative links when baseUri non-empty",
      "path": "B0→B1→B2→B3",
      "precondition": "bodyHtml '<a href=\"r.html\">x</a>' and baseUri 'http://u/'",
      "expectedResult": "doc.body().selectFirst('a').attr('abs:href') == 'http://u/r.html'",
      "tags": [
        "positive",
        "overload",
        "fragment",
        "relative"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"r.html\\\">x</a>\";",
        "    String base = \"http://u/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, base);",
        "  THEN",
        "    assert doc.body().selectFirst(\"a\").attr(\"abs:href\").equals(\"http://u/r.html\");",
        "END"
      ]
    },
