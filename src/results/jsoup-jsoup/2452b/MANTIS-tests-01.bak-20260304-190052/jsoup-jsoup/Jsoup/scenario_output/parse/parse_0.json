      "expectedResult": "throws IOException",
      "tags": [
        "overload:File,String,String",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parse missing-file",
        "  GIVEN",
        "    File file = new File(\"nonexistent.html\");",
        "    String charset = \"UTF-8\"; String baseUri = \"http://x/\";",
        "  WHEN",
        "    call Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    throws IOException;"
      ]
    },
    {
      "id": "TC08",
      "description": "parse(InputStream, charsetName, baseUri) returns Document and closes stream",
      "path": "B0→B13→B14",
      "precondition": "Use ByteArrayInputStream with HTML bytes; verify stream closed by catching IOException on read after parse",
      "expectedResult": "return value is Document with body.html() and InputStream is closed",
      "tags": [
        "overload:InputStream,String,String",
        "positive",
        "loop-0"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parse InputStream",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<p>hi</p>\".getBytes());",
        "    String charset = \"UTF-8\"; String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>hi</p>\");"
      ]
    },
    {
