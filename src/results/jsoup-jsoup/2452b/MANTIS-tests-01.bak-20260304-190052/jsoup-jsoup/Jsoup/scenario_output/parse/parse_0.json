{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(html, baseUri) throws NullPointerException when html is null",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "throws NullPointerException; no document returned",
      "tags": [
        "overload:String,String",
        "exception",
        "branch-true(html==null)"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse null-html",
        "  GIVEN",
        "    String html = null; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(html, baseUri) returns empty Document when html is empty string and baseUri is empty",
      "path": "B0→B1→B3→B4",
      "precondition": "none",
      "expectedResult": "return value is a Document with no child elements and baseUri \"\"",
      "tags": [
        "overload:String,String",
        "boundary",
        "branch-false(html==null)",
        "branch-true(baseUri.isEmpty)"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse empty-html-empty-base",
        "  GIVEN",
        "    String html = \"\"; String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().children().isEmpty();",
        "    assert doc.baseUri().equals(\"\");"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(html, baseUri) correctly resolves relative URLs when baseUri non-empty",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "return value is a Document whose <a> href is \"http://example.com/path/page.html\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-false(html==null)",
        "branch-false(baseUri.isEmpty)"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse resolve-relative",
        "  GIVEN",
        "    String html = \"<a href=\\\"page.html\\\">link</a>\";",
        "    String baseUri = \"http://example.com/path/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    Element a = doc.selectFirst(\"a\");",
        "    assert a.attr(\"abs:href\").equals(\"http://example.com/path/page.html\");"
      ]
    },
    {
      "id": "TC04",
      "description": "parse(html) delegates to parse(html,\"\") and returns Document with body fragment",
      "path": "B0→B6→B4",
      "precondition": "none",
      "expectedResult": "return value is a Document whose body.html() equals \"<p>test</p>\"",
      "tags": [
        "overload:String",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 parse(html) no-base",
        "  GIVEN",
        "    String html = \"<p>test</p>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>test</p>\");"
      ]
    },
    {
      "id": "TC05",
      "description": "parse(html, parser) uses custom parser to parse xml fragment",
      "path": "B0→B7→B8",
      "precondition": "none",
      "expectedResult": "return value is a Document parsed by custom Parser",
      "tags": [
        "overload:String,Parser",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 parse with-Parser",
        "  GIVEN",
        "    String html = \"<root><child/></root>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.select(\"child\").size() == 1;"
      ]
    },
    {
      "id": "TC06",
      "description": "parse(html, baseUri, parser) uses custom parser and resolves baseUri",
      "path": "B0→B9→B10",
      "precondition": "none",
      "expectedResult": "return value is a Document parsed by custom Parser with baseUri",
      "tags": [
        "overload:String,String,Parser",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse html-base-parser",
        "  GIVEN",
        "    String html = \"<img src='img.png'>\";",
        "    String baseUri = \"http://host/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    Element img = doc.selectFirst(\"img\");",
        "    assert img.attr(\"abs:src\").equals(\"http://host/img.png\");"
      ]
    },
    {
