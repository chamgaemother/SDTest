    {
      "id": "TC24",
      "description": "parse(File, charsetName, baseUri, parser) successfully parses with xmlParser",
      "path": "B0→B4→B?→B?→return",
      "precondition": "temp file exists with XML content",
      "expectedResult": "Document contains xml elements and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC24 parse File with charset, baseUri, xml parser",
        "  GIVEN",
        "    File file = createTempFile(\"tc24\", \".xml\");",
        "    write file content \"<root><child/></root>\" in UTF-8;",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://host/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.selectFirst(\"child\") != null;",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC25",
      "description": "parse(Path, charsetName, baseUri, parser) successfully parses with htmlParser",
      "path": "B0→B5→B?→B?→return",
      "precondition": "temp Path exists with HTML content",
      "expectedResult": "Document contains html element and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC25 parse Path with charset, baseUri, html parser",
        "  GIVEN",
        "    Path p = createTempFile(\"tc25\", \".html\");",
        "    write p content \"<p>Hello</p>\" in UTF-8;",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"https://x/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(p, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
