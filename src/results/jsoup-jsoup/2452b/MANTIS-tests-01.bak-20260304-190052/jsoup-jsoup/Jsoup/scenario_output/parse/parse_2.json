      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC26 parse InputStream with null charset",
        "  GIVEN",
        "    byte[] data = \"<span>f</span>\".getBytes(\"UTF-8\");",
        "    ByteArrayInputStream in = new ByteArrayInputStream(data);",
        "    String charset = null;",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>f</span>\");",
        "    assert in.read() == -1;",
        "END"
      ]
