{
  "scenarios": [
    {
      "id": "TC07",
      "description": "parse(File, String charsetName, String baseUri) reads UTF-8 file and resolves relative link",
      "path": "B0→B11→B12",
      "precondition": "temporary HTML file contains '<a href=\"/x\">X</a>' in UTF-8",
      "expectedResult": "Document with absUrl('href') == 'http://base/x'",
      "tags": [
        "positive",
        "file",
        "charset",
        "baseUri"
      ],
      "priority": "P1",
      "environment": "Java 11",
      "pseudocode": [
        "TEST TC07 parse file with explicit charset and baseUri",
        "  GIVEN",
        "    File file = createTempFile(\"<a href=\\\"/x\\\">X</a>\", UTF-8);",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assertEquals(\"http://base/x\", doc.select(\"a\").first().absUrl(\"href\"));",
        "END"
      ]
    },
    {
