{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File) no-arg overload reads UTF-8 file and sets baseUri to file path",
      "path": "B0→B1→B2→B3",
      "precondition": "temp HTML file exists with content",
      "expectedResult": "Document contains HTML and baseUri equals file absolute path",
      "tags": [
        "positive",
        "overload",
        "file",
        "no-arg"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse no-arg File overload",
        "  GIVEN",
        "    File f = createTempFile(\"x.html\", \"<h2>Hello</h2>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(f);",
        "  THEN",
        "    assert doc.html().contains(\"<h2>Hello</h2>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File,charset,baseUri,Parser) uses custom parser and charset",
      "path": "B0→B1→B4→B5",
      "precondition": "file with XML-style content exists",
      "expectedResult": "Parser.parseInput called and document reflects XML parser behavior",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse File with charset, baseUri and parser",
        "  GIVEN",
        "    File f = createTempFile(\"y.html\",\"<tag>XML</tag>\");",
        "    String cs = \"UTF-8\";",
        "    String base = \"http://xml/\";",
        "    Parser p = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, cs, base, p);",
        "  THEN",
        "    assert doc.html().contains(\"<tag>XML</tag>\");",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
