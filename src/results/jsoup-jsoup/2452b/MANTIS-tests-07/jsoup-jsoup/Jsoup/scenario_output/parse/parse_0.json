{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri returns Document with correct baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.getBaseUri() equals \"http://example.com/\" and Document.body().html() contains \"<p>Hello</p>\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-normal"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.getBaseUri().equals(\"http://example.com/\");",
        "    assert doc.body().html().contains(\"<p>Hello</p>\");"
      ]
    },
    {
