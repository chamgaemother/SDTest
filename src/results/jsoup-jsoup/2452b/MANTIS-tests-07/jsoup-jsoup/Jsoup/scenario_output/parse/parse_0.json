        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"https://site/rel\");"
