      "id": "TC11",
      "description": "parse(File, null charsetName, baseUri) loads HTML file and uses file path as baseUri",
      "path": "B0â†’B1â†’DataUtil.loadâ†’return",
      "precondition": "File exists with UTF-8 encoded HTML '<p>File</p>'",
      "expectedResult": "Document.body().html() contains '<p>File</p>' and doc.getBaseUri() equals file.getAbsolutePath()",
      "tags": [
        "positive",
        "file-overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse file with null charset and explicit baseUri",
        "  GIVEN",
        "    File file = tempFileWithContent(\"<p>File</p>\");",
        "    String charset = null;",
        "    String baseUri = file.getAbsolutePath();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>File</p>\");",
        "    assert doc.getBaseUri().equals(baseUri);",
        "END"
      ]
    },
