      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC29 parse(InputStream, charset, baseUri)",
        "  GIVEN",
        "    TrackCloseStream in = wrapStream(\"<h3>S</h3>\");",
        "    String charset = null;",
        "    String baseUri = \"http://in/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<h3>S</h3>\");",
        "    assert doc.getBaseUri().equals(baseUri);",
        "    assert in.closed == true;",
        "END"
      ]
