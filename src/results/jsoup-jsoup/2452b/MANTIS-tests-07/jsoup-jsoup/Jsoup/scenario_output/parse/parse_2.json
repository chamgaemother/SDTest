{
  "scenarios": [
    {
      "id": "TC21",
      "description": "parse(File, null charsetName, explicit baseUri) loads HTML and sets baseUri",
      "path": "B0→B1→B4→B5",
      "precondition": "File exists with UTF-8 content",
      "expectedResult": "Document body contains file HTML and baseUri equals provided baseUri",
      "tags": [
        "positive",
        "file-overload",
        "branch-B1"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 parse(File, null, baseUri)",
        "  GIVEN",
        "    File file = tempFile(\"<p>F</p>\");",
        "    String charset = null;",
        "    String baseUri = \"http://file/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>F</p>\");",
        "    assert doc.getBaseUri().equals(baseUri);",
        "END"
      ]
    },
