    {
      "id": "TC24",
      "description": "parse(File, charsetName, baseUri, parser) delegates to custom parser override",
      "path": "B0→B3",
      "precondition": "File exists; stub Parser overrides parseInput(InputStream, String)",
      "expectedResult": "Document is from stub parser and baseUri equals provided",
      "tags": [
        "positive",
        "file-overload",
        "branch-B3",
        "custom-parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC24 parse(File, charset, baseUri, parser)",
        "  GIVEN",
        "    File file = tempFile(\"<span>S</span>\");",
        "    Parser stub = new Parser() {",
        "      override parseInput(InputStream in, String uri) {",
        "        return Document.createShell(uri);",
        "      }",
        "    };",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://stub/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, stub);",
        "  THEN",
        "    assert doc.getBaseUri().equals(baseUri);",
        "    assert doc.body().html().equals(\"\");",
        "END"
      ]
    },
