    {
      "id": "TC17",
      "description": "clean(bodyHtml, baseUri, safelist) substitutes DummyUri when baseUri empty and preserveRelativeLinks true",
      "path": "B0→B1→B2→B4",
      "precondition": "none",
      "expectedResult": "cleaned HTML preserves relative <a href>",
      "tags": [
        "positive",
        "clean-overload",
        "branch"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 clean with preserveRelativeLinks and empty baseUri",
        "  GIVEN",
        "    String src = \"<a href=foo>Link</a>\";",
        "    Safelist sl = Safelist.basic();",
        "    sl.preserveRelativeLinks(true);",
        "  WHEN",
        "    String out = Jsoup.clean(src, \"\", sl);",
        "  THEN",
        "    assert out.contains(\"href=foo\");"
      ]
    }
  ]
