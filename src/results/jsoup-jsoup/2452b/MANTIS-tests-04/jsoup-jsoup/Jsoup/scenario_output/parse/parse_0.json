      "expectedResult": "returned Document has empty body html string and baseUri equals 'http://empty.test'",
      "tags": [
        "overload:String,String",
        "boundary-emptyHtml",
        "branch-emptyHtml",
        "branch-nonEmptyBaseUri"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse(emptyHtml) returns empty",
        "  GIVEN",
        "    String html = \"\";",
        "    String baseUri = \"http://empty.test\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");",
        "    assert doc.baseUri().equals(\"http://empty.test\");",
        "END"
      ]
    },
    {
      "id": "TC03_O2",
      "description": "parse(String, String, Parser) with custom parser returning uppercase text",
      "path": "B0→B2→B6→B7",
      "precondition": "SimpleParser stub returns Document with body html in uppercase of input html",
      "expectedResult": "returned Document.body().html() equals 'ABC' and baseUri equals 'uri'",
      "tags": [
        "overload:String,String,Parser",
        "stub-parser",
        "branch-customParser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse with custom Parser stub",
        "  GIVEN",
        "    String html = \"abc\";",
        "    String baseUri = \"uri\";",
        "    Parser parser = new Parser(){ public Document parseInput(String h, String b){ Document d=new Document(b); d.body().appendText(h.toUpperCase()); return d;} };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"ABC\");",
        "    assert doc.baseUri().equals(\"uri\");",
        "END"
      ]
    },
    {
