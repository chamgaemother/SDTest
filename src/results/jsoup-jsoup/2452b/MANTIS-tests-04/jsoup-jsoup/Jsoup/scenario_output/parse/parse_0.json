      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parse(File,String) null-charset default",
        "  GIVEN",
        "    File temp = createTempFile(\"test.html\", \"<h1>T</h1>\");",
        "    String charset = null;",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, charset);",
        "  THEN",
        "    assert doc.body().html().equals(\"<h1>T</h1>\");",
