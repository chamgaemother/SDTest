{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String, String) with non-empty HTML and non-empty baseUri returns parsed Document",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document contains a body element with inner HTML equal to '<p>Hello</p>' and baseUri set to 'http://example.com'",
      "tags": [
        "overload:String,String",
        "normal",
        "branch-nonEmptyHtml",
        "branch-nonEmptyBaseUri"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse(String,String) normal-case",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\");",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "END"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parse(String, String) with empty HTML returns empty body Document",
      "path": "B0→B1→B4→B5",
