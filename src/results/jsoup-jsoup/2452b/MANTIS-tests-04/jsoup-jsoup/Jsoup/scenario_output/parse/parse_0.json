    {
      "id": "TC07_O6",
      "description": "parse(URL, int) with valid HTTP URL returns Document via GET",
      "path": "B0→B10→B11→B12",
      "precondition": "Mock HttpConnection.connect(URL) to return Connection stub; stub.get() returns Document with title 'OK'",
      "expectedResult": "returned Document.title() equals 'OK'",
      "tags": [
        "overload:URL,int",
        "mock-minimal",
        "branch-validUrl",
        "branch-timeoutSet"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parse(URL,int) valid-http",
        "  GIVEN",
        "    URL url = new URL(\"http://valid.test\");",
        "    int timeout = 5000;",
        "    Connection connStub = new HttpConnection(); connStub.timeout(timeout); /* override get */",
        "    // Mock HttpConnection.connect to return connStub",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.title().equals(\"OK\");",
        "END"
      ]
    },
    {
      "id": "TC08_O5",
      "description": "parse(File, String) with null charsetName uses BOM/meta or default UTF-8",
      "path": "B0→B8→B13→B14",
      "precondition": "File pointing to real temp file containing UTF-8 content '<h1>T</h1>'",
