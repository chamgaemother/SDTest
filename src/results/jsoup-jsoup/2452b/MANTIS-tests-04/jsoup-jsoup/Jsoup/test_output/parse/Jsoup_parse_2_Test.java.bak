import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.jsoup.Jsoup;
import org.jsoup.nodes.Document;
import org.jsoup.parser.Parser;

import java.io.ByteArrayInputStream;
import java.io.File;
import java.io.IOException;
import java.io.InputStream;
import java.net.InetSocketAddress;
import java.net.URL;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;

import com.sun.net.httpserver.HttpServer;

import static org.junit.jupiter.api.Assertions.*;

public class Jsoup_parse_Test {

    @Test
    @DisplayName("TC18: parse(URL, timeout) with valid HTTP URL returns parsed Document")
    public void test_TC18() throws Exception {
        // Inline HTTP server to simulate remote HTML serving (branch B0→B8→B10→B11)
        HttpServer server = HttpServer.create(new InetSocketAddress(0), 0);
        String html = "<html><body><p>Hello</p></body></html>";
        server.createContext("/", exchange -> {
            byte[] resp = html.getBytes(StandardCharsets.UTF_8);
            exchange.sendResponseHeaders(200, resp.length);
            exchange.getResponseBody().write(resp);
            exchange.close();
        });
        server.start();
        try {
            URL url = new URL("http://localhost:" + server.getAddress().getPort() + "/");
            int timeout = 2000;
            Document doc = Jsoup.parse(url, timeout);
            // Expect the parser to fetch and parse our served HTML
            assertTrue(doc.body().html().contains("<p>Hello</p>"),
                "Body HTML should contain the served fragment");
            assertEquals(url.toString(), doc.baseUri(),
                "Base URI should match the requested URL");
        } finally {
            server.stop(0);
        }
    }

    @Test
    @DisplayName("TC19: parse(InputStream, charsetName, baseUri) without parser returns Document")
    public void test_TC19() throws Exception {
        // Using ByteArrayInputStream to cover B0→B1→B3→B6 path
        String inputHtml = "<li>Item</li>";
        InputStream in = new ByteArrayInputStream(inputHtml.getBytes(StandardCharsets.UTF_8));
        String cs = "UTF-8";
        String base = "http://stream.test";
        Document doc = Jsoup.parse(in, cs, base);
        // Should preserve fragment and baseUri exactly
        assertEquals("<li>Item</li>", doc.body().html(),
            "Parsed body should match the input stream content");
        assertEquals(base, doc.baseUri(),
            "Base URI should be preserved from parameter");
    }

    @Test
    @DisplayName("TC20: parse(Path, charsetName, baseUri, parser) with XML parser returns fragment")
    public void test_TC20() throws Exception {
        // Create temp XML file and use xmlParser() to cover B0→B1→B2→B3→B5
        Path path = Files.createTempFile("t20", ".xml");
        try {
            Files.write(path, "<node/>".getBytes(StandardCharsets.UTF_8));
            String cs = "UTF-8";
            String base = "http://pathparser.test";
            Parser xmlParser = Parser.xmlParser();
            Document doc = Jsoup.parse(path, cs, base, xmlParser);
            // xmlParser should preserve self-closing node in body
            assertTrue(doc.body().html().contains("<node/>"),
                "Body HTML should contain the XML fragment");
            assertEquals(base, doc.baseUri(),
                "Base URI should match the provided base URI");
        } finally {
            Files.deleteIfExists(path);
        }
    }

    @Test
    @DisplayName("TC21: parse(File, charsetName, baseUri) with invalid charset throws IOException")
    public void test_TC21() throws Exception {
        // Use a real temp file and invalid charset to trigger IOException (B0→B1→B2→B4→B7)
        File temp = File.createTempFile("t21", ".html");
        try {
            Files.write(temp.toPath(), "<p>X</p>".getBytes(StandardCharsets.UTF_8));
            String badCs = "NO_SUCH_CHARSET";
            String base = "http://badcs.test";
            assertThrows(IOException.class, () -> Jsoup.parse(temp, badCs, base),
                "Invalid charset name should cause IOException");
        } finally {
            temp.delete();
        }
    }

    @Test
    @DisplayName("TC22: parse(Path, charsetName) with invalid charset throws IOException")
    public void test_TC22() throws Exception {
        // Use temp Path and invalid charset to trigger IOException (B0→B1→B2→B4→B7)
        Path path = Files.createTempFile("t22", ".html");
        try {
            Files.write(path, "<div>Y</div>".getBytes(StandardCharsets.UTF_8));
            String badCs = "INVALID_CHARSET";
            assertThrows(IOException.class, () -> Jsoup.parse(path, badCs),
                "Providing invalid charset should result in IOException");
        } finally {
            Files.deleteIfExists(path);
        }
    }
}