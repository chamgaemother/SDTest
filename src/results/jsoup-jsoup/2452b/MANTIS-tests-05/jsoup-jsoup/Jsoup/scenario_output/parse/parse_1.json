    {
      "id": "TC18",
      "description": "parse(URL, timeoutMillis) returns Document when connection and get succeed",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "mock HttpConnection.connect to return Connection that yields a Document",
      "expectedResult": "return document from connection.get()",
      "tags": [
        "positive",
        "overload",
        "url",
        "mock"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 parse URL success",
        "  GIVEN",
        "    URL url = new URL(\"http://ok.example.com\");",
        "    int timeout = 500;",
        "    MockedStatic<HttpConnection> ms = mockStatic(HttpConnection.class);",
        "    Connection con = mock(Connection.class);",
        "    Document expected = Parser.parse(\"<p>OK</p>\", url.toString());",
        "    ms.when(() -> HttpConnection.connect(url)).thenReturn(con);",
        "    when(con.timeout(timeout)).thenReturn(con);",
        "    when(con.get()).thenReturn(expected);",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>OK</p>\");",
        "    ms.close();",
        "END"
      ]
    },
    {
      "id": "TC19",
      "description": "parse(URL, timeoutMillis) throws HttpStatusException on non-OK status",
      "path": "B0→B1→B2→B3→B4→exception",
      "precondition": "mock HttpConnection.connect to throw HttpStatusException",
      "expectedResult": "HttpStatusException is thrown",
      "tags": [
        "negative",
        "overload",
        "url",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC19 parse URL HttpStatusException",
        "  GIVEN",
        "    URL url = new URL(\"http://error.example.com\");",
        "    int timeout = 200;",
        "    MockedStatic<HttpConnection> ms = mockStatic(HttpConnection.class);",
        "    Connection con = mock(Connection.class);",
        "    ms.when(() -> HttpConnection.connect(url)).thenReturn(con);",
        "    when(con.timeout(timeout)).thenReturn(con);",
        "    when(con.get()).thenThrow(new org.jsoup.HttpStatusException(\"404 not found\", 404, url.toString()));",
        "  WHEN",
        "    call Jsoup.parse(url, timeout);",
        "  THEN",
        "    throws org.jsoup.HttpStatusException;",
        "    ms.close();",
        "END"
      ]
    },
