{
  "scenarios": [
    {
      "id": "TC12",
      "description": "parse(File, charsetName, baseUri, Parser) returns Document using provided parser",
      "path": "B0→B1→B2→B3",
      "precondition": "temp HTML file exists",
      "expectedResult": "return document parsed by XML parser with correct baseUri",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse file with parser overload",
        "  GIVEN",
        "    File file = createTempHtmlFile(\"<tag>XML</tag>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<tag>XML</tag>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
