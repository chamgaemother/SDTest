      "description": "parseBodyFragment(String, String) sets non-empty baseUri and parses fragment body",
      "path": "B0→B7→B17→return",
      "precondition": "none",
      "expectedResult": "Document body contains fragment and baseUri used for resolution",
      "tags": [
        "positive",
        "fragment",
        "baseUri"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String fragment = \"<img src='a.png'>\";",
        "    String baseUri = \"http://img/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<img src=\\\"http://img/a.png\\\">\", true);",
        "END"
      ]
    },
