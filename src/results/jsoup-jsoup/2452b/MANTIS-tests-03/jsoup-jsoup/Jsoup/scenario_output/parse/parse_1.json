{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, charsetName, baseUri, Parser) uses provided Parser overload path",
      "path": "B0→B2→B14→return",
      "precondition": "existing HTML file available",
      "expectedResult": "Document returned with correct baseUri and parsed content",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse file with parser overload",
        "  GIVEN",
        "    File file = createTempFile(\"<u>text</u>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.body().html().contains(\"<u>text</u>\");",
        "END"
      ]
    },
    {
