      "tags": [
        "overload:File,String,String",
        "positive",
        "io"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05_O2 parse file with null charset",
        "  GIVEN",
        "    File tempFile = writeTempFile(\"<h1>Hdr</h1>\", UTF-8);",
        "    String charsetName = null;",
        "    String baseUri = tempFile.getAbsolutePath();",
        "  WHEN",
        "    Document doc = Jsoup.parse(tempFile, charsetName, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.body().html().contains(\"<h1>Hdr</h1>\");"
      ]
    },
