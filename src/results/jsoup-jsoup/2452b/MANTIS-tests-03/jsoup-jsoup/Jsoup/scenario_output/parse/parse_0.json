{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) returns a Document with correct baseUri when html is simple and baseUri is non-empty",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "return Document with .baseUri() == \"https://example.com/\" and Document.html() contains \"<p>Hello</p>\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-delegation"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse with html and baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"https://example.com/\");",
        "    assert doc.html().contains(\"<p>Hello</p>\");"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parse(String html) returns a Document with empty baseUri when no baseUri provided",
      "path": "B0→B1→B5",
      "precondition": "none",
      "expectedResult": "return Document with .baseUri() == \"\" and Document.body().html() contains \"<div>Test</div>\"",
      "tags": [
        "overload:String",
        "boundary",
        "empty-baseUri"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02_O1 parse with html only",
        "  GIVEN",
        "    String html = \"<div>Test</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.body().html().contains(\"<div>Test</div>\");"
      ]
    },
    {
