    {
      "id": "TC04_O1",
      "description": "parse(String html, String baseUri, Parser parser) uses provided parser and baseUri",
      "path": "B0→B1→B7",
      "precondition": "none",
      "expectedResult": "return Document with .baseUri() == \"http://a/\" and body html contains \"<a href=\\\"b\\\">c</a>\"",
      "tags": [
        "overload:String,String,Parser",
        "positive",
        "delegation"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04_O1 parse with html, baseUri, and parser",
        "  GIVEN",
        "    String html = \"<a href=\\\"b\\\">c</a>\";",
        "    String baseUri = \"http://a/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://a/\");",
        "    assert doc.body().html().contains(\"<a href=\\\"b\\\">c</a>\");"
      ]
    },
    {
