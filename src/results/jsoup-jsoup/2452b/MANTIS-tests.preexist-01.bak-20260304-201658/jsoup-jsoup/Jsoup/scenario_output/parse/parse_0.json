    {
      "id": "TC03_O3",
      "description": "parse(html, baseUri, parser) delegates to custom Parser.parseInput",
      "path": "B0→B1→B3",
      "precondition": "Custom Parser stub returns Document with marker element; stub ensures parseInput(html, baseUri) invoked",
      "expectedResult": "returned Document contains element with id 'stub-parsed'",
      "tags": [
        "overload:String,String,Parser",
        "branch-custom-parser",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03 parse(html,baseUri,Parser)",
        "  GIVEN",
        "    String html = \"x\";",
        "    String baseUri = \"u\";",
        "    Parser stub = new Parser() { Document parseInput(String h,String u){ Document d = new Document(u); d.appendElement(\"div\").attr(\"id\",\"stub-parsed\"); return d;} };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stub);",
        "  THEN",
        "    assert doc.getElementById(\"stub-parsed\") != null;"
      ]
    },
