  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html) uses empty baseUri and returns a Document with html content",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.html() equals parsed HTML structure with provided html string",
      "tags": [
        "overload:String",
        "branch-default-baseUri",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse(String)",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\");"
      ]
    },
