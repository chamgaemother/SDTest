    {
      "id": "TC15",
      "description": "parse(InputStream,charset,baseUri,parser) delegates to custom Parser.parseInput and closes stream",
      "path": "B0â†’B1â†’B8â†’B9",
      "precondition": "InputStream over '<b>IS</b>' with trackable close",
      "expectedResult": "Document produced by stub parser and stream is closed",
      "tags": [
        "positive",
        "overload",
        "stream",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 parse InputStream with custom parser",
        "  GIVEN",
        "    class TrackInput extends ByteArrayInputStream {",
        "      boolean closed = false;",
        "      TrackInput(byte[]b){super(b);} ",
        "      @Override public void close() throws IOException { closed=true; super.close(); }",
        "    }",
        "    TrackInput in = new TrackInput('<b>IS</b>'.getBytes('UTF-8'));",
        "    String charset = 'UTF-8';",
        "    String baseUri = 'u';",
        "    Parser stub = new Parser() {",
        "      @Override Document parseInput(String html, String uri) {",
        "        assert html.contains('<b>IS</b>');",
        "        assert uri.equals(baseUri);",
        "        return new Document(uri).appendElement('b').text('ok');",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri, stub);",
        "  THEN",
        "    assertEquals('ok', doc.select('b').first().text());",
        "    assertTrue(in.closed);",
        "END"
      ]
    },
    {
      "id": "TC16",
      "description": "parseBodyFragment(String,baseUri) creates Document body fragment and resolves relative URLs",
      "path": "B0â†’B1â†’B2â†’B3",
      "precondition": "none",
      "expectedResult": "body.html contains fragment and absUrl resolves baseUri",
      "tags": [
        "positive",
        "fragment",
        "baseUri"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 parse body fragment with baseUri",
        "  GIVEN",
        "    String html = '<a href=\"p\">f</a>';",
        "    String baseUri = 'http://b/';",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assertEquals('f', doc.body().select('a').text());",
        "    assertEquals('http://b/p', doc.body().select('a').first().absUrl('href'));",
        "END"
      ]
    },
