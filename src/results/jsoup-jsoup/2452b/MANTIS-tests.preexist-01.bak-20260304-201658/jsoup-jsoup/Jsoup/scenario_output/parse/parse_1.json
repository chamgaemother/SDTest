{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File,charset,baseUri,parser) delegates to custom Parser.parseInput after DataUtil.load",
      "path": "B0â†’B1â†’B2â†’B3â†’B4",
      "precondition": "temp file with content \"<i>X</i>\" exists",
      "expectedResult": "returns Document produced by stub parser",
      "tags": [
        "positive",
        "overload",
        "parser",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse file with custom parser",
        "  GIVEN",
        "    // Arrange: create tempFile with '<i>X</i>'",
        "    File file = createTempFileWithContent('<i>X</i>');",
        "    String charset = 'UTF-8';",
        "    String baseUri = 'http://test/';",
        "    Parser stub = new Parser() {",
        "      @Override Document parseInput(String html, String uri) {",
        "        assert html.contains('<i>X</i>');",
        "        assert uri.equals(baseUri);",
        "        Document d = new Document(uri);",
        "        d.appendElement('i').text('parsed');",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, stub);",
        "  THEN",
        "    assertEquals('parsed', doc.select('i').first().text());",
        "END"
      ]
    },
