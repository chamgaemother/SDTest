{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html,baseUri) with simple HTML and non-empty baseUri returns Document with expected element",
      "path": "B0â†’B1â†’B4â†’B5",
      "precondition": "none",
      "expectedResult": "returned Document has tagName \"html\" and body contains a <p> element with text \"Hello\"",
      "tags": [
        "branch-true",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse(String,baseUri) basic HTML",
        "  GIVEN",
        "    String html = \"<html><body><p>Hello</p></body></html>\"; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.tagName().equals(\"html\"); assert doc.body().select(\"p\").text().equals(\"Hello\");"
      ]
    },
