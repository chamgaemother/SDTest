      "precondition": "URL pointing to non-routable IP",
      "expectedResult": "SocketTimeoutException is thrown",
      "tags": [
        "exception",
        "timeout",
        "network"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC20 parse(URL,timeout) timeout-exception",
        "  GIVEN",
        "    URL url = new URL(\"http://10.255.255.1/\");",
        "    int timeout = 1;",
        "  WHEN",
        "    call Jsoup.parse(url, timeout);",
        "  THEN",
