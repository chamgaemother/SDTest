    {
      "id": "TC17",
      "description": "clean(html,baseUri,safelist) with empty baseUri and preserveRelativeLinks true uses DummyUri branch",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "Safelist with preserveRelativeLinks=true",
      "expectedResult": "output contains relative link with dummy base resolved",
      "tags": [
        "positive",
        "branch",
        "clean",
        "dummyuri"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 clean empty-baseUri preserveRelativeLinks",
        "  GIVEN",
        "    String html = \"<a href=\\\"/x\\\">X</a>\";",
        "    Safelist sl = Safelist.basic();",
        "    sl.preserveRelativeLinks(true);",
        "  WHEN",
        "    String out = Jsoup.clean(html, \"\", sl);",
        "  THEN",
        "    assert out.contains(\"href=\\\"http://x\\\"\") or relative links are passed;",
        "END"
      ]
    },
    {
      "id": "TC18",
      "description": "clean(html,baseUri,safelist,outputSettings) applies outputSettings prettyPrint off",
      "path": "B0→B1→B2→B4→B6",
      "precondition": "OutputSettings with prettyPrint(false)",
      "expectedResult": "output has no line breaks or indentation",
      "tags": [
        "positive",
        "clean",
        "output"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 clean with outputSettings",
        "  GIVEN",
        "    String html = \"<div><p>One</p></div>\";",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String out = Jsoup.clean(html, \"http://b\", Safelist.relaxed(), os);",
        "  THEN",
        "    assert !out.contains(\"\\n\");",
        "END"
      ]
    },
    {
      "id": "TC19",
      "description": "isValid(html,safelist) returns false when tag not allowed",
      "path": "B0→B1→B2→Berror→Breturn",
      "precondition": "html with <script> tag and default safelist",
      "expectedResult": "isValid returns false",
      "tags": [
        "negative",
        "validation",
        "isValid"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC19 isValid rejects script tag",
        "  GIVEN",
        "    String html = \"<script>alert(1)</script>\";",
        "    Safelist sl = Safelist.basic();",
        "  WHEN",
        "    boolean valid = Jsoup.isValid(html, sl);",
        "  THEN",
        "    assert valid == false;",
        "END"
      ]
    },
