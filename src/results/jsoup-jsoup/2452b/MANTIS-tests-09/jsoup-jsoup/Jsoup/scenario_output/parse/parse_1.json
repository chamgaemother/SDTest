{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(File) with missing file throws IOException",
      "path": "B0→B1→B2→Berror",
      "precondition": "file does not exist",
      "expectedResult": "IOException is thrown",
      "tags": [
        "exception",
        "file",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 parse(File) non-existent-file",
        "  GIVEN",
        "    File file = new File(\"nonexistent.html\");",
        "  WHEN",
        "    call Jsoup.parse(file);",
        "  THEN",
        "    throws IOException;",
        "END"
      ]
    },
    {
      "id": "TC11",
      "description": "parse(File,charset,baseUri,parser) uses xmlParser to parse custom input",
      "path": "B0→B1→B3→B4→B5",
      "precondition": "temp file with XML content exists",
      "expectedResult": "Document contains parsed <tag/> element",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse(File,charset,baseUri,parser) xmlParser",
        "  GIVEN",
        "    File temp = createTempFile(\"x\", \".xml\");",
        "    write \"<root><tag/></root>\" to temp;",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, \"UTF-8\", \"http://base\", parser);",
        "  THEN",
        "    assert doc.select(\"tag\").size() == 1;",
        "END"
      ]
    },
    {
