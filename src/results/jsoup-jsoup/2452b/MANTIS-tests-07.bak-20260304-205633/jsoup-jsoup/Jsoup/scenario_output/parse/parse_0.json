    {
      "id": "TC10",
      "description": "parse(URL, timeout) with valid HTTP URL returns parsed Document after get()",
      "path": "B0→B1→B11→B12",
      "precondition": "Use stub HttpConnection.connect to return Connection always yielding Document with marker element",
      "expectedResult": "returned Document.select(\"marker\").first().text().equals(\"OK\")",
      "tags": [
        "overload:URL,int",
        "positive",
        "mock-lightweight"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse(url, timeout) uses connection.get()",
        "  GIVEN",
        "    // stub HttpConnection.connect for isolation",
        "    URL url = new URL(\"http://test\");",
        "    stub HttpConnection.connect(url) -> Connection c; c.timeout(500); c.get() returns Document with <marker>OK</marker>;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, 500);",
        "  THEN",
        "    assert doc.select(\"marker\").first().text().equals(\"OK\");",
        "END"
      ]
