        "overload:File,String,String",
        "positive",
        "io"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parse(file, charset, baseUri)",
        "  GIVEN",
        "    File f = tempFile(\"<div>OK</div>\", \"UTF-8\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, \"UTF-8\", \"http://b\");",
        "  THEN",
        "    assert doc.select(\"div\").first().text().equals(\"OK\");",
        "END"
      ]
