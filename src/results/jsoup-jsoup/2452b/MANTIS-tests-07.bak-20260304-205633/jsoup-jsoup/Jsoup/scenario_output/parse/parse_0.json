      ]
    },
    {
      "id": "TC04",
      "description": "parse(String, String, Parser) with XML parser parses tags case-sensitively",
      "path": "B0→B1→B2→B6",
      "precondition": "none",
      "expectedResult": "returned Document.select(\"foo\").size() == 1 && returned Document.select(\"FOO\").isEmpty()",
      "tags": [
        "overload:String,String,Parser",
        "positive",
        "branch-custom-parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 parse(html, baseUri, xmlParser) case-sensitive",
        "  GIVEN",
        "    String html = \"<foo>v</foo><FOO>u</FOO>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, \"http://x\", parser);",
        "  THEN",
        "    assert doc.select(\"foo\").size() == 1;",
        "    assert doc.select(\"FOO\").isEmpty();",
        "END"
      ]
    },
