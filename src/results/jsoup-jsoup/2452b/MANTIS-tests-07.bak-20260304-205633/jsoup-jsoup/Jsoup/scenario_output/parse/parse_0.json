{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(String, String) with non-empty HTML and baseUri returns Document with correct title and baseUri",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.title() == \"Test\" && returned Document.baseUri().equals(\"http://example.com\")",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-default",
        "boundary-nonempty"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse(html, baseUri) normal-case",
        "  GIVEN",
        "    String html = \"<html><head><title>Test</title></head><body></body></html>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, \"http://example.com\");",
        "  THEN",
        "    assert doc.title().equals(\"Test\");",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(String, String) with empty HTML returns empty Document body and baseUri preserved",
      "path": "B0→B1→B2→B4",
      "precondition": "none",
      "expectedResult": "returned Document.body().html().isEmpty() && returned Document.baseUri().equals(\"\")",
      "tags": [
        "overload:String,String",
        "boundary-empty",
        "branch-empty-html"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02 parse(empty html) returns empty body",
        "  GIVEN",
        "    String html = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, \"\");",
        "  THEN",
        "    assert doc.body().html().isEmpty();",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
    {
