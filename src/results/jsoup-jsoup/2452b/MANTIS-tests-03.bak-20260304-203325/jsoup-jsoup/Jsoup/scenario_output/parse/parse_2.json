      "expectedResult": "Document.body().html() equals '<em>Frag</em>' and baseUri equals provided baseUri",
      "tags": [
        "overload",
        "fragment",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 parseBodyFragment html with baseUri",
        "  GIVEN",
        "    String html = '<em>Frag</em>';",
        "    String baseUri = 'http://frag/';",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals('<em>Frag</em>');",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
