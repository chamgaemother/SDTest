      "expectedResult": "SocketTimeoutException is thrown",
      "tags": [
        "overload",
        "URL",
        "exception",
        "timeout"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 parse(URL,timeout) timeout-exception",
        "  GIVEN",
        "    URL url = new URL('http://example.com');",
        "    stub HttpConnection.Factory to return conn where conn.timeout(any) throws SocketTimeoutException;",
