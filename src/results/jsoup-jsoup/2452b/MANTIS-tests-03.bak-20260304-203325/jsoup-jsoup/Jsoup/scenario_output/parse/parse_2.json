{
  "scenarios": [
    {
      "id": "TC18",
      "description": "parse(File) one-arg overload reads file with default charset inference and sets baseUri to absolute path",
      "path": "B0→B3→B5",
      "precondition": "exist a temp file with <h3>OneArg</h3> content",
      "expectedResult": "Document contains element h3 with text 'OneArg' and baseUri equals file absolute path",
      "tags": [
        "overload",
        "File",
        "positive",
        "default-charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parse(File) default-charset",
        "  GIVEN",
        "    File file = temp file containing '<h3>OneArg</h3>'",
        "  WHEN",
        "    Document doc = Jsoup.parse(file);",
        "  THEN",
        "    assert doc.selectFirst(\"h3\").text().equals(\"OneArg\");",
        "    assert doc.baseUri().equals(file.getAbsolutePath());"
      ]
    },
    {
      "id": "TC19",
      "description": "parse(File, charsetName, baseUri, Parser) four-arg overload with xmlParser preserves provided baseUri",
      "path": "B0→B4→B6",
      "precondition": "exist a temp file with <node>X</node> content",
      "expectedResult": "Document contains element node with text 'X' and baseUri equals provided baseUri",
      "tags": [
        "overload",
        "File",
        "Parser",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse(File,charset,baseUri,parser)",
        "  GIVEN",
        "    File file = temp file containing '<node>X</node>'",
        "    String baseUri = 'http://filebase/';",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, 'UTF-8', baseUri, parser);",
        "  THEN",
        "    assert doc.selectFirst('node').text().equals('X');",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
    {
      "id": "TC20",
      "description": "parse(InputStream, null, baseUri) three-arg overload uses default charset detection and closes stream",
      "path": "B0→B3→B5",
      "precondition": "ByteArrayInputStream wrapping '<li>StreamNull</li>'",
      "expectedResult": "Document contains li text 'StreamNull', baseUri equals provided baseUri, and stream is closed",
      "tags": [
        "overload",
        "InputStream",
        "null-charset",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse(InputStream,null,baseUri)",
        "  GIVEN",
        "    TrackCloseStream in = new TrackCloseStream('<li>StreamNull</li>'.getBytes());",
        "    String baseUri = 'http://instream/';",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, null, baseUri);",
        "  THEN",
        "    assert doc.selectFirst('li').text().equals('StreamNull');",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert in.isClosed();"
      ]
    },
