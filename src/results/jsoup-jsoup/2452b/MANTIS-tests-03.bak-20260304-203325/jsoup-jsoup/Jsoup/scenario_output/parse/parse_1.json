    {
      "id": "TC16",
      "description": "parse(InputStream, charsetName, baseUri) with valid UTF-8 stream returns parsed Document and closes stream",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "InputStream contains <ul><li>One</li></ul> and charsetName UTF-8",
      "expectedResult": "Document contains li 'One' and baseUri equals provided",
      "tags": [
        "positive",
        "overload",
        "stream"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse(InputStream,charsetName,baseUri) valid stream",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<ul><li>One</li></ul>\".getBytes(UTF_8));",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://stream/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.selectFirst(\"li\").text().equals(\"One\");",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert in.isClosed();",
        "END"
      ]
    },
