{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, charsetName) with valid UTF-8 charset returns parsed Document and uses file absolute path as baseUri",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "temporary HTML file exists with <h2>Head2</h2>",
      "expectedResult": "Document contains h2 text 'Head2' and baseUri equals file absolute path",
      "tags": [
        "positive",
        "overload",
        "file",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse(File,charsetName) two-arg overload",
        "  GIVEN",
        "    File file = createTempHtmlFile(\"<h2>Head2</h2>\");",
        "    String charset = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset);",
        "  THEN",
        "    assert doc.selectFirst(\"h2\").text().equals(\"Head2\");",
        "    assert doc.baseUri().equals(file.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File, charsetName, baseUri, Parser) with xmlParser returns XML-parsed Document and preserves provided baseUri",
      "path": "B0→B1→B2→B4→B6",
      "precondition": "temporary HTML file exists with <item>Val</item>",
      "expectedResult": "Document parsed by xml parser contains item 'Val' and baseUri is provided",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse(File,charsetName,baseUri,Parser) xmlParser",
        "  GIVEN",
        "    File file = createTempHtmlFile(\"<item>Val</item>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://mybase/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.selectFirst(\"item\").text().equals(\"Val\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
