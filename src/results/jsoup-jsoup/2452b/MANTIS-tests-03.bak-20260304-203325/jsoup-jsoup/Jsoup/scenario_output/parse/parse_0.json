{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(String, String) with non-empty HTML and non-empty baseUri returns a Document with expected body content",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "returned Document.body().html() equals \"<p>Text</p>\" and Document.baseUri() equals \"http://example.com\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-normal"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>Text</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Text</p>\");",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(String) with empty HTML returns empty Document body and empty baseUri",
      "path": "B0→B1→B5",
      "precondition": "none",
      "expectedResult": "returned Document.body().html() equals \"\" and Document.baseUri() equals \"\"",
      "tags": [
