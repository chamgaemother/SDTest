      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 parse gzipped file",
        "  GIVEN",
        "    File file = createGzippedTempFile(\"<div>GZ</div>\");",
        "    String charset = null;",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.selectFirst(\"div\").text().equals(\"GZ\");",
        "    assert doc.baseUri().equals(\"http://base/\");",
        "END"
      ]
