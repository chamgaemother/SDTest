    {
      "id": "TC25",
      "description": "parse(String, Parser) with htmlParser resolves relative links via empty baseUri",
      "path": "B0→B2→B5→B7",
      "precondition": "none",
      "expectedResult": "empty baseUri yields no absUrl, href remains relative",
      "tags": [
        "positive",
        "parser",
        "relative"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC25 parse string with htmlParser",
        "  GIVEN",
        "    String html = \"<a href='r.html'>R</a>\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.select(\"a\").first().attr(\"href\").equals(\"r.html\");",
        "END"
      ]
    },
    {
      "id": "TC26",
      "description": "parse(String, String, Parser) with htmlParser resolves baseUri on no <base> tag",
      "path": "B0→B2→B6→B8",
      "precondition": "none",
      "expectedResult": "href is resolved against provided baseUri",
      "tags": [
        "positive",
        "parser",
        "absolute"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC26 parse string baseUri htmlParser",
        "  GIVEN",
        "    String html = \"<a href='a.html'>A</a>\";",
        "    String baseUri = \"http://base/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://base/a.html\");",
        "END"
      ]
    }
