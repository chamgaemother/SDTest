        "    String badCharset = \"INVALID-CHARSET\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    call Jsoup.parse(tmp, badCharset, baseUri);",
        "  THEN",
        "    throws IOException;",
        "END"
