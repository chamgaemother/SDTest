      "description": "parseBodyFragment(String, String) with non-empty baseUri resolves relative links",
      "path": "B0→B30→B31",
      "precondition": "none",
      "expectedResult": "body html contains absolute img src",
      "tags": [
        "positive",
        "fragment",
        "relative-resolution"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parseBodyFragment resolves relative URL",
        "  GIVEN",
        "    String frag = \"<img src='img.png'>\"",
        "    String baseUri = \"http://cdn/\"",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag, baseUri)",
        "  THEN",
        "    assert doc.body().html().contains(\"http://cdn/img.png\")"
      ]
    },
