{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, charsetName, baseUri, Parser) uses the provided parser and loads file successfully",
      "path": "B0→B12→B13→B14→B15",
      "precondition": "temporary HTML file exists with content \"<div>X</div>\"",
      "expectedResult": "Document body html is \"<div>X</div>\"",
      "tags": [
        "positive",
        "file",
        "parser",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse(File,charset,baseUri,parser) with xml parser",
        "  GIVEN",
        "    File tmp = create temp file containing \"<div>X</div>\"",
        "    String charset = \"UTF-8\"",
        "    String baseUri = \"http://example.org/\"",
        "    Parser parser = Parser.xmlParser()",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp, charset, baseUri, parser)",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>X</div>\")"
      ]
    },
