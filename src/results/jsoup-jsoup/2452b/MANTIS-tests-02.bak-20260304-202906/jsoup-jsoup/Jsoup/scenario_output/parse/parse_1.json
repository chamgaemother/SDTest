      "id": "TC18",
      "description": "parse(InputStream,charset,baseUri,Parser) closes stream and uses parser",
      "path": "B0→B7→B15",
      "precondition": "ByteArrayInputStream not yet read",
      "expectedResult": "Parser output and baseUri match",
      "tags": [
        "positive",
        "overload",
        "stream"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 parse(InputStream,charset,baseUri,Parser)",
        "  GIVEN",
        "    byte[] data = \"<em>E</em>\".getBytes(StandardCharsets.UTF_8);",
        "    InputStream in = new ByteArrayInputStream(data);",
        "    String cs = \"UTF-8\";",
        "    String base = \"http://u/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, cs, base, parser);",
        "  THEN",
        "    assert doc.select(\"em\").text().equals(\"E\");",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
