    {
      "id": "TC14",
      "description": "parse(File file exists) determines charset from BOM/meta and uses file absolute path",
      "path": "B0→B4→B8",
      "precondition": "temp file with content exists",
      "expectedResult": "Document text matches and baseUri equals file path",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 parse(File) default-charset",
        "  GIVEN",
        "    File tmp = File.createTempFile(\"p14\",\".html\");",
        "    write \"<p>Z</p>\" to tmp;",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp);",
        "  THEN",
        "    assert doc.select(\"p\").text().equals(\"Z\");",
        "    assert doc.baseUri().equals(tmp.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC15",
      "description": "parse(File,charset,baseUri,Parser) uses custom parser and explicit baseUri",
      "path": "B0→B4→B10",
      "precondition": "temp file exists",
      "expectedResult": "Parser applied and baseUri matches provided",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 parse(File,charset,baseUri,Parser)",
        "  GIVEN",
        "    File tmp = File.createTempFile(\"p15\",\".html\");",
        "    write \"<t>Y</t>\" to tmp;",
        "    String cs = \"UTF-8\";",
        "    String base = \"http://base/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp, cs, base, parser);",
        "  THEN",
        "    assert doc.select(\"t\").text().equals(\"Y\");",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
