{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(html non-empty) uses default parser and empty baseUri",
      "path": "B0→B3→B5",
      "precondition": "none",
      "expectedResult": "Document contains the element and baseUri is empty",
      "tags": [
        "positive",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse(html) default-baseUri",
        "  GIVEN",
        "    String html = \"<span>X</span>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.select(\"span\").text().equals(\"X\");",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(html non-empty, Parser) uses provided parser and empty baseUri",
      "path": "B0→B3→B6→B7",
      "precondition": "none",
      "expectedResult": "XML parser produces element and baseUri empty",
      "tags": [
        "positive",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse(html,Parser) empty-baseUri",
        "  GIVEN",
        "    String html = \"<node/>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.select(\"node\").size() == 1;",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
