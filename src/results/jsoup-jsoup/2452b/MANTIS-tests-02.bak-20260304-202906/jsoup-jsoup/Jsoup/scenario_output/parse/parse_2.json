{
  "scenarios": [
    {
      "id": "TC19",
      "description": "parse(html, Parser) throws IllegalArgumentException when html is null with non-null parser",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = Parser.htmlParser()",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse(html=null, parser) throws IAE",
        "  GIVEN",
        "    String html = null;",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call Jsoup.parse(html, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
