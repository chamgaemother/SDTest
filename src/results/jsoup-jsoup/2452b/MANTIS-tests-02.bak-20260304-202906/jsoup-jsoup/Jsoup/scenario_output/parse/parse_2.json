      "path": "B0→B1→B4→B6",
      "precondition": "Path path to a .html file with \"<div>D</div>\", charsetName=null",
      "expectedResult": "Document with tag div text 'D' and baseUri = path.toAbsolutePath().toString()",
      "tags": [
