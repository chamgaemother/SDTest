        "  WHEN",
        "    Document doc = Jsoup.parse(path, cs);",
        "  THEN",
        "    assert doc.select(\"div\").text().equals(\"D\");",
        "    assert doc.baseUri().equals(path.toAbsolutePath().toString());",
        "END"
      ]
    },
    {
      "id": "TC23",
      "description": "parse(Path, charsetName, baseUri, Parser) returns Document when all parameters non-null",
      "path": "B0→B1→B7→B8",
      "precondition": "Path path to temp .html file with \"<span>S</span>\", charsetName=\"UTF-8\", baseUri=\"http://x/\", parser=xmlParser",
      "expectedResult": "Document with span text 'S' and baseUri 'http://x/'",
      "tags": [
        "positive",
        "overload",
        "file-path",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC23 parse(Path,cs,baseUri,parser)",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"tc23\", \".html\");",
        "    Files.write(path, \"<span>S</span>\".getBytes(StandardCharsets.UTF_8));",
        "    String cs = \"UTF-8\";",
        "    String base = \"http://x/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, cs, base, parser);",
        "  THEN",
        "    assert doc.select(\"span\").text().equals(\"S\");",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
    {
      "id": "TC24",
      "description": "parse(File) returns Document when file exists, single-arg File overload",
      "path": "B0→B1→B9→B10",
      "precondition": "File tmp exists with content \"<p>P</p>\"",
      "expectedResult": "Document with p text 'P' and baseUri = tmp.getAbsolutePath()",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC24 parse(File) valid file",
        "  GIVEN",
        "    File tmp = File.createTempFile(\"tc24\", \".html\");",
        "    try (FileWriter w = new FileWriter(tmp)) { w.write(\"<p>P</p>\"); }",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp);",
        "  THEN",
        "    assert doc.select(\"p\").text().equals(\"P\");",
        "    assert doc.baseUri().equals(tmp.getAbsolutePath());",
        "END"
      ]
    },
