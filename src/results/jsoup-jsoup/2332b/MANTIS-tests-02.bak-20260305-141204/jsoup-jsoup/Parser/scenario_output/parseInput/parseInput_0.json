{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String, String) with normal HTML and non-empty baseUri delegates to TreeBuilder.parse and returns Document",
      "path": "B0→B1→B4",
      "precondition": "Use a real Parser with a stub TreeBuilder that returns a sentinel Document when parse is called; no mocks required",
      "expectedResult": "return value is the sentinel Document returned by stub TreeBuilder.parse",
      "tags": [
        "overload:String,BaseUri",
        "branch-normal",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parseInput(String,baseUri) normal-delegation",
        "  GIVEN",
        "    Parser parser = new Parser(stubTreeBuilderReturningDoc);",
        "    String html = \"<p>Text</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document result = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert result == stubTreeBuilderReturningDocDocument;",
        "END"
      ]
    },
    {
