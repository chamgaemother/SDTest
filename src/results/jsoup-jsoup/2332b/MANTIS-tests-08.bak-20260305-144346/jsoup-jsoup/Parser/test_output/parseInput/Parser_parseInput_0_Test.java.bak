package org.jsoup.parser;

import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.nodes.Node;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.io.Reader;
import java.io.StringReader;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

public class Parser_parseInput_Test {

    @Test
    @DisplayName("TC01: String overload delegates to Reader overload and invokes treeBuilder.parse with non-null html and baseUri")
    public void test_TC01() {
        // Setup a stub TreeBuilder that returns a fixed Document when parse is called
        final Document stubDoc = new Document("http://example.com");
        TreeBuilder stubBuilder = new TreeBuilder() {
            @Override
            public ParseSettings defaultSettings() {
                return new ParseSettings();
            }
            @Override
            public TreeBuilder newInstance() {
                return this;
            }
            @Override
            public Document parse(Reader input, String baseUri, Parser parser) {
                // Ensure delegation path B_str->B_rd: Reader is from StringReader(html)
                assertNotNull(input, "Reader should not be null when delegating from String overload");
                assertEquals("http://example.com", baseUri, "Base URI must be passed through");
                return stubDoc;
            }
            @Override
            public List<Node> parseFragment(Reader reader, Element context, String baseUri, Parser parser) {
                return null; // not used
            }
            @Override
            public boolean isContentForTagData(String normalName) {
                return false;
            }
            @Override
            public String defaultNamespace() {
                return "";
            }
        };
        Parser parser = new Parser(stubBuilder);
        String html = "<p>test</p>";
        String baseUri = "http://example.com";
        // Execute String overload, expect stubDoc returned
        Document result = parser.parseInput(html, baseUri);
        assertSame(stubDoc, result, "Should return the Document produced by stubBuilder.parse");
    }

    @Test
    @DisplayName("TC02: Reader overload invokes treeBuilder.parse with non-null Reader and baseUri")
    public void test_TC02() {
        // Setup a stub TreeBuilder that returns a fixed Document
        final Document stubDoc = new Document("base");
        TreeBuilder stubBuilder = new TreeBuilder() {
            @Override
            public ParseSettings defaultSettings() {
                return new ParseSettings();
            }
            @Override
            public TreeBuilder newInstance() {
                return this;
            }
            @Override
            public Document parse(Reader input, String baseUri, Parser parser) {
                // Path B_rd: direct Reader overload
                assertNotNull(input, "Reader argument must be non-null");
                assertEquals("base", baseUri, "Base URI must match provided");
                return stubDoc;
            }
            @Override
            public List<Node> parseFragment(Reader reader, Element context, String baseUri, Parser parser) {
                return null;
            }
            @Override
            public boolean isContentForTagData(String normalName) {
                return false;
            }
            @Override
            public String defaultNamespace() {
                return "";
            }
        };
        Parser parser = new Parser(stubBuilder);
        Reader reader = new StringReader("<div>ok</div>");
        String baseUri = "base";
        // Execute Reader overload
        Document result = parser.parseInput(reader, baseUri);
        assertSame(stubDoc, result, "Should return the Document produced by stubBuilder.parse");
    }

    @Test
    @DisplayName("TC03: String overload with null html throws NullPointerException at StringReader construction")
    public void test_TC03() {
        // Using real HtmlTreeBuilder; null html should cause NPE before delegation
        Parser parser = new Parser(new HtmlTreeBuilder());
        String html = null;
        String baseUri = "uri";
        assertThrows(NullPointerException.class, () -> {
            // Path B_str->exception: StringReader(null) triggers NPE
            parser.parseInput(html, baseUri);
        });
    }

    @Test
    @DisplayName("TC04: Reader overload with null Reader throws NullPointerException before parse")
    public void test_TC04() {
        // Using real HtmlTreeBuilder; passing null Reader should cause NPE immediately
        Parser parser = new Parser(new HtmlTreeBuilder());
        Reader reader = null;
        String baseUri = "uri";
        assertThrows(NullPointerException.class, () -> {
            // Path B_rd->exception: null Reader should lead to NPE
            parser.parseInput(reader, baseUri);
        });
    }

    @Test
    @DisplayName("TC05: String overload with null baseUri passes null to parse and stubBuilder.parse throws IllegalArgumentException")
    public void test_TC05() {
        // Stub TreeBuilder that throws IAE when baseUri is null
        TreeBuilder stubBuilder = new TreeBuilder() {
            @Override
            public ParseSettings defaultSettings() {
                return new ParseSettings();
            }
            @Override
            public TreeBuilder newInstance() {
                return this;
            }
            @Override
            public Document parse(Reader input, String baseUri, Parser parser) {
                // Path B_str->B_rd: delegation with null baseUri
                if (baseUri == null) {
                    throw new IllegalArgumentException("baseUri must not be null");
                }
                return new Document("irrelevant");
            }
            @Override
            public List<Node> parseFragment(Reader reader, Element context, String baseUri, Parser parser) {
                return null;
            }
            @Override
            public boolean isContentForTagData(String normalName) {
                return false;
            }
            @Override
            public String defaultNamespace() {
                return "";
            }
        };
        Parser parser = new Parser(stubBuilder);
        String html = "<span/>";
        String baseUri = null;
        assertThrows(IllegalArgumentException.class, () -> {
            // Expect IllegalArgumentException as stubBuilder enforces non-null baseUri
            parser.parseInput(html, baseUri);
        });
    }
}