{
  "scenarios": [
    {
      "id": "TC08",
      "description": "parseInput(String, String) with HtmlTreeBuilder parses simple HTML string into Document element tree",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "Document contains a <div> element with text 'jsoup'",
      "tags": [
        "positive",
        "overload",
        "string-input",
        "integration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parseInput HTML string overload",
        "  GIVEN",
        "    String html = \"<div>jsoup</div>\";",
        "    String baseUri = \"http://example.org\";",
        "  WHEN",
        "    Document doc = Parser.htmlParser().parseInput(html, baseUri);",
        "  THEN",
        "    assertEquals(\"jsoup\", doc.selectFirst(\"div\").text());",
        "    assertEquals(baseUri, doc.baseUri());",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "parseInput(String, String) with XmlTreeBuilder via xmlParser preserves element case and structure",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "Document contains an <Item> element with attribute TYPE=\"example\"",
      "tags": [
        "positive",
        "overload",
        "string-input",
        "xml",
        "integration"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 parseInput XML string overload",
        "  GIVEN",
        "    String xml = \"<Item TYPE=\\\"example\\\">123</Item>\";",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Parser.xmlParser().parseInput(xml, baseUri);",
        "  THEN",
        "    Element item = doc.selectFirst(\"Item\");",
        "    assertNotNull(item);",
        "    assertEquals(\"example\", item.attr(\"TYPE\"));",
        "    assertEquals(\"123\", item.text());",
        "END"
      ]
    }
  ]
}