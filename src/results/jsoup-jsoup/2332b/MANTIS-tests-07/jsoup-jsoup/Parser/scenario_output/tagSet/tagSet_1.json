    {
      "id": "TC05",
      "description": "newInstance returns deep copy: changing original settings does not affect clone",
      "path": "B0→B13→B15",
      "precondition": "Parser orig = Parser.htmlParser().setTrackErrors(3).setTrackPosition(true)",
      "expectedResult": "clone.isTrackErrors() == false and clone.isTrackPosition() == false",
      "tags": [
        "positive",
        "clone",
        "independent-instance"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 newInstance-deep-copy",
        "  GIVEN",
        "    Parser orig = Parser.htmlParser().setTrackErrors(3).setTrackPosition(true);",
        "  WHEN",
        "    Parser clone = orig.newInstance();",
        "    orig.setTrackErrors(1).setTrackPosition(false);",
        "  THEN",
        "    // clone retains initial settings before original was modified",
        "    assert clone.isTrackErrors() == true;",
        "    assert clone.getErrors().getMaxSize() == 3;",
        "    assert clone.isTrackPosition() == true;",
        "END"
      ]
    },
