{
  "scenarios": [
    {
      "id": "TC01",
      "description": "setTrackErrors enables tracking when maxErrors > 0 and isTrackErrors returns true",
      "path": "B0→B3(true)→B6→B8",
      "precondition": "Parser parser = Parser.htmlParser()",
      "expectedResult": "parser.isTrackErrors() == true and parser.getErrors().getMaxSize() == 5",
      "tags": [
        "positive",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 enable-error-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(5);",
        "  THEN",
        "    assert parser.isTrackErrors() == true;",
        "    assert parser.getErrors().getMaxSize() == 5;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "setTrackErrors disables tracking when maxErrors == 0 and isTrackErrors returns false",
      "path": "B0→B3(false)→B7→B8",
      "precondition": "Parser parser = Parser.xmlParser()",
      "expectedResult": "parser.isTrackErrors() == false and parser.getErrors().getMaxSize() == 0",
      "tags": [
        "negative",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 disable-error-tracking",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(0);",
        "  THEN",
        "    assert parser.isTrackErrors() == false;",
        "    assert parser.getErrors().getMaxSize() == 0;",
        "END"
      ]
    },
