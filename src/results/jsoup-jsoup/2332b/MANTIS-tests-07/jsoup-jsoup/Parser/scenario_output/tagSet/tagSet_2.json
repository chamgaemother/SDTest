      "description": "static parseFragment(fragment, context, baseUri, errorList) tracks errors when provided",
      "path": "B0â†’B1â†’B4â†’B6â†’B8",
      "precondition": "none",
      "expectedResult": "returns list of nodes and errors list populated for malformed HTML",
      "tags": [
        "static",
        "error-tracking",
        "fragment"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 fragment-parse with errorList",
        "  GIVEN",
        "    String fragment = \"<div><span></div>\"; // mismatched tags",
        "    Element ctx = new Document(\"\").body();",
        "    ParseErrorList errs = ParseErrorList.tracking(10);",
        "    String base = \"\";",
        "  WHEN",
        "    List<Node> nodes = Parser.parseFragment(fragment, ctx, base, errs);",
        "  THEN",
        "    assertFalse(nodes.isEmpty());",
        "    assertTrue(errs.size() > 0, \"Expected at least one parse error\");"
      ]
    },
    {
