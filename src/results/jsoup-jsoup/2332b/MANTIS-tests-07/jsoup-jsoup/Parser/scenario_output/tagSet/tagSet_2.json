    {
      "id": "TC12",
      "description": "static parseBodyFragment populates body with only first of multiple nodes after re-parenting loop",
      "path": "B0â†’B3â†’B5(loopĂ—1)â†’B6â†’B8",
      "precondition": "none",
      "expectedResult": "Document.body() contains both <a> and <b> in order",
      "tags": [
        "static",
        "loop",
        "fragment"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 body-fragment-multiple-nodes",
        "  GIVEN",
        "    String fragment = \"<a>one</a><b>two</b>\";",
        "    String base = \"http://test\";",
        "  WHEN",
        "    Document doc = Parser.parseBodyFragment(fragment, base);",
        "  THEN",
        "    List<Element> children = doc.body().children();",
        "    assertEquals(2, children.size());",
        "    assertEquals(\"a\", children.get(0).tagName());",
        "    assertEquals(\"b\", children.get(1).tagName());"
      ]
    },
