      "id": "TC09",
      "description": "static parse(html, baseUri) returns a Document with parsed elements",
      "path": "B0â†’B1â†’B2â†’B3â†’B5",
      "precondition": "none",
      "expectedResult": "Document.body() contains a <p> element with correct text",
      "tags": [
        "static",
        "positive",
        "parse"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 static-parse returns document",
        "  GIVEN",
        "    String html = \"<html><body><p>Hello</p></body></html>\";",
        "    String base = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Parser.parse(html, base);",
        "  THEN",
        "    assertNotNull(doc);",
        "    assertEquals(\"Hello\", doc.selectFirst(\"p\").text());"
      ]
