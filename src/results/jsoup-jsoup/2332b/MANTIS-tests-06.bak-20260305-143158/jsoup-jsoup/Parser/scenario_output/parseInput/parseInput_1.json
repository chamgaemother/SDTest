{
  "scenarios": [
    {
      "id": "TC07",
      "description": "parseInput(String, String) with XmlTreeBuilder and non-null inputs returns non-null Document",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "Parser created with new XmlTreeBuilder()",
      "expectedResult": "returns a non-null Document instance representing parsed XML",
      "tags": [
        "positive",
        "overload",
        "XmlTreeBuilder"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parseInput string-overload with XmlTreeBuilder",
        "  GIVEN",
        "    Parser p = new Parser(new XmlTreeBuilder());",
        "    String xml = \"<root><child/></root>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = p.parseInput(xml, baseUri);",
        "  THEN",
        "    assert doc != null;",
        "    assert doc.child(0).tagName().equals(\"root\");",
        "END"
      ]
    },
    {
