  "scenarios": [
    {
      "id": "TC09",
      "description": "clone() produces a deep copy: independent trackPosition and settings",
      "path": "B0â†’B1â†’B2(clone)â†’B3â†’B4",
      "precondition": "Parser p = Parser.htmlParser(); p.setTrackPosition(true).settings(new ParseSettings(true,true));",
      "expectedResult": "cloned trackPosition==true and settings equal original at clone time; modifications to clone do not affect original",
      "tags": [
        "clone",
        "deep-copy",
        "independence"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 clone deep-copy independence",
        "  GIVEN",
        "    Parser original = Parser.htmlParser().setTrackPosition(true).settings(new ParseSettings(true,true));",
        "  WHEN",
        "    Parser copy = original.clone();",
        "    copy.setTrackPosition(false).settings(new ParseSettings(false,false));",
        "  THEN",
        "    assertTrue(original.isTrackPosition());",
        "    assertNotSame(original.settings(), copy.settings());",
        "    assertEquals(true, copy.isTrackPosition());",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "setTreeBuilder() updates builder and sets builder.parser back-reference",
      "path": "B0â†’B1â†’B2(setTreeBuilder)â†’B3â†’B4",
      "precondition": "Parser p = Parser.htmlParser(); TreeBuilder tb = new XmlTreeBuilder();",
      "expectedResult": "p.getTreeBuilder()==tb and tb.parser==p",
      "tags": [
        "setter",
        "back-reference",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 setTreeBuilder back-reference",
        "  GIVEN",
        "    Parser p = Parser.htmlParser();",
        "    XmlTreeBuilder tb = new XmlTreeBuilder();",
        "  WHEN",
        "    Parser returned = p.setTreeBuilder(tb);",
        "  THEN",
        "    assertSame(p, returned);",
        "    assertSame(tb, p.getTreeBuilder());",
        "    assertSame(p, tb.parser);",
        "END"
      ]
    },
