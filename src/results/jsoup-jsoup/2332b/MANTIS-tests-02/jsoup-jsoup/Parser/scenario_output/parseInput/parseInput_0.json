{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String, String) with valid HTML returns a non-null Document with correct baseUri",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "return Document d; assert d != null; assert d.baseUri().equals(\"http://example.com\");",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-normal"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parseInput valid-string",
        "  GIVEN",
        "    String html = \"<html><head></head><body><p>Hello</p></body></html>\"; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document d = new Parser(new HtmlTreeBuilder()).parseInput(html, baseUri);",
        "  THEN",
        "    assert d != null;",
        "    assert d.baseUri().equals(\"http://example.com\");"
      ]
    },
