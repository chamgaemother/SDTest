      "id": "TC01",
      "description": "setTrackErrors enables and disables error tracking and affects isTrackErrors",
      "path": "B0â†’B2â†’B3â†’B4â†’B5â†’B6",
      "precondition": "Parser created with HtmlTreeBuilder",
      "expectedResult": "isTrackErrors returns true after setTrackErrors(5) and false after setTrackErrors(0)",
      "tags": [
        "positive",
        "branch",
        "error-tracking"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setTrackErrors toggles tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(5);",
        "  THEN",
        "    assert parser.isTrackErrors() == true;",
        "  WHEN",
        "    parser.setTrackErrors(0);",
        "  THEN",
        "    assert parser.isTrackErrors() == false;",
        "END"
      ]
    },
