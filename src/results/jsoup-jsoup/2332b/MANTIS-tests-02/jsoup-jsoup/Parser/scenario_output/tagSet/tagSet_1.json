      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 unescapeEntities modes",
        "  GIVEN",
        "    String input = \"one &amp; two\";",
        "    String inputAttr = \"one &amp; two\";",
        "  WHEN",
        "    String out1 = Parser.unescapeEntities(input, false);",
        "    String out2 = Parser.unescapeEntities(inputAttr, true);",
