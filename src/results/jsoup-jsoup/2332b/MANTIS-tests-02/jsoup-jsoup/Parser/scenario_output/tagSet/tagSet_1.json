    {
      "id": "TC05",
      "description": "parseBodyFragment with two top-level nodes exercises backward removal and append loops",
      "path": "B0â†’B12â†’B13(loopĂ—1)â†’B14(loopĂ—2)â†’B15",
      "precondition": "none",
      "expectedResult": "Document body contains both <p>one</p> and <p>two</p> in order",
      "tags": [
        "positive",
        "loop",
        "static",
        "fragment",
        "body"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 parseBodyFragment two nodes",
        "  GIVEN",
        "    String html = \"<p>one</p><p>two</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Parser.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    List<Element> ps = doc.body().getElementsByTag(\"p\");",
        "    assert ps.get(0).text().equals(\"one\");",
        "    assert ps.get(1).text().equals(\"two\");",
        "END"
      ]
    },
