    {
      "id": "TC07",
      "description": "clone and newInstance create independent parser instances with same settings",
      "path": "B0â†’B2â†’B19â†’B20â†’B21",
      "precondition": "Parser with custom settings and trackPosition=true",
      "expectedResult": "cloned parser has separate treeBuilder and same trackPosition",
      "tags": [
        "positive",
        "clone",
        "newInstance"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 clone and newInstance independence",
        "  GIVEN",
        "    Parser p0 = Parser.htmlParser().setTrackPosition(true).settings(ParseSettings.preserveCase);",
        "  WHEN",
        "    Parser p1 = p0.clone();",
        "    Parser p2 = p0.newInstance();",
        "  THEN",
        "    assert p1 != p0 && p2 != p0;",
        "    assert p1.isTrackPosition() == true && p2.isTrackPosition() == true;",
        "    assert p1.settings().equals(p0.settings());",
        "END"
      ]
    },
