      "description": "defaultNamespace on xmlParser returns XML namespace",
      "path": "B0→B1→B4",
      "precondition": "Parser created via xmlParser()",
      "expectedResult": "defaultNamespace() == Parser.NamespaceHtml? Actually html? Wait xmlParser uses XmlTreeBuilder which defaultNamespace = NamespaceXml",
      "tags": [
        "positive",
        "branch",
        "namespace"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 xml-default-namespace",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    String ns = parser.defaultNamespace();",
        "  THEN",
        "    assert ns.equals(Parser.NamespaceXml);",
        "END"
      ]
