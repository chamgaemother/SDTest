{
  "scenarios": [
    {
      "id": "TC01",
      "description": "setTrackErrors with maxErrors>0 enables tracking and isTrackErrors returns true",
      "path": "B0→B1→B3→B5",
      "precondition": "Parser created via htmlParser()",
      "expectedResult": "isTrackErrors() == true and getErrors().getMaxSize() == 5",
      "tags": [
        "positive",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 enable-error-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(5);",
        "  THEN",
        "    assert parser.isTrackErrors();",
        "    assert parser.getErrors().getMaxSize() == 5;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "setTrackErrors with maxErrors=0 disables tracking and isTrackErrors returns false",
      "path": "B0→B1→B2→B4",
      "precondition": "Parser created via xmlParser()",
      "expectedResult": "isTrackErrors() == false and getErrors().getMaxSize() == 0",
      "tags": [
        "boundary",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 disable-error-tracking",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(0);",
        "  THEN",
        "    assert !parser.isTrackErrors();",
        "    assert parser.getErrors().getMaxSize() == 0;",
        "END"
      ]
    },
    {
