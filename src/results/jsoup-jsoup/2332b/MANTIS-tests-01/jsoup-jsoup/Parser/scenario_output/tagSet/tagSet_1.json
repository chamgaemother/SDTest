{
  "scenarios": [
    {
      "id": "TC01",
      "description": "settings(ParseSettings) accepts a non‐default ParseSettings and returns this instance",
      "path": "B0→B1→B2→B3",
      "precondition": "Parser created via Parser.htmlParser()",
      "expectedResult": "settings() returns the same ParseSettings instance set previously; returns this Parser",
      "tags": [
        "positive",
        "chain-return",
        "settings"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parser settings chaining",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    ParseSettings custom = new ParseSettings(false, false);",
        "  WHEN",
        "    Parser returned = parser.settings(custom);",
        "  THEN",
        "    assert returned == parser;",
        "    assert parser.settings() == custom;",
        "END"
      ]
    },
    {
