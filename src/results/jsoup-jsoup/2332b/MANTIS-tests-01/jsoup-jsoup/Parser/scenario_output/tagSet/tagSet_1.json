    {
      "id": "TC03",
      "description": "settings() returns initial default settings from constructor",
      "path": "B0→B1→B5",
      "precondition": "Parser created via new Parser(new HtmlTreeBuilder())",
      "expectedResult": "settings() returns the default settings from the builder",
      "tags": [
        "positive",
        "getter",
        "default"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03 default settings getter",
        "  GIVEN",
        "    HtmlTreeBuilder tb = new HtmlTreeBuilder();",
        "    Parser parser = new Parser(tb);",
        "  WHEN",
        "    ParseSettings initial = parser.settings();",
        "  THEN",
        "    assert initial.equals(tb.defaultSettings());",
        "END"
      ]
