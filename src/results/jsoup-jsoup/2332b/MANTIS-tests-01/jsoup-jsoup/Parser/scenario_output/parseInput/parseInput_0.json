{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String, String) delegates to parseInput(Reader, String) with non-null html and baseUri",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = new Parser(new StubTreeBuilder()); stubTreeBuilder.parse will return a Document with title \"stub\"; // using hand-written stub to isolate delegation",
      "expectedResult": "return Document.getTitle() equals \"stub\"",
      "tags": [
        "overload:String,String",
        "delegation",
        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parseInput String overload delegates",
        "  GIVEN",
        "    Parser parser = new Parser(new StubTreeBuilder());",
        "    String html = \"<div/>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.getTitle().equals(\"stub\");"
      ]
    },
    {
      "id": "TC02_O2",
      "description": "parseInput(Reader, String) returns parsed Document from TreeBuilder.parse for valid input",
      "path": "B3→B4",
      "precondition": "Parser parser = new Parser(new StubTreeBuilder()); stubTreeBuilder.parse returns Document whose baseUri is set to provided baseUri",
      "expectedResult": "return Document.baseUri() equals \"base://uri\"",
      "tags": [
        "overload:Reader,String",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02_O2 parseInput Reader overload normal",
        "  GIVEN",
        "    Parser parser = new Parser(new StubTreeBuilder());",
        "    Reader rdr = new StringReader(\"<span/>\");",
        "    String baseUri = \"base://uri\";",
        "  WHEN",
        "    Document doc = parser.parseInput(rdr, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"base://uri\");"
      ]
    },
    {
      "id": "TC03_O2",
