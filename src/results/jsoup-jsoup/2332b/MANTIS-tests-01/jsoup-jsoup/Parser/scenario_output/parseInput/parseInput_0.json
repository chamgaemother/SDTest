      "path": "B3→B5",
      "precondition": "Parser parser = new Parser(new ExceptionTreeBuilder()); stubTreeBuilder.parse throws new IllegalArgumentException(\"parse failed\");",
      "expectedResult": "throws IllegalArgumentException; message contains \"parse failed\"",
      "tags": [
        "overload:Reader,String",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03_O2 parseInput Reader overload exception",
        "  GIVEN",
        "    Parser parser = new Parser(new ExceptionTreeBuilder());",
        "    Reader rdr = new StringReader(\"<invalid>\");",
        "    String baseUri = \"u\";",
        "  WHEN",
        "    call parser.parseInput(rdr, baseUri);",
        "  THEN",
        "    throws IllegalArgumentException(\"parse failed\");"
      ]
    },
