      "precondition": "Parser with real HtmlTreeBuilder",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 parseInput Reader null",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    Reader reader = null;",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    call parser.parseInput(reader, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
