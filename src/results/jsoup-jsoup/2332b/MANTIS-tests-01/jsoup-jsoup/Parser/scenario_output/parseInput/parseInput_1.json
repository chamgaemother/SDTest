    {
      "id": "TC08_O2_xmlParser_success",
      "description": "parseInput(Reader, String) with XmlTreeBuilder returns Document containing XML element",
      "path": "B0→B2→B3",
      "precondition": "Parser from xmlParser()",
      "expectedResult": "Document contains element 'tag' parsed from XML input",
      "tags": [
        "positive",
        "overload",
        "xml"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 parseInput xmlParser returns XML document",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "    Reader reader = new StringReader(\"<tag attr='v'/>;\");",
        "    String baseUri = \"urn:xml\";",
        "  WHEN",
        "    Document doc = parser.parseInput(reader, baseUri);",
        "  THEN",
        "    assert doc.select(\"tag\").size() == 1;",
        "    assert doc.select(\"tag\").first().attr(\"attr\").equals(\"v\");",
        "END"
      ]
    }
  ]
