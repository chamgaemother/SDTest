      "description": "htmlParser().tagSet() returns a non-empty lower-case tag set (preserveCase=false branch)",
      "path": "B0→B1→B2→B5",
      "precondition": "none",
      "expectedResult": "Set<String> contains common HTML tags in lower-case",
      "tags": [
        "positive",
        "branch-preserveCase-false"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 htmlParser default tagSet lower-case",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Set<String> tags = parser.tagSet();",
        "  THEN",
        "    assert tags.contains(\"html\");",
        "    assert !tags.contains(\"HTML\");"
      ]
    },
