      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parseInput real-builder",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example/\";",
