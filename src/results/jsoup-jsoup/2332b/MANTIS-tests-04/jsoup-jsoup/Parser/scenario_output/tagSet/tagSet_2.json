{
  "scenarios": [
    {
      "id": "TC07",
      "description": "clone() returns a deep copy with independent TreeBuilder and settings",
      "path": "B0→B1(copy_ctor)→B2(newInstance)→B3(clone)",
      "precondition": "Parser with modified settings and trackPosition enabled",
      "expectedResult": "clone is not same instance, settings and trackPosition equal, but treeBuilder instances differ",
      "tags": [
        "clone",
        "deep-copy",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 clone deep copy independence",
        "  GIVEN",
        "    Parser orig = Parser.htmlParser().setTrackPosition(true).settings(new ParseSettings(false,true));",
        "  WHEN",
        "    Parser copy = orig.clone();",
        "  THEN",
        "    assert copy != orig;",
        "    assert copy.isTrackPosition() == orig.isTrackPosition();",
        "    assert copy.settings().equals(orig.settings());",
        "    assert copy.getTreeBuilder() != orig.getTreeBuilder();",
        "END"
      ]
    },
    {
      "id": "TC08",
      "description": "parseInput(String) parses simple HTML into a Document with correct baseUri",
      "path": "B0→B4→B5(parseInput:String)→B6(treeBuilder.parse)",
      "precondition": "none",
      "expectedResult": "Document contains a <p> text node and baseUri matches",
      "tags": [
        "parseInput",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parseInput with String reader",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String base = \"http://example.com/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = parser.parseInput(html, base);",
        "  THEN",
        "    assert doc.baseUri().equals(base);",
        "    assert doc.select(\"p\").text().equals(\"Hello\");",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "parseFragmentInput(Reader, null) parses fragment without context element",
      "path": "B0→B7(parseFragmentInput:Reader)→B8(treeBuilder.parseFragment)",
      "precondition": "none",
      "expectedResult": "List<Node> contains a single TextNode for fragment",
      "tags": [
        "parseFragmentInput",
        "null-context"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 parseFragmentInput with null context",
        "  GIVEN",
        "    String frag = \"text only\";",
        "    Reader rdr = new StringReader(frag);",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    List<Node> nodes = parser.parseFragmentInput(rdr, null, \"foo\");",
        "  THEN",
        "    assert nodes.size() == 1;",
        "    assert nodes.get(0).toString().equals(\"text only\");",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "static parseFragment(html, context, baseUri, errorList) collects parse errors when malformed",
      "path": "B0→B9(static parseFragment with errorList)→B10(parser.errors=errorList)→B11(parseFragment)",
      "precondition": "errorList tracking size=1",
      "expectedResult": "returned nodes list and errorList.size()==1 containing a ParseError",
      "tags": [
        "static",
        "parseFragment",
        "error-tracking"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 static parseFragment with external errorList",
        "  GIVEN",
        "    String frag = \"<p unclosed\";",
        "    Element ctx = new Element(\"div\");",
        "    ParseErrorList errs = ParseErrorList.tracking(1);",
        "  WHEN",
        "    List<Node> out = Parser.parseFragment(frag, ctx, \"u\", errs);",
        "  THEN",
        "    assert errs.size() == 1;",
        "    assert out.size() >= 1;",
        "END"
      ]
    },
