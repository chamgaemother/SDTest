        "parseBodyFragment",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parseBodyFragment appends nodes",
        "  GIVEN",
        "    String frag = \"<span>X</span>\";",
        "    String base = \"http://b/\";",
        "  WHEN",
        "    Document d = Parser.parseBodyFragment(frag, base);",
