      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 enable position tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser returned = parser.setTrackPosition(true);",
        "  THEN",
        "    assert returned == parser;",
        "    assert parser.isTrackPosition();",
        "END"
      ]
    },
