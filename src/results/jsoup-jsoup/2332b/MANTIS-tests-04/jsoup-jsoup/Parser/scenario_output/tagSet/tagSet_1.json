{
  "scenarios": [
    {
      "id": "TC01",
      "description": "settings(ParseSettings) updates parser settings and returns this for chaining",
      "path": "B0→B2→B5→B7",
      "precondition": "Parser created via Parser.htmlParser()",
      "expectedResult": "Parser.settings() returns the newly set ParseSettings instance",
      "tags": [
        "positive",
        "chaining",
        "settings"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 settings chaining",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    ParseSettings newSettings = new ParseSettings(true, false);",
        "  WHEN",
        "    Parser returned = parser.settings(newSettings);",
        "  THEN",
        "    assert returned == parser;",
        "    assert parser.settings() == newSettings;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "setTrackErrors(5) enables tracking and isTrackErrors() returns true",
      "path": "B0→B3(>0)→B4→B6",
      "precondition": "Parser created via Parser.xmlParser()",
      "expectedResult": "parser.getErrors().getMaxSize() == 5 and isTrackErrors() == true",
      "tags": [
        "positive",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 enable error tracking",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(5);",
        "  THEN",
        "    assert parser.isTrackErrors();",
        "    assert parser.getErrors().getMaxSize() == 5;",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "setTrackErrors(0) disables tracking and isTrackErrors() returns false",
      "path": "B0→B3(=0)→B4→B8",
      "precondition": "Parser created via Parser.htmlParser()",
      "expectedResult": "parser.isTrackErrors() == false and getErrors().getMaxSize() == 0",
      "tags": [
        "negative",
        "branch",
        "error-tracking"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 disable error tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    parser.setTrackErrors(0);",
        "  THEN",
        "    assert !parser.isTrackErrors();",
        "    assert parser.getErrors().getMaxSize() == 0;",
        "END"
      ]
    },
    {
