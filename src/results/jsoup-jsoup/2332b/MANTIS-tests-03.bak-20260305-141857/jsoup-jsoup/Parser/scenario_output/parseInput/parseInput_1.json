        "null-baseUri",
        "overload-resolution"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parseInput String overload null-baseUri",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    String html = \"<div>Test</div>\";",
        "    String baseUri = null;",
        "  WHEN",
        "    call parser.parseInput(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
