{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String,String) with empty HTML returns a minimal Document with html, head, and empty body (branch: html non-null, baseUri non-null)",
      "path": "B0→B1→B2→B3→B4→B5",
      "precondition": "Parser parser = Parser.htmlParser(); // real HtmlTreeBuilder ensures real parsing",
      "expectedResult": "Document doc where doc.html().equals(\"<html><head></head><body></body></html>\") and doc.baseUri().equals(\"http://example.com/\")",
      "tags": [
        "branch-true",
        "overload:String,String",
        "positive",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parseInput empty-string",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    String html = \"\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.html() == \"<html><head></head><body></body></html>\";",
        "END"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parseInput(String,String) with simple HTML containing a single element returns that element in body (branch: html non-null, baseUri non-null)",
      "path": "B0→B1→B2→B3→B4→B5",
      "precondition": "Parser parser = Parser.htmlParser();",
      "expectedResult": "Document doc where doc.body().selectFirst(\"p\").text().equals(\"Hello\") and doc.baseUri().equals(\"http://host/\")",
      "tags": [
        "branch-true",
        "overload:String,String",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02_O1 parseInput simple-html",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://host/\";",
        "  WHEN",
        "    Document doc = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.body().select(\"p\").get(0).text() == \"Hello\";",
        "END"
      ]
    },
