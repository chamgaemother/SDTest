{
  "scenarios": [
    {
      "id": "TC01",
      "description": "Invoking private tagSet(\"div\") returns true for known HTML tag",
      "path": "B0→B1→B3→B5",
      "precondition": "Parser.htmlParser() available; method tagSet(String) is private",
      "expectedResult": "returns true",
      "tags": [
        "positive",
        "reflection",
        "private"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 tagSet-known-html-tag",
        "  GIVEN",
        "    // use reflection to access private tagSet",
        "    Parser parser = Parser.htmlParser();",
        "    Method m = Parser.class.getDeclaredMethod(\"tagSet\", String.class);",
        "    m.setAccessible(true);",
        "    String tag = \"div\";",
        "  WHEN",
        "    boolean result = (boolean) m.invoke(parser, tag);",
        "  THEN",
        "    assert result == true;",
        "END"
      ]
    },
    {
