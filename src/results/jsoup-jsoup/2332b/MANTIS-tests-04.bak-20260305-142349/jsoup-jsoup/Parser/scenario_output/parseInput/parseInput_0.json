{
  "method": "parseInput",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseInput(String,baseUri) with empty HTML returns an empty Document with provided baseUri",
      "path": "B1→B2",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder());",
      "expectedResult": "Document.getBaseUri() equals \"http://example.com/\" and Document.body().children().isEmpty()",
      "tags": [
        "overload:String,String",
        "branch-normal",
        "boundary-empty-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parseInput empty-html",
        "  GIVEN",
        "    String html = \"\"; String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.getBaseUri().equals(\"http://example.com/\");",
        "END"
      ]
    },
    {
      "id": "TC02_O2",
      "description": "parseInput(Reader,baseUri) with simple HTML returns Document with one child element",
      "path": "B1→B2",
