    {
      "id": "TC06_O1",
      "description": "parseInput(String,baseUri) after setTreeBuilder(XmlTreeBuilder) returns XML Document root element",
      "path": "B1→B2",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder()); parser.setTreeBuilder(new XmlTreeBuilder());",
      "expectedResult": "Document.child(0).nodeName() equals \"root\" for input \"<root/>\"",
      "tags": [
        "overload:String,String",
        "branch-normal",
        "variant-xml"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06_O1 parseInput xml-parser",
        "  GIVEN",
        "    Parser p = new Parser(new HtmlTreeBuilder()); p.setTreeBuilder(new XmlTreeBuilder());",
        "  WHEN",
        "    Document doc = p.parseInput(\"<root/>\",\"uri\");",
        "  THEN",
        "    assert doc.child(0).nodeName().equals(\"root\");",
        "END"
