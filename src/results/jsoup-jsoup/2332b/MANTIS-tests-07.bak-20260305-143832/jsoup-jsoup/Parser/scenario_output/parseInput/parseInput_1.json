    {
      "id": "TC08",
      "description": "parseInput(reader, baseUri) with real Reader and HTML parser returns parsed Document",
      "path": "B0→B1→B2",
      "precondition": "Parser.htmlParser()",
      "expectedResult": "Document contains correct elements and baseUri",
      "tags": [
        "positive",
        "reader-overload",
        "integration"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 parseInput reader-valid html-parser",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    Reader reader = new StringReader(\"<ul><li>one</li><li>two</li></ul>\");",
        "    String baseUri = \"http://site\";",
        "  WHEN",
        "    Document doc = parser.parseInput(reader, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assertEquals(2, doc.select(\"li\").size());",
        "    assertEquals(\"one\", doc.select(\"li\").first().text());",
        "END"
      ]
    }
