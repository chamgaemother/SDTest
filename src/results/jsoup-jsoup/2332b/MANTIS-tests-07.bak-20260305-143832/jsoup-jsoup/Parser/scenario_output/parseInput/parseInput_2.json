    {
      "id": "TC06",
      "description": "parseInput(reader, baseUri) propagates RuntimeException thrown by TreeBuilder.parse",
      "path": "B0→B1→B4",
      "precondition": "Parser configured with stub TreeBuilder that throws RuntimeException(IOException)",
      "expectedResult": "RuntimeException with cause IOException is thrown",
      "tags": [
        "negative",
        "reader-overload",
        "exception",
        "stub"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parseInput(Reader, String) stub-exception",
        "  GIVEN",
        "    TreeBuilder stub = new TreeBuilder() {",
        "      @Override public Document parse(Reader in, String baseUri, Parser p) {",
        "        throw new RuntimeException(new IOException(\"err\"));",
        "      }",
        "      @Override public TreeBuilder newInstance() { return defaultStub(); }",
        "      @Override public ParseSettings defaultSettings() { return new ParseSettings(); }",
        "    };",
        "    Parser parser = new Parser(stub);",
        "    Reader reader = new StringReader(\"x\");",
        "    String baseUri = \"uri\";",
        "  WHEN",
        "    call parser.parseInput(reader, baseUri);",
        "  THEN",
        "    RuntimeException ex = thrown;",
        "    assert ex.getCause() instanceof IOException;",
        "    assert ex.getCause().getMessage().equals(\"err\");",
        "END"
      ]
    }
  ]
