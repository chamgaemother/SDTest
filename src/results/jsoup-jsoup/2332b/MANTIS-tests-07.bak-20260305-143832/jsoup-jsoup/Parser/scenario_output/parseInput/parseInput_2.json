{
  "scenarios": [
    {
      "id": "TC01",
      "description": "parseInput(html, baseUri) returns a Document for valid HTML and baseUri (delegates to TreeBuilder.parse)",
      "path": "B0→B1→B2",
      "precondition": "Parser.htmlParser()",
      "expectedResult": "returned Document has correct baseUri and contains parsed elements",
      "tags": [
        "positive",
        "string-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parseInput(String, String) normal-case",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    String html = \"<span>jsoup</span>\";",
        "    String baseUri = \"http://test\";",
        "  WHEN",
        "    Document doc = parser.parseInput(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"span\").first().text().equals(\"jsoup\");",
        "END"
      ]
    },
    {
