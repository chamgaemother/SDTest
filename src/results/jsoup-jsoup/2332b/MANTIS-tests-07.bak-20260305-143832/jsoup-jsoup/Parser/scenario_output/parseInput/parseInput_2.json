    {
      "id": "TC04",
      "description": "parseInput(reader, baseUri) returns a Document when given a valid Reader and baseUri",
      "path": "B0→B1→B2",
      "precondition": "Parser.htmlParser()",
      "expectedResult": "returned Document has correct baseUri and parsed structure",
      "tags": [
        "positive",
        "reader-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 parseInput(Reader, String) normal-case",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    Reader reader = new StringReader(\"<ul><li>a</li><li>b</li></ul>\");",
        "    String baseUri = \"http://site\";",
        "  WHEN",
        "    Document doc = parser.parseInput(reader, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"li\").size() == 2;",
        "END"
      ]
    },
