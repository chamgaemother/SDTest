      "description": "isContentForTagData returns true for script tag and false for div",
      "path": "B37→B38(true) & B37→B38(false)",
      "precondition": "HtmlTreeBuilder default",
      "expectedResult": "script returns true; div returns false",
      "tags": [
        "positive",
        "api",
        "isContentForTagData"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 isContentForTagData cases",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    boolean scr = parser.isContentForTagData(\"script\");",
        "    boolean div = parser.isContentForTagData(\"div\");",
        "  THEN",
        "    assert scr;",
        "    assert !div;",
        "END"
      ]
