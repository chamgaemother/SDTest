  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "String overload with valid html and baseUri invokes Reader overload and returns Document",
      "path": "B0_S→B1_S→B2_S→B0_R→B4_R→B5_R",
      "precondition": "Parser with stub TreeBuilder that returns new Document(\"ok\"); no mocks beyond stub needed",
      "expectedResult": "Document returned has title \"ok\" (stub value)",
      "tags": [
        "overload:String,baseUri",
        "branch-normal",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parseInput(String) normal-case",
        "  GIVEN",
        "    Parser p = new Parser(new FakeTreeBuilderReturningDoc(\"ok\"));",
        "    String html = \"<p>test</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document result = p.parseInput(html, baseUri);",
        "  THEN",
        "    assert result.title().equals(\"ok\");",
        "END"
      ]
    },
