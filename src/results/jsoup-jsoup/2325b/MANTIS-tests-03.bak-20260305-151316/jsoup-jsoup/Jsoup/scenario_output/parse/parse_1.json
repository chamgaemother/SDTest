      "description": "parse(Path, String charsetName) with null charsetName falls back to default and uses path as baseUri",
      "path": "B0→B1→B6→B8",
      "precondition": "Path to temp HTML file with <span>Default</span>",
      "expectedResult": "Document.baseUri() == path.toAbsolutePath().toString() and body.html() == <span>Default</span>",
      "tags": [
        "positive",
        "overload",
        "path",
        "default-charset"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parse(Path,charsetName=null)",
        "  GIVEN",
        "    Path p = Files.write(tempDir.resolve(\"d.html\"), \"<span>Default</span>\".getBytes(StandardCharsets.UTF_8));",
        "  WHEN",
        "    Document doc = Jsoup.parse(p);",
        "  THEN",
        "    assert doc.baseUri().equals(p.toAbsolutePath().toString());",
        "    assert doc.body().html().equals(\"<span>Default</span>\");",
        "END"
      ]
    },
    {
      "id": "TC15",
      "description": "parse(Path, String charsetName, String baseUri, Parser) using xmlParser on a Path source",
      "path": "B0→B1→B9→B10",
      "precondition": "Path to file with <x attr=\"v\"/>",
      "expectedResult": "xml syntax and baseUri == provided",
      "tags": [
        "positive",
        "overload",
        "path",
        "parser"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse(Path,charset,baseUri,parser)",
        "  GIVEN",
        "    Path p = Files.write(tempDir.resolve(\"x.xml\"), \"<x attr=\\\"v\\\"/>\".getBytes(StandardCharsets.UTF_8));",
        "    Parser xml = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(p, \"UTF-8\", \"http://site/\", xml);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://site/\");",
        "    assert doc.outputSettings().syntax() == Document.OutputSettings.Syntax.xml;",
        "END"
      ]
    },
    {
      "id": "TC16",
      "description": "parse(InputStream, String charsetName, String baseUri, Parser) applies parser and closes stream",
      "path": "B0→B11→B12",
      "precondition": "InputStream over UTF-8 bytes of <p>Stream</p>",
      "expectedResult": "Document with baseUri == given, body.html()==<p>Stream</p>, stream closed",
      "tags": [
        "positive",
        "overload",
        "stream",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse(InputStream,charset,baseUri,parser)",
        "  GIVEN",
        "    ByteArrayInputStream in = new ByteArrayInputStream(\"<p>Stream</p>\".getBytes(StandardCharsets.UTF_8));",
        "    Parser xml = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, \"UTF-8\", \"base://\", xml);",
        "  THEN",
        "    assert doc.baseUri().equals(\"base://\");",
        "    assert doc.body().html().equals(\"<p>Stream</p>\");",
        "    assertStreamClosed(in);",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "parseBodyFragment(String, String) with nested tags sets baseUri and body fragment",
      "path": "B0→B13→B14",
      "precondition": "none",
      "expectedResult": "Document.baseUri()==provided, body.html()==<div><a href=\"b.html\">link</a></div>",
      "tags": [
        "positive",
        "fragment",
        "body"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 parseBodyFragment(html,baseUri)",
        "  GIVEN",
        "    String frag = \"<div><a href=\\\"b.html\\\">link</a></div>\";",
        "    String base = \"http://x/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag, base);",
        "  THEN",
        "    assert doc.baseUri().equals(base);",
        "    assert doc.body().html().equals(frag);",
        "END"
      ]
    },
    {
