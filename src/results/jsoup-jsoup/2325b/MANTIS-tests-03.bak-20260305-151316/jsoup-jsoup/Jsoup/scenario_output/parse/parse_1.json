    {
      "id": "TC19",
      "description": "parse(URL, timeout) throws SocketTimeoutException when connection times out",
      "path": "B0→B16→B17",
      "precondition": "HttpConnection.connect(url) returns stub Connection",
      "expectedResult": "SocketTimeoutException is thrown",
      "tags": [
        "negative",
        "url",
        "timeout",
        "exception"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse(URL,timeout) timeout-exception",
        "  GIVEN",
        "    URL u = new URL(\"http://timeout.test\");",
        "    Connection c = mock(Connection.class);",
        "    when(c.timeout(50)).thenReturn(c);",
        "    when(c.get()).thenThrow(new SocketTimeoutException());",
        "    mockStatic(HttpConnection).when(() -> HttpConnection.connect(u)).thenReturn(c);",
        "  WHEN",
        "    call Jsoup.parse(u, 50);",
        "  THEN",
        "    throws SocketTimeoutException;",
        "END"
      ]
    }
  ]
}