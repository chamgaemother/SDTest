{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, String charsetName) with non-null charset uses provided charset and file path as baseUri",
      "path": "B0→B1→B2→B3",
      "precondition": "temp HTML file exists with <h1>Header</h1>",
      "expectedResult": "Document with baseUri equal to file.getAbsolutePath() and body.html() == <h1>Header</h1>",
      "tags": [
        "positive",
        "overload",
        "file",
        "charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse(File, charsetName)",
        "  GIVEN",
        "    File f = createTempFile with content \"<h1>Header</h1>\" in UTF-8;",
        "    String charset = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, charset);",
        "  THEN",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "    assert doc.body().html().equals(\"<h1>Header</h1>\");",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File, String charsetName, String baseUri, Parser) with xmlParser produces xml syntax output",
      "path": "B0→B1→B4→B5",
      "precondition": "temp file contains <item/><child>text</child>",
      "expectedResult": "Document.outputSettings().syntax() == xml and baseUri == provided",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser",
        "exception-free"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse(File,charset,baseUri,Parser)",
        "  GIVEN",
        "    File f = createTempFile with content \"<item/><child>text</child>\";",
        "    String charset = null; // auto-detect",
        "    String base = \"http://base/\";",
        "    Parser p = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, charset, base, p);",
        "  THEN",
        "    assert doc.baseUri().equals(base);",
        "    assert doc.outputSettings().syntax() == Document.OutputSettings.Syntax.xml;",
        "END"
      ]
    },
    {
      "id": "TC13",
      "description": "parse(Path, String charsetName, String baseUri) with non-null charset reads file via Path",
      "path": "B0→B1→B6→B7",
      "precondition": "Path to temp HTML file with <div>PathTest</div>",
      "expectedResult": "Document with correct baseUri (path.toString()) and body.html() == <div>PathTest</div>",
      "tags": [
        "positive",
        "overload",
        "path",
        "charset",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse(Path,charset,baseUri)",
        "  GIVEN",
        "    Path p = Files.write(tempDir.resolve(\"test.html\"), \"<div>PathTest</div>\".getBytes(StandardCharsets.UTF_8));",
        "    String charset = \"UTF-8\";",
        "    String base = \"https://example.org/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(p, charset, base);",
        "  THEN",
        "    assert doc.baseUri().equals(base);",
        "    assert doc.body().html().equals(\"<div>PathTest</div>\");",
        "END"
      ]
    },
    {
