      "tags": [
        "positive",
        "fragment",
        "default-baseUri"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parseBodyFragment(html)",
        "  GIVEN",
        "    String frag = \"<span>F</span>\";",
