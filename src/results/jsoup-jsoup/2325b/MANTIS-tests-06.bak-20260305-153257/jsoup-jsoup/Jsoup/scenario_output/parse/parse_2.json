{
  "scenarios": [
    {
      "id": "TC16",
      "description": "parse(html, baseUri, parser) with null parser throws IllegalArgumentException",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown for null parser",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 null-parser-overload",
        "  GIVEN",
        "    String html = \"<p>X</p>\";",
        "    String baseUri = \"http://x/\";",
        "    Parser parser = null;",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "parse(File, charsetName, baseUri, parser) with XML parser returns Document with supplied parser",
      "path": "B0→B3→B5",
      "precondition": "File exists containing '<h3>F</h3>'",
      "expectedResult": "Document body contains <h3>F</h3> and baseUri set to provided value",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 file-overload-with-parser",
        "  GIVEN",
        "    File file = tempFileWithContent(\"<h3>F</h3>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"https://base/\";",
        "    Parser xmlParser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, xmlParser);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"h3\").first().text().equals(\"F\");",
        "END"
      ]
    },
    {
      "id": "TC18",
