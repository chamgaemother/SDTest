      "path": "B0→B3→B6",
      "precondition": "Path to temp HTML file containing '<p>P</p>'",
      "expectedResult": "Document body contains <p>P</p> and baseUri equals path.toString()",
      "tags": [
        "positive",
        "overload",
        "path",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 path-overload-with-charset-baseUri",
        "  GIVEN",
        "    Path path = tempPathWithContent(\"<p>P</p>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://u/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>P</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
