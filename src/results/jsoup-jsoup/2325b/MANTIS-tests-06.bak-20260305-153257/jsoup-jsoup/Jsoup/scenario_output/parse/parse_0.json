    {
      "id": "TC04_O2",
      "description": "parse(html, baseUri, parser) with custom Parser returns parser.parseInput result",
      "path": "B0→B1→B2",
      "precondition": "Parser stub returns a known Document when parseInput is called",
      "expectedResult": "return value is exactly the Document returned by parser.parseInput(html, baseUri)",
      "tags": [
        "overload:String,String,Parser",
        "positive",
        "inject-parser",
        "branch-calls-parser.parseInput"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04_O2 parse(String, String, Parser) custom-parser",
        "  GIVEN",
        "    String html = \"<div>Test</div>\";",
        "    String baseUri = \"http://x/\";",
        "    Parser parser = new Parser() { public Document parseInput(String h,String b){return Document.createShell(b);} };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC05_O3",
      "description": "parse(html, parser) with non-empty html and custom parser uses empty baseUri",
      "path": "B0→B1→B2",
      "precondition": "Parser stub returns Document with baseUri = empty",
      "expectedResult": "return value is the stub Document with baseUri equal to \"\"",
      "tags": [
        "overload:String,Parser",
        "positive",
        "baseUri-empty",
        "branch-calls-parser.parseInput"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05_O3 parse(String, Parser) no-baseUri",
        "  GIVEN",
        "    String html = \"<span/>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.select(\"span\").size() == 1;",
        "END"
      ]
    },
