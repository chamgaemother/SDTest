{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri calls Parser.parse and returns a Document",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is a Document whose html() equals the input html and baseUri() equals the input baseUri",
      "tags": [
        "overload:String,String",
        "positive",
        "baseUri-nonEmpty",
        "branch-calls-Parser.parse"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse(String, String) standard-case",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.html().contains(\"<p>Hello</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parse(html, baseUri) with empty html returns an empty Document with only html/body tags",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is a Document whose body() is empty and baseUri() equals the input baseUri",
      "tags": [
        "overload:String,String",
        "boundary",
        "html-empty",
        "branch-calls-Parser.parse"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02_O1 parse(String, String) empty-html",
        "  GIVEN",
        "    String html = \"\";",
        "    String baseUri = \"http://test/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
