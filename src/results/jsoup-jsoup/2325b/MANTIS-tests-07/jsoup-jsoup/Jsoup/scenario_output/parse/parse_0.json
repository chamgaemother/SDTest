{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(html,baseUri) with non-empty html and valid baseUri returns parsed Document via Parser.parse",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document has body html equal to input html wrapped in <html><head></head><body>",
      "tags": [
        "branch-false(htmlEmpty)",
        "branch-false(baseUriEmpty)",
        "positive",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse with html and baseUri",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Test</p>\");"
      ]
    },
    {
