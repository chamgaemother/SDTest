{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(html, baseUri) with valid inputs uses default HTML parser and sets baseUri",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals input fragment and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "default-parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse default overload",
        "  GIVEN",
        "    String html = \"<span>OK</span>\";",
        "    String baseUri = \"http://test.example\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>OK</span>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
