      "id": "TC13",
      "description": "parseBodyFragment(bodyHtml, baseUri) with empty baseUri uses \"\" and returns fragment in body",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "body().html() equals fragment and baseUri = \"\"",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parseBodyFragment default-base",
        "  GIVEN",
        "    String fragment = \"<p>frag</p>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>frag</p>\");",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
