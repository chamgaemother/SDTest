{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(File file) reads file and sets baseUri to file absolute path",
      "path": "B0→B14→B15→B16→B17",
      "precondition": "temp HTML file exists with content '<p>F</p>'",
      "expectedResult": "Document.html contains '<p>F</p>' and baseUri equals file.getAbsolutePath()",
      "tags": [
        "positive",
        "overload",
        "file",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse(File) default charset",
        "  GIVEN",
        "    File f = createTempFileWithContent(\"<p>F</p>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(f);",
        "  THEN",
        "    assert doc.html().contains(\"<p>F</p>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());"
      ]
    },
    {
