    {
      "id": "TC16",
      "description": "clean(String bodyHtml, Safelist) removes relative links when preserveRelativeLinks is false",
      "path": "B0→B50→B51→B52→B53",
      "precondition": "none",
      "expectedResult": "returned HTML does not contain href='/y', baseUri empty branch skip",
      "tags": [
        "negative",
        "clean",
        "safelist",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 clean removes relative when not preserved",
        "  GIVEN",
        "    String html = \"<a href='/y'>y</a>\";",
        "    Safelist list = Safelist.basic(); // default preserveRelativeLinks=false",
        "  WHEN",
        "    String out = Jsoup.clean(html, list);",
        "  THEN",
        "    assertFalse(out.contains(\"href='/y'\"));"
      ]
    },
    {
      "id": "TC17",
      "description": "clean(String, String, Safelist, OutputSettings) applies outputSettings prettyPrint=false",
      "path": "B0→B60→B61→B62→B63",
      "precondition": "none",
      "expectedResult": "returned HTML has no newline or indent because prettyPrint disabled",
      "tags": [
        "positive",
        "clean",
        "outputSettings"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 clean with outputSettings",
        "  GIVEN",
        "    String html = \"<p>a</p><p>b</p>\";",
        "    Safelist sl = Safelist.none();",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String out = Jsoup.clean(html, \"http://b/\", sl, os);",
        "  THEN",
        "    assertEquals(\"<p>a</p><p>b</p>\", out);"
      ]
    },
