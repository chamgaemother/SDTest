{
  "scenarios": [
    {
      "id": "TC07",
      "description": "parse(File, charsetName, baseUri) reads HTML file with explicit charset and baseUri",
      "path": "B0→B12→B13→B14→B15",
      "precondition": "temp HTML file exists with <p>File</p>",
      "expectedResult": "Document with body <p>File</p> and baseUri as provided",
      "tags": [
        "positive",
        "file-overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parse file with charset and baseUri",
        "  GIVEN",
        "    File file = createTempFile(\"<p>File</p>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://file.example/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>File</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
