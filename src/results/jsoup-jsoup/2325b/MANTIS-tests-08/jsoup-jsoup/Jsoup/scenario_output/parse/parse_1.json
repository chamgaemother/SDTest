{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(html, baseUri) with relative link and non-empty baseUri resolves to absolute URL",
      "path": "B0→B1→B2→B5",
      "precondition": "none",
      "expectedResult": "body().html() contains absolute href",
      "tags": [
        "positive",
        "overload",
        "relative-link"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse overload(String, String) resolves relative links",
        "  GIVEN",
        "    String html = \"<a href=\\\"/test\\\">x</a>\";",
        "    String baseUri = \"https://site.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<a href=\\\"https://site.com/test\\\">x</a>\");",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(html, baseUri) with empty html returns empty body",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "body().html() is empty string",
      "tags": [
        "boundary",
        "overload",
        "empty-html"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse overload(String, String) empty html",
        "  GIVEN",
        "    String html = \"\";",
        "    String baseUri = \"http://any/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");",
        "END"
      ]
    },
    {
      "id": "TC13",
      "description": "parse(html, baseUri) with null html throws NullPointerException before parsing",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "throws NullPointerException",
      "tags": [
        "negative",
        "overload",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 parse overload(String, String) null html",
        "  GIVEN",
        "    String html = null;",
        "    String baseUri = \"http://x/\";",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    }
  ]
}