  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri resolves relative links (baseUri not empty)",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "return Document with body.html() == \"<a href=\\\"http://example.com/page\\\">link</a>\"",
      "tags": [
        "overload:String,String",
        "branch-baseUri-nonEmpty",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse(html, baseUri) resolves relative URL",
        "  GIVEN",
        "    String html = \"<a href=\\\"/page\\\">link</a>\"; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<a href=\\\"http://example.com/page\\\">link</a>\");"
      ]
    },
