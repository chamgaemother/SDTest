{
  "scenarios": [
    {
      "id": "TC14",
      "description": "parse(File, null charsetName, baseUri) reads uncompressed HTML file and returns Document",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "File exists with simple HTML content",
      "expectedResult": "Document.body().html() equals file HTML fragment",
      "tags": [
        "positive",
        "file-overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parse File with null charset",
        "  GIVEN",
        "    File file = createTempFile(\"<p>Hello</p>\");",
        "    String charset = null;",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\");",
        "END"
      ]
    },
