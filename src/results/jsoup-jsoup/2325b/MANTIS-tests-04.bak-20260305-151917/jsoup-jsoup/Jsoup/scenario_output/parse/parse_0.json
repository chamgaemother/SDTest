    },
    {
      "id": "TC07_O7",
      "description": "parse(Path, charsetName, baseUri) returns Document for existing path with null charsetName",
      "path": "B0→B13→B14",
      "precondition": "Path to temp file created with UTF-8 content '<span>OK</span>'",
      "expectedResult": "returned Document.body().html() equals '<span>OK</span>' and baseUri equals provided baseUri",
      "tags": [
        "overload:Path,String,String",
        "boundary-null-charset",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07_O7 parse(Path,String,String)",
        "  GIVEN",
        "    Path path = Files.write(tempFile(), \"<span>OK</span>\".getBytes(StandardCharsets.UTF_8));",
        "    String baseUri = \"https://p/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, null, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>OK</span>\") && doc.baseUri().equals(\"https://p/\");"
      ]
    },
    {
      "id": "TC08_O8",
      "description": "parse(InputStream, charsetName, baseUri) returns Document reading stream and closing it",
      "path": "B0→B15→B16",
      "precondition": "InputStream over bytes '<i>i</i>' available; no mocking framework; stream closed recorded via wrapper",
      "expectedResult": "returned Document.body().html() equals '<i>i</i>' and stream.isClosed()==true",
      "tags": [
        "overload:InputStream,String,String",
        "positive",
        "resource-management"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08_O8 parse(InputStream,String,String)",
        "  GIVEN",
        "    RecordingInputStream in = new RecordingInputStream(\"<i>i</i>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, \"UTF-8\", \"http://z/\");",
        "  THEN",
        "    assert doc.body().html().equals(\"<i>i</i>\") && in.isClosed();"
      ]
    },
