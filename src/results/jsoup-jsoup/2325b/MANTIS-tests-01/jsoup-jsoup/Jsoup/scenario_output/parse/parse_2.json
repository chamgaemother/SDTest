    {
      "id": "TC25",
      "description": "parseBodyFragment(bodyHtml, baseUri) parses fragment and sets baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "Document.body.html contains fragment; baseUri used to resolve links",
      "tags": [
        "positive",
        "fragment"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC25 parseBodyFragment-with-baseUri",
        "  GIVEN",
        "    String frag = \"<div><a href=one.html>link</a></div>\";",
        "    String baseUri = \"http://u/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<div>\");",
        "    assert doc.select(\"a\").get(0).absUrl(\"href\").startsWith(baseUri);",
        "END"
      ]
    },
