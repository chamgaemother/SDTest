{
  "scenarios": [
    {
      "id": "TC18",
      "description": "parse(File, charsetName, baseUri, parser) delegates to DataUtil.load with provided Parser",
      "path": "B0→B1→B2",
      "precondition": "temp HTML file exists",
      "expectedResult": "Document parsed using custom parser; parser.parseInput called",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 file-overload-with-parser",
        "  GIVEN",
        "    File temp = createTempFile(\"test\", \".html\");",
        "    writeContent(temp, \"<html><body><p>X</p></body></html>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "    Parser stub = new Parser() { override parseInput(h, u) { record h,u; return new Document(\"stub\"); } };",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, charset, baseUri, stub);",
        "  THEN",
        "    assert recordedHtml == fileContent;",
        "    assert recordedBaseUri == baseUri;",
        "    assert doc.baseUri().equals(\"stub\");",
        "END"
      ]
    },
