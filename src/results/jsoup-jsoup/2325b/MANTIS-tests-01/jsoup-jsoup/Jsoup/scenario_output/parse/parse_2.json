      "environment": "Java 8",
      "pseudocode": [
        "TEST TC26 parseBodyFragment-default-baseUri",
        "  GIVEN",
        "    String frag = \"<a href=two.html>l</a>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag);",
        "  THEN",
        "    assert doc.body().html().contains(\"two.html\");",
        "    assert doc.select(\"a\").get(0).absUrl(\"href\").isEmpty();",
        "END"
