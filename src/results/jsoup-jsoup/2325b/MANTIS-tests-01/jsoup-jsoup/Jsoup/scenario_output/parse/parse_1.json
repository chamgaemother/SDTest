    {
      "id": "TC15",
      "description": "parse(File) with valid file infers UTF-8 and uses file path as baseUri",
      "path": "B0→B4→B6→B9",
      "precondition": "temporary file exists with body '<p>Hello</p>'",
      "expectedResult": "doc.body().text() is 'Hello' and baseUri equals file.absolutePath()",
      "tags": [
        "positive",
        "file-overload",
        "default-charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse(file) default-charset",
        "  GIVEN",
        "    File temp = createTempFile(\"<html><body><p>Hello</p></body></html>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp);",
        "  THEN",
        "    assert doc.body().text().equals(\"Hello\");",
        "    assert doc.baseUri().equals(temp.getAbsolutePath());",
        "END"
      ]
    },
