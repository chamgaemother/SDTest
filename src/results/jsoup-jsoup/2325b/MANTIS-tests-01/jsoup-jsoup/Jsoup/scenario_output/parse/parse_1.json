    {
      "id": "TC13",
      "description": "parse(File, charsetName, baseUri) with valid small HTML file returns Document with correct baseUri",
      "path": "B0→B4→B6→B8",
      "precondition": "temporary file exists with content '<title>F</title>'",
      "expectedResult": "Document.title() is 'F' and baseUri equals provided baseUri",
      "tags": [
        "positive",
        "file-overload",
        "IO"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse(file, charset, baseUri) valid-file",
        "  GIVEN",
        "    File temp = createTempFile(\"<html><head><title>F</title></head><body></body></html>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, charset, baseUri);",
        "  THEN",
        "    assert doc.title().equals(\"F\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
