      "description": "parse(html, parser) with null html throws IllegalArgumentException",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "exception",
        "null-input",
        "parser-overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse(html, parser) null-html",
        "  GIVEN",
        "    String html = null;",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call Jsoup.parse(html, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
