{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(File, charsetName) with non-null charsetName reads plain HTML file",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "temporary File with .html content exists",
      "expectedResult": "return Document with baseUri equal to file absolute path and body.html matches file content",
      "tags": [
        "positive",
        "overload",
        "file",
        "charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse File two-arg",
        "  GIVEN",
        "    File file = writeTempFile(\"<h1>hi</h1>\");",
        "    String charset = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset);",
        "  THEN",
        "    assert doc.baseUri().equals(file.getAbsolutePath());",
        "    assert doc.body().html().equals(\"<h1>hi</h1>\");"
      ]
    },
