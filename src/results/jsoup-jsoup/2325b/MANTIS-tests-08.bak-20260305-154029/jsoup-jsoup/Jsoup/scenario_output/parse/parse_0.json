    {
      "id": "TC07_O6",
      "description": "parse(URL, timeoutMillis) with valid HTTP URL returns Document from GET",
      "path": "B0→B11→B12→B13",
      "precondition": "Use a stub HttpConnection.connect(URL) that returns a Connection stub with .get() returning a Document",
      "expectedResult": "return the stub Document returned by con.get()",
      "tags": [
        "overload:URL,int",
        "positive",
        "mocked-HttpConnection",
        "branch-httpUrl",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07_O6 parse valid URL",
        "  GIVEN",
        "    URL url = new URL(\"http://example.com/\");",
        "    int timeout = 5000;",
        "    // stub HttpConnection.connect to return connStub",
        "    Connection connStub = stub(Connection.class);",
        "    when(connStub.timeout(timeout)).thenReturn(connStub);",
        "    when(connStub.get()).thenReturn(new Document(\"http://example.com/\"));",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc != null;",
        "    assert doc.baseUri().equals(\"http://example.com/\");"
      ]
    },
