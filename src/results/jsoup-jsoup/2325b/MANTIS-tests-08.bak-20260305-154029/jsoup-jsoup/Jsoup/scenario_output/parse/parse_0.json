{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty baseUri invokes Parser.parse and returns a Document",
      "path": "B0→B1→B2→B4",
      "precondition": "none",
      "expectedResult": "return a Document whose baseUri equals the provided baseUri and whose html() equals the parsed HTML tree",
      "tags": [
        "branch-baseUriNonEmpty",
        "overload:String,String",
        "positive",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parse with non-empty baseUri",
        "  GIVEN",
        "    String html = \"<p>hello</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "    assert doc.body().html().equals(\"<p>hello</p>\");"
      ]
    },
