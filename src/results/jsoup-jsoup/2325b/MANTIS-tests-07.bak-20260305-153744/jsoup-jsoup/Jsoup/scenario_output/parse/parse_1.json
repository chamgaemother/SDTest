{
  "scenarios": [
    {
      "id": "TC18",
      "description": "clean(String, String, Safelist) with empty baseUri and safelist.preserveRelativeLinks=true retains relative href using DummyUri branch",
      "path": "B0→B1→B2(true)→B3→B4→B5",
      "precondition": "none",
      "expectedResult": "returned HTML contains href starting with DummyUri placeholder and original relative path",
      "tags": [
        "positive",
        "clean",
        "branch",
        "relative-links"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 clean retains relative links via DummyUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"page.html\\\">link</a>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.relaxed().preserveRelativeLinks(true);",
        "  WHEN",
        "    String result = Jsoup.clean(html, baseUri, safelist);",
        "  THEN",
        "    assert result.contains(\"href=\\\"\" + SharedConstants.DummyUri + \"page.html\\\"\");"
      ]
    },
    {
      "id": "TC19",
      "description": "clean(String, Safelist) default preserveRelativeLinks removes relative href attribute branch",
      "path": "B0→B1→B2(false)→B3→B4→B5",
      "precondition": "none",
      "expectedResult": "returned HTML does not contain href attribute for relative link",
      "tags": [
        "positive",
        "clean",
        "branch",
        "relative-links"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 clean removes relative link attributes by default",
        "  GIVEN",
        "    String html = \"<a href=\\\"other.html\\\">x</a>\";",
        "    Safelist safelist = Safelist.basic();",
        "  WHEN",
        "    String result = Jsoup.clean(html, safelist);",
        "  THEN",
        "    assert !result.contains(\"href\");"
      ]
    },
    {
      "id": "TC20",
      "description": "clean(String, String, Safelist, OutputSettings) applies custom OutputSettings branch",
      "path": "B0→B3→B6→B7",
      "precondition": "none",
      "expectedResult": "returned HTML has no pretty printing (single line) and raw entity preserved",
      "tags": [
        "positive",
        "clean",
        "output-settings"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 clean respects OutputSettings",
        "  GIVEN",
        "    String html = \"<p>1 &lt; 2</p>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.none();",
        "    Document.OutputSettings settings = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String result = Jsoup.clean(html, baseUri, safelist, settings);",
        "  THEN",
        "    assert !result.contains(\"\\n\");",
        "    assert result.contains(\"&lt;\");"
      ]
    },
