      "id": "TC23",
      "description": "parse(File, String, String) throws IOException for invalid charsetName branch",
      "path": "B0→B1(invalid-charset)→exception",
      "precondition": "create temp HTML file with simple content",
      "expectedResult": "IOException is thrown due to unsupported charsetName",
      "tags": [
        "negative",
        "exception",
        "file",
        "charset"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 parse(File, invalid charset) throws IOException",
        "  GIVEN",
        "    File file = Files.createTempFile(\"f\",\".html\").toFile();",
        "    Files.write(file.toPath(), \"<p>x</p>\".getBytes());",
        "    String charsetName = \"BAD-CHARSET\";",
        "    String baseUri = \"http://u\";",
        "  WHEN",
        "    call Jsoup.parse(file, charsetName, baseUri);",
        "  THEN",
        "    throws IOException;"
      ]
    },
    {
      "id": "TC24",
      "description": "parse(File) reads .gz file and parses gzipped HTML branch",
      "path": "B0→B1(.gz)→B2→B3",
      "precondition": "create temp .gz file with gzipped HTML",
      "expectedResult": "body contains uncompressed HTML fragment",
      "tags": [
        "positive",
        "file",
        "gzip",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC24 parse gzipped .gz file",
        "  GIVEN",
        "    Path p = Files.createTempFile(\"t\",\".html.gz\");",
        "    try(OutputStream out=new java.util.zip.GZIPOutputStream(Files.newOutputStream(p))){",
        "      out.write(\"<i>GZ</i>\".getBytes(\"UTF-8\"));",
        "    }",
        "    File gz = p.toFile();",
        "  WHEN",
        "    Document doc = Jsoup.parse(gz);",
        "  THEN",
        "    assertEquals(\"<i>GZ</i>\", doc.body().html());"
      ]
    },
