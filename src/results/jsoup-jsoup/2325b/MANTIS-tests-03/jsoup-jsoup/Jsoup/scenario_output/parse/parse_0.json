    {
      "id": "TC08_O8",
      "description": "parse(URL, int) with valid HTTP URL returns Document",
      "path": "B0→B8→B9→B10",
      "precondition": "Embedded test HTTP server at http://localhost:8888 returns 200 and \"<p>OK</p>\"",
      "expectedResult": "returns Document whose body.html equals \"<p>OK</p>\"",
      "tags": [
        "overload:URL,int",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08_O8 parse(URL,int) valid URL",
        "  GIVEN",
        "    URL url = new URL(\"http://localhost:8888/\");",
        "    int timeout = 1000;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>OK</p>\");"
      ]
    },
