{
  "scenarios": [
    {
      "id": "TC08",
      "description": "parse(String, String, Parser) with XML parser returns XML content type",
      "path": "B0→B2→B5→B7→B9",
      "precondition": "none",
      "expectedResult": "Document.contentType() is \"text/xml\"",
      "tags": [
        "overload",
        "positive",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parse-string-baseuri-parser",
        "  GIVEN",
        "    String html = \"<root><a/></root>\";",
        "    String baseUri = \"\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.contentType().equals(\"text/xml\");",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "parse(String) without baseUri defaults to empty and returns parsed body",
      "path": "B0→B3→B6→B8",
