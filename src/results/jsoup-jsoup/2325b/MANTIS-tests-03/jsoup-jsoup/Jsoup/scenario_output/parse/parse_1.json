      "id": "TC17",
      "description": "parse(URL, timeout) with valid HTTP URL returns parsed HTML",
      "path": "B0→B7→B12→B14",
      "precondition": "HTTP server responds 200 OK with HTML",
      "expectedResult": "body.html() equals server response",
      "tags": [
        "overload",
        "network",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 parse-url-success",
        "  GIVEN",
        "    startHttpServer(200, \"<p>OK</p>\");",
        "    URL url = new URL(\"http://localhost:<port>/\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, 1000);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>OK</p>\");",
        "END"
      ]
    },
