package org.jsoup;

import org.jsoup.helper.DataUtil;
import org.jsoup.helper.HttpConnection;
import org.jsoup.nodes.Document;
import org.jsoup.parser.Parser;
import org.jsoup.safety.Safelist;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.function.Executable;

import java.io.ByteArrayInputStream;
import java.io.File;
import java.io.IOException;
import java.io.InputStream;
import java.net.InetSocketAddress;
import java.net.ServerSocket;
import java.net.Socket;
import java.net.URL;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;

import static org.junit.jupiter.api.Assertions.*;

public class Jsoup_parse_Test {

    @Test
    @DisplayName("TC08: parse(String, String, Parser) with XML parser returns XML content type")
    public void test_TC08() {
        // using xmlParser ensures contentType() should be "text/xml"
        String html = "<root><a/></root>";
        String baseUri = "";
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(html, baseUri, parser);
        assertEquals("text/xml", doc.contentType());
    }

    @Test
    @DisplayName("TC09: parse(String) without baseUri defaults to empty and returns parsed body")
    public void test_TC09() {
        // default parse uses HTML parser and baseUri="" so body.html() equals input
        String html = "<div>Hi</div>";
        Document doc = Jsoup.parse(html);
        assertEquals("<div>Hi</div>", doc.body().html());
    }

    @Test
    @DisplayName("TC10: parse(File, charsetName, baseUri, Parser) uses custom parser on file input")
    public void test_TC10() throws IOException {
        // write a temp XML file so xmlParser should detect XML and set contentType
        Path p = Files.createTempFile("JsoupTest", ".xml");
        Files.write(p, "<root/>".getBytes(StandardCharsets.UTF_8));
        File file = p.toFile();
        String charset = "UTF-8";
        String baseUri = "http://example.org/";
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(file, charset, baseUri, parser);
        assertEquals("text/xml", doc.contentType());
    }

    @Test
    @DisplayName("TC11: parse(Path, charsetName, baseUri) loads HTML from path with explicit charset and baseUri")
    public void test_TC11() throws IOException {
        // explicit charset and baseUri, ensures body.html() matches file content
        Path p = Files.createTempFile("t", ".html");
        Files.write(p, "<p>Path</p>".getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "";
        Document doc = Jsoup.parse(p, charset, baseUri);
        assertEquals("<p>Path</p>", doc.body().html());
    }

    @Test
    @DisplayName("TC12: parse(Path, charsetName) with null charsetName and default baseUri")
    public void test_TC12() throws IOException {
        // null charset should let DataUtil detect BOM and meta, so BOM consumed
        byte[] bomUtf8 = new byte[]{(byte)0xEF,(byte)0xBB,(byte)0xBF};
        Path p = Files.createTempFile("b", ".html");
        Files.write(p, concat(bomUtf8, "<span>Test</span>".getBytes(StandardCharsets.UTF_8)));
        Document doc = Jsoup.parse(p, null);
        assertEquals("<span>Test</span>", doc.body().html());
    }

    @Test
    @DisplayName("TC13: parse(Path) with default charset and baseUri uses BOM/UTF-8 fallback")
    public void test_TC13() throws IOException {
        // default parse(Path) should use null charset and correct baseUri
        Path p = Files.createTempFile("d", ".html");
        Files.write(p, "<h2>Hi</h2>".getBytes(StandardCharsets.UTF_8));
        Document doc = Jsoup.parse(p);
        assertEquals("<h2>Hi</h2>", doc.body().html());
    }

    @Test
    @DisplayName("TC14: parse(Path, charsetName, baseUri, Parser) invokes custom parser on path")
    public void test_TC14() throws IOException {
        // xmlParser on path with XML content should yield contentType=text/xml
        Path p = Files.createTempFile("x", ".xml");
        Files.write(p, "<root/>".getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "http://x/";
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(p, charset, baseUri, parser);
        assertEquals("text/xml", doc.contentType());
    }

    @Test
    @DisplayName("TC15: parse(InputStream, charsetName, baseUri) reads and parses stream content")
    public void test_TC15() throws IOException {
        // stream over HTML bytes should be parsed into body.html()
        String html = "<em>In</em>";
        InputStream in = new ByteArrayInputStream(html.getBytes(StandardCharsets.UTF_8));
        String charset = "UTF-8";
        String baseUri = "";
        Document doc = Jsoup.parse(in, charset, baseUri);
        assertEquals("<em>In</em>", doc.body().html());
    }

    @Test
    @DisplayName("TC16: parse(InputStream, charsetName, baseUri, Parser) uses custom parser on stream")
    public void test_TC16() throws IOException {
        // xmlParser on InputStream should yield contentType=text/xml
        String xml = "<root/>";
        InputStream in = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(in, "UTF-8", "", parser);
        assertEquals("text/xml", doc.contentType());
    }

    // minimal HTTP server helper for TC17–TC19
    private static class SimpleHttpServer extends Thread {
        private final int port;
        private final int status;
        private final String body;
        private final String contentType;
        private volatile boolean ready = false;

        SimpleHttpServer(int port, int status, String body, String contentType) {
            this.port = port; this.status = status; this.body = body; this.contentType = contentType;
        }
        public void run() {
            try (ServerSocket server = new ServerSocket(port)) {
                ready = true;
                Socket client = server.accept();
                String responseLine = "HTTP/1.1 " + status + " " + (status==200?"OK":"Error");
                String ct = contentType!=null?"Content-Type: "+contentType:"";
                String resp = responseLine + "\r\n" + ct + "\r\n\r\n" + body;
                client.getOutputStream().write(resp.getBytes(StandardCharsets.UTF_8));
                client.close();
            } catch (IOException ignored) {}
        }
        public void awaitReady() throws InterruptedException { while(!ready) Thread.sleep(10); }
    }

    @Test
    @DisplayName("TC17: parse(URL, timeout) with valid HTTP URL returns parsed HTML")
    public void test_TC17() throws Exception {
        int port = 8087;
        SimpleHttpServer srv = new SimpleHttpServer(port, 200, "<p>OK</p>", "text/html");
        srv.start();
        srv.awaitReady();
        URL url = new URL("http://localhost:" + port + "/");
        Document doc = Jsoup.parse(url, 1000);
        assertEquals("<p>OK</p>", doc.body().html());
    }

    @Test
    @DisplayName("TC18: parse(URL, timeout) for HTTP 404 throws HttpStatusException")
    public void test_TC18() throws Exception {
        int port = 8088;
        SimpleHttpServer srv = new SimpleHttpServer(port, 404, "Not Found", "text/html");
        srv.start();
        srv.awaitReady();
        URL url = new URL("http://localhost:" + port + "/missing");
        assertThrows(org.jsoup.HttpStatusException.class, () -> Jsoup.parse(url, 1000));
    }

    @Test
    @DisplayName("TC19: parse(URL, timeout) for unsupported mime type throws UnsupportedMimeTypeException")
    public void test_TC19() throws Exception {
        int port = 8089;
        SimpleHttpServer srv = new SimpleHttpServer(port, 200, "PDFDATA", "application/pdf");
        srv.start();
        srv.awaitReady();
        URL url = new URL("http://localhost:" + port + "/file.pdf");
        assertThrows(org.jsoup.UnsupportedMimeTypeException.class, () -> Jsoup.parse(url, 1000));
    }

    // helper to concat byte arrays
    private static byte[] concat(byte[] a, byte[] b) {
        byte[] c = new byte[a.length + b.length];
        System.arraycopy(a, 0, c, 0, a.length);
        System.arraycopy(b, 0, c, a.length, b.length);
        return c;
    }
}