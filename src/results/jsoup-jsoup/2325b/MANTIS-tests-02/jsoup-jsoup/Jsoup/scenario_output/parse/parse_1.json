      "id": "TC11",
      "description": "parse(File, charsetName, baseUri) with valid UTF-8 file returns Document with correct content and baseUri",
      "path": "B0â†’B1â†’DataUtil.loadâ†’Parser.parseâ†’Breturn",
      "precondition": "tempFile containing '<p>File</p>' in UTF-8 exists",
      "expectedResult": "Document.body().html() contains '<p>File</p>' and baseUri equals provided baseUri",
      "tags": [
        "positive",
        "file",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse File with charset and baseUri",
        "  GIVEN",
        "    File tempFile = createTempFile(\"<p>File</p>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://example.org/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(tempFile, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>File</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
