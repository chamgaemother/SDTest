      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05_O2 parse with custom parser",
        "  GIVEN",
        "    String html = \"any\";",
        "    Parser parser = new Parser(){ public Document parseInput(String in, String uri){ return new Document(uri).body().append(\"stub\"); }};",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"stub\");",
        "END"
