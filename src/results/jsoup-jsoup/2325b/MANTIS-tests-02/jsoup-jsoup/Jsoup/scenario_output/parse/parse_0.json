{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String, String) with non-empty html and non-empty baseUri returns a Document with correct baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals \"http://example.com/\" and Document.body().html() contains \"<p>Hello</p>\"",
      "tags": [
        "overload:String,String",
        "normal",
        "branch-no-exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "END"
      ]
    },
