    {
      "id": "TC24",
      "description": "clean(String, String, Safelist) with empty baseUri and preserveRelativeLinks=true assigns DummyUri",
      "path": "B0→B1(baseUri.isEmpty)→B2(safelist.preserveRelativeLinks)→B3→B4→return",
      "precondition": "Safelist.relaxed().preserveRelativeLinks(true)",
      "expectedResult": "returned HTML contains absolute URLs starting with DummyUri",
      "tags": [
        "positive",
        "clean",
        "branch",
        "safelist"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC24 clean preserves relative links with DummyUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"p.html\\\">x</a>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.relaxed().preserveRelativeLinks(true);",
        "  WHEN",
        "    String out = Jsoup.clean(html, baseUri, safelist);",
        "  THEN",
        "    assert out.contains(\"href=\\\"\" + org.jsoup.internal.SharedConstants.DummyUri);",
        "END"
      ]
    },
    {
      "id": "TC25",
      "description": "clean(String, String, Safelist) with empty baseUri and preserveRelativeLinks=false removes relative href",
      "path": "B0→B1(baseUri.isEmpty)→B2(!preserveRelativeLinks)→B4→return",
      "precondition": "Safelist.none() default preserveRelativeLinks=false",
      "expectedResult": "returned HTML contains no href attribute",
      "tags": [
        "negative",
        "clean",
        "branch",
        "safelist"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC25 clean removes relative links without preserveRelativeLinks",
        "  GIVEN",
        "    String html = \"<a href=\\\"p.html\\\">x</a>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.none();",
        "  WHEN",
        "    String out = Jsoup.clean(html, baseUri, safelist);",
        "  THEN",
        "    assert !out.contains(\"href\");",
        "END"
      ]
    },
    {
      "id": "TC26",
      "description": "clean(String, String, Safelist, Document.OutputSettings) applies outputSettings to cleaned document",
      "path": "B0→B1→B4(clean)→B5(outputSettings)→return",
      "precondition": "Safe HTML fragment and custom prettyPrint=false",
      "expectedResult": "returned HTML has no pretty-print indentations",
      "tags": [
        "positive",
        "clean",
        "outputSettings"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC26 clean with custom outputSettings",
        "  GIVEN",
        "    String html = \"<div><p>x</p></div>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.simpleText();",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String out = Jsoup.clean(html, baseUri, safelist, os);",
        "  THEN",
        "    assert out.equals(\"<p>x</p>\");",
        "END"
      ]
    },
