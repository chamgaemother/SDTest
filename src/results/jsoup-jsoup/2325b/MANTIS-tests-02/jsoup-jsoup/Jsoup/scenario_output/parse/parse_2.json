{
  "scenarios": [
    {
      "id": "TC19",
      "description": "parse(String, String, Parser) with null baseUri throws IllegalArgumentException",
      "path": "B0→B1(html≠null)→B2(baseUri==null)→B6",
      "precondition": "Parser.htmlParser() available",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse null-baseUri with parser",
        "  GIVEN",
        "    String html = \"<p>OK</p>\";",
        "    String baseUri = null;",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC20",
      "description": "parse(File, charsetName, baseUri, Parser) returns Document from DataUtil.load with custom parser",
      "path": "B0→B1→B2→B3(parser≠null)→B4→B5→B9",
      "precondition": "tempFile exists with content \"<x/>\"",
      "expectedResult": "Document.body.html() == \"<x/>\" and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse file with custom parser",
        "  GIVEN",
        "    File f = tempFile(\".html\",\"<x/>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://a/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<x/>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
