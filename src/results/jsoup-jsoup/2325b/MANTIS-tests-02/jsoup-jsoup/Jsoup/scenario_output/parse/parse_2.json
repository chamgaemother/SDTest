      "expectedResult": "java.net.SocketTimeoutException is thrown",
      "tags": [
        "negative",
        "timeout",
        "network"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC23 parse URL timeout",
        "  GIVEN",
        "    start HTTP server delaying 200ms per request;",
        "    URL url = http://localhost:port/;",
        "  WHEN",
        "    call Jsoup.parse(url, 50);",
        "  THEN",
        "    throws java.net.SocketTimeoutException;",
        "END"
      ]
