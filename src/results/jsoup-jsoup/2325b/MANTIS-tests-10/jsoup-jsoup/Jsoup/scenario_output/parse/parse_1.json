    {
      "id": "TC15",
      "description": "parse(File, charsetName, baseUri, parser) invokes DataUtil.load with parser override",
      "path": "B0→B2→B3",
      "precondition": "temp file exists with valid HTML",
      "expectedResult": "Document returned via DataUtil.load with parser",
      "tags": [
        "positive",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 parse file with custom parser",
        "  GIVEN",
        "    File f = File.createTempFile(\"t\",\".html\");",
        "    f.deleteOnExit();",
        "    Files.write(f.toPath(),\"<p id='x'>X</p>\".getBytes());",
        "    Parser xml = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, \"UTF-8\", \"http://b/\", xml);",
        "  THEN",
        "    assert doc.getElementById(\"x\").text().equals(\"X\");",
        "    assert doc.baseUri().equals(\"http://b/\");",
        "END"
      ]
    },
    {
      "id": "TC16",
      "description": "parse(Path, charsetName) loads from Path with fallback baseUri path.toAbsolutePath()",
      "path": "B0→B2",
      "precondition": "temp path exists with HTML content",
      "expectedResult": "Document.baseUri()==path.toAbsolutePath and element present",
      "tags": [
        "positive",
        "path",
        "fallback"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 parse(Path, charset) fallback baseUri",
        "  GIVEN",
        "    Path p = Files.createTempFile(\"t\",\".html\");",
        "    Files.write(p, \"<div id='d'>D</div>\".getBytes());",
        "  WHEN",
        "    Document doc = Jsoup.parse(p, \"UTF-8\");",
        "  THEN",
        "    assert doc.baseUri().equals(p.toAbsolutePath().toString());",
        "    assert doc.getElementById(\"d\").text().equals(\"D\");",
        "END"
      ]
    },
