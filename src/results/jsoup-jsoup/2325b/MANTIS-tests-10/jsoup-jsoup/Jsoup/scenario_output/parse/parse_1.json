{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(html, baseUri, custom parser) invokes parser.parseInput and returns its Document",
      "path": "B0→B2→B3",
      "precondition": "none",
      "expectedResult": "Document returned from custom parser.parseInput is returned",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse with custom parser",
        "  GIVEN",
        "    String html = \"<div/>\";",
        "    String baseUri = \"http://x/\";",
        "    Parser stub = new Parser(new Parser.Settings()) {",
        "      @Override public Document parseInput(String in, String uri) {",
        "        Document d = Document.createShell(uri);",
        "        d.body().appendElement(\"marker\").attr(\"id\",\"m\");",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stub);",
        "  THEN",
        "    assert doc.getElementById(\"m\") != null;",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(html) uses Parser.parse(html, \"\") default baseUri",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "Document.baseUri() == \"\" and element parsed",
      "tags": [
        "positive",
        "overload",
        "default"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse(html) default overload",
        "  GIVEN",
        "    String html = \"<span id='s'>X</span>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.getElementById(\"s\").text().equals(\"X\");",
        "END"
      ]
    },
