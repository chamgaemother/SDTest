      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 parse(URL,timeout) success",
        "  GIVEN",
        "    URL url = new URL(\"http://x/\");",
        "    int t = 2000;",
        "    // use reflection to stub HttpConnection.connect(URL) to return",
        "    // a Connection whose timeout(int) returns self and get() returns shell with title 'S'",
