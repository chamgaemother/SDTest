{
  "scenarios": [
    {
      "id": "TC19",
      "description": "parse(html, baseUri, custom parser) invokes parser.parseInput path B0→B2→B3",
      "path": "B0→B2→B3",
      "precondition": "none",
      "expectedResult": "Document returned from stub parser",
      "tags": [
        "positive",
        "overload",
        "custom-parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC19 parse html with custom parser",
        "  GIVEN",
        "    String html = \"<custom/>\";",
        "    String baseUri = \"http://u/\";",
        "    Parser stub = new Parser(new Parser.Settings()){",
        "      @Override public Document parseInput(String in, String uri){",
        "        Document d = Document.createShell(uri);",
        "        d.body().appendElement(\"marker\").attr(\"id\",\"m\");",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stub);",
        "  THEN",
        "    assert doc.getElementById(\"m\") != null;",
        "    assertEquals(baseUri, doc.baseUri());",
        "END"
      ]
    },
    {
