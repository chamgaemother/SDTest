        "TEST TC21 parse(File,charsetName) explicit charset",
        "  GIVEN",
        "    File f = File.createTempFile(\"t\",\".html\");",
        "    f.deleteOnExit();",
        "    Files.write(f.toPath(), \"<div>Ž</div>\".getBytes(StandardCharsets.UTF_16));",
        "    String cs = \"UTF-16\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, cs);",
        "  THEN",
        "    assertEquals(\"Ž\", doc.select(\"div\").text());",
        "    assertEquals(f.getAbsolutePath(), doc.baseUri());",
        "END"
