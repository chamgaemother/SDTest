      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 parse(html) default baseUri",
        "  GIVEN",
        "    String html = \"<span/>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
