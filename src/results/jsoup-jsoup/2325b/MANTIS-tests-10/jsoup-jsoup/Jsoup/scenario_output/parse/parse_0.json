{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(html non-empty, baseUri non-empty) returns Document via Parser.parse(html, baseUri)",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "returned Document has html identical to input and baseUri set to provided URI",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-html-non-empty",
        "branch-baseUri-non-empty"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse with html and baseUri",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.html().contains(\"<p>Test</p>\");",
        "    assert doc.baseUri().equals(\"http://example.com/\");"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(html empty, baseUri empty) returns empty Document with no elements",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "returned Document has no body children and baseUri is empty string",
      "tags": [
        "overload:String,String",
        "boundary",
        "branch-html-empty",
        "branch-baseUri-empty"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse empty html and empty baseUri",
        "  GIVEN",
        "    String html = \"\";",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().children().isEmpty();",
        "    assert doc.baseUri().equals(\"\");"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(html, baseUri, parser) invokes parser.parseInput and returns its Document",
      "path": "B0→B5→B6→B7",
      "precondition": "Parser stub used because real Parser.parseInput is heavy; stub returns a Document with a marker element",
      "expectedResult": "returned Document contains element with id \"stub-marker\"",
      "tags": [
        "overload:String,String,Parser",
        "positive",
        "branch-custom-parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse with custom parser",
        "  GIVEN",
        "    String html = \"<div/>\";",
        "    String baseUri = \"\";",
        "    Parser stubParser = new Parser() { public Document parseInput(String h, String b) { Document d = Document.createShell(b); d.body().appendElement(\"marker\").attr(\"id\",\"stub-marker\"); return d; } } ;",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stubParser);",
        "  THEN",
        "    assert doc.getElementById(\"stub-marker\") != null;"
      ]
    },
    {
      "id": "TC04",
      "description": "parse(html, parser) with empty html iterates parseInput with default baseUri",
      "path": "B0→B8→B6→B7",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals empty string",
      "tags": [
        "overload:String,Parser",
        "boundary",
        "branch-html-empty",
        "loop-0"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 parse(html, parser) empty html",
        "  GIVEN",
        "    String html = \"\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");"
      ]
    },
    {
      "id": "TC05",
      "description": "parse(html) uses Parser.parse(html, \"\") default baseUri",
