    {
      "id": "TC06",
      "description": "parse(File, charsetName, baseUri) throws IOException when file does not exist",
      "path": "B0→B10→B11",
      "precondition": "none",
      "expectedResult": "throws IOException; no Document returned",
      "tags": [
        "overload:File,String,String",
        "exception",
        "branch-file-not-found"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse non-existent file throws IOException",
        "  GIVEN",
        "    File file = new File(\"/path/does/not/exist.html\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    call Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    throws IOException;"
      ]
    },
    {
      "id": "TC07",
      "description": "parse(File, null, baseUri) falls back to UTF-8 when meta not present",
      "path": "B0→B10→B12→B4",
      "precondition": "create temp file with content \"<p>abc</p>\" in UTF-8; charsetName=null",
      "expectedResult": "returned Document contains <p>abc</p> and baseUri equals file absolute path",
      "tags": [
        "overload:File,String,String",
        "branch-charset-null",
        "boundary",
        "loop-0"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 parse file with null charset uses UTF-8",
        "  GIVEN",
        "    File file = File.createTempFile(\"test\",\".html\");",
        "    Files.write(file.toPath(), \"<p>abc</p>\".getBytes(StandardCharsets.UTF_8));",
        "    String charset = null;",
        "    String baseUri = file.getAbsolutePath();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.select(\"p\").text().equals(\"abc\");",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
