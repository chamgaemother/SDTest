{
  "scenarios": [
    {
      "id": "TC16",
      "description": "parse(File, String charsetName, String baseUri, Parser) uses provided parser to parse file content",
      "path": "B0→B1→B2",
      "precondition": "temp HTML file exists with UTF-8 content",
      "expectedResult": "Document body matches file content and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "File",
        "Parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse File with parser",
        "  GIVEN",
        "    File file = tempFile(\"<p>X</p>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>X</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
