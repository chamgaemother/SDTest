    {
      "id": "TC15",
      "description": "parse(InputStream in, String charsetName, String baseUri) loads stream and returns Document",
      "path": "B0→B??→DataUtil.load→return",
      "precondition": "InputStream over byte[] of '<i>It</i>' UTF-8",
      "expectedResult": "Document.body().html equals '<i>It</i>' and baseUri preserved",
      "tags": [
        "stream",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse(InputStream, charset, baseUri)",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<i>It</i>\".getBytes(StandardCharsets.UTF_8));",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, \"UTF-8\", \"http://xyz/\");",
        "  THEN",
        "    assert doc.body().html().equals(\"<i>It</i>\");",
        "    assert doc.baseUri().equals(\"http://xyz/\");"
      ]
