{
  "scenarios": [
    {
      "id": "TC09",
      "description": "parse(String html) uses empty baseUri and returns Document with body content",
      "path": "B0→B??→B??→return",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals input fragment and baseUri is empty",
      "tags": [
        "overload",
        "positive",
        "default-baseUri"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 parse(html) default-overload",
        "  GIVEN",
        "    String html = \"<div>Test</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>Test</div>\");",
        "    assert doc.baseUri().equals(\"\");"
      ]
    },
    {
      "id": "TC10",
      "description": "parseBodyFragment(String bodyHtml, String baseUri) returns Document fragment with preserved baseUri",
      "path": "B0→B??→B??→return",
      "precondition": "none",
      "expectedResult": "body.html equals input and baseUri preserved",
      "tags": [
        "fragment",
        "positive",
        "baseUri"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String frag = \"<p>Frag</p>\";",
        "    String base = \"http://bs/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag, base);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Frag</p>\");",
        "    assert doc.baseUri().equals(\"http://bs/\");"
      ]
    },
