      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse(File, null, baseUri)",
        "  GIVEN",
        "    File f = createTempFileWithContent(\"<h1>Hdr</h1>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, null, \"http://base/\");",
        "  THEN",
        "    assert doc.body().html().equals(\"<h1>Hdr</h1>\");",
        "    assert doc.baseUri().equals(\"http://base/\");"
      ]
