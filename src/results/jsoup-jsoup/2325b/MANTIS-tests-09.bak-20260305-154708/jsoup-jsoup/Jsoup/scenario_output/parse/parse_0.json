{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) returns Document with body content when html and baseUri are non-null and non-empty",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.body().html() equals \"<p>Hello</p>\" and Document.baseUri() equals \"http://example.com/\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-regular"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse HTML with baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\"; String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\"); assert doc.baseUri().equals(\"http://example.com/\");",
        "END"
      ]
    },
    {
