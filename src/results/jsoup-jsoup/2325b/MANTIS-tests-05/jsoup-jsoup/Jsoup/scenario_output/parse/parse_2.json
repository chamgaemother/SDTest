{
  "scenarios": [
    {
      "id": "TC18",
      "description": "parse(File, charsetName, baseUri, parser) invokes custom Parser.parseInput overload",
      "path": "B0→B10→B24→B25",
      "precondition": "has a temporary HTML file",
      "expectedResult": "returns the Document produced by stub parser",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 parse file with custom parser",
        "  GIVEN",
        "    // Arrange",
        "    File tmp = createTempFile(\"jsoup\", \".html\");",
        "    write(tmp, \"<u>under</u>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "    class StubParser extends Parser {",
        "      Document doc = new Document(\"stub\");",
        "      String inHtml, inBase;",
        "      StubParser() { super(null); }",
        "      @Override public Document parseInput(String html, String uri) {",
        "        inHtml = html; inBase = uri; return doc;",
        "      }",
        "    }",
        "    Parser parser = new StubParser();",
        "  WHEN",
        "    Document result = Jsoup.parse(tmp, charset, baseUri, parser);",
        "  THEN",
        "    // Assert",
        "    assertSame(((StubParser)parser).doc, result);",
        "    assertEquals(\"<u>under</u>\", ((StubParser)parser).inHtml);",
        "    assertEquals(baseUri, ((StubParser)parser).inBase);"
      ]
    },
    {
