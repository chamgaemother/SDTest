    {
      "id": "TC20",
      "description": "parse(InputStream, charsetName, baseUri, parser) invokes custom Parser.parseInput overload",
      "path": "B0→B17→B26→B27",
      "precondition": "provides a non-empty InputStream",
      "expectedResult": "returns the Document produced by stub parser and closes stream",
      "tags": [
        "positive",
        "overload",
        "parser",
        "resource"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC20 parse stream with custom parser",
        "  GIVEN",
        "    byte[] data = \"<i>one</i>\".getBytes(\"UTF-8\");",
        "    class TrackStream extends ByteArrayInputStream {",
        "      boolean closed = false;",
        "      TrackStream(byte[] b) { super(b); }",
        "      @Override public void close() throws IOException { super.close(); closed=true; }",
        "    }",
        "    TrackStream in = new TrackStream(data);",
        "    String charset = null;",
        "    String baseUri = \"\";",
        "    class StubParser extends Parser {",
        "      Document doc = new Document(\"stub\");",
        "      String inHtml, inBase;",
        "      StubParser() { super(null); }",
        "      @Override public Document parseInput(String html, String uri) {",
        "        inHtml = html; inBase = uri; return doc;",
        "      }",
        "    }",
        "    Parser parser = new StubParser();",
        "  WHEN",
        "    Document result = Jsoup.parse(in, charset, baseUri, parser);",
        "  THEN",
        "    assertSame(((StubParser)parser).doc, result);",
        "    assertTrue(in.closed);",
        "    assertEquals(\"<i>one</i>\", ((StubParser)parser).inHtml);"
      ]
    },
    {
      "id": "TC21",
      "description": "parse(File) on a .gz compressed HTML file reads and parses content",
      "path": "B0→B10→B11",
      "precondition": "create a temp .gz file with gzipped HTML payload",
      "expectedResult": "parses inner HTML and sets baseUri to file path",
      "tags": [
        "positive",
        "boundary",
        "gzipped"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC21 parse gzipped file",
        "  GIVEN",
        "    File gz = createTempFile(\"test\",\".html.gz\");",
        "    gzipWrite(gz, \"<b>zip</b>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(gz);",
        "  THEN",
        "    assertEquals(\"zip\", doc.select(\"b\").text());",
        "    assertEquals(gz.getAbsolutePath(), doc.baseUri());"
      ]
    },
