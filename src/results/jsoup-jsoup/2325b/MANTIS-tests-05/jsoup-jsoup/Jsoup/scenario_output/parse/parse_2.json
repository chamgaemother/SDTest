        "gzipped"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 parse compressed path .z",
        "  GIVEN",
        "    Path p = createTempFilePath(\"test\",\".html.z\");",
        "    gzipWrite(p.toFile(), \"<span>z</span>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(p);",
