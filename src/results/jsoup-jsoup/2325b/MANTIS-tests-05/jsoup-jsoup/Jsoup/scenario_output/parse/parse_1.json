{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File) loads HTML and sets baseUri to file absolute path",
      "path": "B0→B10→B11",
      "precondition": "temp HTML file exists with content \"<p>Fpath</p>\"",
      "expectedResult": "Document baseUri equals file.getAbsolutePath() and p text is 'Fpath'",
      "tags": [
        "positive",
        "file",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse file no-charset/baseUri",
        "  GIVEN",
        "    File tmp = createTempHtmlFile(\"<p>Fpath</p>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp);",
        "  THEN",
        "    assert doc.baseUri().equals(tmp.getAbsolutePath());",
        "    assert doc.select(\"p\").text().equals(\"Fpath\");"
      ]
    },
