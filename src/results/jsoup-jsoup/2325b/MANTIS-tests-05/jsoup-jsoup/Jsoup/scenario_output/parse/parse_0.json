    {
      "id": "TC03",
      "description": "parse(html, baseUri, parser) with custom parser invoked",
      "path": "B0→B4→B5",
      "precondition": "parser is a stub that records parseInput arguments",
      "expectedResult": "parser.parseInput was called with html and baseUri and returned the stubbed Document",
      "tags": [
        "overload:String,String,Parser",
        "branch-parser-invoked",
        "stub:Parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse(String html, String baseUri, Parser parser) custom-parser",
        "  GIVEN",
        "    String html = \"<div>1</div>\";",
        "    String baseUri = \"\";",
        "    Parser parser = new StubParser();",
        "  WHEN",
        "    Document result = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert parser.inputHtml.equals(\"<div>1</div>\");",
        "    assert parser.inputBaseUri.equals(\"\");",
        "    assert result == parser.returnedDocument;",
        "END"
      ]
    },
