        "    int timeout = 5000;",
        "    StubConnection con = new StubConnection();",
        "    stub HttpConnection.connect(url) to return con;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc == con.returnedDocument;",
        "END"
