    {
      "id": "TC06",
      "description": "parse(file, charsetName, baseUri) with valid file returns Document",
      "path": "B0→B10→B11",
      "precondition": "create temp HTML file with content \"<a href='x'>x</a>\"",
      "expectedResult": "returned Document.select(\"a\").attr(\"href\").equals(\"x\") and baseUri equals provided baseUri",
      "tags": [
        "overload:File,String,String",
        "branch-file-load",
        "positive"
