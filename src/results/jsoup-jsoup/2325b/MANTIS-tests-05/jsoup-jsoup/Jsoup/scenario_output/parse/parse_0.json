{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri returns Document via Parser.parse",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document has its baseUri equal to the provided baseUri and contains parsed nodes matching the html input",
      "tags": [
        "overload:String,String",
        "branch-basic",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse(String html, String baseUri) basic-parse",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "    assert doc.select(\"p\").text().equals(\"Test\");",
        "END"
      ]
    },
    {
