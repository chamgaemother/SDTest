      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 parse(File file, String charsetName, String baseUri) valid-file",
        "  GIVEN",
        "    File file = createTempFile(\"<a href='x'>x</a>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://site/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").attr(\"href\").equals(\"x\");",
        "    assert doc.baseUri().equals(\"http://site/\");",
        "END"
      ]
