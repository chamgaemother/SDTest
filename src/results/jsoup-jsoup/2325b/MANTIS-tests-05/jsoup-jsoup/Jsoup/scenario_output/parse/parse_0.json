        "    String charset = null;",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.select(\"b\").text().equals(\"bold\");",
        "    assert in.isClosed();",
