{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(html, empty baseUri) returns Document with empty baseUri and normalized body",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "Document.baseUri() == \"\" and body HTML is normalized",
      "tags": [
        "boundary",
        "overload",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse-empty-baseUri",
        "  GIVEN",
        "    String html = \"<div/>\";",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.body().html().equals(\"<div></div>\");",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(html, custom Parser) invokes parser.parseInput and returns stub Document",
      "path": "B0→B2→B6→B7",
      "precondition": "custom Parser stub overrides parseInput",
      "expectedResult": "Document returned is from stub parser",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse-with-parser-overload",
        "  GIVEN",
        "    String html = \"x\";",
        "    Parser stub = new Parser() {",
        "      @Override Document parseInput(String h, String u) {",
        "        Document d = new Document(\"u\"); d.title(\"stub\"); return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, stub);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.title().equals(\"stub\");",
        "END"
      ]
    },
    {
      "id": "TC13",
      "description": "parse(html, baseUri, custom Parser) delegates to parser.parseInput with correct baseUri",
      "path": "B0→B2→B6→B7",
      "precondition": "Parser stub captures passed baseUri",
      "expectedResult": "Document.baseUri() == provided and title from stub",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse-baseUri-parser",
        "  GIVEN",
        "    String html = \"p\";",
        "    String baseUri = \"u\";",
        "    Parser stub = new Parser() {",
        "      @Override Document parseInput(String h, String bu) {",
        "        Document d = new Document(bu); d.title(\"byStub\"); return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stub);",
        "  THEN",
        "    assert doc.baseUri().equals(\"u\");",
        "    assert doc.title().equals(\"byStub\");",
        "END"
      ]
    },
