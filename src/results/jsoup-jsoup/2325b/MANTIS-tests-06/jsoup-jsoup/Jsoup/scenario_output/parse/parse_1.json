      "pseudocode": [
        "TEST TC14 parse-file-charset-baseUri-parser",
        "  GIVEN",
        "    File file = createTempHtml(\"<p>z</p>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"u\";",
        "    Parser stub = new Parser() {",
        "      @Override Document parseInput(String h, String bu) {",
        "        Document d = new Document(bu); d.title(\"fp\"); return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, stub);",
        "  THEN",
        "    assert doc.baseUri().equals(\"u\");",
        "    assert doc.title().equals(\"fp\");",
        "END"
      ]
