{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and baseUri returns Document with correct baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals provided baseUri and Document.body() parsed content",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-normal"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>hello</p>\"; String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\"); assert doc.body().html().equals(\"<p>hello</p>\");",
        "END"
      ]
    },
    {
