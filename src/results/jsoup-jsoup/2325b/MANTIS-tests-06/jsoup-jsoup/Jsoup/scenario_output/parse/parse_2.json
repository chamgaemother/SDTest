{
  "scenarios": [
    {
      "id": "TC21",
      "description": "parse(html, Parser) invokes custom parser.parseInput and returns stub Document",
      "path": "B0→B3→B4",
      "precondition": "none",
      "expectedResult": "Document returned by stub parser with baseUri '' and title 'stub1'",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC21 parse with parser-only overload",
        "  GIVEN",
        "    String html = \"<x>y</x>\";",
        "    Parser stub = new Parser() {",
        "      @Override",
        "      public Document parseInput(String sourceHtml, String baseUri) {",
        "        Document d = new Document(baseUri);",
        "        d.title(\"stub1\");",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, stub);",
        "  THEN",
        "    assertEquals(\"\", doc.baseUri());",
        "    assertEquals(\"stub1\", doc.title());"
      ]
    },
    {
