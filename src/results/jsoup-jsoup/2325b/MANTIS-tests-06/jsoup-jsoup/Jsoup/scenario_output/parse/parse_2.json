      "expectedResult": "Document returned by stub parser with baseUri 'u2' and title 'stub2'",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC22 parse with baseUri and parser",
        "  GIVEN",
        "    String html = \"body\";",
        "    String baseUri = \"u2\";",
        "    Parser stub = new Parser() {",
        "      @Override",
        "      public Document parseInput(String src, String bu) {",
        "        Document d = new Document(bu);",
        "        d.title(\"stub2\");",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, stub);",
        "  THEN",
        "    assertEquals(\"u2\", doc.baseUri());",
        "    assertEquals(\"stub2\", doc.title());"
      ]
    },
    {
      "id": "TC23",
      "description": "parseBodyFragment(bodyHtml, baseUri) returns Document containing fragment in body",
      "path": "B0→B1→B5",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals '<p>f</p>' and baseUri 'http://a/'",
      "tags": [
        "positive",
        "fragment"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String fragment = \"<p>f</p>\";",
        "    String baseUri = \"http://a/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, baseUri);",
        "  THEN",
        "    assertEquals(\"http://a/\", doc.baseUri());",
        "    assertEquals(\"<p>f</p>\", doc.body().html());"
      ]
    },
