    {
      "id": "TC25",
      "description": "parse(File, charsetName, baseUri, Parser) uses DataUtil.load with parser override",
      "path": "B0→B7→B8",
      "precondition": "temp file exists with '<d>d</d>'",
      "expectedResult": "Document from stub parser with title 'fp2' and baseUri 'u3'",
      "tags": [
        "positive",
        "file",
        "parser",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC25 parse file with parser overload",
        "  GIVEN",
        "    Path temp = Files.createTempFile(\"jsoup\", \".html\");",
        "    Files.write(temp, \"<d>d</d>\".getBytes(StandardCharsets.UTF_8));",
        "    File file = temp.toFile();",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"u3\";",
        "    Parser stub = new Parser() {",
        "      @Override",
        "      public Document parseInput(String h, String bu) {",
        "        Document d = new Document(bu);",
        "        d.title(\"fp2\");",
        "        return d;",
        "      }",
        "    };",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, stub);",
        "  THEN",
        "    assertEquals(\"u3\", doc.baseUri());",
        "    assertEquals(\"fp2\", doc.title());"
      ]
    },
