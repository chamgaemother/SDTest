      "id": "TC19",
      "description": "parse(InputStream, charsetName, baseUri, Parser) loads stream via provided parser",
      "path": "B0→B10→B11→B12→B13",
      "precondition": "ByteArrayInputStream with XML fragment",
      "expectedResult": "Document parsed by xmlParser contains expected tag; baseUri equals provided",
      "tags": [
        "positive",
        "overload",
        "stream",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse(InputStream, charset, baseUri, parser)",
        "  GIVEN",
        "    byte[] data = \"<t>1</t>\".getBytes(UTF_8);",
        "    InputStream in = new ByteArrayInputStream(data);",
        "    String charset = \"UTF-8\";",
        "    String base = \"http://b/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, base, parser);",
        "  THEN",
        "    assert doc.getElementsByTag(\"t\").size() == 1;",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
