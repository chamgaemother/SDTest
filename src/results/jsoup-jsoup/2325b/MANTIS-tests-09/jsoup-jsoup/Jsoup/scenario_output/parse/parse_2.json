{
  "scenarios": [
    {
      "id": "TC16",
      "description": "parse(File) loads file with default null charset and uses file absolute path as baseUri",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "temporary HTML file exists with valid UTF-8 content",
      "expectedResult": "Document.body().html() matches file content; baseUri equals file.getAbsolutePath()",
      "tags": [
        "positive",
        "overload",
        "file",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse(File) default charset",
        "  GIVEN",
        "    Path temp = createTempFile(\"t\", \".html\");",
        "    write temp with \"<h3>Main</h3>\" in UTF-8;",
        "    File f = temp.toFile();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f);",
        "  THEN",
        "    assert doc.body().html().equals(\"<h3>Main</h3>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "parse(File, charsetName, baseUri, Parser) loads file using provided parser and charsetName null",
      "path": "B0→B1→B2→B5→B6",
      "precondition": "temporary HTML file exists with XML-like content",
      "expectedResult": "Document contains XML element parsed; baseUri equals provided baseUri",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 parse(File, null, baseUri, xmlParser)",
        "  GIVEN",
        "    Path temp = createTempFile(\"txml\", \".html\");",
        "    write temp with \"<node>val</node>\" in UTF-8;",
        "    File f = temp.toFile();",
        "    String base = \"http://xml/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, null, base, parser);",
        "  THEN",
        "    assert doc.getElementsByTag(\"node\").size() == 1;",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
