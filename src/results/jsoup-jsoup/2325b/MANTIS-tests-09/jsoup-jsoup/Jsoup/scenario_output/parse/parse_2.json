      "description": "parse(URL, timeoutMillis) with non-http scheme URL throws MalformedURLException",
      "path": "B0→B14→B15",
      "precondition": "URL uses unsupported protocol (ftp)",
      "expectedResult": "MalformedURLException is thrown",
      "tags": [
        "negative",
        "exception",
        "url"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse(URL, timeout) unsupported protocol",
        "  GIVEN",
        "    URL url = new URL(\"ftp://example.com/file\");",
        "    int timeout = 1000;",
        "  WHEN",
        "    call Jsoup.parse(url, timeout);",
        "  THEN",
        "    throws MalformedURLException;",
        "END"
      ]
    },
    {
      "id": "TC21",
      "description": "parse(URL, timeoutMillis) propagates SocketTimeoutException from Connection.get()",
      "path": "B0→B14→B16→B17",
      "precondition": "HttpConnection.connect(url) returns a Connection whose get() throws SocketTimeoutException",
      "expectedResult": "SocketTimeoutException is thrown",
      "tags": [
        "negative",
        "exception",
        "url",
        "timeout"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 parse(URL, timeout) get() timeout",
        "  GIVEN",
        "    URL url = new URL(\"http://slow.example\");",
        "    int tm = 1234;",
        "    MockedStatic<HttpConnection> ms = mockStatic(HttpConnection.class);",
        "    Connection con = mock(Connection.class);",
        "    when(con.timeout(tm)).thenReturn(con);",
        "    when(con.get()).thenThrow(new SocketTimeoutException());",
        "    ms.when(() -> HttpConnection.connect(url)).thenReturn(con);",
        "  WHEN",
        "    call Jsoup.parse(url, tm);",
        "  THEN",
        "    throws SocketTimeoutException;",
        "  CLEANUP",
        "    ms.close();",
        "END"
      ]
    },
