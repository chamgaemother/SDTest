        "  GIVEN",
        "    String html = \"<p>test</p>\";",
        "    String base = \"\";",
        "    Parser parser = null;",
        "  WHEN",
        "    call Jsoup.parse(html, base, parser);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
