{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(String html, String baseUri, Parser parser) uses provided parser and preserves baseUri",
      "path": "B0→B2→B7→B8",
      "precondition": "none",
      "expectedResult": "Document parsed by xmlParser with element count and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse with html, baseUri, and parser",
        "  GIVEN",
        "    String html = \"<a href=\\\"x\\\">link</a>\";",
        "    String base = \"http://test/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, base, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(base);",
        "    assert doc.getElementsByTag(\"a\").size() == 1;"
      ]
    },
    {
