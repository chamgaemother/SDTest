    {
      "id": "TC14",
      "description": "parseBodyFragment(String bodyHtml, String baseUri) wraps fragment in body and resolves relative links",
      "path": "B0→B3→B10→B11",
      "precondition": "none",
      "expectedResult": "Document body contains fragment and baseUri used to resolve links",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parseBodyFragment with html and baseUri",
        "  GIVEN",
        "    String fragment = \"<img src=\\\"img.png\\\">\";",
        "    String base = \"http://site.com/path/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, base);",
        "  THEN",
        "    assert doc.body().html().contains(\"<img src=\\\"http://site.com/path/img.png\\\">\");"
      ]
    },
