    {
      "id": "TC04_O2",
      "description": "parse(String html, Parser parser) with custom xmlParser returns Document parsed by provided parser",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals \"\" and Document output by xmlParser",
      "tags": [
        "overload:String,Parser",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04_O2 parse(String,Parser) xml-parser",
        "  GIVEN",
        "    String html = \"<node>data</node>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.getElementsByTag(\"node\").size() == 1;"
      ]
    },
