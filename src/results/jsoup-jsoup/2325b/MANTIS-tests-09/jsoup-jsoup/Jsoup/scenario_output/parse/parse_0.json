      "id": "TC10_O6",
      "description": "parse(URL url, int timeoutMillis) with valid HTTP URL returns fetched Document",
      "path": "B0→B1→B2→B3",
      "precondition": "mock HttpConnection.connect(URL) to return fake Connection whose get() returns Document with body <ok>",
      "expectedResult": "returned Document.body().html() equals \"<ok>\"",
      "tags": [
        "overload:URL,int",
        "positive",
        "mocked-http"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10_O6 parse(URL,int) http-fetch",
        "  GIVEN",
        "    URL url = new URL(\"http://example.com\");",
        "    Connection con = stub Connection with timeout and get() returning Document with body \"<ok>\";",
        "    stub HttpConnection.connect(url) -> con;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, 1000);",
        "  THEN",
        "    assert doc.body().html().equals(\"<ok>\");"
      ]
    }
