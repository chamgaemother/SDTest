{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) with simple HTML returns Document with correct baseUri",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals \"http://example.com/\" and Document.body().html() equals \"<p>Hi</p>\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-normal"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse(String,String) simple-html",
        "  GIVEN",
        "    String html = \"<p>Hi</p>\";",
        "    String base = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, base);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "    assert doc.body().html().equals(\"<p>Hi</p>\");"
      ]
    },
    {
