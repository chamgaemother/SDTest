      "id": "TC17",
      "description": "parse(InputStream, String charsetName, String baseUri, Parser parser) with XML parser reads and parses correctly",
      "path": "B0→B1→B2→B9",
      "precondition": "ByteArrayInputStream over <item>1</item>",
      "expectedResult": "doc.select(\"item\").text() equals \"1\"; baseUri set accordingly",
      "tags": [
        "positive",
        "stream",
        "parser-overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 parse stream with parser",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<item>1</item>\".getBytes());",
        "    String charsetName = \"UTF-8\";",
        "    String baseUri = \"http://stream/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charsetName, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"item\").first().text().equals(\"1\");",
        "END"
      ]
