    {
      "id": "TC14",
      "description": "parse(File, String charsetName, String baseUri, Parser parser) with XML parser preserves XML structure",
      "path": "B0→B1→B2→B6",
      "precondition": "temporary file contains <root><child/></root>",
      "expectedResult": "doc.select(\"child\") in body is empty under HTML parser semantics with XML parser? uses parser.parse",
      "tags": [
        "positive",
        "file",
        "parser-overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parse file with parser",
        "  GIVEN",
        "    File file = tempXmlFile;",
        "    String charsetName = \"UTF-8\";",
        "    String baseUri = \"\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charsetName, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"root\").size() == 1;",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
