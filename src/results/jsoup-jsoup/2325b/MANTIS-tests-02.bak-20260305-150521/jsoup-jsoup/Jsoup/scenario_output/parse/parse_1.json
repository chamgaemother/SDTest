{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, String charsetName, String baseUri) with null charsetName falls back to meta or UTF-8 and returns correct content and baseUri",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "temporary HTML file with <meta charset=\"UTF-8\"> in head exists",
      "expectedResult": "Document.body().html() contains paragraph text; baseUri equals file absolute path",
      "tags": [
        "positive",
        "file",
        "charset-fallback"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse file null-charset fallback",
        "  GIVEN",
        "    // Arrange: create tempFile.html with <meta charset=\"UTF-8\"><p>hello</p>",
        "    File file = tempFile;",
        "    String charsetName = null;",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charsetName, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>hello</p>\");",
        "    assert doc.baseUri().equals(file.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File, String charsetName) with explicit charsetName returns content and baseUri as file path",
      "path": "B0→B1→B2→B5",
      "precondition": "temporary HTML file encoded UTF-8 exists",
      "expectedResult": "Document contains expected element and baseUri equals file path",
      "tags": [
        "positive",
        "file",
        "explicit-charset"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse file explicit-charset",
        "  GIVEN",
        "    File file = tempFileWithUTF8;",
        "    String charsetName = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charsetName);",
        "  THEN",
        "    assert doc.select(\"p\").first().text().equals(\"hello\");",
        "    assert doc.baseUri().equals(file.getAbsolutePath());",
        "END"
      ]
    },
