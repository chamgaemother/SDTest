{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) with non-empty html and valid baseUri returns Document with correct title",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.title() == \"Test Page\" and Document.baseUri() == \"http://example.com/\"",
      "tags": [
        "branch-true",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse simple HTML",
        "  GIVEN",
        "    String html = \"<html><head><title>Test Page</title></head><body/></html>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.title().equals(\"Test Page\");",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "END"
      ]
    },
    {
