    {
      "id": "TC05_O2",
      "description": "parse(String html, Parser parser) with valid html and custom parser uses parser and returns Document",
      "path": "B0→B1→B2→B3",
      "precondition": "use parser = Parser.xmlParser()",
      "expectedResult": "returned Document.baseUri() == \"\" and Document.select(\"tag\").isEmpty()",
      "tags": [
        "overload:String,Parser",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05_O2 parse with custom parser",
        "  GIVEN",
        "    String html = \"<tag>value</tag>\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.baseUri().equals(\"\");",
        "    assert doc.select(\"tag\").size() == 1;",
        "END"
      ]
    },
