package org.jsoup;

import org.jsoup.nodes.Document;
import org.jsoup.parser.Parser;
import org.jsoup.safety.Safelist;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

public class Jsoup_parse_Test {

    @Test
    @DisplayName("TC01_O1: parse(String html, String baseUri) with non-empty html and non-empty baseUri returns a Document with correct title and resolved base URI")
    void test_TC01_O1() {
        // Branch B0â†’B1â†’B2â†’B3â†’B4: normal path, non-null html and baseUri
        String html = "<p>Test</p>";
        String baseUri = "http://example.com/page.html";
        Document doc = Jsoup.parse(html, baseUri);
        // Expect the parser to preserve the body fragment and set baseUri correctly
        assertAll(
            () -> assertEquals("<p>Test</p>", doc.body().html(), "Body HTML should match the input fragment"),
            () -> assertEquals("http://example.com/page.html", doc.baseUri(), "Base URI should be set as provided")
        );
    }

    @Test
    @DisplayName("TC02_O1: parse(String html, String baseUri) with empty html and empty baseUri returns an empty Document")
    void test_TC02_O1() {
        // Branch B0â†’B1â†’B2â†’B3â†’B4: normal path but html and baseUri are boundary empty strings
        String html = "";
        String baseUri = "";
        Document doc = Jsoup.parse(html, baseUri);
        // Expect an empty body and empty baseUri
        assertAll(
            () -> assertEquals("", doc.body().html(), "Empty HTML input yields empty body"),
            () -> assertEquals("", doc.baseUri(), "Empty baseUri input yields empty baseUri")
        );
    }

    @Test
    @DisplayName("TC03_O1: parse(String html, String baseUri) with null html throws NullPointerException")
    void test_TC03_O1() {
        // Branch B0â†’B1â†’B2â†’B5: html is null, should trigger NPE before parsing
        String html = null;
        String baseUri = "http://example.com";
        assertThrows(NullPointerException.class, () -> Jsoup.parse(html, baseUri),
                "Passing null html should throw NullPointerException");
    }

    @Test
    @DisplayName("TC04_O1: parse(String html, String baseUri) with null baseUri throws NullPointerException")
    void test_TC04_O1() {
        // Branch B0â†’B1â†’B2â†’B5: baseUri is null, should trigger NPE before parsing
        String html = "<p>a</p>";
        String baseUri = null;
        assertThrows(NullPointerException.class, () -> Jsoup.parse(html, baseUri),
                "Passing null baseUri should throw NullPointerException");
    }

    @Test
    @DisplayName("TC05_O2: parse(String html, Parser parser) with non-empty html and custom parser returns a Document parsed by parser")
    void test_TC05_O2() {
        // Branch B0â†’B1â†’B6â†’B7: alternate overload with parser, both args non-null
        String html = "<custom>yes</custom>";
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(html, parser);
        // Expect xmlParser to preserve custom tags in body
        assertEquals("<custom>yes</custom>", doc.body().html(),
                "Custom XML parser should preserve the custom tag structure");
    }

    @Test
    @DisplayName("TC06_O2: parse(String html, Parser parser) with null parser throws NullPointerException")
    void test_TC06_O2() {
        // Branch B0â†’B1â†’B6â†’B8: parser is null, should throw NPE
        String html = "<p>test</p>";
        Parser parser = null;
        assertThrows(NullPointerException.class, () -> Jsoup.parse(html, parser),
                "Passing null parser should throw NullPointerException");
    }

    @Test
    @DisplayName("TC07_O3: parse(String html) with non-empty html returns Document using default baseUri and HTML parser")
    void test_TC07_O3() {
        // Branch B0â†’B1â†’B2â†’B9: default overload, html non-null
        String html = "<div>OK</div>";
        Document doc = Jsoup.parse(html);
        // Expect default baseUri "" and HTML parsing of div
        assertAll(
            () -> assertEquals("<div>OK</div>", doc.body().html(), "Body HTML should match the input div"),
            () -> assertEquals("", doc.baseUri(), "Default overload should set baseUri to empty string")
        );
    }

    @Test
    @DisplayName("TC08_O1: parse(String html, String baseUri, Parser parser) with valid inputs returns Document from parser")
    void test_TC08_O1() {
        // Branch B0â†’B1â†’B2â†’B6â†’B10: three-arg overload, all non-null
        String html = "<xml/>";
        String baseUri = "base";
        Parser parser = Parser.xmlParser();
        Document doc = Jsoup.parse(html, baseUri, parser);
        // Expect xmlParser to produce body html and preserve baseUri
        assertAll(
            () -> assertEquals("<xml/>", doc.body().html(), "Custom XML parser should serialize the self-closing tag"),
            () -> assertEquals("base", doc.baseUri(), "Base URI should be set as provided on three-arg overload")
        );
    }

    @Test
    @DisplayName("TC09_O4: parse(String html, String baseUri, Parser parser) with null html throws NullPointerException")
    void test_TC09_O4() {
        // Branch B0â†’B1â†’B2â†’B6â†’B11: html null on three-arg overload
        String html = null;
        String baseUri = "u";
        Parser parser = Parser.htmlParser();
        assertThrows(NullPointerException.class, () -> Jsoup.parse(html, baseUri, parser),
                "Null html in three-arg overload should throw NullPointerException");
    }

    @Test
    @DisplayName("TC10_O4: parse(String html, String baseUri, Parser parser) with null parser throws NullPointerException")
    void test_TC10_O4() {
        // Branch B0â†’B1â†’B2â†’B6â†’B11: parser null on three-arg overload
        String html = "<p>p</p>";
        String baseUri = "u";
        Parser parser = null;
        assertThrows(NullPointerException.class, () -> Jsoup.parse(html, baseUri, parser),
                "Null parser in three-arg overload should throw NullPointerException");
    }
}