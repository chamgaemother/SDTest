      "id": "TC11",
      "description": "parse(File, null charset, baseUri) loads HTML with BOM/meta-detected charset",
      "path": "B0â†’B1â†’B3â†’B5",
      "precondition": "tmpFile contains '<p>File</p>' encoded UTF-8",
      "expectedResult": "Document.body().html() == '<p>File</p>' and baseUri is provided",
      "tags": [
        "file",
        "charset-null",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse File with null charset",
        "  GIVEN",
        "    File tmp = createTempFile(\"<p>File</p>\");",
        "    String baseUri = \"http://host/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp, null, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>File</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
