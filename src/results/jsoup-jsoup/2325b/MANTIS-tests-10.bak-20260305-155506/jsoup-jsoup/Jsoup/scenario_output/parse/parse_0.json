{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) with non-empty html and non-empty baseUri returns a Document with correct title and resolved base URI",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "Document object with body.html() equal to '<p>Test</p>' and document.baseUri() equal to 'http://example.com/page.html'",
      "tags": [
        "overload:String,String",
        "branch-normal",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parse html with baseUri",
        "  GIVEN",
        "    String html = \"<p>Test</p>\"; String baseUri = \"http://example.com/page.html\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Test</p>\"); assert doc.baseUri().equals(\"http://example.com/page.html\");"
      ]
    },
