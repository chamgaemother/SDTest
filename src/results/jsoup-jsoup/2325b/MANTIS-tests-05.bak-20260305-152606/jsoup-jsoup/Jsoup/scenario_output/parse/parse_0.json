    {
      "id": "TC03",
      "description": "parse(String html, String baseUri) resolves relative URLs against baseUri",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "returned Document contains an <a> with abs:href = \"http://example.com/page\"",
      "tags": [
        "overload:String,String",
        "branch-false(html non-null)",
        "branch-false(baseUri non-null)"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse with-baseUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"page\\\">link</a>\";",
        "    String base = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, base);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://example.com/page\");"
      ]
    },
    {
      "id": "TC04",
