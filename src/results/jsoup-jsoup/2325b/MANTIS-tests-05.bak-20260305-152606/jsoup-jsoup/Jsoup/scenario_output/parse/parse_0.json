    {
      "id": "TC01",
      "description": "parse(String html) with empty input returns an empty document body fragment",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "returned Document has empty body html string",
      "tags": [
        "overload:String",
        "branch-false(html empty)",
        "base-case"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse empty-html",
        "  GIVEN",
        "    String html = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");"
      ]
    },
