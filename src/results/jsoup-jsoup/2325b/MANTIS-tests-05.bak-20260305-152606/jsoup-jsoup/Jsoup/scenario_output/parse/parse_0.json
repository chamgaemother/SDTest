      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 parse empty-baseUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"page\\\">link</a>\";",
        "    String base = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, base);",
        "  THEN",
        "    assert doc.select(\"a\").first().attr(\"href\").equals(\"page\");"
      ]
