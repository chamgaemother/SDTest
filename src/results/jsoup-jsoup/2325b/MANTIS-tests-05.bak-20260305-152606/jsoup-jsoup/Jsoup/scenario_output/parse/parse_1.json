    {
      "id": "TC15",
      "description": "parse(File file, String charsetName, String baseUri, Parser parser) uses xmlParser to parse file",
      "path": "B0→B5→B6",
      "precondition": "temp file exists with <div>X</div> content",
      "expectedResult": "Document with <div> text 'X'",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 parse file with charset, baseUri and xmlParser",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"t\", \".html\");",
        "    Files.write(path, \"<div>X</div>\".getBytes(StandardCharsets.UTF_8));",
        "    File file = path.toFile();",
        "    String charset = \"UTF-8\";",
        "    String base = \"http://b/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, base, parser);",
        "  THEN",
        "    assertEquals(\"X\", doc.select(\"div\").first().text());"
      ]
    },
