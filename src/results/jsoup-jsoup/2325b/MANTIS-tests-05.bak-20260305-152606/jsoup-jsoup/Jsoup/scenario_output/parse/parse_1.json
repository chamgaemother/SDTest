{
  "scenarios": [
    {
      "id": "TC12",
      "description": "parse(String html, String baseUri, Parser parser) resolves relative URLs with htmlParser",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "Document with <img> src attribute resolved to absolute URL",
      "tags": [
        "positive",
        "overload",
        "resolution"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse html with baseUri and parser",
        "  GIVEN",
        "    String html = \"<img src='pic.png'>\";",
        "    String base = \"http://example.com/sub/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, base, parser);",
        "  THEN",
        "    assertEquals(\"http://example.com/sub/pic.png\", doc.select(\"img\").first().absUrl(\"src\"));"
      ]
    },
