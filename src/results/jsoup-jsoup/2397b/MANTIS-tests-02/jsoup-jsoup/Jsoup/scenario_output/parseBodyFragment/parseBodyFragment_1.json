      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parseBodyFragment null-bodyHtml",
        "  GIVEN",
        "    String bodyHtml = null;",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    call Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
