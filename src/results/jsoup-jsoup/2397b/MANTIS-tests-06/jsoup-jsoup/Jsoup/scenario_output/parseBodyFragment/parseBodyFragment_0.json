{
  "method": "parseBodyFragment",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parseBodyFragment(html,baseUri) with non-empty bodyHtml and absolute baseUri returns fragment wrapped and unchanged",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "Document.body().html() == \"<p>text</p>\"",
      "tags": [
        "positive",
        "overload:String,String",
        "branch-baseUri-nonempty"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parseBodyFragment with non-empty HTML and non-empty baseUri",
        "  GIVEN",
        "    String html = \"<p>text</p>\";\n    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>text</p>\");"
      ]
    },
    {
      "id": "TC02",
      "description": "parseBodyFragment(html) uses empty baseUri alias overload and returns fragment unchanged",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "Document.body().html() == \"<span>ok</span>\"",
      "tags": [
        "positive",
        "overload:String",
        "branch-baseUri-empty"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parseBodyFragment overload without baseUri",
        "  GIVEN",
        "    String html = \"<span>ok</span>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>ok</span>\");"
      ]
    },
    {
      "id": "TC03",
      "description": "parseBodyFragment(html,baseUri) resolves relative link to absolute URL when baseUri non-empty",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "Document.body().html() == \"<a href=\\\"http://ex.com/page.html\\\">link</a>\"",
      "tags": [
        "positive",
        "overload:String,String",
        "branch-resolve-relative"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 relative link resolution",
        "  GIVEN",
        "    String html = \"<a href='page.html'>link</a>\";\n    String baseUri = \"http://ex.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<a href=\\\"http://ex.com/page.html\\\">link</a>\");"
      ]
    },
    {
      "id": "TC04",
