{
  "method": "parseBodyFragment",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseBodyFragment(String, String) with simple HTML fragment and non-empty baseUri returns a Document with body children matching fragment",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals \"<p>Test</p>\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-forward",
        "no-exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parseBodyFragment overload with baseUri",
        "  GIVEN",
        "    String fragment = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Test</p>\");"
      ]
    },
