{
  "scenarios": [
    {
      "id": "TC16",
      "description": "Multiple top-level siblings are parsed in sequence (iteration>1)",
      "path": "B0→B1→B2(loop×2)→B3→B4",
      "precondition": "none",
      "expectedResult": "body HTML preserves three siblings in order",
      "tags": [
        "positive",
        "iteration",
        "text-node"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parseBodyFragment multiple siblings",
        "  GIVEN",
        "    String html = \"<h1>One</h1><p>Two</p>Three\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, \"http://example.com/\");",
        "  THEN",
        "    assertEquals(\"<h1>One</h1><p>Two</p>Three\", doc.body().html());",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "Null baseUri throws NullPointerException before parsing",
      "path": "B0→B1→B5",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "null-baseUri"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 parseBodyFragment null baseUri",
        "  GIVEN",
        "    String html = \"<div>Hi</div>\";",
        "    String baseUri = null;",
        "  WHEN",
        "    call Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
      "id": "TC18",
      "description": "Whitespace-only fragment yields whitespace text node preserved",
      "path": "B0→B1→B2(loop×1)→B3→B4",
      "precondition": "none",
      "expectedResult": "body HTML equals exactly the whitespace",
      "tags": [
        "boundary",
        "whitespace",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parseBodyFragment whitespace only",
        "  GIVEN",
        "    String html = \"   \\n  \";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, \"\");",
        "  THEN",
        "    assertEquals(\"   \\n  \", doc.body().html());",
        "END"
      ]
    }
  ]
}