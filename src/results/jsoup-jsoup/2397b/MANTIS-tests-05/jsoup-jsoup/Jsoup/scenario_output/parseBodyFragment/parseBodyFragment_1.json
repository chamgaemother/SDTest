{
  "scenarios": [
    {
      "id": "TC06",
      "description": "parseBodyFragment uses a <base href> tag to override the provided baseUri for resolving relative links",
      "path": "B0→B1→B2(baseTagOverride)→B3",
      "precondition": "none",
      "expectedResult": "the <a> link’s absUrl is resolved against the <base href> value, not the provided baseUri",
      "tags": [
        "positive",
        "base-tag",
        "relative-resolution"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 parseBodyFragment base-tag-overrides-baseUri",
        "  GIVEN",
        "    String bodyHtml = \"<base href='http://override.com/sub/'><a href='p.html'>x</a>\";",
        "    String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    Element link = doc.body().selectFirst(\"a\");",
        "    assert link.absUrl(\"href\").equals(\"http://override.com/sub/p.html\");",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "parseBodyFragment ignores an empty <base href> tag and falls back to the provided baseUri for resolution",
      "path": "B0→B1→B2(emptyBaseTag)→B3",
      "precondition": "none",
      "expectedResult": "the <a> link’s absUrl is resolved against the provided baseUri, because the <base href> is empty",
      "tags": [
        "positive",
        "base-tag",
        "fallback-resolution"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parseBodyFragment empty-base-tag-fallback",
        "  GIVEN",
        "    String bodyHtml = \"<base href=''><a href='page.html'>link</a>\";",
        "    String baseUri = \"https://example.com/root/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    Element link = doc.body().selectFirst(\"a\");",
        "    assert link.absUrl(\"href\").equals(\"https://example.com/root/page.html\");",
        "END"
      ]
    }
  ]
}