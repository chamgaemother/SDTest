{
  "method": "parseBodyFragment",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseBodyFragment(html with relative links, non-empty baseUri) returns Document with resolved links",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "Document.body().html() contains the same fragment and relative URLs are resolved against 'https://example.com/'",
      "tags": [
        "branch-false",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String bodyHtml = \"<a href=\\\"page.html\\\">link</a>\"; String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    assert doc.body().select(\"a\").first().absUrl(\"href\").equals(\"https://example.com/page.html\");"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parseBodyFragment(empty html, non-empty baseUri) returns empty body element",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "Document.body().html() is empty string",
      "tags": [
        "boundary",
        "overload:String,String",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02_O1 parseBodyFragment empty html",
        "  GIVEN",
        "    String bodyHtml = \"\"; String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");"
      ]
    },
    {
      "id": "TC03_O1",
      "description": "parseBodyFragment(null html, non-empty baseUri) throws NullPointerException for null bodyHtml",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "throws NullPointerException; no Document returned",
      "tags": [
        "exception",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03_O1 parseBodyFragment null html",
        "  GIVEN",
        "    String bodyHtml = null; String baseUri = \"https://example.com/\";",
        "  WHEN",
        "    call Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    throws NullPointerException;"
      ]
    },
    {
      "id": "TC04_O2",
      "description": "parseBodyFragment(html with no baseUri overload preserves empty baseUri as default",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals input fragment and absUrl on relative link is empty",
      "tags": [
        "branch-true",
        "overload:String",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04_O2 parseBodyFragment one-arg overload",
        "  GIVEN",
        "    String bodyHtml = \"<img src='pic.png'>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml);",
        "  THEN",
        "    assert doc.body().html().equals(\"<img src=\\\"pic.png\\\">\") && doc.body().select(\"img\").first().absUrl(\"src\").isEmpty();"
      ]
    },
    {
      "id": "TC05_O2",
      "description": "parseBodyFragment(null html in one-arg overload throws NullPointerException",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "throws NullPointerException",
      "tags": [
        "exception",
        "overload:String"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05_O2 parseBodyFragment null html one-arg",
        "  GIVEN",
        "    String bodyHtml = null;",
        "  WHEN",
        "    call Jsoup.parseBodyFragment(bodyHtml);",
        "  THEN",
        "    throws NullPointerException;"
      ]
    }
  ]
}