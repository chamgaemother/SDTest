{
  "method": "parseBodyFragment",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parseBodyFragment(String html, String baseUri) with non-empty html and non-empty baseUri returns Document with body html preserved",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "returned Document.body().html() equals the input html string",
      "tags": [
        "branch-normal",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parseBodyFragment with html and baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\"; String baseUri = \"https://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>Hello</p>\");"
      ]
    },
    {
