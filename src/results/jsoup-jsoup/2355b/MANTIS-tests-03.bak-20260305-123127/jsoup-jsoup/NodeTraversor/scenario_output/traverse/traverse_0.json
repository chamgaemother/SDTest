        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 leaf-node",
        "  GIVEN",
        "    Element root = new Element(\"p\");",
        "    RecordingVisitor visitor = new RecordingVisitor();",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert visitor.headCalls == List.of((root,0));",
        "    assert visitor.tailCalls == List.of((root,0));",
        "END"
      ]
