        "loop-1 child",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04_O1 one-child",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element child = new Element(\"span\");",
        "    root.appendChild(child);",
        "    RecordingVisitor visitor = new RecordingVisitor();",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert visitor.headCalls == List.of((root,0),(child,1));",
        "    assert visitor.tailCalls == List.of((child,1),(root,0));",
        "END"
      ]
    },
    {
      "id": "TC05_O1",
      "description": "node with two siblings ascends multiple times after child-level traversal",
      "path": "B0→B1→B2→B3→B5→B11→B12→B23→B1→B2→B3→B5→B11→B12→B23→B1",
      "precondition": "parent with two children; visitor is no-op",
      "expectedResult": "traversal covers both children in depth-first order without errors",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-false B1",
        "loop-N children (N=2)",
        "P2"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05_O1 two-children",
        "  GIVEN",
        "    Element parent = new Element(\"ul\");",
        "    Element a = new Element(\"li\");",
        "    Element b = new Element(\"li\");",
        "    parent.appendChildren(a, b);",
        "    List<String> order = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)-> order.add(n.nodeName()+d);",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, parent);",
        "  THEN",
        "    assert order == List.of(\"ul0\",\"li1\",\"li1\",\"ul0\");",
        "END"
      ]
    },
    {
      "id": "TC06_O1",
      "description": "visitor.head removes node triggers 'removed' branch then continues at next sibling",
      "path": "B0→B1→B2→B3→B5→B6→B11",
      "precondition": "visitor.head removes every visited node; controlled via stub; root has two children",
      "expectedResult": "removed nodes not visited in tail and traversal moves to next sibling or up when no nextSibling",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-false B1",
        "branch-true B6",
        "exception?",
        "loop-1 removed",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06_O1 head-removes",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element c = new Element(\"span\");",
        "    root.appendChild(c);",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      public void head(Node n,int d){ n.remove(); }",
        "      public void tail(Node n,int d){}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.childNodeSize() == 0;",
        "END"
      ]
    },
    {
      "id": "TC07_O1",
      "description": "visitor.head replaces node triggers 'replaced' branch and continues traversal",
      "path": "B0→B1→B2→B3→B5→B6→B7→B8→B11",
      "precondition": "visitor.head replaces each node with identical sibling; stub simulates replaceWith preserving index",
      "expectedResult": "replacement navigates to new node, preserving traversal depth",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-false B1",
        "branch-true B7",
        "P2"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07_O1 head-replaces",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element child = new Element(\"p\");",
        "    root.appendChild(child);",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      public void head(Node n,int d){ n.replaceWith(new Element(n.nodeName())); }",
        "      public void tail(Node n,int d){}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.childNode(0).nodeName().equals(\"p\");",
        "END"
      ]
    },
