      "id": "TC12",
      "description": "traverse(visitor,Elements) with non-empty Elements delegates to node branch for each element",
      "path": "B0‚ÜíB1‚ÜíB2‚ÜíB1‚ÜíB3",
      "precondition": "none",
      "expectedResult": "head and tail called for each element's text node",
      "tags": [
        "positive",
        "delegation",
        "elements-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 traverse with Elements overload",
        "  GIVEN",
        "    Element e1 = new Element(\"p\");",
        "    e1.appendChild(new TextNode(\"a\"));",
        "    Element e2 = new Element(\"p\");",
        "    e2.appendChild(new TextNode(\"b\"));",
        "    Elements els = new Elements(e1,e2);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      public void head(Node n,int d){ calls.add(\"head(\"+((TextNode)n).text()+\",\"+d+\")\"); }",
        "      public void tail(Node n,int d){ calls.add(\"tail(\"+((TextNode)n).text()+\",\"+d+\")\"); }",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, els);",
        "  THEN",
        "    assert calls.equals(List.of(\"head(a,0)\",\"tail(a,0)\",\"head(b,0)\",\"tail(b,0)\"));",
        "END"
      ]
    }
