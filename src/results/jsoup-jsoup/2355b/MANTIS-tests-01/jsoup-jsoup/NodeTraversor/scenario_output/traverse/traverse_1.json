      "id": "TC02",
      "description": "traverse throws IllegalArgumentException when root is null",
      "path": "B0→B1",
      "precondition": "visitor instantiated, root=null",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "null-check"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 traverse null-root",
        "  GIVEN",
        "    NodeVisitor visitor = valid visitor;",
        "    Node root = null;",
        "  WHEN",
        "    call NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "removal in head triggers origSize!=childNodeSize removal branch and skips tail for removed node",
      "path": "B5→B6→B7→B9→B1",
      "precondition": "root has single TextNode child, no siblings",
      "expectedResult": "head(root,0), head(child,1), tail(root,0); no tail(child)",
      "tags": [
        "branch",
        "removal",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 traverse removal-branch",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    TextNode child = new TextNode(\"x\");",
        "    root.appendChild(child);",
        "    NodeVisitor visitor = head removes TextNode then records calls;",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert calls contains head(div,0) and head(x,1);",
        "    assert no calls tail(x,1);",
        "    assert calls contains tail(div,0);",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "traverse(visitor,Elements) with single Element delegates to node overload once",
      "path": "B0→B1→B2→B1→B3",
      "precondition": "Elements contains one Element with one TextNode child",
      "expectedResult": "one head and one tail call for the TextNode",
      "tags": [
        "positive",
        "delegation",
        "elements-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 traverse single-element list",
        "  GIVEN",
        "    TextNode text = new TextNode(\"t\");",
        "    Element el = new Element(\"div\").appendChild(text);",
        "    Elements els = new Elements(el);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor records head/tail of TextNode;",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, els);",
        "  THEN",
        "    assert calls equals [\"head(t,0)\",\"tail(t,0)\"];",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "traverse(visitor,Elements) with multiple Elements iterates through all before returning",
      "path": "B0→B1→B2(loop×2)→B1→B3",
      "precondition": "Elements contains two Element roots each with one TextNode child",
      "expectedResult": "head/tail calls for both children in order",
      "tags": [
        "positive",
        "delegation",
        "elements-overload",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 traverse multiple-element list",
        "  GIVEN",
        "    TextNode a = new TextNode(\"a\");",
        "    TextNode b = new TextNode(\"b\");",
        "    Element elA = new Element(\"div\").appendChild(a);",
        "    Element elB = new Element(\"div\").appendChild(b);",
        "    Elements els = new Elements(elA, elB);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor records head/tail of TextNode;",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, els);",
        "  THEN",
        "    assert calls equals [\"head(a,0)\",\"tail(a,0)\",\"head(b,0)\",\"tail(b,0)\"];",
        "END"
      ]
    }
  ]
