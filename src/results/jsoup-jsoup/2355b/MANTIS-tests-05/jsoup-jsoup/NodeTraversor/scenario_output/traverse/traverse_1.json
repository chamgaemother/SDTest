      "description": "removes first of two siblings in head: executes removal path B7â†’B9â†’B10 when nextSibling exists",
      "path": "B0â†’B1â†’B2â†’B3â†’B5â†’B6â†’B7â†’B9â†’B10â†’B1â†’B11â†’B12â†’B23â†’B1â†’B11â†’B12â†’B23â†’B1â†’B20â†’B21â†’B24",
      "precondition": "Element root has two children; visitor.head on first child calls remove()",
      "expectedResult": "first child visited & removed; traversal continues to second child; tails called on second and root",
      "tags": [
        "positive",
        "removal",
        "sibling"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 removal with nextSibling traverse",
        "  GIVEN",
        "    Element root = new Element(\"ul\");",
        "    Element li1 = new Element(\"li\");",
        "    Element li2 = new Element(\"li\");",
        "    root.appendChild(li1); root.appendChild(li2);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      public void head(Node node, int depth) {",
        "        calls.add(\"head:\"+node.nodeName()+\":\"+depth);",
        "        if (node == li1) node.remove();",
        "      }",
        "      public void tail(Node node, int depth) { calls.add(\"tail:\"+node.nodeName()+\":\"+depth); }",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert calls.contains(\"head:li:1\"); // removed",
        "    assert calls.contains(\"head:li:1\") && calls.contains(\"tail:li:1\");",
        "    assert calls.get(calls.size()-1).equals(\"tail:ul:0\");",
        "END"
      ]
    },
