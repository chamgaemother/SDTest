      "precondition": "Elements list containing two independent simple roots, RecordingVisitor",
      "expectedResult": "Visitor.head and tail called once per root, total headCount=2, tailCount=2",
      "tags": [
        "elements",
        "overload",
        "iteration",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 multi-element-list",
        "  GIVEN",
        "    Element el1 = new Element(Tag.valueOf(\"div\"), \"\");",
        "    Element el2 = new Element(Tag.valueOf(\"p\"), \"\");",
        "    Elements list = new Elements(el1, el2);",
        "    RecordingVisitor v = new RecordingVisitor();",
        "  WHEN",
        "    NodeTraversor.traverse(v, list);",
        "  THEN",
        "    assertEquals(2, v.headCount);",
        "    assertEquals(2, v.tailCount);"
      ]
    }
