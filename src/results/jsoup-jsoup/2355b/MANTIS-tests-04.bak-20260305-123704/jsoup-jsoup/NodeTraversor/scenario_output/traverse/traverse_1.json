{
  "scenarios": [
    {
      "id": "TC11",
      "description": "RemovingVisitor on a parent with two children skips tail of removed and continues traversal to next sibling",
      "path": "B0вҶ’B1вҶ’B2вҶ’B5вҶ’B6вҶ’B11вҶ’B5вҶ’B6вҶ’B7вҶ’B9вҶ’B10вҶ’B1вҶ’B2вҶ’B5вҶ’B11вҶ’B12вҶ’B23вҶ’B1вҶ’B6вҶ’B11вҶ’B13вҶ’B16вҶ’B20вҶ’B21вҶ’B24",
      "precondition": "Parent element with two child leaf nodes; RemovingVisitor that calls node.remove() in head",
      "expectedResult": "First child head called and removed (no tail), then second child's head and tail called once each, then root tail",
      "tags": [
        "remove",
        "iteration",
        "sibling",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 remove-first-sibling",
        "  GIVEN",
        "    Element parent = new Element(Tag.valueOf(\"div\"), \"\");",
        "    Element c1 = new Element(Tag.valueOf(\"a\"), \"\");",
        "    Element c2 = new Element(Tag.valueOf(\"b\"), \"\");",
        "    parent.appendChild(c1);",
        "    parent.appendChild(c2);",
        "    RemovingVisitor v = new RemovingVisitor();",
        "  WHEN",
        "    NodeTraversor.traverse(v, parent);",
        "  THEN",
        "    assertEquals(2, v.headCount);",
        "    assertEquals(2, v.tailCount);",
        "    // c1 removed, so only c2 and parent tail"
      ]
    },
    {
      "id": "TC12",
      "description": "ReplacingVisitor on a parent with two children replaces first child and then continues to second child",
      "path": "B0вҶ’B1вҶ’B2вҶ’B5вҶ’B6вҶ’B7вҶ’B8вҶ’B11вҶ’B12вҶ’B23вҶ’B1вҶ’B6вҶ’B7вҶ’B8вҶ’B11вҶ’B12вҶ’B23вҶ’B1вҶ’B6вҶ’B11вҶ’B13вҶ’B16вҶ’B20вҶ’B22вҶ’B23вҶ’B1вҶ’B6вҶ’B11вҶ’B13вҶ’B16вҶ’B20вҶ’B21вҶ’B24",
      "precondition": "Parent element with two child leaf nodes; ReplacingVisitor that replaces the node in head",
      "expectedResult": "First child is replaced then both replacement and second original child get head and tail, then parent tail",
      "tags": [
        "replace",
        "sibling",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 replace-first-sibling",
        "  GIVEN",
        "    Element parent = new Element(Tag.valueOf(\"div\"), \"\");",
        "    Element c1 = new Element(Tag.valueOf(\"span\"), \"\");",
        "    Element c2 = new Element(Tag.valueOf(\"em\"), \"\");",
        "    parent.appendChild(c1);",
        "    parent.appendChild(c2);",
        "    ReplacingVisitor v = new ReplacingVisitor();",
        "  WHEN",
        "    NodeTraversor.traverse(v, parent);",
        "  THEN",
        "    assertTrue(v.sequence.indexOf(\"head1\") < v.sequence.indexOf(\"tail1\"));",
        "    assertTrue(v.sequence.contains(\"head1\"));",
        "    assertTrue(v.sequence.contains(\"tail2\"));"
      ]
    },
    {
