package org.jsoup.select;

import org.jsoup.helper.Validate;
import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.nodes.Node;
import org.jsoup.select.NodeTraversor;
import org.jsoup.select.NodeVisitor;
import org.jsoup.select.Elements;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.util.ArrayList;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

public class NodeTraversor_traverse_Test {

    /**
     * Scenario TC11: RemovingVisitor on a parent with two children skips tail of removed and continues to next sibling
     */
    @Test
    @DisplayName("RemovingVisitor on a parent with two children skips tail of removed and continues traversal to next sibling")
    public void test_TC11() {
        // GIVEN: parent with two leaf children
        Element parent = new Element("div");
        Element c1 = new Element("a");
        Element c2 = new Element("b");
        parent.appendChild(c1);
        parent.appendChild(c2);
        RemovingVisitor visitor = new RemovingVisitor();
        // WHEN: traverse, in head we remove node, forcing removal branch for first child
        NodeTraversor.traverse(visitor, parent);
        // THEN: first child head called and removed (no tail), second child head+tail, then parent tail
        assertEquals(2, visitor.headCount, "Expected two head calls: one for each surviving/traversed child");
        assertEquals(2, visitor.tailCount, "Expected two tail calls: one for second child and one for parent");
    }

    /**
     * Scenario TC12: ReplacingVisitor on a parent with two children replaces first child and continues to second
     */
    @Test
    @DisplayName("ReplacingVisitor on a parent with two children replaces first child and then continues to second child")
    public void test_TC12() {
        // GIVEN: parent with two leaf children
        Element parent = new Element("div");
        Element c1 = new Element("span");
        Element c2 = new Element("em");
        parent.appendChild(c1);
        parent.appendChild(c2);
        ReplacingVisitor visitor = new ReplacingVisitor(c1);
        // WHEN: traverse, head replaces c1 with new element 'replacement'
        NodeTraversor.traverse(visitor, parent);
        // THEN: replacement and second child both visited; ensure head1 occurs before its tail
        List<String> seq = visitor.sequence;
        assertTrue(seq.contains("head1"), "Expected head1 recorded");
        assertTrue(seq.contains("tail1"), "Expected tail1 recorded");
        assertTrue(seq.contains("head2"), "Expected head2 recorded");
        // head1 before tail1
        assertTrue(seq.indexOf("head1") < seq.indexOf("tail1"), "head1 should occur before its tail1");
        // head2 and tail2 exist
        assertTrue(seq.contains("tail2"), "Expected tail2 recorded");
    }

    /**
     * Scenario TC13: Traverse overload with two root elements invokes traversal per element
     */
    @Test
    @DisplayName("Traverse overload with two root elements in Elements list invokes traversal for each element and then returns")
    public void test_TC13() {
        // GIVEN: two independent simple roots
        Element el1 = new Element("div");
        Element el2 = new Element("p");
        Elements list = new Elements(el1, el2);
        RecordingVisitor visitor = new RecordingVisitor();
        // WHEN: traverse overload
        NodeTraversor.traverse(visitor, list);
        // THEN: head and tail called once per root => total 2 each
        assertEquals(2, visitor.headCount, "Expected head called for each of two roots");
        assertEquals(2, visitor.tailCount, "Expected tail called for each of two roots");
    }

    // Helper visitor that removes each node in head
    private static class RemovingVisitor implements NodeVisitor {
        int headCount = 0;
        int tailCount = 0;

        @Override
        public void head(Node node, int depth) {
            headCount++;
            // remove node to test removal branch
            node.remove();
        }

        @Override
        public void tail(Node node, int depth) {
            tailCount++;
        }
    }

    // Helper visitor that replaces first specified node in head
    private static class ReplacingVisitor implements NodeVisitor {
        private final Node toReplace;
        private final Element replacement;
        List<String> sequence = new ArrayList<>();
        boolean replaced = false;
        int counter = 1;

        ReplacingVisitor(Node toReplace) {
            this.toReplace = toReplace;
            this.replacement = new Element("i");
        }

        @Override
        public void head(Node node, int depth) {
            if (!replaced && node == toReplace) {
                sequence.add("head1");
                node.replaceWith(replacement);
                replaced = true;
            } else if (node == replacement) {
                sequence.add("head1"); // visitation of replacement
            } else {
                sequence.add("head2");
            }
        }

        @Override
        public void tail(Node node, int depth) {
            if (node == replacement) {
                sequence.add("tail1");
            } else {
                sequence.add("tail2");
            }
        }
    }

    // Helper visitor that records head/tail counts
    private static class RecordingVisitor implements NodeVisitor {
        int headCount = 0;
        int tailCount = 0;

        @Override
        public void head(Node node, int depth) {
            headCount++;
        }

        @Override
        public void tail(Node node, int depth) {
            tailCount++;
        }
    }
}