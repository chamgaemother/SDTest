      "path": "B0â†’B1â†’B2â†’B5â†’B6â†’B7â†’B8â†’B11â†’â€¦â†’B24",
      "precondition": "root has one child; visitor.head replaces that child with a new node",
      "expectedResult": "replacement triggers replacement branch and traversal continues on new node",
      "tags": [
        "positive",
        "branch",
        "replacement"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 replacement-in-head",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element child = new Element(\"p\");",
        "    root.appendChild(child);",
        "    Element replacement = new Element(\"section\");",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      head(n,d) { if (n == child) n.replaceWith(replacement); },",
        "      tail(n,d) {}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.child(0).tagName().equals(\"section\");",
        "END"
      ]
