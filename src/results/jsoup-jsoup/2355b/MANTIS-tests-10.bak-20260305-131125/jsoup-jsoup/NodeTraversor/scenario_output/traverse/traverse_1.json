      "id": "TC05",
      "description": "traverse removal branch: visitor.head removes current node causes removal path",
      "path": "B0â†’B1â†’B2â†’B5â†’B6â†’B7â†’B9â†’B10â†’B1â†’â€¦â†’B24",
      "precondition": "root has two children; visitor.head removes first child node",
      "expectedResult": "first child removed, traversal continues to second child and root tail",
      "tags": [
        "positive",
        "branch",
        "removal"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 removal-in-head",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element c1 = new Element(\"span\"), c2 = new Element(\"span\");",
        "    root.appendChild(c1).appendSibling(c2);",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      head(n,d) { if (n == c1) n.remove(); },",
        "      tail(n,d) {}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.childNodeSize() == 1;",
        "    assert visitor.headCount >= 2;",
        "END"
      ]
    },
    {
