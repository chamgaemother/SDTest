      "pseudocode": [
        "TEST TC07 remove-node-with-next",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element a = new Element(\"a\"), b = new Element(\"b\"); root.appendChildren(a,b);",
        "    List<String> calls = new ArrayList<>();",
