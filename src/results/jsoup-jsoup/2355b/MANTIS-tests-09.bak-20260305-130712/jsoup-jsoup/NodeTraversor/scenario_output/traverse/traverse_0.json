      "pseudocode": [
        "TEST TC06 replace-node",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element orig = new Element(\"x\"); root.appendChild(orig);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor v = (n,d)->{if(n==orig) {orig.replaceWith(new Element(\"y\"));} calls.add(\"head(\"+n.nodeName()+\",\"+d+\")\");};",
        "    v.tail=(n,d)->calls.add(\"tail(\"+n.nodeName()+\",\"+d+\")\");",
        "  WHEN",
        "    NodeTraversor.traverse(v, root);",
        "  THEN",
        "    assert calls.contains(\"head(y,1)\");",
        "END"
