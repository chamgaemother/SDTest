    },
    {
      "id": "TC03_O1",
      "description": "single node no children calls head then tail exactly once",
      "path": "B0→B1→B2→B3→B5→B11→B12→B23→B1→B24",
      "precondition": "visitor records calls; root has no children",
      "expectedResult": "visitor.head invoked once with (root,0) and visitor.tail once with (root,0)",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-true B1",
        "loop-0 children",
        "coverage-base",
        "priority-P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 single-node",
        "  GIVEN",
        "    NodeVisitor visitor = spy recording head/tail;",
        "    Node root = new Element(\"p\");",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert visitor.headCalls == [(root,0)];",
        "    assert visitor.tailCalls == [(root,0)];"
      ]
    },
    {
      "id": "TC04_O1",
      "description": "two-level tree descends then ascends (one child) exercising B12 branch",
      "path": "B0→B1→B2→B3→B5→B11→B12→B23→B1→B11→B13→B16→B20→B21→B24",
      "precondition": "tree: root->child; visitor records depth",
      "expectedResult": "head: (root,0),(child,1); tail: (child,1),(root,0)",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-true B11",
        "loop-1 child",
        "boundary-depth",
        "priority-P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04_O1 one-child-tree",
        "  GIVEN",
        "    Node child = new Element(\"span\");",
        "    Element root = new Element(\"div\").appendChild(child);",
        "    NodeVisitor visitor = spy recording head/tail;",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert visitor.headCalls == [(root,0),(child,1)];",
        "    assert visitor.tailCalls == [(child,1),(root,0)];"
      ]
    },
    {
      "id": "TC05_O1",
      "description": "visitor.head removes node triggers removal branch (origSize!=childNodeSize)",
      "path": "B0→B1→B2→B3→B5→B6→B11",
      "precondition": "visitor.head implementation removes node from its parent; parent has one child",
      "expectedResult": "removed node is not visited on tail; traversal continues with nextSibling or returns",
      "tags": [
        "overload:NodeVisitor,Node",
        "exception-handling removal",
        "branch-true B6",
        "priority-P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05_O1 removal-in-head",
        "  GIVEN",
        "    Element child = new Element(\"b\");",
        "    Element root = new Element(\"div\").appendChild(child);",
        "    NodeVisitor visitor = (n,d)->{ if(n==child) child.remove(); };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.childNodeSize() == 0;",
        "    assert visitor.tailCalls does not contain (child,1);"
      ]
    },
    {
      "id": "TC06_O1",
      "description": "visitor.head replaces node triggers replacement branch (origSize==childNodeSize)",
      "path": "B0→B1→B2→B3→B5→B6→B7→B8→B11→B12→B23→B1→B24",
      "precondition": "visitor.head replaces child with new Node using parent.childNode",
      "expectedResult": "replacement node is visited and traversal completes without error",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-true B7",
        "branch-true B8",
        "priority-P2"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06_O1 replacement-in-head",
        "  GIVEN",
        "    Element child = new Element(\"i\");",
        "    Element root = new Element(\"div\").appendChild(child);",
        "    NodeVisitor visitor = (n,d)->{ if(n==child) root.childNode(0).replaceWith(new Element(\"u\")); };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert root.childNode(0).nodeName().equals(\"u\");"
      ]
    },
    {
      "id": "TC07_O1",
      "description": "deep tree with multiple siblings exercises sibling-null ascend loop and tail on last root",
      "path": "B0→B1→B2→B3→B5→B11→B12→B23→B1→B11→B13→B16→B20→B21→B24",
      "precondition": "root has two children; each child has no children",
      "expectedResult": "visitor.head/tail called in document order on root, first child, then second child, then root tail",
      "tags": [
        "overload:NodeVisitor,Node",
        "loop-N siblings",
        "branch-false B6",
        "priority-P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07_O1 two-siblings",
        "  GIVEN",
        "    Element c1 = new Element(\"a\");",
        "    Element c2 = new Element(\"b\");",
        "    Element root = new Element(\"div\").appendChild(c1).appendChild(c2);",
        "    NodeVisitor visitor = spy recording head/tail;",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert visitor.headCalls == [(root,0),(c1,1),(c2,1)];",
        "    assert visitor.tailCalls == [(c1,1),(c2,1),(root,0)];"
      ]
    },
