    {
      "id": "TC03_O1",
      "description": "single-node tree invokes head and tail once without descent (no children)",
      "path": "B0→B1→B2→B3→B5→B6→B11→B12→B23→B1→B24",
      "precondition": "none",
      "expectedResult": "visitor.head and tail called once with depth 0",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-false(r6.parent==null)",
        "loop-0(children)",
        "P1",
        "Java 8"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 traverse single-node",
        "  GIVEN",
        "    List<String> events = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)->events.add(\"head\"+d);",
        "    visitor = visitor.andThen((n,d)->events.add(\"tail\"+d));",
        "    Node root = new TextNode(\"text\", \"\");",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert events.equals([\"head0\",\"tail0\"]);",
        "END"
      ]
    },
