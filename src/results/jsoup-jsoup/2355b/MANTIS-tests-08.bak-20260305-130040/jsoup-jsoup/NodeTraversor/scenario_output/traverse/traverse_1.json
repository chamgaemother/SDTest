      "path": "B0â†’B1â†’B5â†’B11â†’B12(descend twice)â†’B23â†’B1â†’B5â†’B11â†’B6â†’B9â†’B10â†’B1â†’...â†’B24",
      "precondition": "none",
      "expectedResult": "removed node at depth 2 not tailed, siblings and ancestors still traversed normally",
      "tags": [
        "negative",
        "removal",
        "depth>1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 removal at depth>1 skips tail of removed",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element c1 = new Element(\"p\");",
        "    Element c2 = new Element(\"span\");",
        "    Element sibling = new Element(\"a\");",
        "    root.appendChild(c1);",
        "    c1.appendChild(c2);",
        "    root.appendChild(sibling);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      public void head(Node node, int depth) {",
        "        if (node == c2) { node.remove(); calls.add(\"head:removed:\"+node.nodeName()+\":\"+depth); }",
        "        else { calls.add(\"head:\"+node.nodeName()+\":\"+depth); }",
        "      }",
        "      public void tail(Node node, int depth) { calls.add(\"tail:\"+node.nodeName()+\":\"+depth); }",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, (Node) root);",
        "  THEN",
        "    assert calls.equals(List.of(",
        "      \"head:div:0\",",
        "      \"head:p:1\",",
        "      \"head:removed:span:2\",",
        "      \"head:a:1\",",
        "      \"tail:a:1\",",
        "      \"tail:p:1\",",
        "      \"tail:div:0\"",
        "    ));",
        "END"
      ]
    }
