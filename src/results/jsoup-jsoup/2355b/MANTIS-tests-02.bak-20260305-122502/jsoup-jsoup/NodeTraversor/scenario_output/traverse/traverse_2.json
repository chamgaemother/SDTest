    {
      "id": "TC18",
      "description": "deep single-child chain triggers multiple ascend-loop iterations (depth>1) in traverse(NodeVisitor,Node)",
      "path": "B0→B5→B11(child)→…→leaf→B16→B20(loop ascend×3)→B22→B24",
      "precondition": "none",
      "expectedResult": "head and tail called at depths 0,1,2,3 and then tails ascend back through depths 3→0",
      "tags": [
        "positive",
        "iteration",
        "ascend-loop",
        "depth-boundary"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 traverse deep chain ascend-loop",
        "  GIVEN",
        "    // Build a chain div->a->b->c (depth 0→3)",
        "    Element div = new Element(\"div\");",
        "    Element a = new Element(\"a\"); div.appendChild(a);",
        "    Element b = new Element(\"b\"); a.appendChild(b);",
        "    Element c = new Element(\"c\"); b.appendChild(c);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      public void head(Node n,int d){calls.add(\"h:\"+n.nodeName()+\":\"+d);} ",
        "      public void tail(Node n,int d){calls.add(\"t:\"+n.nodeName()+\":\"+d);} ",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, (Node) div);",
        "  THEN",
        "    // heads at depths 0,1,2,3",
        "    assertEquals(List.of(\"h:div:0\",\"h:a:1\",\"h:b:2\",\"h:c:3\",\"t:c:3\",\"t:b:2\",\"t:a:1\",\"t:div:0\"), calls);",
        "END"
      ]
    }
  ]
}