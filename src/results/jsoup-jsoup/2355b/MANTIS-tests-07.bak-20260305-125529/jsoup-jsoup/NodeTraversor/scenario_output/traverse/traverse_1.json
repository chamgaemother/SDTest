      "path": "B0‚ÜíB1‚ÜíB2‚ÜíB3",
      "precondition": "none",
      "expectedResult": "seeing a null in elements causes Validate.notNull in recursive traverse and throws IllegalArgumentException",
      "tags": [
        "negative",
        "elements",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 traverse(elements) null-element throws",
        "  GIVEN",
        "    Elements elements = new Elements(new Element(\"ok\"), null, new Element(\"skip\"));",
        "    NodeVisitor visitor = (n,d) -> {};",
        "  WHEN",
        "    // Act & Assert",
        "    assertThrows(IllegalArgumentException.class, () -> NodeTraversor.traverse(visitor, elements));",
        "END"
      ]
    }
  ]
