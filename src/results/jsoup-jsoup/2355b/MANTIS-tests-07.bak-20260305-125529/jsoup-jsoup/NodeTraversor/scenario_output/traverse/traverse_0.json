    {
      "id": "TC06_O1",
      "description": "visitor.head removes node triggers removal branch and skips tail for removed",
      "path": "B0â†’B1â†’B2â†’B3â†’B5â†’B6â†’B11â†’B12â†’B23â†’B1â†’B24",
      "precondition": "visitor.head calls node.remove(); this stub simulates removal for origSize!=newSize",
      "expectedResult": "removed node not visited in tail; traversal continues or returns at root end",
      "tags": [
        "overload:NodeVisitor,Node",
        "branch-removal",
        "exception-free"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06_O1 removalInHead",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element child = new Element(\"b\"); root.appendChild(child);",
        "    NodeVisitor visitor = (n,d) -> { if (n == child) n.remove(); };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert child.parentNode() == null;",
        "    assert visitor.headCalls.contains((child,1));",
        "END"
      ]
    },
