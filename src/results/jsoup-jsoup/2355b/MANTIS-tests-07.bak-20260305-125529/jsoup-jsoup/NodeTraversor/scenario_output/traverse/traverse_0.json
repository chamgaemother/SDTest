        "  GIVEN",
        "    Element root = new Element(\"s\");",
        "    Element child = new Element(\"u\"); root.appendChild(child);",
        "    NodeVisitor visitor = (n,d) -> { if (n == child) child.replaceWith(new Element(\"i\")); };",
