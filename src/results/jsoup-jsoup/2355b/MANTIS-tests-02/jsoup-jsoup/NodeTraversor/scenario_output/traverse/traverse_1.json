    {
      "id": "TC13",
      "description": "visitor replaces node in head triggers replaced branch (B6â†’B7â†’B8) and continues traversal",
      "path": "B0â†’B1â†’B5â†’B6â†’B7â†’B8â†’B11â†’B12â†’...â†’B20â†’B22â†’B23â†’...â†’B24",
      "precondition": "Element root with one child; visitor replaces child with <span> on head",
      "expectedResult": "visitor.head called on div,p,span; tail on span and div",
      "tags": [
        "positive",
        "mutation",
        "replace"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 replace-node-in-head",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element child = new Element(\"p\");",
        "    root.appendChild(child);",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      head(n,d)-> { calls.add(\"head:\"+n.nodeName()+\":\"+d); if (\"p\".equals(n.nodeName())) n.replaceWith(new Element(\"span\")); },",
        "      tail(n,d)->calls.add(\"tail:\"+n.nodeName()+\":\"+d);",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert calls.equals(List.of(",
        "      \"head:div:0\",\"head:p:1\",\"head:span:1\",\"tail:span:1\",\"tail:div:0\"",
        "    ));",
        "END"
      ]
