    {
      "id": "TC03_O1",
      "description": "single-node tree (no children) calls head and tail once",
      "path": "B0竊達1竊達2竊達3竊達5竊達11竊達12竊達23竊達1竊達24",
      "precondition": "none",
      "expectedResult": "visitor.head and visitor.tail invoked exactly once on root at depth 0",
      "tags": [
        "branch-parent-null",
        "loop-0",
        "overload:Node"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 traverse single-node",
        "  GIVEN",
        "    List<Node> seen = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)-> seen.add(n);",
        "    Node root = new Element(\"div\");",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert seen.size() == 2;",
        "    assert seen.get(0)==root && seen.get(1)==root;",
        "END"
      ]
    },
    {
      "id": "TC04_O1",
      "description": "two-level tree descends into child and ascends back",
      "path": "B0竊達1竊達2竊達3竊達5竊達11竊達12竊達23竊達1竊達11竊達13竊達16竊達20竊達21竊達24",
      "precondition": "none",
      "expectedResult": "calls head(div,0), head(span,1), tail(span,1), tail(div,0)",
      "tags": [
        "branch-descend",
        "branch-ascend",
        "loop-1",
        "overload:Node"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04_O1 traverse two-level",
        "  GIVEN",
        "    List<String> seq = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)->seq.add(n.nodeName()+\"@\"+d);",
        "    Element div = new Element(\"div\");",
        "    Element span = new Element(\"span\");",
        "    div.appendChild(span);",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, div);",
        "  THEN",
        "    assert seq.equals([\"div@0\",\"span@1\",\"span@1\",\"div@0\"]);",
        "END"
      ]
    },
    {
      "id": "TC05_O1",
      "description": "child replaced in head triggers replace branch",
      "path": "B0竊達1竊達2竊達3竊達5竊達6竊達7竊達8竊達11竊達12竊達23竊達1竊達24",
      "precondition": "visitor.head replaces child with newNode at same index to simulate FilterResult replace",
      "expectedResult": "visitor.tail called on new child and root only once each at correct depths",
      "tags": [
        "branch-replace",
        "overload:Node"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05_O1 traverse replace-child",
        "  GIVEN",
        "    Element div = new Element(\"div\");",
        "    Element child = new Element(\"p\");",
        "    div.appendChild(child);",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      public void head(Node n,int d){ if(n==child){ n.replaceWith(new Element(\"b\")); }}",
        "      public void tail(Node n,int d){}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, div);",
        "  THEN",
        "    assert div.child(0).tagName().equals(\"b\");",
        "END"
      ]
    },
    {
      "id": "TC06_O1",
      "description": "child removed in head triggers removal branch and skip tail",
      "path": "B0竊達1竊達2竊達3竊達5竊達6竊達7竊達9竊達10竊達1竊達24",
      "precondition": "visitor.head removes child to simulate removal path",
      "expectedResult": "child no longer in parent and tail not called on removed node",
      "tags": [
        "branch-remove",
        "overload:Node"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06_O1 traverse remove-child",
        "  GIVEN",
        "    Element div = new Element(\"div\");",
        "    Element child = new Element(\"p\");",
        "    div.appendChild(child);",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      public void head(Node n,int d){ if(n==child){ n.remove(); }}",
        "      public void tail(Node n,int d){}",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, div);",
        "  THEN",
        "    assert div.children().isEmpty();",
        "END"
      ]
    },
