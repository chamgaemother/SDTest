        "    Element l2 = new Element(\"em\");",
        "    root.appendChild(l1); l1.appendChild(l2);",
        "    List<String> seq = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor(){",
        "      head(n,d)-> seq.add(n.nodeName()+\"@\"+d);",
        "      tail(n,d)-> seq.add(n.nodeName()+\"@\"+d);",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert seq equals [\"div@0\",\"span@1\",\"em@2\",\"em@2\",\"span@1\",\"div@0\"];",
        "END"
      ]
