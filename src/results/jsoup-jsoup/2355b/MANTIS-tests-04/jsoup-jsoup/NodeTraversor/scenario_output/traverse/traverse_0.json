{
  "method": "traverse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "visitor is null causes IllegalArgumentException at Validate.notNull(visitor)",
      "path": "B0→B1→B24",
      "precondition": "none",
      "expectedResult": "throws IllegalArgumentException; no traversal attempted",
      "tags": [
        "overload:NodeVisitor,Node",
        "exception",
        "branch-false B1"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 null-visitor",
        "  GIVEN",
        "    NodeVisitor visitor = null;",
        "    Node root = new Element(\"div\");",
        "  WHEN",
        "    call NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
