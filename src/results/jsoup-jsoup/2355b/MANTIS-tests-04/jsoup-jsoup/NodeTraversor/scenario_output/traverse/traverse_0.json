    {
      "id": "TC08_O2",
      "description": "single-element list delegates to Node overload once",
      "path": "B0→B1→B2→B1→B3",
      "precondition": "none",
      "expectedResult": "visitor.head and tail called exactly twice for single element tree",
      "tags": [
        "overload:NodeVisitor,Elements",
        "loop-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08_O2 one-element",
        "  GIVEN",
        "    List<String> calls = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)->calls.add(\"h\"), (n,d)->calls.add(\"t\");",
        "    Element el = new Element(\"span\");",
        "    Elements elements = new Elements(el);",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, elements);",
        "  THEN",
        "    assert calls.size() == 2;",
        "END"
      ]
    },
    {
      "id": "TC09_O2",
      "description": "multiple-elements stops on STOP filter in filter overload stops iteration early",
      "path": "B0→B1→B2→B1→B2→B1→B3",
      "precondition": "none",
      "expectedResult": "traversal stops when visitor.head returns FilterResult.STOP for second element",
      "tags": [
        "overload:NodeVisitor,Elements",
        "filter:STOP",
        "loop-N"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09_O2 stop-early",
        "  GIVEN",
        "    NodeFilter filter = new NodeFilter(){public FilterResult head(Node n,int d){return n.nodeName().equals(\"p\")?FilterResult.STOP:FilterResult.CONTINUE;}public FilterResult tail(Node n,int d){return FilterResult.CONTINUE;}};",
        "    Elements elements = new Elements(new Element(\"div\"), new Element(\"p\"), new Element(\"span\"));",
        "  WHEN",
        "    NodeTraversor.filter(filter, elements);",
        "  THEN",
        "    assert filter.head_called_on_contains(\"p\");",
        "END"
      ]
    }
  ]
