        "    root.appendChild(new Element(\"li\"));",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assert events.get(0).equals(\"li@1\") && events.get(1).equals(\"/li@1\")",
        "END"
