      "pseudocode": [
        "TEST TC05_O1 traverse two-siblings",
        "  GIVEN",
        "    List<String> events = new ArrayList<>();",
        "    NodeVisitor visitor = (n,d)->events.add(n.nodeName()+\"@\"+d);",
        "    visitor = visitor.andThen((n,d)->events.add(\"/\"+n.nodeName()+\"@\"+d));",
