      "path": "B0â†’B1â†’B2â†’B5â†’B6â†’B7â†’B9â†’B10â†’B1â†’B5â†’B11â†’B12â†’B23â†’B1â†’B24",
      "precondition": "root has two leaf children; visitor.head removes the first child only",
      "expectedResult": "first child is removed without tail, then second child is visited head/tail, then root tail",
      "tags": [
        "negative",
        "removal",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 traverse remove-first-sibling",
        "  GIVEN",
        "    Element root = new Element(\"div\");",
        "    Element c1 = new Element(\"a\");",
        "    Element c2 = new Element(\"b\");",
        "    root.appendChild(c1); root.appendChild(c2);",
        "    List<String> log = new ArrayList<>();",
        "    NodeVisitor visitor = new NodeVisitor() {",
        "      @Override public void head(Node node, int depth) {",
        "        log.add(node.nodeName()+\":head:\"+depth);",
        "        if (node == c1) node.remove();",
        "      }",
        "      @Override public void tail(Node node, int depth) {",
        "        log.add(node.nodeName()+\":tail:\"+depth);",
        "      }",
        "    };",
        "  WHEN",
        "    NodeTraversor.traverse(visitor, root);",
        "  THEN",
        "    assertIterableEquals(List.of(",
        "      \"div:head:0\",",
        "      \"a:head:1\",           // c1 removed, tail skipped",
        "      \"b:head:1\",\"b:tail:1\",",
        "      \"div:tail:0\"",
        "    ), log);",
        "END"
      ]
    }
