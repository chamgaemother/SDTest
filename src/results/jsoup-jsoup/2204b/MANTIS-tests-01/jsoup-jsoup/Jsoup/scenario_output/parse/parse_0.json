    "id":"TC01",
    "description":"parse(String html, String baseUri) with non-empty html and valid baseUri returns Document with resolved links",
    "path":"B0→B1→B2",
    "precondition":"none",
    "expectedResult":"returned Document.baseUri() equals \"http://example.com/\" and document.html() contains \"<p>Test</p>\"",
    "tags":["overload:String,String","positive","branch-baseUri-nonEmpty"],
    "priority":"P0",
    "environment":"Java 8+",
    "pseudocode":[
      "TEST TC01 parse html with baseUri",
      "  GIVEN",
      "    String html = \"<p>Test</p>\";",
      "    String baseUri = \"http://example.com/\";",
      "  WHEN",
      "    Document doc = Jsoup.parse(html, baseUri);",
      "  THEN",
      "    assert doc.baseUri().equals(\"http://example.com/\");"
    ]
  },
