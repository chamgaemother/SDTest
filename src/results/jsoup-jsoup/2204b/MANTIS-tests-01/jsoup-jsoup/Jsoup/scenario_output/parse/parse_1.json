{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(File, charsetName, baseUri) reads HTML file with explicit charset and sets baseUri",
      "path": "B0→B1→B2→B3",
      "precondition": "a temp File containing '<p>FileTest</p>' encoded in UTF-8",
      "expectedResult": "Document.body().html() contains '<p>FileTest</p>' and baseUri equals provided URI",
      "tags": [
        "positive",
        "file",
        "charset",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse File with charset and baseUri",
        "  GIVEN",
        "    File file = createTempFile(\"<p>FileTest</p>\", UTF-8);",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://file.example/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>FileTest</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC12",
