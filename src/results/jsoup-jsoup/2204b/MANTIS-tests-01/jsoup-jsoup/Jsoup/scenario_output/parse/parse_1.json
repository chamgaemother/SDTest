        "END"
      ]
    },
    {
      "id": "TC13",
      "description": "parse(File, charsetName, baseUri, Parser) applies custom parser on file input",
      "path": "B0→B1→B2→B5",
      "precondition": "a temp File containing '<item>42</item>'",
      "expectedResult": "xmlParser produces <item> with text '42' and baseUri matches provided",
      "tags": [
        "positive",
        "file",
        "parser",
        "xml"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse File with parser",
        "  GIVEN",
        "    File file = createTempFile(\"<item>42</item>\");",
        "    Parser parser = Parser.xmlParser();",
        "    String baseUri = \"file://xml/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, null, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"item\").first().text().equals(\"42\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
