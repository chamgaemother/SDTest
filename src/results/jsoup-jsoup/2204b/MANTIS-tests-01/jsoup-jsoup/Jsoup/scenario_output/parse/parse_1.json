      "path": "B0→B13→B14→B15",
      "precondition": "a local HTTP test server serving '<title>URL</title>'",
      "expectedResult": "Document contains title 'URL'",
      "tags": [
        "positive",
        "network",
        "url"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse URL with timeout",
        "  GIVEN",
        "    URL url = startLocalHttpServer(\"<title>URL</title>\");",
        "    int timeout = 5000;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.title().equals(\"URL\");",
        "END"
      ]
