{
  "method": "setTrackPosition",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Calling setTrackPosition(true) enables position tracking when previously disabled",
      "path": "B0→B1→B2→B3",
      "precondition": "Parser parser = Parser.htmlParser(); // default trackPosition=false",
      "expectedResult": "parser.setTrackPosition(true) returns the same parser instance; parser.isTrackPosition() == true",
      "tags": [
        "branch-true",
        "state-change",
        "fluent"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 enable-position-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser returned = parser.setTrackPosition(true);",
        "  THEN",
        "    assert returned == parser;",
        "    assert parser.isTrackPosition() == true;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "Calling setTrackPosition(false) leaves position tracking disabled when already disabled",
      "path": "B0→B1→B2→B4",
      "precondition": "Parser parser = Parser.htmlParser(); // default trackPosition=false",
      "expectedResult": "parser.setTrackPosition(false) returns the same parser instance; parser.isTrackPosition() == false",
      "tags": [
        "branch-false",
        "idempotent",
        "fluent"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 disable-position-tracking-no-op",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser returned = parser.setTrackPosition(false);",
        "  THEN",
        "    assert returned == parser;",
        "    assert parser.isTrackPosition() == false;",
        "END"
      ]
    }
  ]
}