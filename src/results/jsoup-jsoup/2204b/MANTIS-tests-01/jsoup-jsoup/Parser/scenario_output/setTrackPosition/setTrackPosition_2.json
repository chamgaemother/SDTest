{
  "scenarios": [
    {
      "id": "TC05",
      "description": "newInstance() copies trackPosition=true state into new parser instance",
      "path": "B0→B1→B2→B3→B4→B5",
      "precondition": "Parser created via htmlParser(), trackPosition set to true",
      "expectedResult": "Cloned parser has trackPosition=true and is a distinct instance",
      "tags": [
        "positive",
        "clone",
        "state-copy"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 clone-preserves-true-trackPosition",
        "  GIVEN",
        "    Parser orig = Parser.htmlParser().setTrackPosition(true);",
        "    assertTrue(orig.isTrackPosition());",
        "  WHEN",
        "    Parser clone = orig.newInstance();",
        "  THEN",
        "    assertNotSame(orig, clone);",
        "    assertTrue(clone.isTrackPosition());",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "newInstance() copies trackPosition=false state into new parser instance",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "Parser created via xmlParser(), trackPosition remains default false",
      "expectedResult": "Cloned parser has trackPosition=false and is a distinct instance",
      "tags": [
        "positive",
        "clone",
        "state-copy",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 clone-preserves-false-trackPosition",
        "  GIVEN",
        "    Parser orig = Parser.xmlParser();",
        "    assertFalse(orig.isTrackPosition());",
        "  WHEN",
        "    Parser clone = orig.newInstance();",
        "  THEN",
        "    assertNotSame(orig, clone);",
        "    assertFalse(clone.isTrackPosition());",
        "END"
      ]
    }
  ]
}