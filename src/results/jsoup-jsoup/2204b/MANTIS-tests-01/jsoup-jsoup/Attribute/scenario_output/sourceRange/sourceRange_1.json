{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange delegates to parent.sourceRange when parent is non-null",
      "path": "B0→B2",
      "precondition": "Attributes stub with overridden sourceRange(String) returning a known range",
      "expectedResult": "returns the stubbed Range.AttributeRange instance",
      "tags": [
        "positive",
        "delegation"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange delegates to parent",
        "  GIVEN",
        "    // Arrange: create stub Attributes with custom sourceRange",
        "    Range.AttributeRange expected = new Range.AttributeRange(5, 10);",
        "    Attributes stubParent = new Attributes() {",
        "      @Override public Range.AttributeRange sourceRange(String k) {",
        "        return expected;",
        "      }",
        "      // implement other abstract/required methods as no-ops or default",
        "    };",
        "    Attribute a = new Attribute(\"data-key\", \"value\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = a.sourceRange();",
        "  THEN",
        "    // Assert",
        "    assertSame(expected, result);",
        "END"
      ]
    }
  ]
}