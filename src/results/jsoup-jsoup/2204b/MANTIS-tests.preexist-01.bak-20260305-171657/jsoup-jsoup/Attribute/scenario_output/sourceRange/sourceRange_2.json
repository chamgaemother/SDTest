{
  "scenarios": [
    {
      "id": "TC02",
      "description": "When parent is non-null delegates to parent.sourceRange(key)",
      "path": "B0→B2",
      "precondition": "A stub Attributes instance with overridden sourceRange returning a dummy range",
      "expectedResult": "Returns the dummy Range.AttributeRange instance from the stub parent",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange delegates to parent",
        "  GIVEN",
        "    // Arrange",
        "    Range.AttributeRange DUMMY_RANGE = new Range.AttributeRange(1, 2, 3);",
        "    Attributes stubParent = new Attributes() {",
        "      @Override",
        "      public Range.AttributeRange sourceRange(String key) {",
        "        return DUMMY_RANGE;",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"customKey\", \"value\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    // Assert",
        "    assertSame(DUMMY_RANGE, result);",
        "END"
      ]
    }
  ]
}