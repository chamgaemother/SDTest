{
  "scenarios": [
    {
      "id": "TC02",
      "description": "When parent is non-null delegates to parent.sourceRange(key)",
      "path": "B0→B2",
      "precondition": "stub Attributes parent overrides sourceRange(String)",
      "expectedResult": "returns the AttributeRange instance returned by parent.sourceRange",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange delegates to parent",
        "  GIVEN",
        "    // Arrange: create stub Attributes with overridden sourceRange",
        "    Range.AttributeRange DUMMY = new Range.AttributeRange(5, 10, 1);",
        "    Attributes stubParent = new Attributes() {",
        "      @Override",
        "      public Range.AttributeRange sourceRange(String key) {",
        "        return DUMMY;",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"customKey\", \"value\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    // Assert",
        "    assertSame(DUMMY, result);",
        "END"
      ]
    }
  ]
}