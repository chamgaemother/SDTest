{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange() delegates to parent.sourceRange(key) when parent is non-null (parent != null branch)",
      "path": "B0→B2",
      "precondition": "stubbed Attributes parent with overridden sourceRange",
      "expectedResult": "returns the exact instance returned by parent.sourceRange(key)",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange with non-null parent",
        "  GIVEN",
        "    String key = \"k\";",
        "    Range.AttributeRange expected = new Range.AttributeRange(5, 10, 15);",
        "    Attributes stubParent = new Attributes() {",
        "      @Override public Range.AttributeRange sourceRange(String k) {",
        "        return expected;",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(key, \"v\", stubParent);",
        "  WHEN",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    assertSame(expected, result);",
        "END"
      ]
    }
  ]
}