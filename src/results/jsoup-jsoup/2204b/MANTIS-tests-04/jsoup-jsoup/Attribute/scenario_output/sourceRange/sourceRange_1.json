{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange delegates to parent.sourceRange when parent is non-null (parent != null branch)",
      "path": "B0→B2",
      "precondition": "Attributes parent stubbed to return a specific AttributeRange for given key",
      "expectedResult": "returns the stubbed AttributeRange instance",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02 sourceRange delegates to non-null parent",
        "  GIVEN",
        "    String key = \"k\";",
        "    Range.AttributeRange expected = new Range.AttributeRange(5, 10, 15);",
        "    Attributes stubParent = new Attributes() {",
        "        @Override",
        "        public Range.AttributeRange sourceRange(String k) {",
        "            // Always return our expected stubbed range",
        "            return expected;",
        "        }",
        "    };",
        "    Attribute attr = new Attribute(key, \"v\", stubParent);",
        "  WHEN",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    assertSame(expected, result);",
        "END"
      ]
    }
  ]
}