{
  "scenarios": [
    {
      "id": "TC23",
      "description": "parse(String html, String baseUri, Parser parser) with null html throws NullPointerException",
      "path": "B0→B1→B2→B6",
      "precondition": "parser = Parser.htmlParser()",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 parse null-html with parser",
        "  GIVEN",
        "    String html = null;",
        "    String baseUri = \"http://x\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
      "id": "TC24",
      "description": "parseBodyFragment(String bodyHtml, String baseUri) returns document fragment with resolved baseUri",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "Document with body.html() = \"<a href='r'>r</a>\" and baseUri = \"http://b/\"",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC24 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String bodyHtml = \"<a href='r'>r</a>\";",
        "    String baseUri = \"http://b/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<a href='r'>r</a>\");",
        "    assert doc.baseUri().equals(\"http://b/\");",
        "END"
      ]
    },
    {
      "id": "TC25",
      "description": "parseBodyFragment(String bodyHtml) returns document fragment with empty baseUri",
      "path": "B0→B1→B2→B5",
      "precondition": "none",
      "expectedResult": "Document with body.html() = \"<span/>\" and baseUri = \"\"",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC25 parseBodyFragment default-baseUri",
        "  GIVEN",
        "    String bodyHtml = \"<span/>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(bodyHtml);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span/>\");",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
    {
      "id": "TC26",
      "description": "parse(Path path, String charsetName, String baseUri, Parser parser) with XML parser preserves unbalanced tags",
      "path": "B0→B1→B4→B5",
      "precondition": "path points to temp file containing \"<x>y\"; parser = Parser.xmlParser()",
      "expectedResult": "Document body.html() = \"<x>y</x>\" and baseUri = custom baseUri",
      "tags": [
        "positive",
        "file",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC26 parse(Path,charset,baseUri,parser) xml preserves unbalanced",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"jsoup\", \".xml\");",
        "    Files.write(path, \"<x>y\".getBytes(UTF_8));",
        "    String charset = null;",
        "    String baseUri = \"custom\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<x>y</x>\");",
        "    assert doc.baseUri().equals(\"custom\");",
        "END"
      ]
    },
    {
