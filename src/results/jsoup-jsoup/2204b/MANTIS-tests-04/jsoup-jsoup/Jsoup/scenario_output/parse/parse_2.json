        "  GIVEN",
        "    Path path = Paths.get(\"no-such-file.html\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"u\";",
        "  WHEN",
        "    call Jsoup.parse(path, charset, baseUri);",
        "  THEN",
        "    throws IOException;",
        "END"
      ]
    },
    {
      "id": "TC28",
      "description": "parse(Path path, String charsetName) with null charset uses path as baseUri",
      "path": "B0→B1→B3→B5",
      "precondition": "path points to temp HTML file with content",
      "expectedResult": "Document body.html() matches and baseUri = path.toAbsolutePath().toString()",
      "tags": [
        "positive",
        "overload",
        "boundary"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC28 parse(Path, null) auto-baseUri",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"jsoup\", \".html\");",
        "    Files.write(path, \"<p>z</p>\".getBytes(UTF_8));",
        "    String charset = null;",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>z</p>\");",
        "    assert doc.baseUri().equals(path.toAbsolutePath().toString());",
        "END"
      ]
    }
  ]
