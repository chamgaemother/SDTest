{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(InputStream, charsetName, baseUri) reads a UTF-8 stream and returns a Document with correct body and baseUri",
      "path": "B0→B12→B13→B14→B17",
      "precondition": "input stream contains \"<p>Hi</p>\" in UTF-8",
      "expectedResult": "Document.body().html() is \"<p>Hi</p>\" and baseUri is \"http://base/\"",
      "tags": [
        "positive",
        "overload",
        "stream"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse InputStream with charset and baseUri",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(\"<p>Hi</p>\".getBytes(StandardCharsets.UTF_8));",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assertEquals(\"<p>Hi</p>\", doc.body().html());",
        "    assertEquals(\"http://base/\", doc.baseUri());"
      ]
    },
    {
