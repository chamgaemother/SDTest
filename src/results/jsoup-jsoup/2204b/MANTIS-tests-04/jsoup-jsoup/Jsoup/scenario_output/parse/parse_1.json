        "boundary",
        "overload",
        "stream",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse empty stream with xml parser",
        "  GIVEN",
        "    InputStream in = new ByteArrayInputStream(new byte[0]);",
        "    String charset = null;",
        "    String baseUri = \"\";",
        "    Parser p = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri, p);",
        "  THEN",
        "    assertEquals(\"\", doc.body().html());",
        "    assertEquals(\"\", doc.baseUri());"
      ]
    },
    {
      "id": "TC13",
      "description": "parse(File, charsetName, baseUri) loads a temporary HTML file and returns a Document with resolved baseUri",
      "path": "B0→B19→B20→B21→B24",
      "precondition": "file exists containing \"<h1>Title</h1>\", charsetName=\"UTF-8\"",
      "expectedResult": "Document.body().html() is \"<h1>Title</h1>\" and baseUri is file-based",
      "tags": [
        "positive",
        "overload",
        "file"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 parse File with charset and baseUri",
        "  GIVEN",
        "    File file = Files.createTempFile(\"jsoup\", \".html\").toFile();",
        "    Files.write(file.toPath(), \"<h1>Title</h1>\".getBytes(StandardCharsets.UTF_8));",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://fbase/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assertEquals(\"<h1>Title</h1>\", doc.body().html());",
        "    assertEquals(\"http://fbase/\", doc.baseUri());"
      ]
    },
