{
  "method": "setTrackPosition",
  "scenarios": [
    {
      "id": "TC01",
      "description": "setTrackPosition(true) enables position tracking (trackPosition changes from default false to true)",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = Parser.htmlParser(); // default trackPosition=false",
      "expectedResult": "returned Parser instance equals parser, and parser.isTrackPosition() returns true",
      "tags": [
        "branch-none",
        "loop-0",
        "trackPosition-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setTrackPosition enables tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(true);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == true;"
      ]
    },
    {
      "id": "TC02",
      "description": "setTrackPosition(false) keeps position tracking disabled (trackPosition remains false)",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = Parser.htmlParser(); // default trackPosition=false",
      "expectedResult": "returned Parser instance equals parser, and parser.isTrackPosition() returns false",
      "tags": [
        "branch-none",
        "loop-0",
        "trackPosition-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setTrackPosition disables tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(false);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == false;"
      ]
    }
  ]
