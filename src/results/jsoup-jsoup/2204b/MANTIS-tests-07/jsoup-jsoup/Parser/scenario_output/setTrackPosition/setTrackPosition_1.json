{
  "scenarios": [
    {
      "id": "TC03",
      "description": "newInstance() after setTrackPosition(true) carries over enabled tracking",
      "path": "B0→B1→B2→B4",
      "precondition": "Parser.htmlParser() with default trackPosition=false",
      "expectedResult": "new parser instance has trackPosition=true and is separate object",
      "tags": [
        "positive",
        "chaining",
        "copy"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 newInstance retains trackPosition",
        "  GIVEN",
        "    Parser original = Parser.htmlParser().setTrackPosition(true);",
        "    assertTrue(original.isTrackPosition());",
        "  WHEN",
        "    Parser copy = original.newInstance();",
        "  THEN",
        "    assertNotSame(original, copy);",
        "    assertTrue(copy.isTrackPosition());"
      ]
    },
    {
      "id": "TC04",
      "description": "newInstance() without prior setTrackPosition() retains default disabled tracking",
      "path": "B0→B1→B2→B4",
      "precondition": "Parser.htmlParser() with default trackPosition=false",
      "expectedResult": "new parser instance has trackPosition=false and is separate object",
      "tags": [
        "positive",
        "copy",
        "default"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 newInstance default trackPosition",
        "  GIVEN",
        "    Parser original = Parser.htmlParser();",
        "    assertFalse(original.isTrackPosition());",
        "  WHEN",
        "    Parser copy = original.newInstance();",
        "  THEN",
        "    assertNotSame(original, copy);",
        "    assertFalse(copy.isTrackPosition());"
      ]
    }
  ]
}