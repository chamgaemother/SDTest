      "pseudocode": [
        "TEST TC09 clean removes disallowed tags",
        "  GIVEN",
        "    String html = \"<b>bold</b>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.none();",
        "  WHEN",
