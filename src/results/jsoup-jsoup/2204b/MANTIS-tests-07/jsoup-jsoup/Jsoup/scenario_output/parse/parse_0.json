    {
      "id": "TC10_isValid_trueFalse",
      "description": "isValid returns true when html allowed, false when disallowed",
      "path": "B0→B16→B17",
      "precondition": "Safelist safelist = Safelist.simpleText();",
      "expectedResult": "first call returns true for \"abc\", second returns false for \"<img/>\"",
      "tags": [
        "isValid",
        "branch-true",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 isValid allowed and then disallowed",
        "  GIVEN",
        "    Safelist safelist = Safelist.simpleText();",
        "  WHEN",
        "    boolean ok1 = Jsoup.isValid(\"abc\", safelist);",
        "    boolean ok2 = Jsoup.isValid(\"<img/>\", safelist);",
        "  THEN",
        "    assert ok1 == true;",
        "    assert ok2 == false;"
      ]
    }
  ]
}