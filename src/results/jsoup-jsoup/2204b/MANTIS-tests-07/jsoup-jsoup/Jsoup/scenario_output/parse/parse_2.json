{
  "scenarios": [
    {
      "id": "TC27",
      "description": "parse(html=null, parser non-null) throws IllegalArgumentException for null html with Parser overload",
      "path": "B0→B1→B6",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "null-input",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC27 parse_string_parser_nullHtml",
        "  GIVEN",
        "    String html = null;",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    call Jsoup.parse(html, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
