{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(html non-empty) uses default baseUri and returns parsed Document",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "doc.body().html() equals input HTML; doc.baseUri() is empty string",
      "tags": [
        "positive",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse String overload no-baseUri",
        "  GIVEN",
        "    String html = \"<div>X</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>X</div>\");",
        "    assert doc.baseUri().equals(\"\");"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(html null) overload without baseUri throws IllegalArgumentException",
      "path": "B0→B1→B6",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse String overload no-baseUri null-html",
        "  GIVEN",
        "    String html = null;",
        "  WHEN",
        "    call Jsoup.parse(html);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC13",
      "description": "parseBodyFragment(bodyHtml, baseUri) returns Document with correct baseUri and body fragment",
      "path": "B0→B3→B5",
      "precondition": "none",
      "expectedResult": "doc.body().html() equals fragment; doc.baseUri() equals provided baseUri",
      "tags": [
        "positive",
        "fragment"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC13 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String fragment = \"<span>f</span>\";",
        "    String base = \"https://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, base);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>f</span>\");",
        "    assert doc.baseUri().equals(\"https://base/\");"
      ]
    },
