    {
      "id": "TC25",
      "description": "clean(html, baseUri, safelist, outputSettings) applies custom outputSettings",
      "path": "B0→B3→B5",
      "precondition": "none",
      "expectedResult": "output respects prettyPrint=false, no newlines, cleaned fragment",
      "tags": [
        "positive",
        "clean",
        "outputSettings"
