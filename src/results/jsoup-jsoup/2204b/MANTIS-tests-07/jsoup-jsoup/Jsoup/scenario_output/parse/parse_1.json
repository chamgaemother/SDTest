      "id": "TC24",
      "description": "clean(html, safelist) overload removes disallowed tags using empty baseUri",
      "path": "B0→B3→B5",
      "precondition": "none",
      "expectedResult": "returns cleaned HTML fragment equivalent to clean(html, \"\", safelist)",
      "tags": [
        "positive",
        "clean",
