      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC24 clean overload no-baseUri",
        "  GIVEN",
        "    String html = \"<script>bad</script><p>ok</p>\";",
        "    Safelist sl = Safelist.basic();",
        "  WHEN",
        "    String out = Jsoup.clean(html, sl);",
        "  THEN",
        "    assert out.equals(\"<p>ok</p>\");"
