{
  "method": "setTrackPosition",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Calling setTrackPosition(true) sets trackPosition from default false to true and returns the same Parser instance",
      "path": "B0→B1",
      "precondition": "Parser parser = Parser.htmlParser(); // initial trackPosition=false",
      "expectedResult": "returned object is the same parser instance; parser.isTrackPosition() == true",
      "tags": [
        "branch-true",
        "chainable",
        "boolean-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setTrackPosition enable-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(true);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == true;"
      ]
    },
    {
      "id": "TC02",
      "description": "Calling setTrackPosition(false) resets trackPosition from true to false and returns the same Parser instance",
      "path": "B0→B1",
      "precondition": "Parser parser = Parser.htmlParser().setTrackPosition(true); // ensure initial trackPosition=true",
      "expectedResult": "returned object is the same parser instance; parser.isTrackPosition() == false",
      "tags": [
        "branch-false",
        "chainable",
        "boolean-false"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setTrackPosition disable-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser().setTrackPosition(true);",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(false);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == false;"
      ]
    }
  ]
}