{
  "scenarios": [
    {
      "id": "TC05",
      "description": "Calling setTrackPosition(false) on a fresh parser (default false) leaves trackPosition false and returns same instance",
      "path": "B0→B1(false)→B2",
      "precondition": "Parser parser = Parser.htmlParser(); // trackPosition=false",
      "expectedResult": "returned instance is same parser; parser.isTrackPosition() == false",
      "tags": [
        "boundary",
        "negative-case",
        "fluent"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 default-false-no-op",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    assert parser.isTrackPosition() == false;",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(false);",
        "  THEN",
        "    assertSame(result, parser);",
        "    assertFalse(parser.isTrackPosition());",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "newInstance() on a parser with default trackPosition=false produces a distinct parser with trackPosition=false",
      "path": "B0→B3→B4(false)",
      "precondition": "Parser original = Parser.htmlParser(); // trackPosition=false",
      "expectedResult": "original != copy; copy.isTrackPosition() == false",
      "tags": [
        "newInstance",
        "state-propagation",
        "negative-case"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 newInstance-propagates-default-false",
        "  GIVEN",
        "    Parser original = Parser.htmlParser();",
        "    assertFalse(original.isTrackPosition());",
        "  WHEN",
        "    Parser copy = original.newInstance();",
        "  THEN",
        "    assertNotSame(copy, original);",
        "    assertFalse(copy.isTrackPosition());",
        "END"
      ]
    }
  ]
}