{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and baseUri returns a Document with correct baseUri",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals \"http://example.com\" and Document.html() contains \"<p>Test</p>\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-default"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01_O1 parse(String,String) typical",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "    assert doc.html().contains(\"<p>Test</p>\");"
      ]
    },
    {
