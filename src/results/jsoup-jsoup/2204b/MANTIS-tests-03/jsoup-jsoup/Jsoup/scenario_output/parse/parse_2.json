        "    assert !clean.contains(\"img\");",
        "END"
      ]
    },
    {
      "id": "TC22",
      "description": "clean(html, baseUri, safelist, outputSettings) applies custom outputSettings",
      "path": "B0→B31→B32→B35",
      "precondition": "none",
      "expectedResult": "output respects no pretty-print and returns single-line HTML",
      "tags": [
        "overload",
        "clean",
        "settings"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 clean with outputSettings",
        "  GIVEN",
        "    String dirty = \"<div> A </div>\";",
        "    String baseUri = \"buri\";",
        "    Safelist safelist = Safelist.none();",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String clean = Jsoup.clean(dirty, baseUri, safelist, os);",
        "  THEN",
        "    assert clean.equals(\"A\");",
        "END"
      ]
    },
