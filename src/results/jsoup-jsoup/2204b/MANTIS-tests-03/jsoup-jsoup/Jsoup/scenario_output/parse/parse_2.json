{
  "scenarios": [
    {
      "id": "TC18",
      "description": "parseBodyFragment(html, baseUri) preserves body fragment and sets baseUri",
      "path": "B0→B28→B29",
      "precondition": "none",
      "expectedResult": "Document.body().html() contains fragment and baseUri is set",
      "tags": [
        "positive",
        "overload",
        "fragment"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String fragment = \"<p>F</p>\";",
        "    String baseUri = \"http://f.test/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, baseUri);",
        "  THEN",
        "    assert doc.body().html().contains(\"<p>F</p>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC19",
      "description": "parseBodyFragment(html) uses empty baseUri by default",
      "path": "B0→B28→B30",
      "precondition": "none",
      "expectedResult": "Document.body().html() contains fragment and baseUri is empty",
      "tags": [
        "boundary",
        "fragment",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parseBodyFragment default baseUri",
        "  GIVEN",
        "    String fragment = \"<div>X</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment);",
        "  THEN",
        "    assert doc.body().html().contains(\"<div>X</div>\");",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
    {
      "id": "TC20",
      "description": "clean(html, baseUri, safelist) removes disallowed tags and preserves allowed ones",
      "path": "B0→B31→B32→B33",
      "precondition": "none",
      "expectedResult": "cleaned HTML does not contain <script> and retains <b>",
      "tags": [
        "positive",
        "security",
        "clean"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 clean with baseUri and safelist",
        "  GIVEN",
        "    String dirty = \"<b>Ok</b><script>alert()</script>\";",
        "    String baseUri = \"http://clean.test/\";",
        "    Safelist safelist = Safelist.basic();",
        "  WHEN",
        "    String clean = Jsoup.clean(dirty, baseUri, safelist);",
        "  THEN",
        "    assert clean.contains(\"<b>Ok</b>\");",
        "    assert !clean.contains(\"script\");",
        "END"
      ]
    },
    {
      "id": "TC21",
      "description": "clean(html, safelist) delegates to clean(html, \"\", safelist)",
      "path": "B0→B31→B34",
