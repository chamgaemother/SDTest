    {
      "id": "TC27",
      "description": "newSession() returns independent HttpConnection session",
      "path": "B0→B40",
      "precondition": "none",
      "expectedResult": "returned Connection maintains session state separately",
      "tags": [
        "positive",
        "session",
        "connection"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC27 newSession state isolation",
        "  GIVEN",
        "    Connection s1 = Jsoup.newSession();",
        "    Connection s2 = Jsoup.newSession();",
        "  WHEN",
        "    s1.userAgent(\"A\").timeout(100);",
        "    s2.userAgent(\"B\").timeout(200);",
        "  THEN",
        "    assert !s1.request().userAgent().equals(s2.request().userAgent());",
        "    assert s1.request().timeoutMillis() == 100;",
        "    assert s2.request().timeoutMillis() == 200;",
        "END"
      ]
    }
  ]
