        "parser",
        "xml"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse(Path, charsetName, baseUri, parser) xml overload",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"jsoupPathXML\", \".xml\");",
        "    Files.write(path, \"<root/>\".getBytes(\"UTF-8\"));",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"u\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"root\").size() == 1;",
        "    assert doc.baseUri().equals(baseUri);"
