      "path": "B0→B24→B25",
      "precondition": "ByteArrayInputStream with XML content",
      "expectedResult": "return Document parsed by xmlParser and InputStream is closed after parsing",
      "tags": [
        "positive",
        "io",
        "inputstream",
        "parser",
        "xml"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse(InputStream, charsetName, baseUri, parser) xml overload",
        "  GIVEN",
        "    byte[] bytes = \"<a/>\".getBytes(\"UTF-8\");",
        "    InputStream in = new ByteArrayInputStream(bytes);",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"base\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.select(\"a\").size() == 1;",
        "    assertThrows(IOException.class, in::read);"
      ]
    },
