      "pseudocode": [
        "TEST TC13 parse(Path, charsetName) default baseUri",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"jsoupPath2\", \".html\");",
        "    Files.write(path, \"<div>P13</div>\".getBytes(\"UTF-8\"));",
        "    String charset = \"UTF-8\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset);",
        "  THEN",
        "    assert doc.html().contains(\"<div>P13</div>\");",
        "    assert doc.baseUri().equals(path.toAbsolutePath().toString());"
      ]
    },
