{
  "scenarios": [
    {
      "id": "TC12",
      "description": "parse(Path, charsetName, baseUri) successfully loads HTML and sets baseUri",
      "path": "B0→B19→B20",
      "precondition": "temporary HTML file exists",
      "expectedResult": "return Document containing file HTML and baseUri equals provided baseUri",
      "tags": [
        "positive",
        "file",
        "path",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC12 parse(Path, charsetName, baseUri) success",
        "  GIVEN",
        "    Path path = Files.createTempFile(\"jsoupPath\", \".html\");",
        "    Files.write(path, \"<p>Path</p>\".getBytes(\"UTF-8\"));",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://path.test/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(path, charset, baseUri);",
        "  THEN",
        "    assert doc.html().contains(\"<p>Path</p>\");",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
    {
