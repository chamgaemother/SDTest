package org.jsoup.nodes;

import static org.junit.jupiter.api.Assertions.assertSame;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

/**
 * Test suite for {@link Attribute#sourceRange()} behavior.
 */
public class Attribute_sourceRange_Test {

    @Test
    @DisplayName("sourceRange() returns parent's sourceRange(key) when parent is non-null (TC02)")
    public void test_TC02() {
        // Arrange: create a fake AttributeRange and an Attributes stub whose sourceRange returns it
        final Range.AttributeRange fakeRange = new Range.AttributeRange(5, 10);
        Attributes stubParent = new Attributes() {
            @Override
            public Range.AttributeRange sourceRange(String key) {
                // Always return our fakeRange to satisfy branch where parent != null
                return fakeRange;
            }
        };
        // The attribute is constructed with a non-null parent => triggers B0->B2 path
        Attribute attr = new Attribute("testKey", "testVal", stubParent);

        // Act: invoke sourceRange, expecting delegation to stubParent.sourceRange
        Range.AttributeRange result = attr.sourceRange();

        // Assert: must be exactly the fakeRange instance provided by parent
        assertSame(fakeRange, result, "When parent is non-null, sourceRange() should delegate to parent's sourceRange(key)");
    }
}