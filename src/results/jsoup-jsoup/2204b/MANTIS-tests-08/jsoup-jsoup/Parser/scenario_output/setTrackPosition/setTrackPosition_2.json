{
  "scenarios": [
    {
      "id": "TC05",
      "description": "newInstance() copies a true trackPosition value set by setTrackPosition(true)",
      "path": "B0→B1(setTrue)→B3(newInstance)→B4(copyConstructor)→B5(return)",
      "precondition": "Parser.htmlParser() with default trackPosition=false",
      "expectedResult": "new parser instance has trackPosition=true",
      "tags": [
        "positive",
        "chaining",
        "copy-constructor"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 newInstance preserves trackPosition=true",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    parser.setTrackPosition(true);",
        "    Parser copy = parser.newInstance();",
        "  THEN",
        "    assert copy != parser;",
        "    assert copy.isTrackPosition() == true;"
      ]
    },
    {
      "id": "TC06",
      "description": "newInstance() copies a false trackPosition value after setTrackPosition(false)",
      "path": "B0→B1(setFalse)→B3(newInstance)→B4(copyConstructor)→B5(return)",
      "precondition": "Parser.htmlParser() with default trackPosition=false",
      "expectedResult": "new parser instance has trackPosition=false",
      "tags": [
        "positive",
        "chaining",
        "copy-constructor",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 newInstance preserves trackPosition=false",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser().setTrackPosition(false);",
        "  WHEN",
        "    Parser copy = parser.newInstance();",
        "  THEN",
        "    assert copy != parser;",
        "    assert copy.isTrackPosition() == false;"
      ]
    }
  ]
}