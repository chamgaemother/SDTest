    {
      "id": "TC23",
      "description": "parse(URL, timeoutMillis) with valid HTTP URL returns parsed Document",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "embedded HTTP server running at http://localhost:8080/test.html returning '<div>ok</div>'",
      "expectedResult": "Document contains body html '<div>ok</div>'",
      "tags": [
        "positive",
        "http",
        "integration"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC23 parse with HTTP URL",
        "  GIVEN",
        "    // start simple HTTP server on localhost:8080 serving /test.html",
        "    URL url = new URL(\"http://localhost:8080/test.html\");",
        "    int timeout = 5000;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>ok</div>\");",
        "    server.stop();",
        "END"
      ]
    },
