      "description": "parse(html, baseUri, parser) with null parser throws NullPointerException",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "overload"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse with null parser",
        "  GIVEN",
        "    String html = \"<p>x</p>\";",
        "    String baseUri = \"http://example/\";",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri, (Parser) null);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
