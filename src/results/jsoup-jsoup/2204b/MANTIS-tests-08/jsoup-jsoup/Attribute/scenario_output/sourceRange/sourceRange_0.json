{
  "method": "sourceRange",
  "scenarios": [
    {
      "id": "TC01",
      "description": "sourceRange returns UntrackedAttr when parent is null (branch parent==null)",
      "path": "B0→B1",
      "precondition": "Attribute constructed with parent=null",
      "expectedResult": "returns Range.AttributeRange.UntrackedAttr",
      "tags": [
        "branch-parentNull",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 sourceRange parent-null",
        "  GIVEN",
        "    Attribute attr = new Attribute(\"key\", \"value\", null);",
        "  WHEN",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    assert result == Range.AttributeRange.UntrackedAttr;",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "sourceRange calls parent.sourceRange when parent is non-null (branch parent!=null)",
      "path": "B0→B2",
      "precondition": "using a stub Attributes where sourceRange(key) returns a known range",
      "expectedResult": "returns the stub's Range.AttributeRange for the given key",
      "tags": [
        "branch-parentNonNull",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange parent-non-null",
        "  GIVEN",
        "    Attributes stubParent = new Attributes(){ public Range.AttributeRange sourceRange(String k){ return new Range.AttributeRange(1,2,3,4); }};",
        "    Attribute attr = new Attribute(\"key\", \"value\", stubParent);",
        "  WHEN",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    assert result.start == 1 && result.end == 4;",
        "END"
      ]
    }
  ]
}