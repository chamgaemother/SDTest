{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange calls parent.sourceRange when parent is non-null (branch parent!=null)",
      "path": "B0→B2",
      "precondition": "Attributes stub with overridden sourceRange",
      "expectedResult": "returns the stubbed Range.AttributeRange with the specified start and end",
      "tags": [
        "positive",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange when parent non-null",
        "  GIVEN",
        "    // Arrange a stub Attributes that returns a known AttributeRange",
        "    Attributes stubParent = new Attributes() {",
        "      @Override public Range.AttributeRange sourceRange(String k) {",
        "        return new Range.AttributeRange(5, 10);",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"key\", \"value\", stubParent);",
        "  WHEN",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    assert result.getStart() == 5;",
        "    assert result.getEnd() == 10;",
        "END"
      ]
    }
  ]
}