package org.jsoup.parser;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertSame;
import static org.junit.jupiter.api.Assertions.assertTrue;

/**
 * Test class for Parser#setTrackPosition(boolean).
 * These tests verify that calling setTrackPosition updates the internal trackPosition flag and returns the same Parser instance.
 */
public class Parser_setTrackPosition_Test {

    @Test
    @DisplayName("TC01: setTrackPosition(true) sets trackPosition to true and returns this (branch-true)")
    public void test_TC01() {
        // GIVEN a fresh HTML parser with default trackPosition=false
        Parser parser = Parser.htmlParser();
        // WHEN enabling position tracking (true) → takes the branch that sets trackPosition = true
        Parser result = parser.setTrackPosition(true);
        // THEN the returned instance must be the same object (return-self) and isTrackPosition() should now be true
        assertSame(parser, result, "Expected setTrackPosition to return the same Parser instance");
        assertTrue(parser.isTrackPosition(), "Expected trackPosition to be true after setTrackPosition(true)");
    }

    @Test
    @DisplayName("TC02: setTrackPosition(false) sets trackPosition to false and returns this (branch-false)")
    public void test_TC02() {
        // GIVEN an HTML parser with trackPosition initially enabled
        Parser parser = Parser.htmlParser().setTrackPosition(true);
        // Precondition check: trackPosition must be true before disabling
        assertTrue(parser.isTrackPosition(), "Precondition: trackPosition should be true before calling setTrackPosition(false)");
        // WHEN disabling position tracking (false) → takes the branch that sets trackPosition = false
        Parser result = parser.setTrackPosition(false);
        // THEN the returned instance must be the same object (return-self) and isTrackPosition() should now be false
        assertSame(parser, result, "Expected setTrackPosition to return the same Parser instance");
        assertFalse(parser.isTrackPosition(), "Expected trackPosition to be false after setTrackPosition(false)");
    }
}