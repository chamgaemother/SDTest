      "id": "TC18",
      "description": "parse(InputStream in, String charsetName, String baseUri, Parser parser) closes stream after use",
      "path": "B0→B9→B40→B42",
      "precondition": "ByteArrayInputStream with HTML fragment",
      "expectedResult": "Body matches input and baseUri preserved, stream closed afterwards",
      "tags": [
        "overload",
        "stream",
        "parser",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC18 parse InputStream with charset, baseUri and parser",
        "  GIVEN",
        "    byte[] data = \"<i>I</i>\".getBytes(\"UTF-8\");",
        "    InputStream in = new ByteArrayInputStream(data);",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, \"UTF-8\", \"baseUriX\", parser);",
        "  THEN",
        "    assert doc.body().html().equals(\"<i>I</i>\");",
        "    assert doc.baseUri().equals(\"baseUriX\");",
        "    assert in.read() == -1; // stream is closed",
        "END"
      ]
    }
