{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(String html, String baseUri, Parser parser) uses provided parser and preserves baseUri",
      "path": "B0→B3→B12→B14",
      "precondition": "none",
      "expectedResult": "Document parsed by custom parser with correct body and baseUri",
      "tags": [
        "overload",
        "positive",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 parse with custom parser and baseUri",
        "  GIVEN",
        "    String html = \"<item>1</item>\";",
        "    String baseUri = \"https://xml.example/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().contains(\"<item>1</item>\");",
        "    assert doc.baseUri().equals(baseUri);",
        "END"
      ]
    },
    {
      "id": "TC12",
      "description": "parse(File file, String charsetName) loads file with explicit charset and uses file path as baseUri",
      "path": "B0→B5→B20→B22",
      "precondition": "temporary HTML file exists",
      "expectedResult": "Document body reflects file contents and baseUri equals file absolute path",
      "tags": [
        "overload",
        "file",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC12 parse file with charset overload",
        "  GIVEN",
        "    File temp = File.createTempFile(\"jsoup\", \".html\");",
        "    write \"<div>F</div>\" to temp using UTF-8;",
        "  WHEN",
        "    Document doc = Jsoup.parse(temp, \"UTF-8\");",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>F</div>\");",
        "    assert doc.baseUri().equals(temp.getAbsolutePath());",
        "END"
      ]
    },
