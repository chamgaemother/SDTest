{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange delegates to parent.sourceRange when parent is non-null",
      "path": "B0→B2",
      "precondition": "Attributes stub parent with overridden sourceRange method",
      "expectedResult": "returns the Range.AttributeRange instance provided by the parent",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange parent-not-null",
        "  GIVEN",
        "    // Arrange a stub Attributes that returns a known range",
        "    Range.AttributeRange stubRange = new Range.AttributeRange(5, 15);",
        "    Attributes stubParent = new Attributes() {",
        "      @Override",
        "      public Range.AttributeRange sourceRange(String key) {",
        "        return stubRange;",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"myKey\", \"myVal\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    // Assert",
        "    assertSame(stubRange, result);",
        "END"
      ]
    }
  ]
}