      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08_O1 parse(relativeLink) url-resolution",
        "  GIVEN",
        "    String html = \"<a href=\\\"page.html\\\">Link</a>\";",
        "    String baseUri = \"http://example.com/path/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://example.com/path/page.html\");",
        "END"
      ]
