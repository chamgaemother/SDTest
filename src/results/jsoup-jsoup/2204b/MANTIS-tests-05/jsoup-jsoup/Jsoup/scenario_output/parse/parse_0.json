        "TEST TC09_O1 parse(malformedHtml) auto-balance",
        "  GIVEN",
        "    String html = \"<b>bold text\";",
        "    String baseUri = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().children().size() == 1;",
        "    assert doc.body().child(0).tagName().equals(\"b\");",
