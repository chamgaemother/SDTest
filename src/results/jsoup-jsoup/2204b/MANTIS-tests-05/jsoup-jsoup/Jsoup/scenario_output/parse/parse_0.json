{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(String html, String baseUri) with non-empty html and baseUri returns a Document with correct text and baseUri resolved",
      "path": "B0→B1→B3→B4",
      "precondition": "none",
      "expectedResult": "returned Document.text() equals \"Hello World\" and Document.baseUri() equals \"http://example.com/\"",
      "tags": [
        "branch-normal",
        "overload:String,String",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse(html,baseUri) normal-case",
        "  GIVEN",
        "    String html = \"<p>Hello World</p>\";",
        "    String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.text().equals(\"Hello World\");",
        "    assert doc.baseUri().equals(\"http://example.com/\");",
        "END"
      ]
    },
    {
