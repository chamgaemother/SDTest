        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC16 parse InputStream with charset",
        "  GIVEN",
        "    byte[] bytes = \"<p>Stream</p>\".getBytes(\"UTF-8\");",
        "    InputStream in = new java.io.ByteArrayInputStream(bytes);",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://s/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, charset, baseUri);",
        "  THEN",
        "    assert doc.text().equals(\"Stream\");",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
