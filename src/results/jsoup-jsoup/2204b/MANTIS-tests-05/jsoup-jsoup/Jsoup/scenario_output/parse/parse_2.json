{
  "scenarios": [
    {
      "id": "TC15",
      "description": "parse(String html, String baseUri, Parser parser) with valid HTML and HTML parser returns Document with correct syntax and baseUri",
      "path": "B7→B8",
      "precondition": "none",
      "expectedResult": "Document with html syntax, baseUri preserved, element present",
      "tags": [
        "overload",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse html with custom Parser",
        "  GIVEN",
        "    String html = \"<div id='x'>X</div>\";",
        "    String baseUri = \"http://test/\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.outputSettings().syntax().equals(\"html\");",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"div#x\").first() != null;"
      ]
    },
    {
