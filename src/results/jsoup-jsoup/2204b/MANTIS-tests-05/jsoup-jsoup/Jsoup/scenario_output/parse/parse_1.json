{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(String html, String baseUri, Parser parser) with valid HTML and custom parser returns parsed Document with correct syntax and baseUri",
      "path": "B0→B2→B3→B7→B8",
      "precondition": "Parser parser = Parser.xmlParser()",
      "expectedResult": "Document with xml syntax and baseUri preserved",
      "tags": [
        "positive",
        "overload",
        "custom-parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse(html,baseUri,parser) with custom XML parser",
        "  GIVEN",
        "    String html = \"<node attr='v'>text</node>\";",
        "    String baseUri = \"http://example.org/\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    assert doc.outputSettings().syntax().equals(\"xml\");",
        "    assert doc.baseUri().equals(baseUri);",
        "    assert doc.select(\"node\").first().attr(\"attr\").equals(\"v\");",
        "END"
      ]
    },
    {
