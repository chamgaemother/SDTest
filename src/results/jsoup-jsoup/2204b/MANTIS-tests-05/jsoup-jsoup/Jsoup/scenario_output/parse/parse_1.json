        "  GIVEN",
        "    String html = \"<p>x</p>\";",
        "    String baseUri = \"http://x/\";",
        "    Parser parser = null;",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri, parser);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
