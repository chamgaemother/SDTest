      "id": "TC09",
      "description": "unescapeEntities returns correct unescaped string in strict mode and non-strict mode",
      "path": "B0→B14→B15→B16",
      "precondition": "none",
      "expectedResult": "unescapeEntities(\"&amp;lt; &lt;\",false) == \"&lt; <\" and ... inAttribute true escapes differently",
      "tags": [
        "static",
        "utility",
        "positive",
        "entities"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 unescapeEntities variations",
        "  GIVEN",
        "    String input = \"&amp;lt;&amp;gt;\";",
        "  WHEN",
        "    String out1 = Parser.unescapeEntities(input, false);",
        "    String out2 = Parser.unescapeEntities(input, true);",
        "  THEN",
        "    assertEquals(\"<>\", out1);",
        "    assertEquals(\"<>\", out2);"
