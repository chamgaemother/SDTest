      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 defaultNamespace for html and xml",
        "  GIVEN",
        "    Parser ph = Parser.htmlParser();",
        "    Parser px = Parser.xmlParser();",
        "  WHEN",
        "    String nh = ph.defaultNamespace();",
        "    String nx = px.defaultNamespace();",
