    {
      "id": "TC10",
      "description": "parse(File, charsetName, baseUri) reads UTF-8 file and resolves relative URL in HTML",
      "path": "B0â†’B1â†’DataUtil.loadâ†’Parser.parseâ†’return",
      "precondition": "temp HTML file exists with '<a href=\"foo.html\">x</a>' content",
      "expectedResult": "Document resolves absUrl('href') to baseUri + 'foo.html'",
      "tags": [
        "positive",
        "file",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 parse file with explicit charset and baseUri",
        "  GIVEN",
        "    File file = create temp file containing '<a href=\"foo.html\">link</a>';",
        "    String charset = 'UTF-8';",
        "    String baseUri = 'http://host/' ;",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.select('a').first().absUrl('href').equals('http://host/foo.html');",
        "END"
      ]
    },
