      "path": "B0→B1→B2(body-fragment-no-base)→B4",
      "precondition": "none",
      "expectedResult": "body().html() equals input fragment",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parseBodyFragment default-base",
        "  GIVEN",
        "    String html = \"<div>f</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html);",
