{
  "scenarios": [
    {
      "id": "TC17",
      "description": "parse(File, charsetName, baseUri, Parser) with xmlParser preserves tag case from file",
      "path": "B0→B1→B2(parser-overload-file)→B3→B5",
      "precondition": "temp HTML file containing <Tag>Value</Tag>",
      "expectedResult": "body HTML contains <Tag>Value</Tag> with case preserved",
      "tags": [
        "positive",
        "overload",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC17 parse(File,charset,baseUri,parser) xmlParser-case",
        "  GIVEN",
        "    File file = tempFileWithContent(\"<Tag>Value</Tag>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"\";",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri, parser);",
        "  THEN",
        "    assert doc.body().html().contains(\"<Tag>Value</Tag>\");"
      ]
    },
    {
