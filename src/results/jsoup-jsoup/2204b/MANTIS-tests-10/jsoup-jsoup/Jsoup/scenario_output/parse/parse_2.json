    },
    {
      "id": "TC20",
      "description": "parseBodyFragment(String, baseUri) resolves relative links in fragment",
      "path": "B0→B1→B3(body-fragment-with-base)→B4",
      "precondition": "none",
      "expectedResult": "absUrl on <a> resolves against provided baseUri",
      "tags": [
        "positive",
        "fragment",
        "relative",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String html = \"<a href=\\\"p.html\\\">p</a>\";",
        "    String baseUri = \"http://host/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"a\").first().absUrl(\"href\").equals(\"http://host/p.html\");"
      ]
    },
    {
      "id": "TC21",
      "description": "clean(String, Safelist.none()) escapes HTML entities and removes tags",
      "path": "B0→B1→B2(clean-two-arg)→B5",
      "precondition": "none",
      "expectedResult": "returns escaped text without tags",
      "tags": [
        "positive",
        "clean",
        "safelist",
        "entities"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 clean(html, safelist.none) escapes-and-strips",
        "  GIVEN",
        "    String html = \"<p>5 &lt; 6</p>\";",
        "    Safelist safelist = Safelist.none();",
        "  WHEN",
        "    String out = Jsoup.clean(html, safelist);",
        "  THEN",
        "    assert out.contains(\"5 &amp;lt; 6\") && !out.contains(\"<p>\");"
      ]
    },
    {
      "id": "TC22",
      "description": "clean(String, baseUri, Safelist, OutputSettings) applies output settings prettyPrint=false",
      "path": "B0→B1→B2(clean-4-arg)→B7",
      "precondition": "none",
      "expectedResult": "output has no newline for prettyPrint=false",
      "tags": [
        "positive",
        "clean",
        "outputSettings",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 clean(html, baseUri, safelist, settings) no-pretty",
        "  GIVEN",
        "    String html = \"<div>a</div>\";",
        "    String baseUri = \"\";",
        "    Safelist safelist = Safelist.basic();",
        "    Document.OutputSettings os = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    String out = Jsoup.clean(html, baseUri, safelist, os);",
        "  THEN",
        "    assert !out.contains(\"\\n\");"
      ]
    },
    {
      "id": "TC23",
      "description": "isValid(String, Safelist) returns false for disallowed tags and true for safe content",
      "path": "B0→B1→B2(isValid)→B3/B4",
      "precondition": "none",
      "expectedResult": "false for <script>, true for <p>",
      "tags": [
        "positive",
        "validation",
        "safelist"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC23 isValid unsafe-and-safe",
        "  GIVEN",
        "    String bad = \"<script>alert(1)</script>\";",
        "    String good = \"<p>ok</p>\";",
        "    Safelist safelist = Safelist.basic();",
        "  WHEN",
        "    boolean vBad = Jsoup.isValid(bad, safelist);",
        "    boolean vGood = Jsoup.isValid(good, safelist);",
        "  THEN",
        "    assert !vBad && vGood;"
      ]
    },
