    {
      "id": "TC25",
      "description": "parse(URL, timeoutMillis) happy path uses HttpConnection stub to return parsed Document",
      "path": "B0→B1→B2(connect-url)→B3(timeout)→B4(get)",
      "precondition": "mock HttpConnection.connect to return stub with get() returning known Document",
      "expectedResult": "returned Document matches stub content",
      "tags": [
        "positive",
        "network",
        "overload",
        "mock"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC25 parse(URL,timeout) success-stub",
        "  GIVEN",
        "    URL url = new URL(\"http://example.com/\");",
        "    stubConnection = stub(HttpConnection.connect(url));",
        "    stubConnection.get() returns Document.parse(\"<b>ok</b>\", \"\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, 5000);",
        "  THEN",
        "    assert doc.body().html().equals(\"<b>ok</b>\");"
      ]
    }
  ]
