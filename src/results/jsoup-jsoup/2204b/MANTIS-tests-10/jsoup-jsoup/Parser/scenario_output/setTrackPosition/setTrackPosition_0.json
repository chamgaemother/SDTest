{
  "method": "setTrackPosition",
  "scenarios": [
    {
      "id": "TC01",
      "description": "setTrackPosition(true) sets trackPosition to true and returns the same Parser instance",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder()); // default trackPosition is false",
      "expectedResult": "returned Parser is the same instance as parser; parser.isTrackPosition() == true",
      "tags": [
        "functional",
        "set-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setTrackPosition enables tracking",
        "  GIVEN",
        "    Parser parser = new Parser(new HtmlTreeBuilder());",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(true);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == true;"
      ]
    },
    {
      "id": "TC02",
      "description": "setTrackPosition(false) sets trackPosition to false and returns the same Parser instance",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder()).setTrackPosition(true); // initial trackPosition is true",
      "expectedResult": "returned Parser is the same instance as parser; parser.isTrackPosition() == false",
      "tags": [
        "functional",
        "set-false"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setTrackPosition disables tracking",
        "  GIVEN",
        "    Parser parser = new Parser(new HtmlTreeBuilder()).setTrackPosition(true);",
        "  WHEN",
        "    Parser result = parser.setTrackPosition(false);",
        "  THEN",
        "    assert result == parser;",
        "    assert parser.isTrackPosition() == false;"
      ]
    },
    {
      "id": "TC03",
      "description": "chain setTrackPosition calls and verify last call determines trackPosition",
      "path": "B0→B1→B2",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder());",
      "expectedResult": "after chaining, parser.isTrackPosition() == false",
      "tags": [
        "functional",
        "chaining"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 chained setTrackPosition calls",
        "  GIVEN",
        "    Parser parser = new Parser(new HtmlTreeBuilder());",
        "  WHEN",
        "    parser.setTrackPosition(true).setTrackPosition(false);",
        "  THEN",
        "    assert parser.isTrackPosition() == false;"
      ]
    }
  ]
