{
  "scenarios": [
    {
      "id": "TC04",
      "description": "newInstance() copies a true trackPosition setting into the new Parser instance",
      "path": "B0→B1→B2→B3",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder()).setTrackPosition(true)",
      "expectedResult": "newParser.isTrackPosition() returns true; newParser != parser",
      "tags": [
        "positive",
        "copy",
        "newInstance"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 newInstance copies trackPosition=true",
        "  GIVEN",
        "    Parser parser = new Parser(new HtmlTreeBuilder()).setTrackPosition(true);",
        "  WHEN",
        "    Parser newParser = parser.newInstance();",
        "  THEN",
        "    assert newParser != parser;",
        "    assertTrue(newParser.isTrackPosition());"
      ]
    },
    {
      "id": "TC05",
      "description": "newInstance() copies a false trackPosition setting into the new Parser instance",
      "path": "B0→B1→B2→B3",
      "precondition": "Parser parser = new Parser(new HtmlTreeBuilder()) // default trackPosition = false",
      "expectedResult": "newParser.isTrackPosition() returns false; newParser != parser",
      "tags": [
        "boundary",
        "copy",
        "newInstance"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 newInstance copies trackPosition=false",
        "  GIVEN",
        "    Parser parser = new Parser(new HtmlTreeBuilder());",
        "  WHEN",
        "    Parser newParser = parser.newInstance();",
        "  THEN",
        "    assert newParser != parser;",
        "    assertFalse(newParser.isTrackPosition());"
      ]
    }
  ]
