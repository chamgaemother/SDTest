{
  "scenarios": [
    {
      "id": "TC22",
      "description": "parse(html) with non-empty HTML returns a Document with correct body element",
      "path": "B0→B2→B5→B8",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals input fragment",
      "tags": [
        "positive",
        "overload",
        "single-arg"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC22 parse non-empty single-arg overload",
        "  GIVEN",
        "    String html = \"<p>hello</p>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>hello</p>\");"
      ]
    },
    {
      "id": "TC23",
      "description": "parse(html, Parser.htmlParser()) exercises htmlParser path in two-arg overload",
      "path": "B0→B3→B6→B9",
      "precondition": "none",
      "expectedResult": "Document.select(\"p\").text() equals 'test'",
      "tags": [
        "positive",
        "overload",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC23 parse with htmlParser two-arg overload",
        "  GIVEN",
        "    String html = \"<p>test</p>\";",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, parser);",
        "  THEN",
        "    assert doc.select(\"p\").first().text().equals(\"test\");"
      ]
    },
    {
      "id": "TC24",
      "description": "parse(InputStream,charset,baseUri,Parser.xmlParser()) processes self-closing tags via xmlParser",
      "path": "B0→B7→B11→B14",
      "precondition": "input stream with XML fragment",
      "expectedResult": "Document.select(\"item\").size() == 1",
      "tags": [
        "positive",
        "overload",
        "parser",
        "inputstream"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC24 parse InputStream with xmlParser overload",
        "  GIVEN",
        "    byte[] data = \"<item/>\".getBytes(\"UTF-8\");",
        "    InputStream in = new ByteArrayInputStream(data);",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(in, \"UTF-8\", \"base\", parser);",
        "  THEN",
        "    assert doc.select(\"item\").size() == 1;"
      ]
    },
