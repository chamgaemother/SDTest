{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(null, anyBaseUri) throws NullPointerException when html is null",
      "path": "B0→B1",
      "precondition": "none",
      "expectedResult": "throws NullPointerException; no state mutated",
      "tags": [
        "exception",
        "branch-true",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 parse null-html",
        "  GIVEN",
        "    String html = null; String baseUri = \"http://example.com\";",
        "  WHEN",
        "    call Jsoup.parse(html, baseUri);",
        "  THEN",
        "    throws NullPointerException;"
      ]
    },
    {
      "id": "TC02",
      "description": "parse(\"\",\"\") returns empty Document when html is empty",
      "path": "B0→B2",
      "precondition": "none",
      "expectedResult": "return Document with empty body html",
      "tags": [
        "boundary",
        "branch-false",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 parse empty-html",
        "  GIVEN",
        "    String html = \"\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"\");"
      ]
    },
    {
      "id": "TC03",
      "description": "parse(\"<p>Hi</p>\",\"/base\") returns Document resolving relative URLs against baseUri",
      "path": "B0→B2",
      "precondition": "none",
      "expectedResult": "return Document where doc.select(\"p\").first().text() is \"Hi\" and doc.baseUri() is \"/base\"",
      "tags": [
        "positive",
        "branch-false",
        "overload:String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 parse html-with-base",
        "  GIVEN",
        "    String html = \"<p>Hi</p>\";",
        "    String baseUri = \"/base\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.select(\"p\").first().text().equals(\"Hi\");",
        "    assert doc.baseUri().equals(\"/base\");"
      ]
    },
    {
