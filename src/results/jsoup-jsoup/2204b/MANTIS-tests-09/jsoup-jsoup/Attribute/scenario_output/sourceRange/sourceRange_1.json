{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange returns parent's sourceRange(key) when parent is non-null (parent != null branch)",
      "path": "B0→B2",
      "precondition": "stubbed Attributes parent with overridden sourceRange",
      "expectedResult": "return value matches stubbed AttributeRange",
      "tags": [
        "positive",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange with non-null parent",
        "  GIVEN",
        "    // Arrange a stub Attributes that returns a fixed range",
        "    Attributes stubParent = new Attributes() {",
        "      @Override public Range.AttributeRange sourceRange(String k) {",
        "        return new Range.AttributeRange(10,20,30,40);",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"myKey\",\"myVal\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    // Assert that stub value is returned",
        "    assert result.startTagStart() == 10;",
        "    assert result.startTagEnd() == 20;",
        "    assert result.endTagStart() == 30;",
        "    assert result.endTagEnd() == 40;",
        "END"
      ]
    }
  ]
}