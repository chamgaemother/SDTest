{
  "scenarios": [
    {
      "id": "TC04",
      "description": "newInstance() copies trackPosition state when true",
      "path": "B0→B1→B2",
      "precondition": "Parser with trackPosition=true via setTrackPosition(true)",
      "expectedResult": "newInstance parser has trackPosition=true and is distinct instance",
      "tags": [
        "positive",
        "copy",
        "trackPosition"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 newInstance copies true state",
        "  GIVEN",
        "    Parser original = Parser.htmlParser().setTrackPosition(true);",
        "  WHEN",
        "    Parser copy = original.newInstance();",
        "  THEN",
        "    assertTrue(copy.isTrackPosition());",
        "    assertNotSame(original, copy);",
        "END"
      ]
    },
    {
      "id": "TC05",
      "description": "newInstance() copies trackPosition state when false",
      "path": "B0→B1→B3",
      "precondition": "Parser with trackPosition=false (default)",
      "expectedResult": "newInstance parser has trackPosition=false and is distinct instance",
      "tags": [
        "positive",
        "copy",
        "trackPosition"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 newInstance copies false state",
        "  GIVEN",
        "    Parser original = Parser.xmlParser();",
        "    assertFalse(original.isTrackPosition());",
        "  WHEN",
        "    Parser copy = original.newInstance();",
        "  THEN",
        "    assertFalse(copy.isTrackPosition());",
        "    assertNotSame(original, copy);",
        "END"
      ]
    }
  ]
