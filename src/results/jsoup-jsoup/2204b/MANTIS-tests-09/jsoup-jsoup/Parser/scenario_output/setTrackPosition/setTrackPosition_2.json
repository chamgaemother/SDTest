{
  "scenarios": [
    {
      "id": "TC06",
      "description": "Chaining setTrackPosition(true) twice retains trackPosition=true and returns same instance on second call",
      "path": "B0→B1→B2→B2→B3",
      "precondition": "Parser.htmlParser() yields trackPosition=false",
      "expectedResult": "After two setTrackPosition(true) calls, parser.isTrackPosition() remains true and both returns are same instance",
      "tags": [
        "positive",
        "chaining",
        "no-state-change"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 double-enable-position-tracking",
        "  GIVEN",
        "    Parser parser = Parser.htmlParser();",
        "    assertFalse(parser.isTrackPosition());",
        "  WHEN",
        "    Parser first = parser.setTrackPosition(true);",
        "    Parser second = first.setTrackPosition(true);",
        "  THEN",
        "    assertSame(parser, first);",
        "    assertSame(parser, second);",
        "    assertTrue(parser.isTrackPosition());",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "Chaining setTrackPosition(false) twice retains trackPosition=false and returns same instance on second call",
      "path": "B0→B1→B3→B3→B3",
      "precondition": "Parser.xmlParser() yields trackPosition=false",
      "expectedResult": "After two setTrackPosition(false) calls, parser.isTrackPosition() remains false and both returns are same instance",
      "tags": [
        "positive",
        "chaining",
        "no-state-change"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 double-disable-position-tracking",
        "  GIVEN",
        "    Parser parser = Parser.xmlParser();",
        "    assertFalse(parser.isTrackPosition());",
        "  WHEN",
        "    Parser first = parser.setTrackPosition(false);",
        "    Parser second = first.setTrackPosition(false);",
        "  THEN",
        "    assertSame(parser, first);",
        "    assertSame(parser, second);",
        "    assertFalse(parser.isTrackPosition());",
        "END"
      ]
    }
  ]
