{
  "scenarios": [
    {
      "id": "TC03",
      "description": "setTrackPosition(false) when already false leaves tracking disabled and returns same parser instance",
      "path": "B0→B1→B2→B3",
      "precondition": "new Parser with default trackPosition = false",
      "expectedResult": "returned instance is same, isTrackPosition() remains false",
      "tags": [
        "negative",
        "chaining",
        "no-op"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 setTrackPosition no-op false→false",
        "  GIVEN",
        "    Parser p = new Parser(new HtmlTreeBuilder());",
        "    assertFalse(p.isTrackPosition());",
        "  WHEN",
        "    Parser result = p.setTrackPosition(false);",
        "  THEN",
        "    assertSame(p, result);",
        "    assertFalse(result.isTrackPosition());",
        "END"
      ]
    },
    {
      "id": "TC04",
      "description": "setTrackPosition(true) when already true leaves tracking enabled and returns same parser instance",
      "path": "B0→B1→B2→B3",
      "precondition": "Parser with trackPosition already true",
      "expectedResult": "returned instance is same, isTrackPosition() remains true",
      "tags": [
        "positive",
        "chaining",
        "no-op"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 setTrackPosition no-op true→true",
        "  GIVEN",
        "    Parser p = new Parser(new HtmlTreeBuilder()).setTrackPosition(true);",
        "    assertTrue(p.isTrackPosition());",
        "  WHEN",
        "    Parser result = p.setTrackPosition(true);",
        "  THEN",
        "    assertSame(p, result);",
        "    assertTrue(result.isTrackPosition());",
        "END"
      ]
    }
  ]
}