{
  "scenarios": [
    {
      "id": "TC02",
      "description": "sourceRange() delegates to parent.sourceRange when parent is non-null",
      "path": "B0→B2",
      "precondition": "Attributes stub with overridden sourceRange",
      "expectedResult": "returns the stubbed AttributeRange from parent.sourceRange",
      "tags": [
        "positive",
        "delegation",
        "branch"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 sourceRange delegation",
        "  GIVEN",
        "    // Arrange a stubbed Attributes with a known return for sourceRange",
        "    Attributes stubParent = new Attributes() {",
        "      @Override public Range.AttributeRange sourceRange(String key) {",
        "        return new Range.AttributeRange(5, 10);",
        "      }",
        "    };",
        "    Attribute attr = new Attribute(\"data-test\", \"value\", stubParent);",
        "  WHEN",
        "    // Act",
        "    Range.AttributeRange result = attr.sourceRange();",
        "  THEN",
        "    // Assert",
        "    assert result.equals(new Range.AttributeRange(5, 10));",
        "END"
      ]
    }
  ]
}