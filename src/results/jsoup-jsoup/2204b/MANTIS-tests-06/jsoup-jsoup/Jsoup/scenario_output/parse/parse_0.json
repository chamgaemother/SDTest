{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01_O1",
      "description": "parse(html, baseUri) with non-empty html and non-empty baseUri returns a Document with correct baseUri resolution",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "returned Document has baseUri 'http://example.com' and contains a single <p>Test</p> element",
      "tags": [
        "positive",
        "overload:String,String",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01_O1 parse(html, baseUri) normal",
        "  GIVEN",
        "    String html = \"<p>Test</p>\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com\");",
        "    assert doc.select(\"p\").size() == 1;"
      ]
    },
    {
      "id": "TC02_O1",
      "description": "parse(html, baseUri) with empty html returns empty Document body",
      "path": "B0→B1→B3→B5",
      "precondition": "none",
      "expectedResult": "returned Document has no body children and baseUri equals ''",
      "tags": [
        "boundary",
        "overload:String,String",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC02_O1 parse(empty html, baseUri)",
        "  GIVEN",
        "    String html = \"\";",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().children().isEmpty();",
        "    assert doc.baseUri().equals(\"http://example.com\");"
      ]
    },
