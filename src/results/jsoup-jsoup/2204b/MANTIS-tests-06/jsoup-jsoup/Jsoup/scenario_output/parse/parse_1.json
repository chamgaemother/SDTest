{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parse(File,charsetName,baseUri) with real HTML file returns parsed Document",
      "path": "B0→BXX_file_load_success→BZZ_return",
      "precondition": "temp HTML file exists with <h1> heading",
      "expectedResult": "Document contains h1 text and baseUri applied",
      "tags": [
        "positive",
        "file",
        "parse"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 parse File with explicit charset and baseUri",
        "  GIVEN",
        "    File file = createTempFile(\"<h1>Hi</h1>\");",
        "    String charset = \"UTF-8\";",
        "    String baseUri = \"http://base/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, charset, baseUri);",
        "  THEN",
        "    assert doc.select(\"h1\").text().equals(\"Hi\");",
        "    assert doc.baseUri().equals(baseUri);"
      ]
    },
