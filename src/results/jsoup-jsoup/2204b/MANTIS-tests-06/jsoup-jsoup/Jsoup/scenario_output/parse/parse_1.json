      "id": "TC13",
      "description": "parse(File,charsetName,baseUri,parser) with xmlParser returns XML structure",
      "path": "B0→BXX_file_load_success→BZZ_return",
      "precondition": "temp XML-like file exists",
      "expectedResult": "xmlParser retains empty-element syntax",
      "tags": [
        "positive",
        "file",
        "parser"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC13 parse File with custom Parser",
        "  GIVEN",
        "    File file = createTempFile(\"<root><empty/></root>\");",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    Document doc = Jsoup.parse(file, null, \"base://\", parser);",
        "  THEN",
        "    assert doc.select(\"root > empty\").size() == 1;",
        "    assert doc.baseUri().equals(\"base://\");"
      ]
