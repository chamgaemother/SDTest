{
  "scenarios": [
    {
      "id": "TC18",
      "description": "parseBodyFragment(html, baseUri) returns a Document whose body contains the fragment and correct baseUri",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals fragment and baseUri is applied",
      "tags": [
        "positive",
        "fragment",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC18 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String fragment = \"<span>F</span>\";",
        "    String base = \"http://b/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment, base);",
        "  THEN",
        "    assert doc.body().html().equals(\"<span>F</span>\");",
        "    assert doc.baseUri().equals(base);",
        "END"
      ]
    },
    {
      "id": "TC19",
