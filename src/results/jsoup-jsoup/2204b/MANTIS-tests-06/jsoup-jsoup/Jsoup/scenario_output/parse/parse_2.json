      "id": "TC28",
      "description": "parse(URL, timeout) with HTTP URL returns Document and applies timeout",
      "path": "B0→B1→B3→B10→B11",
      "precondition": "URL url = new URL(\"http://httpbin.org/html\");",
      "expectedResult": "Document contains html tag and no exception",
      "tags": [
        "positive",
        "network",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC28 parse URL success",
        "  GIVEN",
        "    URL url = new URL(\"http://httpbin.org/html\");",
        "    int timeout = 5000;",
        "  WHEN",
        "    Document doc = Jsoup.parse(url, timeout);",
        "  THEN",
        "    assert doc.select(\"html\").size() > 0;",
        "END"
