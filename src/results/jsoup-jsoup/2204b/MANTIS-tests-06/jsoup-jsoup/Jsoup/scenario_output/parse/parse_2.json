      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parseBodyFragment no-baseUri",
        "  GIVEN",
        "    String fragment = \"<div>X</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(fragment);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div> X</div>\") || doc.body().html().contains(\"<div>X</div>\");",
        "    assert doc.baseUri().equals(\"\");",
        "END"
      ]
    },
