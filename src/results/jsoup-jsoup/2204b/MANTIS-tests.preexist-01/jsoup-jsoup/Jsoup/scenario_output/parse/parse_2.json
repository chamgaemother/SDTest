{
  "scenarios": [
    {
      "id": "TC19",
      "description": "parse(String html, String baseUri) overload returns Document with given baseUri and parsed content",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "none",
      "expectedResult": "Document.body().html() equals input HTML and baseUri is preserved",
      "tags": [
        "positive",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC19 parse html-with-baseUri",
        "  GIVEN",
        "    String html = \"<div>X</div>\";",
        "    String baseUri = \"http://host/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>X</div>\");",
        "    assert doc.baseUri().equals(\"http://host/\");",
        "END"
      ]
    },
    {
      "id": "TC20",
      "description": "parse(File file, String charsetName) overload loads file with default baseUri from file path",
      "path": "B0→B1→B4→B6",
      "precondition": "Temporary HTML file exists on disk",
      "expectedResult": "Document.body().html() equals file content and baseUri equals file absolute path",
      "tags": [
        "positive",
        "file",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC20 parse file-with-null-charset",
        "  GIVEN",
        "    Path tmp = createTempFile(\".html\");",
        "    write tmp \"<p>File</p>\";",
        "    File f = tmp.toFile();",
        "    String charset = null;",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, charset);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>File</p>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "END"
      ]
    },
    {
      "id": "TC21",
      "description": "parse(File file, String charsetName, String baseUri, Parser parser) overload uses custom parser and baseUri",
      "path": "B0→B1→B4→B7",
      "precondition": "Temporary XML file exists on disk",
      "expectedResult": "Document parsed by xmlParser and baseUri set as given",
      "tags": [
        "positive",
        "file",
        "parser",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC21 parse file-with-parser",
        "  GIVEN",
        "    Path tmp = createTempFile(\".html\");",
        "    write tmp \"<root><a/></root>\";",
        "    File f = tmp.toFile();",
        "    Parser xml = Parser.xmlParser();",
        "    String base = \"http://x/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(f, null, base, xml);",
        "  THEN",
        "    assert doc.select(\"a\").size() == 1;",
        "    assert doc.baseUri().equals(\"http://x/\");",
        "END"
      ]
    },
    {
      "id": "TC22",
      "description": "parse(Path path, String charsetName, String baseUri, Parser parser) overload uses XML parser on Path",
      "path": "B0→B1→B4→B7",
      "precondition": "Temporary file Path exists",
      "expectedResult": "Document parsed by xmlParser and baseUri set to provided value",
      "tags": [
        "positive",
        "path",
        "parser",
        "overload"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC22 parse path-with-parser",
        "  GIVEN",
        "    Path tmp = createTempFile(\".html\");",
        "    writeString tmp \"<tag>v</tag>\";",
        "    Parser xml = Parser.xmlParser();",
        "    String base = \"https://u/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(tmp, null, base, xml);",
        "  THEN",
        "    assert doc.select(\"tag\").size() == 1;",
        "    assert doc.baseUri().equals(\"https://u/\");",
        "END"
      ]
    },
