    {
      "id": "TC14",
      "description": "parseBodyFragment(String bodyHtml, String baseUri) with fragment and baseUri resolves relative links",
      "path": "B0→B1→B4→B5",
      "precondition": "none",
      "expectedResult": "Relative link in fragment resolved against provided baseUri",
      "tags": [
        "positive",
        "fragment",
        "relative-link"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC14 parseBodyFragment with baseUri",
        "  GIVEN",
        "    String frag = \"<a href='/path'>link</a>\";",
        "    String base = \"http://host/\";",
        "  WHEN",
        "    Document doc = Jsoup.parseBodyFragment(frag, base);",
        "  THEN",
        "    Element a = doc.selectFirst(\"a\");",
        "    assert a.absUrl(\"href\").equals(\"http://host/path\");",
        "END"
      ]
    },
    {
      "id": "TC15",
      "description": "parse(File file) with valid HTML file returns Document and uses file path as baseUri",
      "path": "B0→B2→B7",
      "precondition": "File file = new temp file containing \"<p>F</p>\"",
      "expectedResult": "Document.body.html() equals \"<p>F</p>\" and baseUri equals file.getAbsolutePath()",
      "tags": [
        "positive",
        "file",
        "overload"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC15 parse single-arg File",
        "  GIVEN",
        "    File f = writeTempFile(\"<p>F</p>\");",
        "  WHEN",
        "    Document doc = Jsoup.parse(f);",
        "  THEN",
        "    assert doc.body().html().equals(\"<p>F</p>\");",
        "    assert doc.baseUri().equals(f.getAbsolutePath());",
        "END"
      ]
    },
