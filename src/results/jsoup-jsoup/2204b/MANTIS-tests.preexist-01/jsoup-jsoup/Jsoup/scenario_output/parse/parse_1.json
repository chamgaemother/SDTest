{
  "scenarios": [
    {
      "id": "TC11",
      "description": "parse(String html) with valid HTML returns a Document parsed with empty baseUri",
      "path": "B0→B1→B2→B5",
      "precondition": "none",
      "expectedResult": "Document.body.html() matches input and baseUri is empty",
      "tags": [
        "positive",
        "overload",
        "parse(String)"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC11 parse single-arg overload",
        "  GIVEN",
        "    String html = \"<div>Test</div>\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html);",
        "  THEN",
        "    assert doc.body().html().equals(\"<div>Test</div>\");",
        "    assert doc.baseUri().isEmpty();",
        "END"
      ]
    },
