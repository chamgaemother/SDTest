{
  "method": "parse",
  "scenarios": [
    {
      "id": "TC01",
      "description": "parse(String html, String baseUri) with valid HTML and absolute baseUri returns a Document with correct baseUri",
      "path": "B0→B1→B4",
      "precondition": "none",
      "expectedResult": "returned Document.baseUri() equals \"http://example.com/\" and Document.select(\"p\").text() equals \"Hello\"",
      "tags": [
        "overload:String,String",
        "positive",
        "branch-false"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parse valid-html-and-baseUri",
        "  GIVEN",
        "    String html = \"<p>Hello</p>\"; String baseUri = \"http://example.com/\";",
        "  WHEN",
        "    Document doc = Jsoup.parse(html, baseUri);",
        "  THEN",
        "    assert doc.baseUri().equals(\"http://example.com/\"); assert doc.select(\"p\").text().equals(\"Hello\");"
      ]
    },
    {
