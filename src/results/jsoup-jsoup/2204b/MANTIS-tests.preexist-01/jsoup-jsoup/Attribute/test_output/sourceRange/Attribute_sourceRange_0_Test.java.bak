package org.jsoup.nodes;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

public class Attribute_sourceRange_Test {

    @Test
    @DisplayName("TC01: parent is null returns UntrackedAttr (branch parent==null)")
    public void test_TC01() {
        // GIVEN an Attribute with key="foo" and parent=null, so parent == null branch (B0→B2)
        Attribute attr = new Attribute("foo", "bar", null);
        // WHEN sourceRange() is called
        Range.AttributeRange result = attr.sourceRange();
        // THEN the result is Range.AttributeRange.UntrackedAttr
        assertEquals(Range.AttributeRange.UntrackedAttr, result,
                "Expected UntrackedAttr when parent is null");
    }

    @Test
    @DisplayName("TC02: parent is non-null returns parent's sourceRange(key) (branch parent!=null)")
    public void test_TC02() {
        // GIVEN an Attribute with key="foo" and a stubbed Attributes parent where sourceRange("foo") returns a unique stubRange
        final Range.AttributeRange stubRange = Range.AttributeRange.UntrackedAttr; // using UntrackedAttr as a distinguishable constant
        Attributes stubParent = new Attributes() {
            @Override
            public Range.AttributeRange sourceRange(String key) {
                // Ensure this method is called by returning our stubRange
                return stubRange;
            }
        };
        Attribute attr = new Attribute("foo", "bar", stubParent);
        // WHEN sourceRange() is called
        Range.AttributeRange result = attr.sourceRange();
        // THEN the result is stubRange from the parent stub
        assertSame(stubRange, result,
                "Expected to delegate to parent's sourceRange when parent is non-null");
    }
}