      "path": "B0→B1(ex)",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "string-overload",
        "null-input"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 parseFragmentInput string-overload null-html",
        "  GIVEN",
        "    Parser parser = new Parser(new StubTreeBuilderEmpty());",
        "    String fragment = null;",
        "    Element context = null;",
        "    String baseUri = \"\";",
        "  WHEN",
        "    call parser.parseFragmentInput(fragment, context, baseUri);",
