{
  "scenarios": [
    {
      "id": "TC07",
      "description": "parseFragmentInput(Reader, context) propagates UncheckedIOException when TreeBuilder.parseFragment throws",
      "path": "B0→B1→B2(ex)→B3",
      "precondition": "Parser constructed with StubTreeBuilderFail",
      "expectedResult": "UncheckedIOException is thrown",
      "tags": [
        "exception",
        "reader-overload",
        "treebuilder-fail"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 parseFragmentInput reader-overload treebuilder exception",
        "  GIVEN",
        "    // Arrange stub builder that fails in parseFragment",
        "    Parser parser = new Parser(new StubTreeBuilderFail());",
        "    Reader reader = new StringReader(\"<tag>\");",
        "    Element context = new Element(\"div\");",
        "    String baseUri = \"http://example.com\";",
        "  WHEN",
        "    // Act & Assert",
        "    call parser.parseFragmentInput(reader, context, baseUri);",
        "  THEN",
        "    // Expect",
        "    throws UncheckedIOException;",
        "END"
      ]
    },
    {
      "id": "TC08",
