package org.jsoup.parser;

import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.nodes.Node;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.io.Reader;
import java.io.StringReader;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

public class Parser_parseFragmentInput_Test {

    @Test
    @DisplayName("TC06_O2: Reader overload with non-null context and two sibling elements returns two nodes")
    public void test_TC06_O2() {
        // Arrange: use a Reader to trigger the Reader overload path (B1->B2)
        Reader fragment = new StringReader("<div>one</div><span>two</span>");
        Document doc = Document.createShell("http://x");
        Element context = doc.body(); // non-null context to follow B3->B4
        Parser parser = Parser.htmlParser();

        // Act: call the Reader overload
        List<Node> result = parser.parseFragmentInput(fragment, context, "http://x");

        // Assert: expecting two elements in the fragment (B6)
        assertEquals(2, result.size(), "Expected two sibling nodes");
        // First node is a div element
        assertTrue(result.get(0) instanceof Element, "First node should be an Element");
        assertEquals("div", ((Element) result.get(0)).tagName(), "First tag should be 'div'");
        // Second node is a span element
        assertTrue(result.get(1) instanceof Element, "Second node should be an Element");
        assertEquals("span", ((Element) result.get(1)).tagName(), "Second tag should be 'span'");
    }

    @Test
    @DisplayName("TC07_O1: String overload returns single TextNode when fragment has only text and non-null context")
    public void test_TC07_O1() {
        // Arrange: use String overload to go B1->B2->B4 (skipping Reader path)
        String fragment = "plain text"; // simple text triggers no element parsing
        Document doc = Document.createShell("http://y");
        Element context = doc.body(); // non-null context to follow B3->B4
        Parser parser = Parser.htmlParser();

        // Act: call the String overload
        List<Node> result = parser.parseFragmentInput(fragment, context, "http://y");

        // Assert: expecting exactly one TextNode with the given text (B6)
        assertEquals(1, result.size(), "Expected a single TextNode");
        Node node = result.get(0);
        // Text nodes print as their literal text
        assertEquals("plain text", node.toString(), "TextNode content should match input text");
    }
}