      "description": "String overload with null fragment throws NullPointerException before parse",
      "path": "B0→B1→B2→B7",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "negative",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parseFragmentInput null-string-fragment",
        "  GIVEN",
        "    String fragment = null;",
        "    Element context = Document.createShell(\"http://x\").body();",
        "  WHEN",
        "    call Parser.htmlParser().parseFragmentInput(fragment, context, \"http://x\");",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
