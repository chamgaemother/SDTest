        "xml",
        "reader-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 xmlParser reader-overload",
        "  GIVEN",
        "    Reader fragment = new StringReader(\"<a/>\");",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    List<Node> result = parser.parseFragmentInput(fragment, null, \"base\");",
        "  THEN",
        "    assert result.size() == 1;",
        "    Element el = (Element) result.get(0);",
        "    assert el.tagName().equals(\"a\");"
      ]
