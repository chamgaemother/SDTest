      "expectedResult": "returned list has size 1 and first node is an Element with tagName \"p\" and text \"Hi\"",
      "tags": [
        "overload:Reader,Element,String",
        "integration",
        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03_O1 real-parse single-element",
        "  GIVEN",
        "    Reader fragment = new StringReader(\"<p>Hi</p>\");",
        "    Parser parser = Parser.htmlParser();",
        "  WHEN",
        "    List<Node> result = parser.parseFragmentInput(fragment, null, \"base\");",
        "  THEN",
        "    assert result.size() == 1;",
        "    assert ((Element)result.get(0)).tagName().equals(\"p\");",
        "    assert ((Element)result.get(0)).text().equals(\"Hi\");"
      ]
