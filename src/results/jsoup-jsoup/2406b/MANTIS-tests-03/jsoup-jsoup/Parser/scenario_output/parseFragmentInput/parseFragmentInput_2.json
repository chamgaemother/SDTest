{
  "scenarios": [
    {
      "id": "TC16",
      "description": "String overload with xmlParser and non-null context appends parsed node to context",
      "path": "B0→B3→B4→B7→B8",
      "precondition": "Element context = new Element(\"div\"); Parser parser = Parser.xmlParser()",
      "expectedResult": "context.children() contains one Element with tagName 'a'",
      "tags": [
        "positive",
        "xml",
        "context",
        "string-overload"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 xmlParser string-overload with context",
        "  GIVEN",
        "    String fragment = \"<a/>\";",
        "    Element context = new Element(\"div\");",
        "    Parser parser = Parser.xmlParser();",
        "  WHEN",
        "    List<Node> result = parser.parseFragmentInput(fragment, context, \"base\");",
        "  THEN",
        "    assertEquals(1, result.size());",
        "    Element el = (Element) result.get(0);",
        "    assertEquals(\"a\", el.tagName());",
        "    assertTrue(context.children().contains(el));",
        "END"
      ]
    },
    {
      "id": "TC17",
      "description": "Reader overload with stub TreeBuilderReturningEmpty and non-null context returns empty result and leaves context unchanged",
      "path": "B0→B1→B2→B3→unlock",
      "precondition": "StubTreeBuilderReturningEmpty stub = new StubTreeBuilderReturningEmpty(); Parser parser = new Parser(stub); Element context = new Element(\"div\");",
      "expectedResult": "result.isEmpty() and context.children() is empty",
      "tags": [
        "negative",
        "stub",
        "context",
        "reader-overload"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC17 stub-returning-empty reader-overload with context",
        "  GIVEN",
        "    Reader fragment = new StringReader(\"anything\");",
        "    StubTreeBuilderReturningEmpty stub = new StubTreeBuilderReturningEmpty();",
        "    Parser parser = new Parser(stub);",
        "    Element context = new Element(\"div\");",
        "  WHEN",
        "    List<Node> result = parser.parseFragmentInput(fragment, context, \"base\");",
        "  THEN",
        "    assertTrue(result.isEmpty());",
        "    assertTrue(context.children().isEmpty());",
        "END"
      ]
    },
