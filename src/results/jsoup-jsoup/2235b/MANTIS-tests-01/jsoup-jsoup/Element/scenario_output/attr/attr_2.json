{
  "scenarios": [
    {
      "id": "TC10",
      "description": "attr(String key, String value) sets a new attribute when value is empty string (covers B0→B1→B3→B4)",
      "path": "B0→B1→B3→B4",
      "precondition": "none",
      "expectedResult": "new attribute 'empty' is present with value '' and method returns this element",
      "tags": [
        "positive",
        "boundary",
        "empty-value"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 attr empty-value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"empty\";",
        "    String val = \"\";",
        "  WHEN",
        "    Element returned = el.attr(key, val);",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().hasKey(\"empty\");",
        "    assert el.attributes().get(\"empty\").equals(\"\");",
        "END"
      ]
    },
    {
      "id": "TC11",
      "description": "attr(String key, String value) replaces existing attribute value with empty string (covers B0→B1→B3→B4)",
      "path": "B0→B1→B3→B4",
      "precondition": "Element has existing attribute 'foo' with value 'bar'",
      "expectedResult": "attribute 'foo' is present with updated value '' and method returns this element",
      "tags": [
        "positive",
        "boundary",
        "replace"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 attr replace-with-empty",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"foo\", \"bar\");",
        "  WHEN",
        "    Element returned = el.attr(\"foo\", \"\");",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().hasKey(\"foo\");",
        "    assert el.attributes().get(\"foo\").equals(\"\");",
        "END"
      ]
    }
  ]
}