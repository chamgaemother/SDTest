  "scenarios": [
    {
      "id": "TC07",
      "description": "attr(String key, String value) throws IllegalArgumentException when key is empty string",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown due to empty key",
      "tags": [
        "negative",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 attr empty-key",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"\";",
        "    String value = \"val\";",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
