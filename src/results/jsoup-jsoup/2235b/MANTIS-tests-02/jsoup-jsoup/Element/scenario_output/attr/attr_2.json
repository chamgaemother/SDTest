{
  "scenarios": [
    {
      "id": "TC10",
      "description": "attr(String,boolean) with false on a non-existing key does not add attribute and returns same element",
      "path": "B0→B3(booleanFalse)→B4",
      "precondition": "Element with no 'foo' attribute",
      "expectedResult": "returns same element and 'foo' is not present",
      "tags": [
        "negative",
        "boolean",
        "no-op"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 attr-boolean-nonExistingKey-false",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    // no 'foo' attribute present",
        "  WHEN",
        "    Element result = el.attr(\"foo\", false);",
        "  THEN",
        "    assertSame(el, result);",
        "    assertFalse(el.attributes().hasKey(\"foo\"));",
        "END"
      ]
    },
    {
      "id": "TC11",
      "description": "attr(String,boolean) with empty-string key adds boolean attribute with empty value",
      "path": "B0→B3(booleanTrue)→B4",
      "precondition": "Element with no '' attribute",
      "expectedResult": "returns same element and empty key attribute present with empty string value",
      "tags": [
        "boundary",
        "boolean",
        "empty-key"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 attr-boolean-emptyKey-true",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    // no '' attribute present",
        "  WHEN",
        "    Element result = el.attr(\"\", true);",
        "  THEN",
        "    assertSame(el, result);",
        "    assertTrue(el.attributes().hasKey(\"\"));",
        "    assertEquals(\"\", el.attributes().get(\"\"));",
        "END"
      ]
    }
  ]
}