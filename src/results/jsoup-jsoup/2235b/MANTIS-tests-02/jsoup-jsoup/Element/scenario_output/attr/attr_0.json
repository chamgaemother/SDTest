{
  "method": "attr",
  "scenarios": [
    {
      "id": "TC01",
      "description": "attr(String,String) with new key and non-null value sets attribute and returns same element",
      "path": "B0→B1→B3",
      "precondition": "Element el = new Element(\"div\"); no mocks",
      "expectedResult": "el.attr(\"data-test\",\"value\") returns el; el.attributes().get(\"data-test\")==\"value\"",
      "tags": [
        "branch-false(keyNull)",
        "branch-false(valueNull)",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 attr new key",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"data-test\";",
        "    String val = \"value\";",
        "  WHEN",
        "    Element result = el.attr(key, val);",
        "  THEN",
        "    assert result == el;",
        "    assert el.attributes().get(key).equals(val);",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "attr(String,String) with existing key updates its value",
      "path": "B0→B1→B3",
      "precondition": "Element el = new Element(\"span\"); el.attr(\"id\",\"old\"); no mocks",
      "expectedResult": "el.attr(\"id\",\"new\"); el.attributes().get(\"id\")==\"new\"",
      "tags": [
        "branch-false(keyNull)",
        "branch-false(valueNull)",
        "update"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 attr update existing",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"id\",\"old\");",
        "  WHEN",
        "    el.attr(\"id\",\"new\");",
        "  THEN",
        "    assert el.attributes().get(\"id\").equals(\"new\");",
        "END"
      ]
    },
