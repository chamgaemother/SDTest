{
  "scenarios": [
    {
      "id": "TC08",
      "description": "attr(String,String) with empty key throws IllegalArgumentException (key empty string)",
      "path": "B0→B1(keyEmpty)→B2",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown and no attribute is added",
      "tags": [
        "negative",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 attr empty-key throws",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"\";",
        "    String val = \"value\";",
        "  WHEN",
        "    call el.attr(key, val);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "    assert !el.attributes().hasKey(\"\");",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "attr(String,String) with empty value sets attribute to empty string",
      "path": "B0→B3→B4(return)",
      "precondition": "none",
      "expectedResult": "attribute exists with empty string value and returns same element",
      "tags": [
        "positive",
        "boundary"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 attr empty-value sets empty",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    String key = \"data-empty\";",
        "    String val = \"\";",
        "  WHEN",
        "    Element result = el.attr(key, val);",
        "  THEN",
        "    assertSame(el, result);",
        "    assertTrue(el.attributes().hasKey(key));",
        "    assertEquals(\"\", el.attributes().get(key));",
        "END"
      ]
    }
  ]
}