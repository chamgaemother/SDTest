    {
      "id": "TC04",
      "description": "outputSettings(custom) returns the same Document instance for chaining",
      "path": "B0→B1→B2",
      "precondition": "Document doc = new Document(\"http://example.com\"); custom = new OutputSettings()",
      "expectedResult": "returned Document is the same reference as doc",
      "tags": [
        "positive",
        "chaining",
        "setter"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 outputSettings returns this",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings custom = new Document.OutputSettings();",
        "  WHEN",
        "    Document returned = doc.outputSettings(custom);",
        "  THEN",
        "    assertSame(doc, returned);",
        "END"
      ]
    }
  ]
