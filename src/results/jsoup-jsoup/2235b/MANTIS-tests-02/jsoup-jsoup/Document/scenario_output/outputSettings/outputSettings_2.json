{
  "scenarios": [
    {
      "id": "TC05",
      "description": "Fluent chaining: setter followed immediately by getter returns the custom instance",
      "path": "B0→B1→B2",
      "precondition": "Document doc = new Document(baseUri); customSettings != null",
      "expectedResult": "doc.outputSettings(customSettings).outputSettings() == customSettings",
      "tags": [
        "positive",
        "chaining",
        "getter"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 fluent-setter-getter returns custom",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings customSettings = new Document.OutputSettings().prettyPrint(false);",
        "  WHEN",
        "    Document.OutputSettings result = doc.outputSettings(customSettings).outputSettings();",
        "  THEN",
        "    assertSame(customSettings, result);",
        "END"
      ]
    }
  ]
}