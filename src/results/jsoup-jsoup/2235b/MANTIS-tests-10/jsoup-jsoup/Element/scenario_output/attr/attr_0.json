,"P0"],"priority":"P0","environment":"Java 8","pseudocode":["TEST TC04 Element.attr null-value","  GIVEN","    Element el = new Element(\"span\");","  WHEN","    call el.attr(\"key\",null);","  THEN","    throws IllegalArgumentException;","END"]}]}}
