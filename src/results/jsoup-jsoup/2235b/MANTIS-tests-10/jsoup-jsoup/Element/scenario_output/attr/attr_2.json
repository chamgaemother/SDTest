{
  "scenarios": [
    {
      "id": "TC05",
      "description": "attr with empty string value sets attribute to empty string without error (branch B1→B2→B3)",
      "path": "B1→B2→B3",
      "precondition": "Element el = new Element(\"div\") with no prior attributes",
      "expectedResult": "attribute 'key' exists with value \"\" and method returns el",
      "tags": [
        "positive",
        "boundary",
        "empty-value"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 attr empty-value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"key\";",
        "    String value = \"\";",
        "  WHEN",
        "    Element ret = el.attr(key, value);",
        "  THEN",
        "    assertSame(el, ret);",
        "    assertTrue(el.attributes().hasKey(key));",
        "    assertEquals(\"\", el.attributes().get(key));",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "attr with empty string key throws IllegalArgumentException (Validate.notEmptyParam(key))",
      "path": "B1→B4",
      "precondition": "Element el = new Element(\"span\")",
      "expectedResult": "IllegalArgumentException is thrown, no attributes created",
      "tags": [
        "negative",
        "exception",
        "boundary",
        "empty-key"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 attr empty-key",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    String key = \"\";",
        "    String value = \"v\";",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "    assertTrue(el.attributes() == null || !el.attributes().hasKey(key));",
        "END"
      ]
    }
  ]
}