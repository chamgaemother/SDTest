{
  "scenarios": [
    {
      "id": "TC05",
      "description": "outputSettings assigns the exact instance (no cloning) so subsequent mutations affect the document",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "the same OutputSettings instance is stored and any further changes to it are reflected in document.outputSettings()",
      "tags": [
        "positive",
        "reference-assignment"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 outputSettings instance-reference",
        "  GIVEN",
        "    Document doc = new Document(\"baseUri\");",
        "    OutputSettings settings = new OutputSettings().prettyPrint(true);",
        "  WHEN",
        "    doc.outputSettings(settings);",
        "    settings.prettyPrint(false);",
        "  THEN",
        "    assert doc.outputSettings().prettyPrint() == false;",
        "END"
      ]
    }
  ]
}