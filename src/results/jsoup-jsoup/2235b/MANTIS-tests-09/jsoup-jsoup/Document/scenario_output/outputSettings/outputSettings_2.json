      "precondition": "Document doc = new Document(\"http://example.com\");",
      "expectedResult": "IllegalArgumentException is thrown with message containing 'must not be null'",
      "tags": [
        "exception",
        "negative",
        "message-validation"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 outputSettings null-message",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "  WHEN",
        "    call doc.outputSettings(null)",
        "  THEN",
        "    catch IllegalArgumentException e",
        "    assert e.getMessage().contains(\"must not be null\");",
        "END"
      ]
    }
