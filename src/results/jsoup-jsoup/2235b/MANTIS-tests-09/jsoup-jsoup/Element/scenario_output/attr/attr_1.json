{
  "scenarios": [
    {
      "id": "TC06",
      "description": "attr(String,String): null value argument throws IllegalArgumentException (branch: Validate.notNull(value) fails)",
      "path": "B0→B1(value null)→B2(exception)",
      "precondition": "Element created without attributes",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "attr"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 attr null-value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"data-null\";",
        "    String value = null;",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "attr(String,boolean): false on non-existing key results in no attribute added (branch: attributeValue false, key absent)",
      "path": "B0→B3(key absent)→B4(no-op removal)→B5(return)",
      "precondition": "Element created without attributes",
      "expectedResult": "no attribute present for the key and method returns this Element",
      "tags": [
        "negative",
        "boolean",
        "attr"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 attr-boolean-false-noop",
        "  GIVEN",
        "    Element el = new Element(\"input\");",
        "    String key = \"readonly\";",
        "  WHEN",
        "    Element returned = el.attr(key, false);",
        "  THEN",
        "    assertFalse(el.attributes().hasKey(key));",
        "    assertSame(el, returned);",
        "END"
      ]
    }
  ]
}