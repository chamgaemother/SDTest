{
  "scenarios": [
    {
      "id": "TC08",
      "description": "attr(String,String) returns this Element instance for chaining when adding a new attribute",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "returns same Element instance and adds attribute with correct value",
      "tags": [
        "positive",
        "chainable"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 attr chaining returns self",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "  WHEN",
        "    Element returned = el.attr(\"data-test\", \"xyz\");",
        "  THEN",
        "    assertSame(el, returned);",
        "    assertEquals(\"xyz\", el.attributes().get(\"data-test\"));",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "attr(String,String) adds attribute with empty-string value when value is empty",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "attribute present with empty string value and size==1",
      "tags": [
        "boundary",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 attr empty-string value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    el.attr(\"title\", \"\");",
        "  THEN",
        "    assertTrue(el.attributes().hasKey(\"title\"));",
        "    assertEquals(\"\", el.attributes().get(\"title\"));",
        "    assertEquals(1, el.attributes().size());",
        "END"
      ]
    }
  ]
}