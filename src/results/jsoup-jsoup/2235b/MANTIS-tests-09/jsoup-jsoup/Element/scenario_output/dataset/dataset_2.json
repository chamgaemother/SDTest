      "path": "B0→B1→B2(putAllNull)→B4",
      "precondition": "Element has no data- attributes",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "null-input"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 dataset putAll null argument",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    Map<String,String> additions = null;",
        "  WHEN",
        "    Map<String,String> data = el.dataset();",
        "    call data.putAll(additions);",
        "  THEN",
        "    throws NullPointerException"
      ]
    }
  ]
