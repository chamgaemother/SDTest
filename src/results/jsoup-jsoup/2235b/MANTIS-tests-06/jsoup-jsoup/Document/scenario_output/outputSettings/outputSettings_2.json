{
  "scenarios": [
    {
      "id": "TC06",
      "description": "Setting an OutputSettings with XML syntax via Document.outputSettings updates escapeMode to xhtml",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "Document.outputSettings().syntax() == xml and .escapeMode() == xhtml",
      "tags": [
        "positive",
        "side-effect",
        "syntax-branch"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 apply-xml-syntax-updates-escapeMode",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings settings = new Document.OutputSettings();",
        "  WHEN",
        "    doc.outputSettings(settings).outputSettings().syntax(OutputSettings.Syntax.xml);",
        "  THEN",
        "    assert doc.outputSettings().syntax() == OutputSettings.Syntax.xml;",
        "    assert doc.outputSettings().escapeMode() == Entities.EscapeMode.xhtml;",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "Chaining Document.outputSettings().prettyPrint(false) retains the same OutputSettings instance",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "Chained call returns same OutputSettings and prettyPrint() == false",
      "tags": [
        "positive",
        "chain",
        "iteration"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 chain-prettyPrint-on-outputSettings",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings original = doc.outputSettings();",
        "  WHEN",
        "    Document.OutputSettings returned = doc.outputSettings().prettyPrint(false);",
        "  THEN",
        "    assertSame(original, returned);",
        "    assertFalse(doc.outputSettings().prettyPrint());",
        "END"
      ]
    }
  ]
}