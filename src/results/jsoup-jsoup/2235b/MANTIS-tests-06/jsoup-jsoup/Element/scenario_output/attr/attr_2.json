{
  "scenarios": [
    {
      "id": "TC14",
      "description": "attr(String,boolean) is chainable and returns same Element instance",
      "path": "B0→B3→B4",
      "precondition": "none",
      "expectedResult": "returned Element is same instance and attribute added",
      "tags": [
        "chainable",
        "boolean",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 attr-boolean chainable",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"draggable\";",
        "  WHEN",
        "    Element returned = el.attr(key, true);",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().hasKey(\"draggable\");"
      ]
    },
    {
      "id": "TC15",
      "description": "attr(String,boolean) true on empty key adds boolean attribute under empty key",
      "path": "B0→B3→B4",
      "precondition": "none",
      "expectedResult": "attributes map has empty key with empty-string value",
      "tags": [
        "boundary",
        "boolean",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 boolean attr with empty key",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"\";",
        "  WHEN",
        "    el.attr(key, true);",
        "  THEN",
        "    assert el.attributes().hasKey(\"\");",
        "    assert el.attributes().get(\"\").equals(\"\");"
      ]
    },
    {
      "id": "TC16",
      "description": "attr(String,boolean) false on empty key does nothing (no exception, no attribute)",
      "path": "B0→B5",
      "precondition": "none",
      "expectedResult": "attributes map does not contain empty key",
      "tags": [
        "boundary",
        "boolean",
        "negative"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC16 boolean false attr with empty key no-op",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"\";",
        "  WHEN",
        "    el.attr(key, false);",
        "  THEN",
        "    assertFalse(el.attributes().hasKey(\"\"));"
      ]
    }
  ]
}