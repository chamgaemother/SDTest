      "description": "dataset().put on existing key updates underlying attribute (live view update path)",
      "path": "B1â†’B2â†’B3(loopĂ—1)â†’B4â†’B6â†’B7(update)",
      "precondition": "Element with one data- attribute 'data-key'='old'",
