      "description": "attr(String,String) throws IllegalArgumentException when key is null covering exception on key null",
      "path": "B0→B1→BError",
      "precondition": "none",
      "expectedResult": "throws IllegalArgumentException",
      "tags": [
        "exception",
        "key-null",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 attr null key exception",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
