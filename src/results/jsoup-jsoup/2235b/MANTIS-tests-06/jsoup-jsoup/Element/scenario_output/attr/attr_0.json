      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "attributes().hasKey(\"\") is true and attributes().get(\"\").equals(\"value\")",
      "tags": [
        "boundary",
        "empty-key",
        "overload:String,String"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 attr with empty key",
