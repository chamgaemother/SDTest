      ]
    },
    {
      "id": "TC10",
      "description": "attr(String,boolean) true then false toggles attribute covering boolean toggle sequence",
      "path": "B0→B1→B2→B3→B2→B3",
      "precondition": "none",
      "expectedResult": "after true: attributes().hasKey(\"hidden\")==true; after false: attributes().hasKey(\"hidden\")==false",
      "tags": [
        "sequence",
        "boolean-toggle",
        "overload:String,boolean"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 attr boolean toggle sequence",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"hidden\";",
        "  WHEN",
        "    el.attr(key, true);",
        "    el.attr(key, false);",
        "  THEN",
        "    assert !el.attributes().hasKey(key);"
      ]
    }
  ]
}