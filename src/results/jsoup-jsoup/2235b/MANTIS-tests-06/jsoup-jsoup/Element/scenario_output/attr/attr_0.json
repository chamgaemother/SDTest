{
  "method": "attr",
  "scenarios": [
    {
      "id": "TC01",
      "description": "attr(String,String) sets new attribute when key and value non-null covering normal branch",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "attributes().get(\"title\") == \"Jsoup\"",
      "tags": [
        "branch-true",
        "normal",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 attr sets new attribute",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"title\";",
        "    String value = \"Jsoup\";",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert el.attributes().get(key).equals(value);"
      ]
    },
    {
      "id": "TC02",
      "description": "attr(String,String) overrides existing attribute value covering update branch",
      "path": "B0→B1→B2→B3",
      "precondition": "element already has attribute \"data\"",
      "expectedResult": "attributes().get(\"data\") == \"updated\"",
      "tags": [
        "branch-true",
        "override",
        "overload:String,String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 attr overrides existing attribute",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"data\", \"initial\");",
        "  WHEN",
        "    el.attr(\"data\", \"updated\");",
        "  THEN",
        "    assert el.attributes().get(\"data\").equals(\"updated\");"
      ]
    },
    {
      "id": "TC03",
      "description": "attr(String,String) with empty value sets attribute to empty string covering boundary empty value",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "attributes().get(\"empty\") == \"\"",
      "tags": [
        "boundary",
        "empty-value",
        "overload:String,String"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 attr with empty value",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "    String key = \"empty\";",
        "    String value = \"\";",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert el.attributes().get(key).equals(\"\");"
      ]
    },
    {
