        "    String value = \"v\";",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC05",
      "description": "attr(String,String) throws IllegalArgumentException when value is null covering exception on value null",
      "path": "B0→B1→BError",
      "precondition": "none",
      "expectedResult": "throws IllegalArgumentException",
      "tags": [
        "exception",
        "value-null",
        "overload:String,String"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 attr null value exception",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"k\";",
        "    String value = null;",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC06",
      "description": "attr(String,boolean) true adds boolean attribute covering boolean-true branch",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "attributes().hasKey(\"checked\") is true and attributes().get(\"checked\").equals(\"\")",
      "tags": [
        "branch-true",
        "boolean-true",
        "overload:String,boolean"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 attr boolean true adds attribute",
        "  GIVEN",
        "    Element el = new Element(\"input\");",
        "    String key = \"checked\";",
        "    boolean value = true;",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert el.attributes().hasKey(key) && el.attributes().get(key).equals(\"\");"
      ]
    },
    {
      "id": "TC07",
      "description": "attr(String,boolean) false removes existing attribute covering boolean-false remove branch",
      "path": "B0→B1→B2→B3",
      "precondition": "element has boolean attribute \"disabled\"",
      "expectedResult": "attributes().hasKey(\"disabled\") is false",
      "tags": [
        "branch-false",
        "boolean-false",
        "overload:String,boolean"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 attr boolean false removes attribute",
        "  GIVEN",
        "    Element el = new Element(\"button\");",
        "    el.attr(\"disabled\", true);",
        "    String key = \"disabled\";",
        "    boolean value = false;",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert !el.attributes().hasKey(key);"
      ]
    },
    {
      "id": "TC08",
      "description": "attr(String,boolean) false on absent attribute does nothing covering boolean-false no-op",
      "path": "B0→B1→B2→B3",
      "precondition": "element does not have attribute \"readonly\"",
      "expectedResult": "attributes().hasKey(\"readonly\") is false",
      "tags": [
        "branch-false",
        "boolean-false-noop",
        "overload:String,boolean"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 attr boolean false no-op when absent",
        "  GIVEN",
        "    Element el = new Element(\"input\");",
        "    String key = \"readonly\";",
        "    boolean value = false;",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert !el.attributes().hasKey(key);"
      ]
    },
