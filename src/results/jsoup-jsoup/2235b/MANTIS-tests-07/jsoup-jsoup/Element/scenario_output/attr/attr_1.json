{
  "scenarios": [
    {
      "id": "TC05",
      "description": "attr returns this and initializes attributes when first called",
      "path": "B0→B1→B2→B4",
      "precondition": "new Element(\"div\") with attributes==null",
      "expectedResult": "returned Element instance is same as original and attributes() now contains key",
      "tags": [
        "positive",
        "initialization",
        "chainable"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC05 attr initializes attribute store and returns this",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    assert el.attributes()==null : \"precondition: attributes initially null\";",
        "  WHEN",
        "    Element returned = el.attr(\"key\",\"val\");",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().get(\"key\").equals(\"val\");",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "attr accepts empty-string key and value, stores empty value",
      "path": "B0→B1→B2→B4",
      "precondition": "new Element(\"span\")",
      "expectedResult": "attribute map contains entry \"\" -> \"\"",
      "tags": [
        "boundary",
        "empty-string"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 attr with empty key and empty value",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "  WHEN",
        "    el.attr(\"\",\"\"\");",
        "  THEN",
        "    assert el.attributes().get(\"\").equals(\"\");",
        "END"
      ]
    }
  ]
}