{
  "method": "attr",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Adding a new attribute when none exists (attributeKey non-null, attributeValue non-null)",
      "path": "B0→B1→B2→B4",
      "precondition": "Element el = new Element(\"div\"); // fresh element with no attributes",
      "expectedResult": "el.attributes().get(\"data-test\") == \"value\"",
      "tags": [
        "branch-false",
        "normal",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 attr adds new attribute",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    el.attr(\"data-test\",\"value\");",
        "  THEN",
        "    assert el.attributes().get(\"data-test\").equals(\"value\");"
      ]
    },
    {
      "id": "TC02",
      "description": "Overriding an existing attribute value (attributeKey non-null, attributeValue non-null)",
      "path": "B0→B1→B2→B4",
      "precondition": "Element el = new Element(\"span\"); el.attr(\"id\",\"first\"); // existing attribute",
      "expectedResult": "el.attributes().get(\"id\") == \"second\"",
      "tags": [
        "branch-false",
        "override",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 attr overrides existing attribute",
        "  GIVEN",
        "    Element el = new Element(\"span\"); el.attr(\"id\",\"first\");",
        "  WHEN",
        "    el.attr(\"id\",\"second\");",
        "  THEN",
        "    assert el.attributes().get(\"id\").equals(\"second\");"
      ]
    },
    {
      "id": "TC03",
      "description": "Passing a null attributeKey triggers a NullPointerException",
      "path": "B0→B1→B3",
      "precondition": "Element el = new Element(\"p\"); // new element",
      "expectedResult": "throws NullPointerException",
      "tags": [
        "branch-true",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 attr null-key exception",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "  WHEN",
        "    call el.attr(null,\"value\");",
        "  THEN",
        "    throws NullPointerException;"
      ]
    },
    {
      "id": "TC04",
