    {
      "id": "TC09",
      "description": "dataset().put(existingKey, newValue) updates underlying data- attribute value",
      "path": "B0â†’B1â†’loop(1)â†’B2.putâ†’B3",
      "precondition": "Element with one data-x attribute",
      "expectedResult": "el.attr(\"data-x\") equals \"new\"",
      "tags": [
        "positive",
        "mutation",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 update-existing",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    el.attr(\"data-x\",\"old\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
        "    ds.put(\"x\",\"new\");",
        "  THEN",
        "    assertEquals(\"new\", el.attr(\"data-x\"));",
        "END"
      ]
    },
    {
      "id": "TC10",
      "description": "dataset().clear() removes only data-* attributes and preserves non-data attributes",
      "path": "B0â†’B1â†’loop(2)â†’B2.clearâ†’removeLoop(2)â†’B4",
      "precondition": "Element with data-a and foo attributes",
      "expectedResult": "data-a removed; foo remains",
      "tags": [
        "positive",
        "removal",
        "iteration"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 clear-data",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"data-a\",\"1\");",
        "    el.attr(\"foo\",\"bar\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
