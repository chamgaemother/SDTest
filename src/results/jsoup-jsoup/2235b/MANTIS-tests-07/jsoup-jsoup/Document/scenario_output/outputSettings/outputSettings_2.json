{
  "scenarios": [
    {
      "id": "TC04",
      "description": "Setter with non-null OutputSettings stores the instance for later retrieval",
      "path": "B0→B1→B3",
      "precondition": "Document created with default settings",
      "expectedResult": "outputSettings() returns the same instance passed to outputSettings(...)",
      "tags": [
        "positive",
        "setter",
        "getter",
        "field-storage"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 outputSettings stores instance",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings custom = new Document.OutputSettings();",
        "  WHEN",
        "    doc.outputSettings(custom);",
        "  THEN",
        "    assert doc.outputSettings() == custom;",
        "END"
      ]
    },
    {
      "id": "TC05",
      "description": "Chaining multiple setter calls updates the stored OutputSettings each time and returns same Document",
      "path": "B0→B1→B3 (×2)",
      "precondition": "Document created with default settings",
      "expectedResult": "After two chained outputSettings calls, outputSettings() returns the last instance and chaining returns the original Document",
      "tags": [
        "positive",
        "chaining",
        "setter"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 chaining outputSettings updates field",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings s1 = new Document.OutputSettings();",
        "    Document.OutputSettings s2 = new Document.OutputSettings();",
        "  WHEN",
        "    Document result = doc.outputSettings(s1).outputSettings(s2);",
        "  THEN",
        "    assertSame(doc, result);",
        "    assert doc.outputSettings() == s2;",
        "END"
      ]
    }
  ]
}