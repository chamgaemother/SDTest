{
  "scenarios": [
    {
      "id": "TC02",
      "description": "outputSettings(null) throws IllegalArgumentException on null argument",
      "path": "B0→B1→B2",
      "precondition": "Document doc = new Document(\"http://example.com\")",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "null-check"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 outputSettings rejects null",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings settings = null;",
        "  WHEN",
        "    call doc.outputSettings(settings);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "outputSettings returns this Document allowing call chaining",
      "path": "B0→B1→B3",
      "precondition": "Document doc = new Document(\"http://example.com\"); Document.OutputSettings s = new Document.OutputSettings()",
      "expectedResult": "returned Document is the same instance as receiver",
      "tags": [
        "positive",
        "chaining"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 outputSettings returns this instance",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings s1 = new Document.OutputSettings();",
        "  WHEN",
        "    Document returned = doc.outputSettings(s1);",
        "  THEN",
        "    assert returned == doc;",
        "    // chaining: ensure next call works",
        "    Document returned2 = returned.outputSettings(new Document.OutputSettings());",
        "    assert returned2 == doc;",
        "END"
      ]
    }
  ]
}