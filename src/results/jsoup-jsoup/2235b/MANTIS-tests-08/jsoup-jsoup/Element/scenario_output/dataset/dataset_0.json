{
  "method": "dataset",
  "scenarios": [
    {
      "id": "TC01",
      "description": "No attributes yields empty dataset (attributes==null branch)",
      "path": "B0→B1→B3",
      "precondition": "Element el = new Element(\"div\"); // no attrs initially",
      "expectedResult": "returned map is empty",
      "tags": [
        "branch-true(attributes==null)",
        "boundary",
        "loop-0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 dataset empty-with-no-attributes",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
        "  THEN",
        "    assert ds.isEmpty();"
      ]
    },
    {
      "id": "TC02",
      "description": "Only non-data attributes yields empty dataset (filters by 'data-' prefix)",
      "path": "B0→B2→B3",
      "precondition": "Element el = new Element(\"span\"); el.attr(\"class\",\"x\");",
      "expectedResult": "returned map is empty",
      "tags": [
        "branch-false(attributes==null)",
        "boundary",
        "loop-0"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 dataset ignores-non-data-attributes",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"class\",\"x\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
        "  THEN",
        "    assert ds.isEmpty();"
      ]
    },
    {
      "id": "TC03",
      "description": "Single data- attribute yields one entry (key without prefix)",
      "path": "B0→B2→B3",
      "precondition": "Element el = new Element(\"p\"); el.attr(\"data-name\",\"value\");",
      "expectedResult": "returned map contains {\"name\"=\"value\"}",
      "tags": [
        "branch-false(attributes==null)",
        "loop-1"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 dataset single-data-attribute",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "    el.attr(\"data-name\",\"value\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
        "  THEN",
        "    assert ds.size() == 1 && ds.get(\"name\").equals(\"value\");"
      ]
    },
    {
      "id": "TC04",
      "description": "Multiple data- attributes yields multiple entries (loop-N with N=2)",
      "path": "B0→B2→B3",
      "precondition": "Element el = new Element(\"div\"); el.attr(\"data-one\",\"1\"); el.attr(\"data-two\",\"2\");",
      "expectedResult": "returned map contains {\"one\"=\"1\",\"two\"=\"2\"}",
      "tags": [
        "loop-N",
        "branch-false(attributes==null)"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 dataset multiple-data-attributes",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    el.attr(\"data-one\",\"1\");",
        "    el.attr(\"data-two\",\"2\");",
        "  WHEN",
        "    Map<String,String> ds = el.dataset();",
        "  THEN",
        "    assert ds.size() == 2 && ds.get(\"one\").equals(\"1\") && ds.get(\"two\").equals(\"2\");"
      ]
    },
    {
