{
  "scenarios": [
    {
      "id": "TC10",
      "description": "attr(String,String) with empty key stores an attribute entry with empty name",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "none",
      "expectedResult": "attribute map contains key \"\" with provided value",
      "tags": [
        "positive",
        "boundary",
        "empty-key"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 attr empty-key stores entry",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"\";",
        "    String val = \"v\";",
        "  WHEN",
        "    el.attr(key, val);",
        "  THEN",
        "    assert el.attributes().hasKey(\"\") == true;",
        "    assert el.attributes().get(\"\").equals(\"v\");",
        "END"
      ]
    },
    {
      "id": "TC11",
      "description": "attr(String,boolean) false removes an existing non-boolean attribute keyed by empty string",
      "path": "B0→B1→B2→B3→B5",
      "precondition": "an element with attribute key \"\" set to any value",
      "expectedResult": "empty-string key attribute is removed",
      "tags": [
        "positive",
        "boundary",
        "empty-key",
        "boolean-false"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 attr boolean-false removes non-boolean attr",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"\", \"x\");",
        "    assert el.attributes().hasKey(\"\");",
        "  WHEN",
        "    el.attr(\"\", false);",
        "  THEN",
        "    assert el.attributes().hasKey(\"\") == false;",
        "END"
      ]
    }
  ]
}