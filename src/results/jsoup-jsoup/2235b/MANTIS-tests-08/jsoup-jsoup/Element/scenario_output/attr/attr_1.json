{
  "scenarios": [
    {
      "id": "TC08",
      "description": "attr(String,String) with empty value stores empty string without error",
      "path": "B0→B1→B3→B5",
      "precondition": "Element with no existing 'foo' attribute",
      "expectedResult": "attribute 'foo' exists with empty string value and returns same element",
      "tags": [
        "boundary",
        "positive"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 attr empty-value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"foo\";",
        "    String value = \"\";",
        "  WHEN",
        "    Element ret = el.attr(key, value);",
        "  THEN",
        "    assertSame(el, ret);",
        "    assertTrue(el.attributes().hasKey(\"foo\"));",
        "    assertEquals(\"\", el.attributes().get(\"foo\"));",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "attr(String,String) with null value throws IllegalArgumentException",
      "path": "B0→B1→B2→B6",
      "precondition": "Element with no attributes",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 attr null-value",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    String key = \"foo\";",
        "    String value = null;",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    }
  ]
}