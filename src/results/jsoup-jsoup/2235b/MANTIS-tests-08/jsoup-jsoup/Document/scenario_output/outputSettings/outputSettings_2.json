      "id": "TC06",
      "description": "OutputSettings.indentAmount throws IllegalArgumentException for negative input",
      "path": "B0→B1→B2→B3",
      "precondition": "none",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "OutputSettings",
        "indentAmount",
        "exception",
        "boundary"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 indentAmount negative value",
        "  GIVEN",
        "    Document.OutputSettings settings = new Document.OutputSettings();",
        "    int indent = -1;",
        "  WHEN",
        "    call settings.indentAmount(indent);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
