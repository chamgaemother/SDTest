    {
      "id": "TC08",
      "description": "OutputSettings.syntax(xml) sets syntax to xml and escapeMode to xhtml",
      "path": "B0→B1→B2→B4→B5",
      "precondition": "none",
      "expectedResult": "syntax() returns Syntax.xml and escapeMode() returns Entities.EscapeMode.xhtml",
      "tags": [
        "OutputSettings",
        "syntax",
        "branch"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 syntax xml resets escape mode",
        "  GIVEN",
        "    Document.OutputSettings settings = new Document.OutputSettings().escapeMode(Entities.EscapeMode.extended);",
        "  WHEN",
        "    settings.syntax(Document.OutputSettings.Syntax.xml);",
        "  THEN",
        "    assert settings.syntax() == Document.OutputSettings.Syntax.xml;",
        "    assert settings.escapeMode() == Entities.EscapeMode.xhtml;",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "OutputSettings.syntax(html) retains existing escapeMode",
