    {
      "id": "TC10",
      "description": "OutputSettings.clone produces a distinct instance with identical state",
      "path": "B0→B1→B2→B6",
      "precondition": "none",
      "expectedResult": "clone is not same instance but equals charset, escapeMode, indentAmount, maxPaddingWidth, prettyPrint",
      "tags": [
        "OutputSettings",
        "clone",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC10 clone duplicates settings",
        "  GIVEN",
        "    Document.OutputSettings settings = new Document.OutputSettings()",
        "      .charset(\"ISO-8859-1\").escapeMode(Entities.EscapeMode.extended)",
        "      .prettyPrint(false).outline(true).indentAmount(3).maxPaddingWidth(5);",
        "  WHEN",
        "    Document.OutputSettings copy = settings.clone();",
        "  THEN",
        "    assertNotSame(settings, copy);",
        "    assertEquals(settings.charset(), copy.charset());",
        "    assertEquals(settings.escapeMode(), copy.escapeMode());",
        "    assertEquals(settings.prettyPrint(), copy.prettyPrint());",
        "    assertEquals(settings.outline(), copy.outline());",
        "    assertEquals(settings.indentAmount(), copy.indentAmount());",
        "    assertEquals(settings.maxPaddingWidth(), copy.maxPaddingWidth());",
        "END"
      ]
    }
  ]
}