      "expectedResult": "el.attr(\"title\",\"new\") returns same instance; el.attributes().get(\"title\") == \"new\"",
      "tags": [
        "positive",
        "update",
        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 attr update-existing",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"title\",\"old\");",
        "  WHEN",
        "    Element returned = el.attr(\"title\",\"new\");",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().get(\"title\").equals(\"new\");"
      ]
    },
