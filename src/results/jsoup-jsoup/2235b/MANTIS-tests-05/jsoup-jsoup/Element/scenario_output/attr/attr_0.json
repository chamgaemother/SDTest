    {
      "id": "TC09",
      "description": "attr(String key, String value) on element with pre-existing attributes object uses existing Attributes instance",
      "path": "B0→B1→B2→B3",
      "precondition": "Element el = new Element(\"div\"); el.attributes(); // instantiate attributes",
      "expectedResult": "el.attr(\"k\",\"v\"); el.attributes() remains same instance; get(\"k\")==\"v\"",
      "tags": [
        "positive",
        "reuse",
        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 attr reuse-attributes",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    Attributes before = el.attributes();",
        "  WHEN",
        "    el.attr(\"k\",\"v\");",
        "  THEN",
        "    assert el.attributes() == before;",
        "    assert before.get(\"k\").equals(\"v\");"
      ]
    },
