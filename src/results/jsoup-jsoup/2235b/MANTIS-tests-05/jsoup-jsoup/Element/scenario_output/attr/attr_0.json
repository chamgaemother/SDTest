{
  "method": "attr",
  "scenarios": [
    {
      "id": "TC01",
      "description": "attr(String key, String value) with normal non-empty key and value sets attribute and returns this",
      "path": "B0→B1→B2→B3",
      "precondition": "Element el = new Element(\"div\"); el.attributes == null",
      "expectedResult": "el.attr(\"data-test\",\"123\") returns same instance; el.attributes().get(\"data-test\") == \"123\"",
      "tags": [
        "positive",
        "branch-false",
        "initial-attributes-null"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 attr normal-key-value",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    Element returned = el.attr(\"data-test\",\"123\");",
        "  THEN",
        "    assert returned == el;",
        "    assert el.attributes().get(\"data-test\").equals(\"123\");"
      ]
    },
    {
