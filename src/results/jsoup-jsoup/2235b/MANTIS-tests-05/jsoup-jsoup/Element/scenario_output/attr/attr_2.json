{
  "scenarios": [
    {
      "id": "TC14",
      "description": "attr(String key with internal spaces, String value) preserves key exactly and stores value",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "attribute with key \"a b\" is stored with value \"v\"",
      "tags": [
        "positive",
        "key-with-spaces"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC14 attr internal-space-key",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    el.attr(\"a b\", \"v\");",
        "  THEN",
        "    assertEquals(\"v\", el.attributes().get(\"a b\"));"
      ]
    },
    {
      "id": "TC15",
      "description": "attr(String key with leading/trailing whitespace, String value) uses key verbatim without trimming",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "attribute with key \"  k  \" is stored with value \"x\"",
      "tags": [
        "positive",
        "boundary",
        "key-with-whitespace"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC15 attr leading-trailing-whitespace-key",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "  WHEN",
        "    el.attr(\"  k  \", \"x\");",
        "  THEN",
        "    assertEquals(\"x\", el.attributes().get(\"  k  \"));"
      ]
    }
  ]
}