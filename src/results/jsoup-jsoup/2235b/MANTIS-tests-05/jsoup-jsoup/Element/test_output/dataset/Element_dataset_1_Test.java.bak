package org.jsoup.nodes;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;

/**
 * JUnit 5 tests for org.jsoup.nodes.Element.dataset()
 */
public class Element_dataset_Test {

    @Test
    @DisplayName("TC07: dataset() converts dashed data-attribute keys to camelCase property names (data-foo-bar → fooBar)")
    public void test_TC07() {
        // GIVEN a fresh element with no prior attributes (attributes==null path B1)
        Element e = new Element("div");
        // add a data attribute that should be transformed
        e.attr("data-foo-bar", "baz");

        // WHEN retrieving the dataset view (loop over attributes path B3→B4→B5)
        Map<String, String> data = e.dataset();

        // THEN the map should contain exactly the transformed key and original value
        assertEquals(1, data.size(), "Dataset should contain one entry after adding one data- attribute");
        assertTrue(data.containsKey("fooBar"), "Key 'fooBar' must appear in camelCase form");
        assertEquals("baz", data.get("fooBar"), "Value for 'fooBar' must match the attribute value");
    }

    @Test
    @DisplayName("TC08: dataset() live view remove operation removes underlying data- attribute")
    public void test_TC08() {
        // GIVEN an element with an existing data attribute (attributes!=null path B1)
        Element e = new Element("p");
        e.attr("data-test", "X");
        Map<String, String> data = e.dataset();
        assertTrue(data.containsKey("test"), "Precondition: dataset view must contain key 'test'");

        // WHEN removing the entry from the live dataset view (view supports remove path B6)
        data.remove("test");

        // THEN the underlying attribute and the view entry should both be removed
        assertFalse(e.attributes().hasKey("data-test"), "Removing 'test' from dataset must delete the data-test attribute");
        assertFalse(data.containsKey("test"), "After removal, dataset must no longer contain key 'test'");
    }
}