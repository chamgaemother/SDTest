{
  "scenarios": [
    {
      "id": "TC03",
      "description": "Calling the setter outputSettings(OutputSettings) with a valid instance sets and returns the custom settings",
      "path": "B0→B1→B2→B4",
      "precondition": "Document created with default settings",
      "expectedResult": "Setter returns the Document instance and subsequent outputSettings() returns the same custom OutputSettings",
      "tags": [
        "positive",
        "setter",
        "chaining"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC03 outputSettings setter normal-path",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings custom = new Document.OutputSettings().prettyPrint(false).indentAmount(5);",
        "  WHEN",
        "    Document returnedDoc = doc.outputSettings(custom);",
        "  THEN",
        "    assert returnedDoc == doc;",
        "    assert doc.outputSettings() == custom;"
      ]
    },
    {
      "id": "TC04",
      "description": "Calling outputSettings(null) triggers a validation failure (IllegalArgumentException)",
      "path": "B0→B1→B3",
      "precondition": "Document created with default settings",
      "expectedResult": "IllegalArgumentException is thrown due to null argument",
      "tags": [
        "negative",
        "exception",
        "setter"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 outputSettings setter null-argument",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings nullSettings = null;",
        "  WHEN",
        "    call doc.outputSettings(nullSettings);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    }
  ]
