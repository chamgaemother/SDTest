    {
      "id": "TC04",
      "description": "outputSettings returns this Document instance to allow chaining",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "return value is the same Document instance",
      "tags": [
        "positive",
        "return-value",
        "chaining"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 outputSettings chaining-return",
        "  GIVEN",
        "    Document doc = new Document(\"http://example.com\");",
        "    Document.OutputSettings os = new Document.OutputSettings();",
        "  WHEN",
        "    Document returned = doc.outputSettings(os);",
        "  THEN",
        "    assert returned == doc;",
        "END"
      ]
