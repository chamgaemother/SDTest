package org.jsoup.nodes;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;

public class Element_dataset_Test {

    @Test
    @DisplayName("dataset converts hyphenated data- attribute names to camelCase keys (prefix removed, hyphens→upper-case)")
    public void test_TC06() {
        // GIVEN an element with a single hyphenated data- attribute to trigger one loop iteration in dataset()
        Element el = new Element("div");
        el.attr("data-user-name", "Alice");

        // WHEN retrieving the dataset view
        Map<String, String> ds = el.dataset();

        // THEN the map should contain exactly one entry, with camelCase key and original value
        assertEquals(1, ds.size(), "Expected one entry in dataset");
        assertTrue(ds.containsKey("userName"), "Expected key 'userName' after conversion");
        assertEquals("Alice", ds.get("userName"), "Expected value 'Alice' for key 'userName'");
    }

    @Test
    @DisplayName("dataset view remove() deletes the corresponding data- attribute from the element")
    public void test_TC07() {
        // GIVEN an element with a single data- attribute "data-x" to have one entry in dataset()
        Element el = new Element("div");
        el.attr("data-x", "y");

        // WHEN removing the entry via the dataset view
        Map<String, String> ds = el.dataset();
        ds.remove("x");  // should remove the underlying attribute "data-x"

        // THEN the element should no longer have the original attribute and the view should be empty
        assertFalse(el.attributes().hasKey("data-x"), "Attribute 'data-x' should be removed from element");
        assertTrue(ds.isEmpty(), "Dataset view should be empty after removal");
    }

    @Test
    @DisplayName("dataset.put null key throws NullPointerException when attempting to insert a null key")
    public void test_TC08() {
        // GIVEN an element with no data- attributes (loop×0 in dataset())
        Element el = new Element("span");
        Map<String, String> ds = el.dataset();

        // WHEN attempting to put a null key, THEN a NullPointerException must be thrown
        assertThrows(NullPointerException.class,
            () -> ds.put(null, "v"),
            "Putting a null key into dataset should throw NullPointerException");
    }
}