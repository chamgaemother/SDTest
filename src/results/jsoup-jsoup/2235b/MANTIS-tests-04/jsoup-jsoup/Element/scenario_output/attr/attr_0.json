{
  "method": "attr",
  "scenarios": [
    {
      "id": "TC01",
      "description": "attr adds a new attribute when key and value are non-null and not previously present",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "Element el = new Element(\"div\"); attributes empty",
      "expectedResult": "el.attributes().get(\"data-test\") == \"value\" and return value is el",
      "tags": [
        "positive",
        "branch-normal",
        "no-exception"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 attr adds attribute",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    Element result = el.attr(\"data-test\",\"value\");",
        "  THEN",
        "    assert result == el;",
        "    assert el.attributes().get(\"data-test\").equals(\"value\");",
        "END"
      ]
    },
    {
      "id": "TC02",
      "description": "attr overwrites an existing attribute value when the same key is used",
      "path": "B0→B1→B2→B3→B4",
      "precondition": "Element el = new Element(\"span\"); el.attr(\"id\",\"first\");",
      "expectedResult": "el.attributes().get(\"id\") == \"second\" after overwrite and return value is el",
      "tags": [
        "positive",
        "branch-normal",
        "overwrite"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 attr overwrites existing",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"id\",\"first\");",
        "  WHEN",
        "    Element result = el.attr(\"id\",\"second\");",
        "  THEN",
        "    assert result == el;",
        "    assert el.attributes().get(\"id\").equals(\"second\");",
        "END"
      ]
    },
    {
      "id": "TC03",
      "description": "attr throws IllegalArgumentException when attribute key is null",
      "path": "B0→B1→B5",
      "precondition": "Element el = new Element(\"p\");",
      "expectedResult": "throws IllegalArgumentException; no attribute added",
      "tags": [
        "exception",
        "branch-key-null"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 attr null-key",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "  WHEN",
        "    call el.attr(null,\"v\");",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    },
    {
      "id": "TC04",
      "description": "attr throws IllegalArgumentException when attribute value is null",
      "path": "B0→B1→B5",
      "precondition": "Element el = new Element(\"p\");",
      "expectedResult": "throws IllegalArgumentException; no attribute added",
      "tags": [
        "exception",
        "branch-value-null"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 attr null-value",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "  WHEN",
        "    call el.attr(\"key\",null);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "END"
      ]
    }
  ]
}