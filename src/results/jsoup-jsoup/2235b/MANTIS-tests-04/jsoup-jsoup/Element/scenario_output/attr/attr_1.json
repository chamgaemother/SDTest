{
  "scenarios": [
    {
      "id": "TC05",
      "description": "attr allows empty attribute key and sets an attribute with empty name",
      "path": "B0→B1→B4→B5",
      "precondition": "Element el has no attributes",
      "expectedResult": "attribute with key \"\" is added and value is \"empty\" without exception",
      "tags": [
        "boundary",
        "positive"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 attr empty-key",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    Element result = el.attr(\"\", \"empty\");",
        "  THEN",
        "    assert result == el;",
        "    assert el.attributes().get(\"\").equals(\"empty\");",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "attr accepts empty string value and retains other attributes",
      "path": "B0→B1→B4→B5",
      "precondition": "Element el initially has attribute \"foo\"=\"bar\"",
      "expectedResult": "existing attribute remains and new key \"baz\" gets empty value",
      "tags": [
        "boundary",
        "regression"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 attr empty-value",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"foo\", \"bar\");",
        "  WHEN",
        "    el.attr(\"baz\", \"\");",
        "  THEN",
        "    assert el.attributes().get(\"foo\").equals(\"bar\");",
        "    assert el.attributes().get(\"baz\").equals(\"\");",
        "END"
      ]
    }
  ]
}