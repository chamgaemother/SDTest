        "boundary"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC11 boolean attr chaining false no-op",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "  WHEN",
        "    Element result = el.attr(\"notPresent\", false);",
