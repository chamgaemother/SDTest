{
  "scenarios": [
    {
      "id": "TC09",
      "description": "attr(String,String) returns this for call chaining",
      "path": "B0→B1→B3→B4",
      "precondition": "none",
      "expectedResult": "returned object is the same Element instance",
      "tags": [
        "positive",
        "chaining"
      ],
      "priority": "P2",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC09 attr chaining",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "  WHEN",
        "    Element result = el.attr(\"key\",\"value\");",
        "  THEN",
        "    assertSame(el, result);",
        "END"
      ]
    },
    {
