{
  "scenarios": [
    {
      "id": "TC06",
      "description": "attr(String key, String value) throws IllegalArgumentException when value is null",
      "path": "B0→B1(key non-null)→B2(value null)→B6",
      "precondition": "Element created via new Element(\"div\")",
      "expectedResult": "IllegalArgumentException is thrown",
      "tags": [
        "negative",
        "exception",
        "null-value"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 attr null-value throws",
        "  GIVEN",
        "    Element el = new Element(\"div\");",
        "    String key = \"data\";",
        "    String value = null;",
        "  WHEN",
        "    call el.attr(key, value);",
        "  THEN",
        "    throws IllegalArgumentException",
        "END"
      ]
    },
    {
      "id": "TC07",
      "description": "attr(String key, String value) accepts empty-string key and adds attribute of empty name",
      "path": "B0→B1(key non-null)→B2(value non-null)→B3(new attribute)→B4→B5",
      "precondition": "Element created via new Element(\"p\")",
      "expectedResult": "attribute with key \"\" exists and has value \"v\"",
      "tags": [
        "boundary",
        "positive",
        "empty-key"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 attr empty-key adds attribute",
        "  GIVEN",
        "    Element el = new Element(\"p\");",
        "    String key = \"\";",
        "    String value = \"v\";",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert el.hasAttr(\"\");",
        "    assert el.attributes().get(\"\").equals(\"v\");",
        "END"
      ]
    },
    {
      "id": "TC08",
      "description": "attr(String key, String value) overrides existing attribute value when value is empty string",
      "path": "B0→B1(key non-null)→B2(value non-null empty)→B3(existing attribute)→B4→B5",
      "precondition": "Element created via new Element(\"span\") and el.attr(\"title\",\"old\")",
      "expectedResult": "attribute 'title' value updated to empty string",
      "tags": [
        "boundary",
        "positive",
        "override"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 attr override to empty-string",
        "  GIVEN",
        "    Element el = new Element(\"span\");",
        "    el.attr(\"title\", \"old\");",
        "    assert el.attributes().get(\"title\").equals(\"old\");",
        "    String key = \"title\";",
        "    String value = \"\";",
        "  WHEN",
        "    el.attr(key, value);",
        "  THEN",
        "    assert el.attributes().get(\"title\").equals(\"\");",
        "END"
      ]
    }
  ]
}