{
  "scenarios": [
    {
      "id": "TC08",
      "description": "parseAndAddToColumn throws DateTimeParseException for malformed date under custom strict two-digit pattern",
      "path": "B0→B3→B4→B6",
      "precondition": "DateSchemaColumn created with custom pattern 'MM/dd/uuuu'",
      "expectedResult": "DateTimeParseException is thrown",
      "tags": [
        "custom-pattern",
        "exception",
        "negative"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC08 parseAndAddToColumn invalid-custom-pattern",
        "  GIVEN",
        "    // Arrange a schema with strict two-digit month/day",
        "    DateSchemaColumn col = new DateSchemaColumn(null, \"date\", \"MM/dd/uuuu\");",
        "    StubDfColumn stubDfColumn = new StubDfColumn();",
        "    String aString = \"1/2/2020\";  // missing leading zeros, does not match 'MM/dd/uuuu'",
        "  WHEN",
        "    // Act",
        "    call col.parseAndAddToColumn(aString, stubDfColumn);",
        "  THEN",
        "    // Assert",
        "    throws DateTimeParseException;",
        "END"
      ]
    }
  ]
}