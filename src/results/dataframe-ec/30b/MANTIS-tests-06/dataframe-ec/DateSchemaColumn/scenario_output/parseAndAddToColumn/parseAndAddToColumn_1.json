      "precondition": "DateSchemaColumn created with null pattern (uses default \"uuuu-M-d\")",
      "expectedResult": "LocalDate.of(2022,3,5) is added to the column",
      "tags": [
        "positive",
        "trimming",
        "default-pattern",
        "parse"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 parseAndAddToColumn with surrounding spaces",
        "  GIVEN",
        "    String aString = \" 2022-3-5 \";",
        "    DfColumn dfColumn = new StubColumn();",
        "    DateSchemaColumn column = new DateSchemaColumn(null, \"col\", null);",
        "  WHEN",
        "    column.parseAndAddToColumn(aString, dfColumn);",
        "  THEN",
        "    assert ((StubColumn) dfColumn).lastAddedObject.equals(LocalDate.of(2022,3,5));"
      ]
    }
