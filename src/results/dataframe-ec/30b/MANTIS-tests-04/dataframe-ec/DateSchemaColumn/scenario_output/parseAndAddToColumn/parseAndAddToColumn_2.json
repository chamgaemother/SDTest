{
  "scenarios": [
    {
      "id": "TC07",
      "description": "parseAndAddToColumn adds null when input string is empty (\"\" triggers trimmed.isEmpty branch)",
      "path": "B0→B1→B4→B5",
      "precondition": "DateSchemaColumn with default pattern",
      "expectedResult": "stubDfColumn.lastAdded is null and addCount == 1",
      "tags": [
        "boundary",
        "empty-string",
        "null-return"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC07 empty-string returns null",
        "  GIVEN",
        "    DateSchemaColumn col = new DateSchemaColumn(null, \"d\", null);",
        "    StubDfColumn stub = new StubDfColumn();",
        "    String aString = \"\";",
        "  WHEN",
        "    col.parseAndAddToColumn(aString, stub);",
        "  THEN",
        "    assertNull(stub.lastAdded);",
        "    assertEquals(1, stub.addCount);",
        "END"
      ]
    },
