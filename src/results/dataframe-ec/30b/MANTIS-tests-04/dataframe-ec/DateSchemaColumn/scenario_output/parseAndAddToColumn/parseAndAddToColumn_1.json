        "branch-null",
        "positive"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC01 parseAndAddToColumn null-input",
        "  GIVEN",
        "    DateSchemaColumn col = new DateSchemaColumn(null, \"d\", null)",
        "    StubDfColumn stub = new StubDfColumn()",
        "    String aString = null",
        "  WHEN",
        "    col.parseAndAddToColumn(aString, stub)",
