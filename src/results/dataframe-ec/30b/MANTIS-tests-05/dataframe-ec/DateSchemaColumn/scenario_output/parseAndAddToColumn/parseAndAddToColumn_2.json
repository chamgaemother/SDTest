{
  "scenarios": [
    {
      "id": "TC10",
      "description": "parseAndAddToColumn parses and adds LocalDate for default pattern with zero-padded month and day",
      "path": "B2(false)→B3(false)→parse→addObject",
      "precondition": "DateSchemaColumn instantiated with null pattern",
      "expectedResult": "added LocalDate.of(2021,1,2)",
      "tags": [
        "positive",
        "default-pattern",
        "zero-padded",
        "trim-not-needed"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC10 default pattern zero-padded date",
        "  GIVEN",
        "    String aString = \"2021-01-02\";",
        "    StubColumn stubColumn = new StubColumn();",
        "    DateSchemaColumn schema = new DateSchemaColumn(null, \"col\", null);",
        "  WHEN",
        "    schema.parseAndAddToColumn(aString, stubColumn);",
        "  THEN",
        "    assert stubColumn.getLastAdded().equals(LocalDate.of(2021, 1, 2));"
      ]
    },
