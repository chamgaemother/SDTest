{
  "scenarios": [
    {
      "id": "TC07",
      "description": "Null pattern in constructor leads to default pattern and valid date is parsed correctly",
      "path": "B0→B1(aString!=null)→B2(trimmed.isEmpty==false)→B3(parse)→B5(return)",
      "precondition": "newPattern == null in constructor",
      "expectedResult": "LocalDate.of(2021,12,5) added to column",
      "tags": [
        "positive",
        "constructor-null-pattern",
        "default-pattern"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC07 default-pattern-via-null-constructor with valid date",
        "  GIVEN",
        "    DateSchemaColumn col = new DateSchemaColumn(null, \"name\", null);",
        "    StubDfColumn stub = new StubDfColumn();",
        "    String input = \"2021-12-5\";",
        "  WHEN",
        "    col.parseAndAddToColumn(input, stub);",
        "  THEN",
        "    assert stub.getLastAdded() == LocalDate.of(2021,12,5);"
      ]
    },
    {
      "id": "TC08",
