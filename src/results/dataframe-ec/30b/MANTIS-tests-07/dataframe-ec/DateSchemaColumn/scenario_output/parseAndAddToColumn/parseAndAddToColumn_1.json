      "path": "B0→B1(aString!=null)→B2(trimmed.isEmpty==false)→B3(parse)→B4(exception)",
      "precondition": "newPattern == null in constructor",
      "expectedResult": "DateTimeParseException is thrown; no object added",
      "tags": [
        "negative",
        "constructor-null-pattern",
        "strict-resolver",
        "exception"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 default-pattern with invalid date structure",
        "  GIVEN",
        "    DateSchemaColumn col = new DateSchemaColumn(null, \"name\", null);",
        "    StubDfColumn stub = new StubDfColumn();",
        "    String input = \"2021-02-29\"; // non-leap year invalid day",
        "  WHEN",
        "    call col.parseAndAddToColumn(input, stub);",
        "  THEN",
        "    throws DateTimeParseException;",
        "    assert stub.getLastAdded() == null;"
      ]
    },
