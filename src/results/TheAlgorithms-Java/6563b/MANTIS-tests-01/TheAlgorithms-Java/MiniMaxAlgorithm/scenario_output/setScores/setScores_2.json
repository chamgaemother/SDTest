{
  "scenarios": [
    {
      "id": "TC06",
      "description": "setScores accepts array of length 2 (power of two) and updates scores and height (branch-false, shallow log2)",
      "path": "B0→B1→B3",
      "precondition": "new MiniMaxAlgorithm instance",
      "expectedResult": "scores updated to [7,8] and height == 1",
      "tags": [
        "positive",
        "boundary",
        "power-of-two",
        "log2-depth-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 setScores length-2",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {7,8};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assertArrayEquals([7,8], alg.getScores());",
        "    assertEquals(1, alg.getHeight());"
      ]
    },
    {
