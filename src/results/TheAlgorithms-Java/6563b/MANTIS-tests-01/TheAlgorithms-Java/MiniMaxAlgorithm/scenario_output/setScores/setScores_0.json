    },
    {
      "id": "TC03",
      "description": "setScores rejects array of length 3 (not power of two) and leaves scores and height unchanged (branch-true)",
      "path": "B0→B2→B3",
      "precondition": "MiniMaxAlgorithm instance with controlled initial scores and height",
      "expectedResult": "getScores() unchanged from initial; getHeight() unchanged; prints \"The number of scores must be a power of 2.\" to System.out",
      "tags": [
        "branch-true",
        "exception-path?",
        "invalid",
        "length-3"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 setScores invalid-length",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] originalScores = alg.getScores();",
        "    int originalHeight = alg.getHeight();",
        "    int[] newScores = {5,6,7};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), originalScores);",
        "    assert alg.getHeight() == originalHeight;",
        "    assert System.out.toString().contains(\"The number of scores must be a power of 2.\");"
      ]
    }
  ]
