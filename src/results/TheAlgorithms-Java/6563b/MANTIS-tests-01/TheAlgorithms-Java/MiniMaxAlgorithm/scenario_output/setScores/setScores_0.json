{
  "method": "setScores",
  "scenarios": [
    {
      "id": "TC01",
      "description": "setScores accepts array of length 1 (power of two) and updates scores and height (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance with default scores and height from constructor",
      "expectedResult": "getScores() equals [42]; getHeight() == 0",
      "tags": [
        "branch-false",
        "boundary",
        "power-of-two",
        "length-1"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setScores length1",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {42};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), new int[]{42});",
        "    assert alg.getHeight() == 0;"
      ]
    },
    {
      "id": "TC02",
      "description": "setScores accepts array of length 8 (power of two) and updates scores and height (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance with default scores and height",
      "expectedResult": "getScores() equals [1,2,3,4,5,6,7,8]; getHeight() == 3",
      "tags": [
        "branch-false",
        "typical",
        "power-of-two",
        "length-8"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setScores length8",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {1,2,3,4,5,6,7,8};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), new int[]{1,2,3,4,5,6,7,8});",
        "    assert alg.getHeight() == 3;"
