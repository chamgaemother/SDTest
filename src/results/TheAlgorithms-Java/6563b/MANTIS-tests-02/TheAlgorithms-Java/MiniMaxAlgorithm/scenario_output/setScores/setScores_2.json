{
  "scenarios": [
    {
      "id": "TC06",
      "description": "setScores accepts a large power-of-2 length (8) and correctly updates height via log2 recursion",
      "path": "B0→B1→B3",
      "precondition": "none",
      "expectedResult": "scores updated to new 8-element array; height = 3 (log2(8))",
      "tags": [
        "positive",
        "boundary",
        "recursion"
      ],
      "priority": "P2",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC06 setScores with 8 elements",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = new int[]{1,2,3,4,5,6,7,8};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assertArrayEquals(new int[]{1,2,3,4,5,6,7,8}, alg.getScores());",
        "    assertEquals(3, alg.getHeight());",
        "END"
      ]
    },
