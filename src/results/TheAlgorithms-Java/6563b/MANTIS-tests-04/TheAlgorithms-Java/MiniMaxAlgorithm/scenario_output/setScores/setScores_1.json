      "id": "TC05",
      "description": "setScores with length=2 (2^1) sets scores and height=1 via B1 path",
      "path": "B0→B1→B3",
      "precondition": "none",
      "expectedResult": "scores referenced to new array of length 2 and height is 1",
      "tags": [
        "positive",
        "boundary",
        "power-of-two"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 setScores length-2",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] newScores = new int[2];",
        "  WHEN",
        "    algo.setScores(newScores);",
        "  THEN",
        "    assertSame(newScores, algo.getScores());",
        "    assertEquals(1, algo.getHeight());"
      ]
    },
