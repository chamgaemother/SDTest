{
  "scenarios": [
    {
      "id": "TC08",
      "description": "setScores(null) on new instance throws NullPointerException before any branch",
      "path": "exception",
      "precondition": "none",
      "expectedResult": "NullPointerException is thrown",
      "tags": [
        "exception",
        "null-input"
      ],
      "priority": "P0",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC08 setScores null-input throws NPE",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "  WHEN",
        "    call alg.setScores(null);",
        "  THEN",
        "    throws NullPointerException;",
        "END"
      ]
    },
    {
      "id": "TC09",
      "description": "setScores on zero-length array triggers rejection branch (length%1!=0)",
      "path": "B0→B2→B3",
      "precondition": "System.out redirected to capture output",
      "expectedResult": "Original scores retained, height unchanged, message printed",
      "tags": [
        "negative",
        "boundary",
        "print-branch"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC09 setScores zero-length prints rejection",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] original = alg.getScores().clone();",
        "    int origHeight = alg.getHeight();",
        "    redirect System.out to outStream;",
        "    int[] newScores = new int[0];",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assertArrayEquals(original, alg.getScores());",
        "    assertEquals(origHeight, alg.getHeight());",
        "    assert outStream contains \"must be a power of 2\";",
        "END"
      ]
    },
