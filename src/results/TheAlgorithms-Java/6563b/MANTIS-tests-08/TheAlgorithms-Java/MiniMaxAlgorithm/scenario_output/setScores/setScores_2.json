{
  "scenarios": [
    {
      "id": "TC05",
      "description": "setScores(0-length array) causes infinite recursion in log2 and throws StackOverflowError",
      "path": "B0→B1→B1→…→B1 (recursive)→[StackOverflowError]",
      "precondition": "none",
      "expectedResult": "StackOverflowError is thrown due to log2(0) recursion",
      "tags": [
        "exception",
        "boundary",
        "zero-length"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 setScores zero-length recursion",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] newScores = new int[0];",
        "  WHEN",
        "    call algo.setScores(newScores);",
        "  THEN",
        "    throws StackOverflowError;",
        "END"
      ]
    },
    {
      "id": "TC06",
      "description": "setScores accepts power-of-2 array of length 2 and updates height to 1",
      "path": "B0→B1→B3",
      "precondition": "none",
      "expectedResult": "scores reference updated and height == 1",
      "tags": [
        "positive",
        "boundary",
        "power-of-two"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC06 setScores minimal-nontrivial-power",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] newScores = new int[]{10,20};",
        "  WHEN",
        "    algo.setScores(newScores);",
        "  THEN",
        "    assertSame(newScores, algo.getScores());",
        "    assertEquals(1, algo.getHeight());",
        "END"
      ]
    }
  ]
}