{
  "scenarios": [
    {
      "id": "TC04",
      "description": "setScores with length=1 triggers log2 base-case branch and sets height to 0",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance created",
      "expectedResult": "scores replaced and getHeight() returns 0",
      "tags": [
        "boundary",
        "positive",
        "power-of-two"
      ],
      "priority": "P1",
      "environment": "Java 8+",
      "pseudocode": [
        "TEST TC04 setScores single-element-array",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {42};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assertArrayEquals(newScores, alg.getScores());",
        "    assertEquals(0, alg.getHeight());"
      ]
    },
    {
      "id": "TC05",
