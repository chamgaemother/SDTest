{
  "method": "setScores",
  "scenarios": [
    {
      "id": "TC01",
      "description": "Valid power-of-two array of length 1 (2^0) sets scores and height correctly (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance created; use real int[] {42} of length 1",
      "expectedResult": "getScores() returns [42] and getHeight() returns 0",
      "tags": [
        "branch-false",
        "boundary",
        "power-of-two",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setScores minimal-power-of-two",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] scores = new int[] {42};",
        "  WHEN",
        "    algo.setScores(scores);",
        "  THEN",
        "    assert Arrays.equals(algo.getScores(), new int[] {42});",
        "    assert algo.getHeight() == 0;"
      ]
    },
    {
      "id": "TC02",
      "description": "Valid power-of-two array of length 8 (2^3) sets scores and height correctly (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance created; use real int[] of length 8",
      "expectedResult": "getScores() returns the provided array and getHeight() returns 3",
      "tags": [
        "branch-false",
        "power-of-two",
        "loop-recursion",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setScores larger-power-of-two",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] scores = new int[] {1,2,3,4,5,6,7,8};",
        "  WHEN",
        "    algo.setScores(scores);",
        "  THEN",
        "    assert Arrays.equals(algo.getScores(), new int[] {1,2,3,4,5,6,7,8});",
        "    assert algo.getHeight() == 3;"
      ]
    },
    {
      "id": "TC03",
      "description": "Invalid non-power-of-two array length 3 triggers exception (branch-true)",
      "path": "B0→B2→B3",
      "precondition": "MiniMaxAlgorithm instance created; use real int[] of length 3",
      "expectedResult": "throws IllegalArgumentException; no change to existing scores or height",
      "tags": [
        "branch-true",
        "exception",
        "non-power-of-two",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 setScores invalid-length",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] original = algo.getScores();",
        "    int originalHeight = algo.getHeight();",
        "    int[] invalid = new int[] {1,2,3};",
        "  WHEN",
        "    call algo.setScores(invalid);",
        "  THEN",
        "    throws IllegalArgumentException;",
        "    assert Arrays.equals(algo.getScores(), original);",
        "    assert algo.getHeight() == originalHeight;"
      ]
    }
  ]
}