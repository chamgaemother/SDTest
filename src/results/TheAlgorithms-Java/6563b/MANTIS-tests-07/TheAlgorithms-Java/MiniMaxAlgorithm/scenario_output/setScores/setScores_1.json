{
  "scenarios": [
    {
      "id": "TC04",
      "description": "setScores with 16-element array (2^4) sets scores and height=4 via log2 recursion",
      "path": "B0→B1→B3",
      "precondition": "MiniMaxAlgorithm instance created",
      "expectedResult": "scores replaced with provided array; getHeight() returns 4",
      "tags": [
        "positive",
        "boundary",
        "recursion"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 setScores valid-power-of-two-high-order",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] input = new int[16]; // fill with sample values",
        "  WHEN",
        "    algo.setScores(input);",
        "  THEN",
        "    assertArrayEquals(input, algo.getScores());",
        "    assertEquals(4, algo.getHeight());"
      ]
    },
    {
      "id": "TC05",
      "description": "setScores with zero-length array triggers StackOverflowError in log2 recursion",
      "path": "B0→B1→(log2 recursion infinite)→error",
      "precondition": "MiniMaxAlgorithm instance created",
      "expectedResult": "StackOverflowError is thrown",
      "tags": [
        "negative",
        "exception",
        "recursion"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC05 setScores zero-length-array",
        "  GIVEN",
        "    MiniMaxAlgorithm algo = new MiniMaxAlgorithm();",
        "    int[] input = new int[0];",
        "  WHEN",
        "    call algo.setScores(input);",
        "  THEN",
        "    throws StackOverflowError;"
      ]
    }
  ]
