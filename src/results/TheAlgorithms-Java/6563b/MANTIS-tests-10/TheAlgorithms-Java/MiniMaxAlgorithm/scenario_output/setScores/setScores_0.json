{
  "method": "setScores",
  "scenarios": [
    {
      "id": "TC01",
      "description": "setScores with length 1 (power of 2) sets scores and height correctly (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "Instantiate MiniMaxAlgorithm; original scores overwritten by supplied array",
      "expectedResult": "scores field equals [42]; getHeight() returns 0",
      "tags": [
        "branch-false",
        "boundary-length-1",
        "positive",
        "P0",
        "loop-0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 setScores single-element",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {42};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), new int[]{42});",
        "    assert alg.getHeight() == 0;"
      ]
    },
    {
      "id": "TC02",
      "description": "setScores with length 8 (power of 2) sets scores and height correctly (branch-false)",
      "path": "B0→B1→B3",
      "precondition": "Instantiate MiniMaxAlgorithm; original scores overwritten by supplied array",
      "expectedResult": "scores field equals [1,2,3,4,5,6,7,8]; getHeight() returns 3",
      "tags": [
        "branch-false",
        "boundary-length-8",
        "positive",
        "loop-N",
        "P1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 setScores eight-elements",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] newScores = {1,2,3,4,5,6,7,8};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), new int[]{1,2,3,4,5,6,7,8});",
        "    assert alg.getHeight() == 3;"
      ]
    },
    {
      "id": "TC03",
      "description": "setScores with length 3 (not power of 2) does not change state and prints error (branch-true)",
      "path": "B0→B2→B3",
      "precondition": "Instantiate MiniMaxAlgorithm with known initial scores; capture System.out",
      "expectedResult": "scores field remains equal to initial array; height unchanged; System.out contains \"The number of scores must be a power of 2.\"",
      "tags": [
        "branch-true",
        "negative",
        "invalid-length-3",
        "P0"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC03 setScores invalid-length",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] initial = alg.getScores().clone();",
        "    ByteArrayOutputStream out = new ByteArrayOutputStream();",
        "    System.setOut(new PrintStream(out));",
        "    int[] newScores = {5,6,7};",
        "  WHEN",
        "    alg.setScores(newScores);",
        "  THEN",
        "    assert Arrays.equals(alg.getScores(), initial);",
        "    assert alg.getHeight() == log2(initial.length);",
        "    assert out.toString().contains(\"The number of scores must be a power of 2.\");"
      ]
    }
  ]
}