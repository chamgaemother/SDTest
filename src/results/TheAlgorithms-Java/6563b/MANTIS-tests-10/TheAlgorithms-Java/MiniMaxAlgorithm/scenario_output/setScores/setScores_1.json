{
  "scenarios": [
    {
      "id": "TC04",
      "description": "setScores prints error and does not update state when scores length is odd (error branch)",
      "path": "B0→B2→B3",
      "precondition": "none",
      "expectedResult": "original scores and height unchanged; error message printed",
      "tags": [
        "branch-true",
        "error-path",
        "negative"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC04 setScores odd-length array triggers error",
        "  GIVEN",
        "    MiniMaxAlgorithm alg = new MiniMaxAlgorithm();",
        "    int[] beforeScores = alg.getScores().clone();",
        "    int beforeHeight = alg.getHeight();",
        "    int[] oddScores = new int[]{1, 2, 3}; // length 3 (odd)",
        "    ByteArrayOutputStream baos = new ByteArrayOutputStream();",
        "    System.setOut(new PrintStream(baos));",
        "  WHEN",
        "    alg.setScores(oddScores);",
        "  THEN",
        "    assertArrayEquals(beforeScores, alg.getScores());",
        "    assertEquals(beforeHeight, alg.getHeight());",
        "    String out = baos.toString();",
        "    assertTrue(out.contains(\"The number of scores must be a power of 2.\"));",
        "END"
      ]
    }
  ]
}