      "tags": [
        "branch-true",
        "branch-false",
        "loop-1"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN points = [P1,P2,P3] colinear",
        "WHEN convexHullRecursive(points)",
        "THEN result == [P1,P3]"
      ]
    },
    {
