{
  "method": "convexHullRecursive",
  "scenarios": [
    {
      "id": "TC01",
      "description": "convexHullRecursive([]) throws IndexOutOfBoundsException when input list is empty",
      "path": "B0",
      "precondition": "none",
      "expectedResult": "throws IndexOutOfBoundsException",
      "tags": [
        "exception",
        "branch-true"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN points = []",
        "WHEN convexHullRecursive(points)",
        "THEN throws IndexOutOfBoundsException"
      ]
    },
    {
      "id": "TC02",
      "description": "convexHullRecursive([P]) returns the single point when list size is 1",
      "path": "B0→B7→B6",
      "precondition": "none",
      "expectedResult": "return list contains the same single point P",
      "tags": [
        "boundary",
        "loop-0",
        "branch-true",
        "branch-false"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN points = [P]",
        "WHEN convexHullRecursive(points)",
        "THEN result == [P]"
      ]
    },
    {
      "id": "TC03",
      "description": "convexHullRecursive([P1,P2]) returns both points in sorted order when list size is 2",
      "path": "B0→B7→B6",
      "precondition": "none",
      "expectedResult": "return list == sorted([P1,P2])",
      "tags": [
        "boundary",
        "loop-0",
        "branch-true"
      ],
      "priority": "P1",
      "environment": "Java 8",
      "pseudocode": [
        "GIVEN points = [P1,P2]",
