{
  "method": "generate",
  "scenarios": [
    {
      "id": "TC01",
      "description": "generate throws IllegalArgumentException when f < -5e9 (lower bound violation)",
      "path": "B0→B1→B2",
      "precondition": "none",
      "expectedResult": "throws IllegalArgumentException with message \"Value must be between -5000000000.0 and 5000000000.0, inclusive\"",
      "tags": [
        "branch-true",
        "exception",
        "boundary-below",
        "generate:double"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC01 generate lower-bound-violation",
        "  GIVEN",
        "    double f = -5000000000.000001;",
        "  WHEN",
        "    call ComparableNumber.generate(f);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
      "id": "TC02",
      "description": "generate throws IllegalArgumentException when f > 5e9 (upper bound violation)",
      "path": "B0→B1→B2",
      "precondition": "none",
