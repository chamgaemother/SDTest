      "tags": [
        "branch-true",
        "exception",
        "boundary-above",
        "generate:double"
      ],
      "priority": "P0",
      "environment": "Java 8",
      "pseudocode": [
        "TEST TC02 generate upper-bound-violation",
        "  GIVEN",
        "    double f = 5000000000.000001;",
        "  WHEN",
        "    call ComparableNumber.generate(f);",
        "  THEN",
        "    throws IllegalArgumentException;"
      ]
    },
    {
